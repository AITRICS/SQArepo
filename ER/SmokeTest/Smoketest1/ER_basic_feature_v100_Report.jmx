          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 StayDischargePatientNameDataSet" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">// Get variable values
String name1 = vars.get(&quot;DisChargePatientName&quot;)
String name2 = vars.get(&quot;PATIENT_NAME&quot;)

// Initialize max common substring
String longestCommonName = &quot;&quot;

// Nested loop to find the longest common substring
for (int i = 0; i &lt; name1.length(); i++) {
    for (int j = 0; j &lt; name2.length(); j++) {
        int len = 0
        while ((i + len &lt; name1.length()) &amp;&amp; 
               (j + len &lt; name2.length()) &amp;&amp; 
               (name1.charAt(i + len) == name2.charAt(j + len))) {
            len++
        }
        if (len &gt; longestCommonName.length()) {
            longestCommonName = name1.substring(i, i + len)
        }
    }
}

// Store result in JMeter variable
vars.put(&quot;CommonPatientName&quot;, longestCommonName)

// Optional: log the result
log.info(&quot;CommonPatientName between ${name1} and ${name2} = ${longestCommonName}&quot;)
</stringProp>
            </JSR223PreProcessor>
            <hashTree/>
          </hashTree>
