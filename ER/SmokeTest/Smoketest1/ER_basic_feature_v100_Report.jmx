            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 Login_Header_Handling_PreProcessor" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">// Remove Authorization header in PreProcessor
def headerManager = sampler.getHeaderManager()

if (headerManager != null) {
    for (int i = headerManager.size() - 1; i &gt;= 0; i--) {
        def header = headerManager.get(i)
		if (header.getName().equalsIgnoreCase(&quot;Authorization&quot;)) {
            headerManager.remove(i)
        }
    }
}
</stringProp>
