          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 StayDischargePatientIdDataSet" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">// Get variable values
String str1 = vars.get(&quot;DisCharGePatientID&quot;)
String str2 = vars.get(&quot;PATIENT_ID&quot;)

// Initialize max common substring
String longestCommon = &quot;&quot;

// Nested loop to find the longest common substring
for (int i = 0; i &lt; str1.length(); i++) {
    for (int j = 0; j &lt; str2.length(); j++) {
        int len = 0
        while ((i + len &lt; str1.length()) &amp;&amp; 
               (j + len &lt; str2.length()) &amp;&amp; 
               (str1.charAt(i + len) == str2.charAt(j + len))) {
            len++
        }
        if (len &gt; longestCommon.length()) {
            longestCommon = str1.substring(i, i + len)
        }
    }
}

// Store result in JMeter variable
vars.put(&quot;CommonPatientId&quot;, longestCommon)

// Optional: log the result
log.info(&quot;CommonPatientId between ${str1} and ${str2} = ${longestCommon}&quot;)
</stringProp>
            </JSR223PreProcessor>
            <hashTree/>
          </hashTree>
