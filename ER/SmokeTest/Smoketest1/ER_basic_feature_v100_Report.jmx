            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 DNR False PatientSet" enabled="false">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper

// Get response body
def response = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(response)

// Initialize result lists
def encounterIds = []
def patientIds = []
def patientNames = []

// Filter by condition and extract
json.data.patientSummaries.each { patient -&gt;
    if (patient.dnr == false) {
        encounterIds &lt;&lt; patient.encounterId
        patientIds &lt;&lt; patient.patientId
        patientNames &lt;&lt; patient.name
    }
}

// Store the count of each list as variables
vars.put(&quot;ENCOUNTER_ID_Count&quot;, encounterIds.size().toString())
vars.put(&quot;PATIENT_ID_Count&quot;, patientIds.size().toString())
vars.put(&quot;PATIENT_NAME_Count&quot;, patientNames.size().toString())

// Store each value as a variable with index
encounterIds.eachWithIndex { id, idx -&gt;
    vars.put(&quot;ENCOUNTER_ID_&quot; + idx, id)
}

patientIds.eachWithIndex { id, idx -&gt;
    vars.put(&quot;PATIENT_ID_&quot; + idx, id)
}

patientNames.eachWithIndex { name, idx -&gt;
    vars.put(&quot;PATIENT_NAME_&quot; + idx, name)
}

// Store the first value separately (if needed)
if (encounterIds) {
    vars.put(&quot;ENCOUNTER_ID&quot;, encounterIds[0])
    vars.put(&quot;PATIENT_ID&quot;, patientIds[0])
