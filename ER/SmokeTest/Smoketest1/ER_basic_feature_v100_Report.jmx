            <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Patient_ID JSON Extractor" enabled="true">
              <stringProp name="JSONPostProcessor.referenceNames">PATIENT_ID</stringProp>
              <stringProp name="JSONPostProcessor.jsonPathExprs">$.data.patientSummaries[?(@.dnr == false)].patientId</stringProp>
              <stringProp name="JSONPostProcessor.match_numbers">1</stringProp>
            </JSONPostProcessor>
            <hashTree/>
            <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Patient_NAME JSON Extractor" enabled="true">
              <stringProp name="JSONPostProcessor.referenceNames">PATIENT_NAME</stringProp>
              <stringProp name="JSONPostProcessor.jsonPathExprs">$.data.patientSummaries[?(@.dnr == false)].name</stringProp>
