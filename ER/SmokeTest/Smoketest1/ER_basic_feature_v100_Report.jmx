          <stringProp name="script">import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.TimeZone;

long timestampDefault = ${timestamp_default}; // UTC timestamp in milliseconds

// Create Date objects based on UTC time calculations
Date startDate = new Date(timestampDefault - 24 * 60 * 60 * 1000);      // 24 hours ago UTC
Date endDate = new Date(timestampDefault);                             // now UTC
Date versionDate = new Date(timestampDefault);                         // now UTC
Date lastScreenedDate = new Date(timestampDefault - 1 * 60 * 60 * 1000); // 1 hour ago UTC

// Set timezone for formatting (example: Seoul)
TimeZone timeZone = TimeZone.getTimeZone(&quot;${TimeZone}&quot;);

SimpleDateFormat sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
sdf.setTimeZone(timeZone);

String startDtString = sdf.format(startDate);
String endDtString = sdf.format(endDate);
String versionString = sdf.format(versionDate);
String lastScreenedString = sdf.format(lastScreenedDate);

// Put the formatted date strings into variables
vars.put(&quot;param_start_dt&quot;, startDtString);
vars.put(&quot;param_end_dt&quot;, endDtString);
vars.put(&quot;param_version&quot;, versionString);
vars.put(&quot;param_last_screened_dt&quot;, lastScreenedString);
</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
