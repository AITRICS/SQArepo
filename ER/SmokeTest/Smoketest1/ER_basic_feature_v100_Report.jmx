            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonOutput

def responseJson = prev.getResponseDataAsString()
def parsed = new JsonSlurper().parseText(responseJson)

def result = []

parsed.data.vitals.each { item -&gt;
    def sub = item.subcategory
    def below = item.belowRange
    def above = item.aboveRange

    if (sub == &quot;O2&quot;) {
        return
    }

    if (below?.to?.editable &amp;&amp; below?.name) {
        result &lt;&lt; [
            subcategory: sub,
            name: below.name,
            value: below.to.value,
            on: true
        ]
    }

    if (above?.from?.editable &amp;&amp; above?.name) {
        result &lt;&lt; [
            subcategory: sub,
            name: above.name,
            value: above.from.value,
            on: true
        ]
    }
}

def resultJson = JsonOutput.toJson(result)
log.info(&quot;Extracted vitals Default CoV: &quot; + resultJson)
vars.put(&quot;VITALS_DefaultCoV&quot;, resultJson)
</stringProp>
            </JSR223PostProcessor>
