            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST_REGISTER_Type_GroupUser(ER_Physician_${GROUP_USER}_${userGroup})" enabled="true">
              <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
              <stringProp name="HTTPSampler.path">/api/v1/auth/register</stringProp>
              <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
              <stringProp name="HTTPSampler.method">POST</stringProp>
              <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
              <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                <collectionProp name="Arguments.arguments">
                  <elementProp name="" elementType="HTTPArgument">
                    <boolProp name="HTTPArgument.always_encode">false</boolProp>
                    <stringProp name="Argument.value">{&#xd;
  &quot;username&quot;: &quot;${GROUP_USER}&quot;,&#xd;
  &quot;password&quot;: &quot;${USER_PW}&quot;,&#xd;
  &quot;name&quot;: &quot;${USER_NAME}&quot;,&#xd;
  &quot;phone&quot;: &quot;${USER_PHONE}&quot;,&#xd;
  &quot;userType&quot;: &quot;ER Physician&quot;,&#xd;
  &quot;userGroup&quot;: &quot;${userGroup}&quot;&#xd;
}</stringProp>
                    <stringProp name="Argument.metadata">=</stringProp>
                  </elementProp>
                </collectionProp>
              </elementProp>
            </HTTPSamplerProxy>
            <hashTree>
              <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">// 1. Get the current loop index (initialize to 0 if not set), then increment by 1
def loopIndex = (vars.get(&quot;loopIndex&quot;) ?: &quot;0&quot;).toInteger() + 1

// 2. Reset if needed
if (loopIndex &gt; 28) {
    loopIndex = 1
}
vars.put(&quot;loopIndex&quot;, loopIndex.toString())

// 3. Set username using the loop index (e.g., group_user1, group_user2, ...)
def username = &quot;Group${vars.get(&quot;loopIndex&quot;)}&quot;
vars.put(&quot;GROUP_USER&quot;, username)

// 4. Define the list of user groups (will cycle through the list if loopIndex exceeds length)
def userGroups = [
    &quot;가정의학과&quot;, &quot;결핵과&quot;, &quot;내과&quot;, &quot;마취통증의학과&quot;, &quot;방사선종양학과&quot;,
    &quot;병리과&quot;, &quot;비뇨의학과&quot;, &quot;산부인과&quot;, &quot;성형외과&quot;, &quot;소아청소년과&quot;,
    &quot;신경과&quot;, &quot;신경외과&quot;, &quot;심장혈관흉부외과&quot;, &quot;안과&quot;, &quot;영상의학과&quot;,
    &quot;예방의학과&quot;, &quot;외과&quot;, &quot;응급의학과&quot;, &quot;이비인후과&quot;, &quot;일반의&quot;,
    &quot;재활의학과&quot;, &quot;정신건강의학과&quot;, &quot;정형외과&quot;, &quot;직업환경의학과&quot;,    
    &quot;진단검사의학과&quot;, &quot;치과&quot;, &quot;피부과&quot;, &quot;핵의학과&quot;
]

// 5. Determine the index for userGroup (wraps around using modulo if loopIndex &gt; list size)
def groupIndex = (loopIndex - 1) % userGroups.size()
vars.put(&quot;userGroup&quot;, userGroups[groupIndex])

// (Optional) Log the values for debugging
log.info(&quot;Register▶ Loop #${vars.get(&quot;loopIndex&quot;)} | Username: ${vars.get(&quot;GROUP_USER&quot;)} | UserGroup: ${vars.get(&quot;userGroup&quot;)}&quot;)</stringProp>
              </JSR223PreProcessor>
              <hashTree/>
            </hashTree>
          </hashTree>
