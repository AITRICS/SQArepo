            <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
            <stringProp name="HTTPSampler.path">/api/v1/auth/login</stringProp>
            <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
            <stringProp name="HTTPSampler.method">POST</stringProp>
            <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
            <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
              <collectionProp name="Arguments.arguments">
                <elementProp name="" elementType="HTTPArgument">
                  <boolProp name="HTTPArgument.always_encode">false</boolProp>
                  <stringProp name="Argument.value">{&#xd;
  &quot;username&quot;: &quot;${USER_ID}&quot;,&#xd;
  &quot;password&quot;: &quot;${USER_PW}&quot;,&#xd;
  &quot;forceLogin&quot;: false&#xd;
}</stringProp>
                  <stringProp name="Argument.metadata">=</stringProp>
                </elementProp>
              </collectionProp>
            </elementProp>
          </HTTPSamplerProxy>
          <hashTree>
            <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="ACCESS_TOKEN JSON Extractor" enabled="true">
              <stringProp name="JSONPostProcessor.referenceNames">USER_TOKEN</stringProp>
              <stringProp name="JSONPostProcessor.jsonPathExprs">data.accessToken</stringProp>
              <stringProp name="JSONPostProcessor.match_numbers">1</stringProp>
            </JSONPostProcessor>
            <hashTree/>
            <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
              <collectionProp name="HeaderManager.headers">
                <elementProp name="" elementType="Header">
                  <stringProp name="Header.name">Content-Type</stringProp>
                  <stringProp name="Header.value">application/json</stringProp>
                </elementProp>
              </collectionProp>
            </HeaderManager>
            <hashTree/>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 Login_Header_Handling_PreProcessor" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">// Remove Authorization header in PreProcessor
def headerManager = sampler.getHeaderManager()

if (headerManager != null) {
    for (int i = headerManager.size() - 1; i &gt;= 0; i--) {
        def header = headerManager.get(i)
		if (header.getName().equalsIgnoreCase(&quot;Authorization&quot;)) {
            headerManager.remove(i)
        }
    }
}
</stringProp>
            </JSR223PreProcessor>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 Login_Header_Handling_PostProcessor" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">// Restore Authorization header in PostProcessor
def savedAuthHeader = vars.get(&quot;USER_TOKEN&quot;)
if (savedAuthHeader != null &amp;&amp; !savedAuthHeader.isEmpty()) {
    def headerManager = sampler.getHeaderManager()
    
    if (headerManager != null) {
		// Restore the Authorization header
        headerManager.add(new org.apache.jmeter.protocol.http.control.Header(&quot;Authorization&quot;, &quot;Bearer &quot; + savedAuthHeader))        
		// Force apply the HeaderManager to the sampler
        sampler.setHeaderManager(headerManager)
    }
}
</stringProp>
            </JSR223PostProcessor>
