            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 Login_Header_Handling_PreProcessor" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">// Remove Authorization header in PreProcessor
def headerManager = sampler.getHeaderManager()

if (headerManager != null) {
    for (int i = headerManager.size() - 1; i &gt;= 0; i--) {
        def header = headerManager.get(i)
		if (header.getName().equalsIgnoreCase(&quot;Authorization&quot;)) {
            headerManager.remove(i)
        }
    }
}
</stringProp>
            </JSR223PreProcessor>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 Login_Header_Handling_PostProcessor" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">// Restore Authorization header in PostProcessor
def savedAuthHeader = vars.get(&quot;USER_TOKEN&quot;)
if (savedAuthHeader != null &amp;&amp; !savedAuthHeader.isEmpty()) {
    def headerManager = sampler.getHeaderManager()
    
    if (headerManager != null) {
		// Restore the Authorization header
        headerManager.add(new org.apache.jmeter.protocol.http.control.Header(&quot;Authorization&quot;, &quot;Bearer &quot; + savedAuthHeader))        
		// Force apply the HeaderManager to the sampler
        sampler.setHeaderManager(headerManager)
    }
}</stringProp>
            </JSR223PostProcessor>
