          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 DischargePatientNameDataSet" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import java.sql.DriverManager
import java.sql.PreparedStatement
import java.sql.ResultSet
import java.sql.Connection

// JDBC connection info
String url = vars.get(&quot;JDBC_ORACLE_URL&quot;)
String user = vars.get(&quot;JDBC_ORACLE_USER&quot;)
String password = vars.get(&quot;JDBC_ORACLE_PW&quot;)

Connection conn = null
PreparedStatement pstmt = null
ResultSet rs = null

try {
    // Get patient ID from previous step
    String patientId = vars.get(&quot;DisCharGePatientID&quot;)
    if (patientId == null || patientId.trim().isEmpty()) {
        log.warn(&quot;⚠ No patient ID to search for name.&quot;)
        return
    }

    conn = DriverManager.getConnection(url, user, password)

    String sql = &quot;SELECT NAME FROM ROOT.ER_PATIENTS WHERE PATIENT_ID = ?&quot;

    pstmt = conn.prepareStatement(sql)
    pstmt.setString(1, patientId)
    rs = pstmt.executeQuery()

    if (rs.next()) {
        String name = rs.getString(&quot;NAME&quot;)
        vars.put(&quot;DisChargePatientName&quot;, name)
        log.info(&quot;✔ Found patient name: &quot; + name)
    } else {
        log.warn(&quot;⚠ No patient name found for ID: &quot; + patientId)
        vars.put(&quot;DisChargePatientName&quot;, &quot;&quot;)
    }

} catch (Exception e) {
    log.error(&quot;❌ Error fetching patient name: &quot; + e.message)
    throw e
} finally {
    rs?.close()
    pstmt?.close()
    conn?.close()
}
</stringProp>
            </JSR223PreProcessor>
            <hashTree/>
          </hashTree>
