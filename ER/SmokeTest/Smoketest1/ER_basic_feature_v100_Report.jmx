            <stringProp name="LoopController.loops">${areaName_matchNr}</stringProp>
          </LoopController>
          <hashTree>
            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET_DashBoard_Area_Filter(${currentAreaName})" enabled="true">
              <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
              <stringProp name="HTTPSampler.path">/api/v1/er/dashboard?observing=false&amp;areas=${currentAreaName}</stringProp>
              <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
              <stringProp name="HTTPSampler.method">GET</stringProp>
              <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
              <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="사용자 정의 변수들">
                <collectionProp name="Arguments.arguments"/>
              </elementProp>
            </HTTPSamplerProxy>
            <hashTree>
              <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223_screening_API_QueryParam_SET" enabled="true">
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="script">// Get the total number of extracted areaName variables
def maxIndex = vars.get(&quot;areaName_matchNr&quot;)?.toInteger() ?: 1

// Get current loopIndex from JMeter variables, increment by 1
def loopIndex = (vars.get(&quot;loopIndex&quot;) ?: &quot;0&quot;).toInteger() + 1

// Reset loopIndex to 1 if it exceeds the maximum number of extracted variables
if (loopIndex &gt; maxIndex) {
    loopIndex = 1
}

// Save the updated loopIndex back to JMeter variables
vars.put(&quot;loopIndex&quot;, loopIndex.toString())

// Build the variable name dynamically based on current loopIndex (e.g., areaName_1)
def areaVarName = &quot;areaName_&quot; + loopIndex

// Retrieve the actual areaName value from JMeter variables
def currentAreaName = vars.get(areaVarName)

// Store the currentAreaName into a variable for later use
vars.put(&quot;currentAreaName&quot;, currentAreaName)

// Log the current loop iteration and selected areaName for debugging
log.info(&quot;Loop #${loopIndex} | currentAreaName: ${currentAreaName}&quot;)
</stringProp>
                <stringProp name="scriptLanguage">groovy</stringProp>
              </JSR223PreProcessor>
              <hashTree/>
            </hashTree>
          </hashTree>
