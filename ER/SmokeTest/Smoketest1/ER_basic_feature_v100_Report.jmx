          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 DischargePatientIdDataSet" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import java.sql.DriverManager
import java.sql.PreparedStatement
import java.sql.ResultSet
import java.sql.Connection

// JDBC connection info from JMeter variables
String url = vars.get(&quot;JDBC_ORACLE_URL&quot;)
String user = vars.get(&quot;JDBC_ORACLE_USER&quot;)
String password = vars.get(&quot;JDBC_ORACLE_PW&quot;)

Connection conn = null
PreparedStatement pstmt = null
ResultSet rs = null

try {
    // Connect to the Oracle database
    conn = DriverManager.getConnection(url, user, password)

    // Query to get the most recently updated patient with DISCHARGE_DATE not null and updated within 96 hours
String sql = &quot;&quot;&quot;
SELECT * FROM (
  SELECT PATIENT_ID, DISCHARGE_DATE, UPDATED_DT
  FROM ROOT.ER_ENCOUNTERS
  WHERE DISCHARGE_DATE IS NOT NULL
    AND UPDATED_DT &lt; SYSDATE - INTERVAL &apos;4&apos; DAY
  ORDER BY UPDATED_DT DESC
) WHERE ROWNUM = 1
&quot;&quot;&quot;

    pstmt = conn.prepareStatement(sql)
    rs = pstmt.executeQuery()

    if (rs.next()) {
        String patientId = rs.getString(&quot;PATIENT_ID&quot;)
        String dischargeDate = rs.getString(&quot;DISCHARGE_DATE&quot;)

        // Store variables in JMeter
        vars.put(&quot;DisCharGePatientID&quot;, patientId)

        // Log the values
        log.info(&quot;✔ Found patientId: &quot; + patientId + &quot; | DischargeDate: &quot; + dischargeDate)
    } else {
        log.warn(&quot;⚠ No matching patient found.&quot;)
        vars.put(&quot;DisCharGePatientID&quot;, &quot;&quot;)
    }

} catch (Exception e) {
    log.error(&quot;❌ DB error: &quot; + e.message)
    throw e
} finally {
    rs?.close()
    pstmt?.close()
    conn?.close()
}
</stringProp>
            </JSR223PreProcessor>
