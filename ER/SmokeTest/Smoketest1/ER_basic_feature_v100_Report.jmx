              <stringProp name="script">log.info(&quot;Extracted ktas: &quot; + vars.get(&quot;ktas_LIST&quot;));
log.info(&quot;Extracted mentalStatus: &quot; + vars.get(&quot;mentalStatus_LIST&quot;));
log.info(&quot;Extracted alertItems: &quot; + vars.get(&quot;alertItems_LIST&quot;));</stringProp>
            </BeanShellPostProcessor>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="alertItems_JSR223 PostProcessor" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper

// Get the JSON string stored in the variable AlertItems_LIST
def alertItemsJsonString = vars.get(&quot;alertItems_LIST&quot;);

// Parse the JSON string to an object
def jsonSlurper = new JsonSlurper();
def jsonObject = jsonSlurper.parseText(alertItemsJsonString);

// Initialize a list to hold the keys
def aiScoreKeys = []
def vitalSignKeys = []

// Access the &apos;alertItems&apos; object
def alertItems = jsonObject // Directly use the parsed object

// Extract aiScore keys
alertItems.aiScore.each { key, value -&gt;
    aiScoreKeys.add(&quot;\&quot;${key}\&quot;&quot;)
}

// Extract vitalSign keys
alertItems.vitalSign.each { key, value -&gt;
    vitalSignKeys.add(&quot;\&quot;${key}\&quot;&quot;)
}


// Log for verification
log.info(&quot;aiScore Keys: &quot; + aiScoreKeys)
log.info(&quot;vitalSign Keys: &quot; + vitalSignKeys)

// Save as JMeter variables
vars.put(&quot;aiScore_KEYS&quot;, aiScoreKeys.join(&quot;,&quot;))
vars.put(&quot;vitalSign_KEYS&quot;, vitalSignKeys.join(&quot;,&quot;))</stringProp>
            </JSR223PostProcessor>
