          <stringProp name="script">import java.text.SimpleDateFormat;
import java.util.Calendar;
import java.util.Date;
import java.util.TimeZone;

long timestampDefault = ${timestamp_default}; // UTC timestamp in milliseconds

// Start time: based on timestampDefault
Calendar startCal = Calendar.getInstance(TimeZone.getTimeZone(&quot;UTC&quot;));
startCal.setTimeInMillis(timestampDefault);

// End time: add 23 hours and 59 minutes to the start time
Calendar endCal = (Calendar) startCal.clone();
endCal.add(Calendar.HOUR_OF_DAY, 23);
endCal.add(Calendar.MINUTE, 59);

// Timezone and formatter setup (e.g., Asia/Seoul)
TimeZone timeZone = TimeZone.getTimeZone(&quot;${TimeZone}&quot;); 
SimpleDateFormat sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
sdf.setTimeZone(timeZone);

// Format the Calendar instances into strings
String startDtString = sdf.format(startCal.getTime());
String endDtString = sdf.format(endCal.getTime());

// Store the formatted strings in JMeter variables
vars.put(&quot;param_start_dt&quot;, startDtString);
vars.put(&quot;param_end_dt&quot;, endDtString);
</stringProp>
