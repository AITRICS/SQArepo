              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.TimeZone;

long timestampDefault = System.currentTimeMillis(); // UTC timestamp in milliseconds

// Create Date objects based on UTC time calculations
Date nowDate = new Date(timestampDefault); // now UTC

// Set timezone for formatting (example: Seoul)
TimeZone timeZone = TimeZone.getTimeZone(&quot;${TimeZone}&quot;);

SimpleDateFormat sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
sdf.setTimeZone(timeZone);

String nowDtString = sdf.format(nowDate);

// Put the formatted date strings into variables
vars.put(&quot;param_now_dt&quot;, nowDtString);
</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PreProcessor>
