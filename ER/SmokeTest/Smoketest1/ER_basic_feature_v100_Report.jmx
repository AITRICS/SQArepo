          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223_screening_API_QueryParam_SET" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">int count = vars.get(&quot;areaName_matchNr&quot;) as int
def queryParts = []
for (int i = 1; i &lt;= count; i++) {
    def area = vars.get(&quot;areaName_&quot; + i)
    queryParts &lt;&lt; &quot;areas=&quot; + URLEncoder.encode(area, &quot;UTF-8&quot;)
}
String finalAreaParam = queryParts.join(&quot;&amp;&quot;)
vars.put(&quot;areaQueryString&quot;, finalAreaParam)
</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PreProcessor>
            <hashTree/>
          </hashTree>
