          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Observation Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar
import java.util.Random

int repeatCount = vars.get(&quot;PatientCount&quot;) as int
long timestampDefault = vars.get(&quot;timestamp_default&quot;) as long
int intervalMin = vars.get(&quot;Ob_Interval_Min&quot;) as int
String timeZone = vars.get(&quot;TimeZone&quot;)
Random random = new Random()

def LOC_OPTIONS = [&quot;1&quot;, &quot;2&quot;, &quot;3&quot;, &quot;4&quot;, &quot;5&quot;]

for (int i = 0; i &lt; repeatCount; i++) {
    Calendar calendar = Calendar.getInstance(TimeZone.getTimeZone(timeZone))
    calendar.setTimeInMillis(timestampDefault)
    calendar.add(Calendar.MINUTE, -(i * intervalMin))
    
    // Align minute to previous 10-minute mark
    int minute = calendar.get(Calendar.MINUTE)
    calendar.add(Calendar.MINUTE, -(minute % 10))
    calendar.set(Calendar.SECOND, 0)
    calendar.set(Calendar.MILLISECOND, 0)

    long ObservedDtSetTimestamp = calendar.getTimeInMillis()

    def sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    sdf.setTimeZone(TimeZone.getTimeZone(timeZone))
    String ObservedDt = sdf.format(new Date(ObservedDtSetTimestamp))

    String INITIAL_PR_Value   = &quot;${random.nextInt(300)}&quot;
    String INITIAL_RR_Value   = &quot;${random.nextInt(120)}&quot;
    String INITIAL_BT_Value   = &quot;${random.nextInt(25) + 25}.${random.nextInt(10)}&quot;
    String INITIAL_SBP_Value  = &quot;${random.nextInt(300)}&quot;
    String INITIAL_DBP_Value  = &quot;${random.nextInt(300)}&quot;
    String INITIAL_SpO2_Value = &quot;${random.nextInt(100)}&quot;
    String INITIAL_LOC_Value  = LOC_OPTIONS[random.nextInt(LOC_OPTIONS.size())]

    // Store variables (with INITIAL_ prefix for vital signs)
    vars.put(&quot;ObservedDate&quot; + i, ObservedDt.split(&quot; &quot;)[0])
    vars.put(&quot;ObservedTime&quot; + i, ObservedDt.split(&quot; &quot;)[1])
    vars.put(&quot;INITIAL_PR_Value&quot; + i, INITIAL_PR_Value)
    vars.put(&quot;INITIAL_RR_Value&quot; + i, INITIAL_RR_Value)
    vars.put(&quot;INITIAL_BT_Value&quot; + i, INITIAL_BT_Value)
    vars.put(&quot;INITIAL_SBP_Value&quot; + i, INITIAL_SBP_Value)
    vars.put(&quot;INITIAL_DBP_Value&quot; + i, INITIAL_DBP_Value)
    vars.put(&quot;INITIAL_SpO2_Value&quot; + i, INITIAL_SpO2_Value)
    vars.put(&quot;INITIAL_LOC_Value&quot; + i, INITIAL_LOC_Value)
}
</stringProp>
          </JSR223PreProcessor>
