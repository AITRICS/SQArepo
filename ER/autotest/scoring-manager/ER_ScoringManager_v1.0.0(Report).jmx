          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Action Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar
import java.util.Random

// Default timestamp (usually passed as a parameter)
long timestampDefault = ${timestamp_default}

// Number of times to repeat
int repeatCount = ${PatientCount}

// Set the desired timezone
TimeZone tz = TimeZone.getTimeZone(&quot;${TimeZone}&quot;)

// Loop through each iteration
for (int i = 0; i &lt; repeatCount; i++) {
    // Randomly choose one of the ActionTypes
    String[] actionTypes = [&quot;intubation&quot;, &quot;vasopressor&quot;, &quot;icu&quot;, &quot;cpr&quot;]
    String ActionType = actionTypes[new Random().nextInt(actionTypes.length)]

    // Create ActionDT by subtracting 1 hour from the default timestamp
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault)
    calendar.add(Calendar.HOUR, -1)
    Date ActionDT = calendar.getTime()

    // Format date as yyyymmdd
    SimpleDateFormat sdfDate = new SimpleDateFormat(&quot;yyyyMMdd&quot;)
    sdfDate.setTimeZone(tz)

    // Format time as hhmm
    SimpleDateFormat sdfTime = new SimpleDateFormat(&quot;HHmm&quot;)
    sdfTime.setTimeZone(tz)

    // Format and store the values into variables
    String ActionDate = sdfDate.format(ActionDT)
    String ActionTime = sdfTime.format(ActionDT)

    vars.put(&quot;ActionType&quot; + i, ActionType)
    vars.put(&quot;ActionDate&quot; + i, ActionDate) // e.g., 20250808
    vars.put(&quot;ActionTime&quot; + i, ActionTime) // e.g., 0159
}
</stringProp>
          </JSR223PreProcessor>
