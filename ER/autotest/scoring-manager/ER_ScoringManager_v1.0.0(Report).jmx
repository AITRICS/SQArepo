          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET KTAS Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar
import java.util.Random
import java.nio.file.Files
import java.nio.file.Paths
import java.nio.charset.StandardCharsets

// Get the default timestamp (epoch millis) from JMeter variable
long timestampDefault = Long.parseLong(vars.get(&quot;timestamp_default&quot;))

// Get the number of patients and observations to generate
int repeatCount       = Integer.parseInt(vars.get(&quot;PatientCount&quot;))
int observationCount  = Integer.parseInt(vars.get(&quot;ObservationCount&quot;))

// Load KTAS code and level from CSV file
def csvPath = &quot;${KTASContentsPath}&quot;
def lines = Files.readAllLines(Paths.get(csvPath), StandardCharsets.UTF_8)

// Remove header row
lines.remove(0)

// Get timezone from JMeter variables
def timeZone  = vars.get(&quot;TimeZone&quot;)

// Initialize random number generator
def random = new Random()

// Generate data for each patient
for (int i = 0; i &lt; repeatCount; i++) {
    // Set triage datetime based on the default timestamp
    Date InitTriagetDTSet = new Date(timestampDefault)

    // Format triage date as yyyyMMdd
    def sdf_date = new SimpleDateFormat(&quot;yyyyMMdd&quot;)
    sdf_date.setTimeZone(TimeZone.getTimeZone(timeZone))
    String InitTriagetDate = sdf_date.format(InitTriagetDTSet)

    // Format triage time as HHmm
    def sdf_time = new SimpleDateFormat(&quot;HHmmss&quot;)
    sdf_time.setTimeZone(TimeZone.getTimeZone(timeZone))
    String InitTriagetTime = sdf_time.format(InitTriagetDTSet)

    // Pick a random KTAS row and parse code and level
    def randIndex = random.nextInt(lines.size())
    def row  = lines.get(randIndex)
    def parts  = row.split(&quot;,&quot;)
    def InitCode  = parts[0].trim()
    def InitLevel = parts[1].trim()

    // Save generated values into JMeter variables
    vars.put(&quot;InitTriagetDate&quot; + i, InitTriagetDate)
    vars.put(&quot;InitTriagetTime&quot; + i, InitTriagetTime)
    vars.put(&quot;InitCode&quot; + i, InitCode)
    vars.put(&quot;InitLevel&quot; + i, InitLevel)
}</stringProp>
          </JSR223PreProcessor>
