          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Visit Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Number of repetitions
int repeatCount = ${PatientCount}

for (int i = 0; i &lt; repeatCount; i++) {
    // Initialize calendar with the default timestamp
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault)

    // Create Date object for the visit (admission)
    Date visitDateObj = new Date(calendar.getTimeInMillis())

    // Format VisitDate as yyMMdd
    SimpleDateFormat sdf_date = new SimpleDateFormat(&quot;yyyyMMdd&quot;)
    sdf_date.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    String VisitDate = sdf_date.format(visitDateObj)

    // Format VisitTime as HHmm
    SimpleDateFormat sdf_time = new SimpleDateFormat(&quot;HHmmss&quot;)
    sdf_time.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    String VisitTime = sdf_time.format(visitDateObj)

    // Generate VisitID as yyyyMMddHHmmss plus user thread number
    def scenarioNum = vars.get(&quot;currentScenario&quot;)
    SimpleDateFormat sdf_visitId1 = new SimpleDateFormat(i + &quot;yyyyMMddHHmmss&quot; + scenarioNum + ${User_Thread})
    sdf_visitId1.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    String VisitID1 = sdf_visitId1.format(visitDateObj)

    SimpleDateFormat sdf_visitId2 = new SimpleDateFormat(i + &quot;yyMMddHHmmss&quot; + scenarioNum + ${User_Thread})
    sdf_visitId2.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    String VisitID2 = sdf_visitId2.format(visitDateObj)

    // Store variables
    vars.put(&quot;VisitID&quot; + i, VisitID1 + &quot;|&quot; + VisitID2)
    vars.put(&quot;VisitDate&quot; + i, VisitDate)
    vars.put(&quot;VisitTime&quot; + i, VisitTime)
}
</stringProp>
