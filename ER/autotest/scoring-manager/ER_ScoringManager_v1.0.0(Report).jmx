        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="ER_PI_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection
import java.sql.DriverManager
import java.sql.PreparedStatement
import java.sql.SQLException

// JDBC connection information
String url = &quot;${JDBC_URL}&quot;
String user = &quot;${JDBC_USER}&quot;
String password = &quot;${JDBC_PW}&quot;

// SQL insert query for all VARCHAR fields
String query = &quot;INSERT INTO ROOT.EMR_PRESENT_ILLNESS (PATIENT_ID, VISIT_ID, PI_TEXT) &quot; +
               &quot;VALUES (?, ?, ?)&quot;

// Create connection and prepare statement
Connection conn = DriverManager.getConnection(url, user, password)
PreparedStatement stmt = conn.prepareStatement(query)

// Repeat insert for each set of variables
int repeatCount = Integer.parseInt(vars.get(&quot;PatientCount&quot;))

for (int i = 0; i &lt; repeatCount; i++) {
    String patientId = vars.get(&quot;PatientID&quot; + i)
    String visitId = vars.get(&quot;VisitID&quot; + i)
    
    // Example: static or template text
    String piText = &quot;&quot;&quot;QA 테스트 –
 환자는 [증상 발생 시간] 전부터,
 [주요 증상]을(를) 호소하였으며,
 [발생 상황] 중 발생함.
 과거력: [과거 질환 또는 상태].&quot;&quot;&quot;

    int userThread = Integer.parseInt(vars.get(&quot;User_Thread&quot;))
    if (userThread % 2 == 0) {
    	stmt.setString(1, patientId)
     stmt.setString(2, visitId)
     stmt.setString(3, piText)
     stmt.executeUpdate()
     stmt.clearParameters()

     log.info(&quot;Inserted PI Patient_ID: &quot; + patientId)
     log.info(&quot;Inserted PI VISIT_ID: &quot; + visitId)
    } else {
    log.info(&quot;PI Patient_ID insert skipped: &quot; + patientId)
    }
}

// Close resources
stmt.close()
conn.close()
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Patient Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount}  // Number of patients to generate
int observationCount = ${ObservationCount}  // Number of observations

// Iterate to create patient data
for (int i = 0; i &lt; repeatCount; i++) {
    
	// Create base Date objects
	Date PatientSet = new Date(timestampDefault)
	Date EncounterSet = new Date(timestampDefault)
	Date NameSet = new Date(timestampDefault)
	
	// Set up calendar based on default timestamp
	Calendar calendar = Calendar.getInstance()
	calendar.setTimeInMillis(timestampDefault)
	
	// Shift timestamp by observation interval to simulate past observations
	calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}))
	
	// --- Generate random birthdate for age between 19 and 110 ---
	int minAge = 19
	int maxAge = 110
	int randomAge = minAge + (int)(Math.random() * (maxAge - minAge + 1))
	
	// Copy current timestamp for age validation
	Calendar nowCal = Calendar.getInstance()
	nowCal.setTimeInMillis(timestampDefault)
	
	// Subtract random age in years
	calendar.setTimeInMillis(timestampDefault)
	calendar.add(Calendar.YEAR, -randomAge)
	
	// Randomize month and day
	int randomMonth = (int)(Math.random() * 12)  // 0-11
	calendar.set(Calendar.MONTH, randomMonth)
	int maxDay = calendar.getActualMaximum(Calendar.DAY_OF_MONTH)
	int randomDay = 1 + (int)(Math.random() * maxDay)
	calendar.set(Calendar.DAY_OF_MONTH, randomDay)
	
	// Ensure age is at least 19 (if birthday has not occurred yet, subtract one more year)
	Calendar checkCal = (Calendar) calendar.clone()
	checkCal.add(Calendar.YEAR, minAge)
	
	if (checkCal.after(nowCal)) {
	    calendar.add(Calendar.YEAR, -1)
	}
	
	// Final birthdate object
	long BirthDatetimeStamp = calendar.getTimeInMillis()
	Date BirthSet = new Date(BirthDatetimeStamp)
	
	// --- Generate PatientID ---
	def scenarioNum = vars.get(&quot;currentScenario&quot;)
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i + &quot;yyMMddHHmmss&quot; + scenarioNum + ${User_Thread})
	sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
	String PatientID = sdf_patient.format(PatientSet)
	
	// --- Generate Name ---
	SimpleDateFormat sdf_name = new SimpleDateFormat(i + &quot;ddHHmmss&quot; + scenarioNum + ${User_Thread})
	sdf_name.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
	String Name = sdf_name.format(NameSet)
	
	// --- Format BirthDate ---
	SimpleDateFormat sdf_birthdate = new SimpleDateFormat(&quot;yyyyMMdd&quot;)
	sdf_birthdate.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
	String BirthDate = sdf_birthdate.format(BirthSet)
	
	// --- Store variables ---
	vars.put(&quot;PatientID&quot; + i, PatientID)
	vars.put(&quot;Name&quot; + i, &quot;QA&quot; + Name)
	vars.put(&quot;BirthDate&quot; + i, BirthDate)
	vars.put(&quot;PatientSex&quot; + i, (Math.random() &lt; 0.5) ? &quot;1&quot; : &quot;2&quot;);
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Visit Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Number of repetitions
int repeatCount = ${PatientCount}

for (int i = 0; i &lt; repeatCount; i++) {
    // Initialize calendar with the default timestamp
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault)

    // Create Date object for the visit (admission)
    Date visitDateObj = new Date(calendar.getTimeInMillis())

    // Format VisitDate as yyMMdd
    SimpleDateFormat sdf_date = new SimpleDateFormat(&quot;yyyyMMdd&quot;)
    sdf_date.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    String VisitDate = sdf_date.format(visitDateObj)

    // Format VisitTime as HHmm
    SimpleDateFormat sdf_time = new SimpleDateFormat(&quot;HHmmss&quot;)
    sdf_time.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    String VisitTime = sdf_time.format(visitDateObj)

    // Generate VisitID as yyyyMMddHHmmss plus user thread number
    def scenarioNum = vars.get(&quot;currentScenario&quot;)
    SimpleDateFormat sdf_visitId1 = new SimpleDateFormat(i + &quot;yyyyMMddHHmmss&quot; + scenarioNum + ${User_Thread})
    sdf_visitId1.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    String VisitID1 = sdf_visitId1.format(visitDateObj)

    SimpleDateFormat sdf_visitId2 = new SimpleDateFormat(i + &quot;yyMMddHHmmss&quot; + scenarioNum + ${User_Thread})
    sdf_visitId2.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    String VisitID2 = sdf_visitId2.format(visitDateObj)

    // Store variables
    vars.put(&quot;VisitID&quot; + i, VisitID1 + &quot;|&quot; + VisitID2)
    vars.put(&quot;VisitDate&quot; + i, VisitDate)
    vars.put(&quot;VisitTime&quot; + i, VisitTime)
}
</stringProp>
          </JSR223PreProcessor>
