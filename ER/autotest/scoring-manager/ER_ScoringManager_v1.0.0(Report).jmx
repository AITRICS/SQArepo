      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(result)_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.io.File
import groovy.json.JsonSlurper
import java.nio.charset.StandardCharsets
import groovy.json.JsonOutput
import java.text.SimpleDateFormat

// 경로 설정
def userHome = props.get(&quot;userHome&quot;)
def date = props.get(&quot;date&quot;)
def outputDir = props.get(&quot;outputDir&quot;)
def outputVersion = vars.get(&quot;version&quot;)
def outputHtmlPath = outputDir + &quot;${outputVersion}_Scoring_Manager_Result.html&quot;

def dateFormatter = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)


// HTML 파일 작성 시작
def htmlContent = &quot;&quot;&quot;
&lt;html&gt;
&lt;head&gt;
    &lt;meta charset=&quot;UTF-8&quot;&gt;
    &lt;title&gt;Scoring_Manager_Result&lt;/title&gt;
    &lt;script src=&quot;https://cdn.jsdelivr.net/npm/chart.js&quot;&gt;&lt;/script&gt;
    &lt;style&gt;
       .chart-container {
           margin-top: 20px;  /* 타이틀과 차트 사이에 여백 추가 */
           margin-bottom: 30px;
           width: 100% !important;        /* 차트가 부모 요소에 맞게 크기를 자동으로 조정하도록 */
           height: 400px;     /* 차트의 높이 설정 */
       }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th, td {
            padding: 10px;
            border: 1px solid #ddd;
        }
    &lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;
&lt;h1&gt;Test Summary&lt;/h1&gt;
&quot;&quot;&quot;

// CSV 파일 처리
def csvFiles = Files.list(Paths.get(outputDir))
    .filter { it.toString().endsWith(&quot;.csv&quot;) }
    .sorted()
    .collect()

def overallStats = [startTime: null, endTime: null, totalTest: 0, passCount: 0, failCount: 0, duration : 0]
def scenarioStatsMap = [:]

// CSV 병합 및 Scenario별 통계 계산
csvFiles.each { file -&gt;
    processCsvFile(file.toFile(), scenarioStatsMap)
}

// Map → List 변환 + Scenario 숫자 정렬 (1,2,10)
def scenarioStats = scenarioStatsMap.values().toList().sort { a, b -&gt;
    def aNum = (a.name =~ /\d+/) ? (a.name =~ /\d+/)[0].toInteger() : 9999
    def bNum = (b.name =~ /\d+/) ? (b.name =~ /\d+/)[0].toInteger() : 9999
    aNum &lt;=&gt; bNum
}

// overallStats 계산
scenarioStats.each { stats -&gt;
    updateOverallStats(overallStats, stats)
}


// HTML 콘텐츠 구성
htmlContent += createSummaryTable(overallStats)
htmlContent += createThreadGroupTable(scenarioStats)
htmlContent += createtotalTestChart(scenarioStats)
htmlContent += createPassFailPieChart(overallStats.passCount, overallStats.failCount)
htmlContent += &quot;&lt;/body&gt;&lt;/html&gt;&quot;

// Summary Table에 startTime, endTime, duration 추가
def createSummaryTable(overallStats) {
    def html = &quot;&quot;&quot;
    &lt;h2&gt;Total Summary Statistics&lt;/h2&gt;
    &lt;table&gt;
        &lt;tr&gt;&lt;th&gt;Total TestCases&lt;/th&gt;&lt;td&gt;${overallStats.totalTest}&lt;/td&gt;&lt;/tr&gt;
        &lt;tr&gt;&lt;th&gt;PASS (Count)&lt;/th&gt;&lt;td&gt;${overallStats.passCount}&lt;/td&gt;&lt;/tr&gt;
        &lt;tr&gt;&lt;th&gt;FAIL (Count)&lt;/th&gt;&lt;td&gt;${overallStats.failCount}&lt;/td&gt;&lt;/tr&gt;
        &lt;tr&gt;&lt;th&gt;Start Time&lt;/th&gt;&lt;td&gt;${overallStats.startTime ? overallStats.startTime : &apos;N/A&apos;}&lt;/td&gt;&lt;/tr&gt;
        &lt;tr&gt;&lt;th&gt;End Time&lt;/th&gt;&lt;td&gt;${overallStats.endTime ? overallStats.endTime : &apos;N/A&apos;}&lt;/td&gt;&lt;/tr&gt;
        &lt;tr&gt;&lt;th&gt;Duration (sec)&lt;/th&gt;&lt;td&gt;${overallStats.duration != null ? overallStats.duration : &apos;N/A&apos;}&lt;/td&gt;&lt;/tr&gt;
    &lt;/table&gt;
    &quot;&quot;&quot;
    return html
}

// Thread Group Table 생성 함수
def createThreadGroupTable(threadGroupStats) {
    def html = &quot;&quot;&quot;
    &lt;h2&gt;Scenario Summary Statistics&lt;/h2&gt;
    &lt;table&gt;
        &lt;tr&gt;
            &lt;th&gt;Scenario&lt;/th&gt;
            &lt;th&gt;TestCases&lt;/th&gt;
            &lt;th&gt;PASS Count&lt;/th&gt;
            &lt;th&gt;FAIL Count&lt;/th&gt;
            &lt;th&gt;StartTime&lt;/th&gt;
            &lt;th&gt;EndTime&lt;/th&gt;
            &lt;th&gt;Duration (sec)&lt;/th&gt;
        &lt;/tr&gt;
    &quot;&quot;&quot;
    
    threadGroupStats.each { stats -&gt;
        html += &quot;&quot;&quot;
        &lt;tr&gt;
            &lt;td&gt;${stats.name}&lt;/td&gt;
            &lt;td&gt;${stats.totalTest}&lt;/td&gt;
            &lt;td&gt;${stats.passCount}&lt;/td&gt;
            &lt;td&gt;${stats.failCount}&lt;/td&gt;
            &lt;td&gt;${stats.startTime ?: &apos;n/a&apos;}&lt;/td&gt;
            &lt;td&gt;${stats.endTime ?: &apos;n/a&apos;}&lt;/td&gt;
            &lt;td&gt;${stats.duration}&lt;/td&gt;
        &lt;/tr&gt;
        &quot;&quot;&quot;
    }
    
    html += &quot;&lt;/table&gt;&quot;
    return html
}

// Total Requests per Thread Group 차트 생성 함수
def createtotalTestChart(threadGroupStats) {
    def threadGroupNames = threadGroupStats.collect { it.name }
    def totalTest = threadGroupStats.collect { it.totalTest }

    def html = &quot;&quot;&quot;
    &lt;h2&gt;Visualizations&lt;/h2&gt;
    &lt;h3&gt;TestCases per Scenario&lt;/h3&gt;
    &lt;div class=&quot;chart-container&quot; style=&quot;margin-top: 50px; margin-bottom: 50px;&quot;&gt;
        &lt;canvas id=&quot;bar-chart&quot; style=&quot;height: 400px;&quot;&gt;&lt;/canvas&gt;
    &lt;/div&gt;

    &lt;script&gt;
        window.addEventListener(&apos;load&apos;, function() {
            setTimeout(function() {
                var ctxBar = document.getElementById(&apos;bar-chart&apos;).getContext(&apos;2d&apos;);
                if (ctxBar) {
                    new Chart(ctxBar, {
                        type: &apos;bar&apos;,
                        data: {
                            labels: ${JsonOutput.toJson(threadGroupNames)},
                            datasets: [{
                                label: &apos;Count&apos;,
                                data: ${JsonOutput.toJson(totalTest)},
                                backgroundColor: &apos;#4A90E2&apos;,
                                borderColor: &apos;#4A90E2&apos;,
                                borderWidth: 1
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            scales: {
                                x: {
                                    title: {
                                        display: true,
                                        text: &apos;Scenario&apos;
                                    }
                                },
                                y: {
                                    title: {
                                        display: true,
                                        text: &apos;TestCase Count&apos;
                                    }
                                }
                            }
                        }
                    });
                } else {
                    console.error(&quot;Canvas element with id &apos;bar-chart&apos; not found!&quot;);
                }
            }, 100);  // 100ms 지연 후 차트 생성
        });
    &lt;/script&gt;
    &quot;&quot;&quot;
    return html
}

// PASS vs FAIL 원형 차트 생성 함수 (Chart.js 스타일)
def createPassFailPieChart(overallPassCount, overallFailCount) {
    def html = &quot;&quot;&quot;
    &lt;h3&gt;PASS vs FAIL&lt;/h3&gt;
    &lt;div class=&quot;chart-container&quot; style=&quot;margin-top: 50px; margin-bottom: 50px;&quot;&gt;
        &lt;canvas id=&quot;pie-chart&quot; style=&quot;height: 400px;&quot;&gt;&lt;/canvas&gt;
    &lt;/div&gt;

    &lt;script&gt;
        window.addEventListener(&apos;load&apos;, function() {
            setTimeout(function() {
                var ctxPie = document.getElementById(&apos;pie-chart&apos;).getContext(&apos;2d&apos;);
                if (ctxPie) {
                    new Chart(ctxPie, {
                        type: &apos;pie&apos;,
                        data: {
                            labels: [&apos;PASS&apos;, &apos;FAIL&apos;], // 성공 및 실패
                            datasets: [{
                                data: [${overallPassCount}, ${overallFailCount}], 
                                backgroundColor: [&apos;#4A90E2&apos;, &apos;#D0021B&apos;] // PASS(파란색), FAIL(빨간색)
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    position: &apos;bottom&apos;,
                                    labels: {
                                        font: { size: 14 },
                                        generateLabels: function(chart) {
                                            var labels = chart.data.labels;
                                            var dataValues = chart.data.datasets[0].data;
                                            var total = dataValues.reduce((sum, value) =&gt; sum + value, 0);

                                            return labels.map(function(label, index) {
                                                var currentValue = dataValues[index];
                                                var percentage = ((currentValue / total) * 100).toFixed(2);
                                                return {
                                                    text: label + &apos; (&apos; + currentValue + &apos;, &apos; + percentage + &apos;%)&apos;,
                                                    fillStyle: chart.data.datasets[0].backgroundColor[index]
                                                };
                                            });
                                        }
                                    }
                                },
                                tooltip: {
                                    callbacks: {
                                        label: function(tooltipItem) {
                                            var dataValues = tooltipItem.chart.data.datasets[0].data;
                                            var total = dataValues.reduce((sum, val) =&gt; sum + val, 0);
                                            var currentValue = dataValues[tooltipItem.dataIndex];
                                            var percentage = ((currentValue / total) * 100).toFixed(2);
                                            return currentValue + &apos; (&apos; + percentage + &apos;%)&apos;;
                                        }
                                    }
                                }
                            }
                        }
                    });
                }
            }, 100);  // 100ms 지연 후 차트 생성
        });
    &lt;/script&gt;
    &quot;&quot;&quot;
    return html
}

// HTML 파일 저장
try {
    Files.write(Paths.get(outputHtmlPath), htmlContent.getBytes(&quot;UTF-8&quot;))
    log.info(&quot;HTML report generated: ${outputHtmlPath}&quot;)
} catch (Exception e) {
    log.error(&quot;Failed to write HTML file: ${outputHtmlPath}, error: ${e.message}&quot;)
}

// 특수 문자 HTML-Escape 함수
def escapeHtml(String input) {
    if (input == null) {
        return &quot;&quot;
    }
    return input.replaceAll(&quot;&lt;&quot;, &quot;&amp;lt;&quot;).replaceAll(&quot;&gt;&quot;, &quot;&amp;gt;&quot;)
}

// CSV 파일 처리 함수
def processCsvFile(File file, Map scenarioStatsMap) {

    def lines = file.readLines()
    def dataLines = lines.drop(1) // header 제거

    dataLines.each { line -&gt;
        def columns = line.split(&quot;,&quot;).collect { it.trim() }

        def scenario = columns[1]
        def startTs  = columns[2]
        def endTs    = columns[3]
        def result   = columns[-1]

        def stats = scenarioStatsMap.get(scenario)
        if (!stats) {
            stats = [
                name      : scenario,
                totalTest: 0,
                passCount: 0,
                failCount: 0,
                startTime: null,
                endTime  : null,
                duration : 0
            ]
            scenarioStatsMap.put(scenario, stats)
        }

        stats.totalTest++
        if (result == &quot;PASS&quot;) stats.passCount++
        else stats.failCount++

        if (!stats.startTime || startTs &lt; stats.startTime) stats.startTime = startTs
        if (!stats.endTime   || endTs   &gt; stats.endTime)   stats.endTime   = endTs
    }

    // duration 계산
    scenarioStatsMap.values().each { s -&gt;
        if (s.startTime &amp;&amp; s.endTime) {
            def st = Date.parse(&quot;yyyy-MM-dd HH:mm:ss&quot;, s.startTime)
            def et = Date.parse(&quot;yyyy-MM-dd HH:mm:ss&quot;, s.endTime)
            s.duration = (et.time - st.time) / 1000
        }
    }
}




// Summary Stats 업데이트 및 값 누적
def updateOverallStats(overallStats, stats) {
    // 누적할 필드들 업데이트
    overallStats.totalTest += stats.totalTest
    overallStats.passCount += stats.passCount
    overallStats.failCount += stats.failCount

    // startTime과 endTime을 비교하여 전체 범위 설정
    if (overallStats.startTime == null || stats.startTime &lt; overallStats.startTime) {
        overallStats.startTime = stats.startTime
    }
    if (overallStats.endTime == null || stats.endTime &gt; overallStats.endTime) {
        overallStats.endTime = stats.endTime
    }
    
    // 문자열을 Date로 변환하여 계산
    if (overallStats.startTime != null &amp;&amp; overallStats.endTime != null) {
        // startTime과 endTime을 Date로 변환
        def startTimeDate = Date.parse(&quot;yyyy-MM-dd HH:mm:ss&quot;, overallStats.startTime) 
        def endTimeDate = Date.parse(&quot;yyyy-MM-dd HH:mm:ss&quot;, overallStats.endTime)
        
        // 시간 차이 계산 (밀리초 단위)
        overallStats.duration = (endTimeDate.time - startTimeDate.time) / 1000        
    }
}


</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(Result_Detail_Log)_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import groovy.json.JsonOutput
import groovy.json.JsonSlurper
import java.nio.charset.StandardCharsets
import org.apache.commons.lang3.StringEscapeUtils

// 경로 설정
def userHome = props.get(&quot;userHome&quot;)
def date = props.get(&quot;date&quot;)
def outputDir = props.get(&quot;outputDir&quot;)

// 디렉토리 내 .csv 파일 처리 및 정렬
def detailLogFiles = Files.list(Paths.get(outputDir))
    .filter { it.toString().endsWith(&quot;.csv&quot;) } // .csv 파일만 필터링
    .sorted { a, b -&gt; a.getFileName().toString() &lt;=&gt; b.getFileName().toString() } // 파일 이름으로 정렬
    .collect()

if (detailLogFiles.isEmpty()) {
    println &quot;No log files found.&quot;
} else {
    detailLogFiles.eachWithIndex { logFile, idx -&gt;
        def logFileName = logFile.getFileName().toString().replace(&quot;.csv&quot;, &quot;&quot;)        
        def htmlContent = &quot;&quot;&quot;
        &lt;html&gt;
        &lt;head&gt;
            &lt;title&gt;${logFileName} - CSV to HTML Report&lt;/title&gt;
            &lt;meta charset=&quot;UTF-8&quot;&gt;
            &lt;style&gt;
                table {
                    width: 100%;
                    border-collapse: collapse;
                }
                th, td {
                    padding: 10px;
                    border: 1px solid #ddd;
                }
            &lt;/style&gt;
        &lt;/head&gt;
        &lt;body&gt;
        &lt;table&gt;
        &quot;&quot;&quot;

        try {
            def lines = Files.readAllLines(logFile, StandardCharsets.UTF_8)
            if (lines.size() &gt; 1) {
                // 첫 번째 줄을 헤더로 사용
                def headers = lines[0].split(&quot;,&quot;)
                htmlContent += &quot;&lt;tr&gt;&quot; + headers.drop(1).collect { &quot;&lt;th&gt;${escapeHtml(it)}&lt;/th&gt;&quot; }.join(&apos;&apos;) + &quot;&lt;/tr&gt;&quot;
                
                // 나머지 줄을 데이터로 사용 (두 번째 컬럼을 기준으로 정렬)
			def sortedLines = lines.drop(1).sort { line -&gt;
			    def columns = line.split(&quot;,&quot;)
			    def scenarioText = columns[1].trim() // 두 번째 컬럼 (Scenario)
			    
			    // &quot;Scenario &quot; 뒤 숫자만 추출
			    def matcher = (scenarioText =~ /Scenario (\d+)/)
			    if (matcher) {
			        return matcher[0][1].toInteger() // 숫자로 변환하여 정렬
			    } else {
			        return Integer.MAX_VALUE // 숫자가 없으면 가장 뒤로 정렬
			    }
			}
                
                sortedLines.each { line -&gt;
                    def columns = line.split(&quot;,&quot;)
                    htmlContent += &quot;&lt;tr&gt;&quot; + columns.drop(1).collect { &quot;&lt;td&gt;${escapeHtml(it)}&lt;/td&gt;&quot; }.join(&apos;&apos;) + &quot;&lt;/tr&gt;&quot;
                }
            }
        } catch (Exception e) {
            println &quot;Failed to read log file: ${logFile}, error: ${e.message}&quot;
        }

        htmlContent += &quot;&quot;&quot;
        &lt;/table&gt;
        &lt;/body&gt;
        &lt;/html&gt;
        &quot;&quot;&quot;

        // 각 CSV 파일에 대해 개별 HTML 파일 저장
        def outputHtmlPath = outputDir + &quot;${logFileName}.html&quot;
        try {
            Files.write(Paths.get(outputHtmlPath), htmlContent.getBytes(StandardCharsets.UTF_8))
            println &quot;HTML report generated for ${logFileName}: ${outputHtmlPath}&quot;
        } catch (Exception e) {
            println &quot;Failed to write HTML file: ${outputHtmlPath}, error: ${e.message}&quot;
        }
    }
}

// 특수 문자 HTML-Escape 함수 (JSON 데이터 보호 포함)
def escapeHtml(String input) {
    if (input == null) {
        return &quot;&quot;
    }
    return input.replaceAll(&quot;&amp;&quot;, &quot;&amp;amp;&quot;)
                .replaceAll(&quot;&lt;&quot;, &quot;&amp;lt;&quot;)
                .replaceAll(&quot;&gt;&quot;, &quot;&amp;gt;&quot;)
                .replaceAll(&quot;\&quot;&quot;, &quot;&amp;quot;&quot;)
                .replaceAll(&quot;&apos;&quot;, &quot;&amp;#39;&quot;)
}

// 유니코드 이스케이프 문자열을 한글로 변환
def decodeUnicode(String input) {
    return StringEscapeUtils.unescapeJava(input)
}

def formatJson(String jsonString) {
    try {
        def jsonObj = new JsonSlurper().parseText(jsonString)
        return decodeUnicode(JsonOutput.prettyPrint(JsonOutput.toJson(jsonObj))) 
    } catch (Exception e) {
        return decodeUnicode(jsonString) 
    }
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(Intergration)_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*;
import java.nio.charset.StandardCharsets;

// 경로 설정
def userHome = props.get(&quot;userHome&quot;);
def date = props.get(&quot;date&quot;);
def outputDir = props.get(&quot;outputDir&quot;);
def outputVersion = vars.get(&quot;version&quot;)
def outputHtmlPath = outputDir + &quot;${outputVersion}_Scoring_Manager_Report.html&quot;;

// 파일 내용 읽기
def TestResult = Paths.get(outputDir, &quot;${outputVersion}_Scoring_Manager_Result.html&quot;).toString();

// group 파일 경로 설정
def groupFiles = Files.newDirectoryStream(Paths.get(outputDir), &quot;Group*.html&quot;)
                        .toList()
                        .collect { it.toString() }
                        .sort { it }

def contentFile1 = new File(TestResult).text;
def groupContents = groupFiles.collect { new File(it).text };

def groupNameMapping = [
    &quot;Group 1&quot;: &quot;Group 1 (default)&quot;,
    &quot;Group 2&quot;: &quot;Group 2 (필수값 관련)&quot;,
    &quot;Group 3&quot;: &quot;Group 3 (O2 관련)&quot;,
    &quot;Group 4&quot;: &quot;Group 4 (Total fetch hour 관련)&quot;,
    &quot;Group 5&quot;: &quot;Group 5 (미래시)&quot;,
    &quot;Group 6&quot;: &quot;Group 6 (현재시)&quot;,
    &quot;Group 7&quot;: &quot;Group 7 (VITAL)&quot;,
    &quot;Group 8&quot;: &quot;Group 8 (LAB)&quot;
]

def groupDescriptions = [
    &quot;Group 1&quot;: &quot;기본 기능에 대한 스코어 계산 시나리오 케이스&quot;,
    &quot;Group 2&quot;: &quot;필수 입력값 유무에 따른 스코어 계산 시나리오 케이스&quot;,
    &quot;Group 3&quot;: &quot;다중 출처 평가항목 중 추가 산소 공급 여부 입력에 따른 스코어 계산 시나리오 케이스&quot;,
    &quot;Group 4&quot;: &quot;Total Fetch Hour 이내/이외 범위의 필수 입력값 유무에 따른 스코어 계산 시나리오 케이스&quot;,
    &quot;Group 5&quot;: &quot;미래시 관측 데이터에 대한 스코어 계산 시나리오 케이스&quot;,
    &quot;Group 6&quot;: &quot;현재시 관측 데이터에 대한 스코어 계산 시나리오 케이스&quot;,
    &quot;Group 7&quot;: &quot;VITAL 한개씩 추가 시 스코어 계산 시나리오 케이스&quot;,
    &quot;Group 8&quot;: &quot;LAB 한개씩 추가 시 스코어 계산 시나리오 케이스&quot;
]

// HTML 탭 이름 처리 수정된 부분
def tabButtons = groupFiles.collect { file -&gt;
    def groupName = file.replace(&quot;.html&quot;, &quot;&quot;).split(&quot;/&quot;).last();
    def displayName = groupNameMapping.getOrDefault(groupName, groupName) // 매핑된 이름이 있으면 사용, 없으면 원본
    return &apos;&lt;button class=&quot;tablinks&quot; onclick=&quot;openTab(event, \&apos;&apos; + groupName + &apos;\&apos;)&quot;&gt;&apos; + displayName + &apos;&lt;/button&gt;&apos;
}.join(&quot;\n&quot;)

// 그룹별 HTML 컨텐츠 추가 (파일 정렬 후 순서대로 추가)
def groupHtmlContent = groupFiles.collect { file -&gt;
    def groupName = file.replace(&quot;.html&quot;, &quot;&quot;).split(&quot;/&quot;).last()
    def displayName = groupNameMapping.getOrDefault(groupName, groupName)
    def description = groupDescriptions.getOrDefault(groupName, &quot;해당 그룹의 설명이 없습니다.&quot;) // 설명 추가
    &quot;&quot;&quot;&lt;div id=&quot;${groupName}&quot; class=&quot;tabcontent&quot;&gt;
        &lt;h2&gt;${displayName}&lt;/h2&gt;
        &lt;h3 style=&quot;font-style: italic; color: #555;&quot;&gt;${description}&lt;/h3&gt;
        ${new File(file).text}
    &lt;/div&gt;&quot;&quot;&quot;
}.join(&quot;\n&quot;)

// HTML 파일 작성
def combinedHtml = &quot;&quot;&quot;
&lt;html&gt;
&lt;head&gt;
    &lt;title&gt;${outputVersion}_Score_Generation_Report&lt;/title&gt;
    &lt;meta charset=&quot;UTF-8&quot;&gt;
    &lt;style&gt;
        body {
            font-family: Arial, sans-serif;
            margin: 10px;
            background-color: #f4f4f9;
            padding: 2%;
            font-size: 16px;
        }
        h1, h2 {
            color: #333;
        }
        h1 {
            font-size: 1.5em;
        }
        h2 {
            font-size: 1.0em;
        }
        h3 {
            font-size: 0.9em;
        }
        .PASS {
            font-weight: bold;
            color: blue;
        }
        .FAIL {
            font-weight: bold;
            color: red;
        }
        table {
            width: 100%;
            table-layout: fixed;
            border-collapse: collapse;
            margin-top: 20px;
            font-size: 0.8em;
        }
        th, td {
            padding: 10px;
            text-align: left;
            border: 1px solid #ddd;
            word-wrap: break-word;
            white-space: normal;
        }
        th {
            background-color: #f2f2f2;
        }
        tr:nth-child(even) {
            background-color: #f9f9f9;
        }

        .tab {
            overflow: hidden;
            background-color: #f4f4f9;
            border-bottom: 2px solid #ddd;
            margin-bottom: 20px;
        }
        .tab button {
            background-color: #e9e9f3;
            color: #333;
            float: left;
            border: none;
            outline: none;
            cursor: pointer;
            padding: 14px 20px;
            transition: 0.3s;
            font-size: 14px;
            font-weight: bold;
            margin-right: 5px;
            border-radius: 5px 5px 0 0;
        }
        .tab button:hover {
            background-color: #d6d6ee;
        }
        .tab button.active {
            background-color: #b3b3dd;
            color: white;
            border-bottom: 3px solid #6c63ff;
        }
        .tabcontent {
            display: none;
            padding: 20px;
            border: 1px solid #ddd;
            border-top: none;
            border-radius: 0 0 5px 5px;
            background-color: white;
            width: 100vw;
            max-width: 100%;
        }
        .tabcontent.active {
            display: block;
        }
        .tabcontent .chart-container {
            width: 100% !important;
            height: 35vh !important;
            margin: 0 auto;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
        }
        @media (max-width: 1024px) {
            body {
                font-size: 10px;
            }
            h1 {
                font-size: 1.5em;
            }
            table {
                font-size: 0.9em;
            }
        }
        @media print {
            body {
                font-size: 10px;
            }
            table {
                font-size: 0.8em;
            }
        }
    &lt;/style&gt;
    
    &lt;script&gt;
        function openTab(evt, tabName) {
            var i, tabcontent, tablinks;
            tabcontent = document.getElementsByClassName(&quot;tabcontent&quot;);
            for (i = 0; i &lt; tabcontent.length; i++) {
                tabcontent[i].classList.remove(&quot;active&quot;);
            }
            tablinks = document.getElementsByClassName(&quot;tablinks&quot;);
            for (i = 0; i &lt; tablinks.length; i++) {
                tablinks[i].classList.remove(&quot;active&quot;);
            }
            document.getElementById(tabName).classList.add(&quot;active&quot;);
            evt.currentTarget.classList.add(&quot;active&quot;);
        }
        document.addEventListener(&quot;DOMContentLoaded&quot;, function() {
            document.getElementsByClassName(&quot;tablinks&quot;)[0].click();
        });
        window.addEventListener(&quot;resize&quot;, function() {
            Plotly.relayout(&apos;chart-container&apos;, {
                width: window.innerWidth * 0.9,
                height: window.innerHeight * 0.4
            });
        });
    &lt;/script&gt;
&lt;/head&gt;
&lt;body&gt;
    &lt;h1&gt;${outputVersion}_Score Generation Report&lt;/h1&gt;
    &lt;div class=&quot;tab&quot;&gt;
        &lt;button class=&quot;tablinks&quot; onclick=&quot;openTab(event, &apos;Result&apos;)&quot;&gt;Test Result&lt;/button&gt;
        ${tabButtons}
    &lt;/div&gt;
    &lt;div id=&quot;Result&quot; class=&quot;tabcontent&quot;&gt;
        ${contentFile1}
    &lt;/div&gt;
	${groupHtmlContent}

&lt;/body&gt;
&lt;/html&gt;
&quot;&quot;&quot;;

// HTML 파일 저장
Files.write(Paths.get(outputHtmlPath), combinedHtml.getBytes(StandardCharsets.UTF_8));

// 로그 출력
log.info(&quot;Combined HTML file saved at: ${outputHtmlPath}&quot;);</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
    </hashTree>
  </hashTree>
</jmeterTestPlan>
