        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="ER_PI_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection
import java.sql.DriverManager
import java.sql.PreparedStatement
import java.sql.SQLException

// JDBC connection information
String url = &quot;${JDBC_URL}&quot;
String user = &quot;${JDBC_USER}&quot;
String password = &quot;${JDBC_PW}&quot;

// SQL insert query for all VARCHAR fields
String query = &quot;INSERT INTO ROOT.EMR_PRESENT_ILLNESS (PATIENT_ID, VISIT_ID, PI_TEXT) &quot; +
               &quot;VALUES (?, ?, ?)&quot;

// Create connection and prepare statement
Connection conn = DriverManager.getConnection(url, user, password)
PreparedStatement stmt = conn.prepareStatement(query)

// Repeat insert for each set of variables
int repeatCount = Integer.parseInt(vars.get(&quot;PatientCount&quot;))

for (int i = 0; i &lt; repeatCount; i++) {
    String patientId = vars.get(&quot;PatientID&quot; + i)
    String visitId = vars.get(&quot;VisitID&quot; + i)
    
    // Example: static or template text
    String piText = &quot;&quot;&quot;QA 테스트 –
 환자는 [증상 발생 시간] 전부터,
 [주요 증상]을(를) 호소하였으며,
 [발생 상황] 중 발생함.
 과거력: [과거 질환 또는 상태].&quot;&quot;&quot;

    int userThread = Integer.parseInt(vars.get(&quot;User_Thread&quot;))
    if (userThread % 2 == 0) {
    	stmt.setString(1, patientId)
     stmt.setString(2, visitId)
     stmt.setString(3, piText)
     stmt.executeUpdate()
     stmt.clearParameters()

     log.info(&quot;Inserted PI Patient_ID: &quot; + patientId)
     log.info(&quot;Inserted PI VISIT_ID: &quot; + visitId)
    } else {
    log.info(&quot;PI Patient_ID insert skipped: &quot; + patientId)
    }
}

// Close resources
stmt.close()
conn.close()
</stringProp>
        </JSR223Sampler>
