        </elementProp>
      </ThreadGroup>
      <hashTree>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter
import java.nio.charset.StandardCharsets

def logResults = { prev, ctx, props, vars, csvDataString -&gt;

	if (csvDataString == null || csvDataString.trim().isEmpty()) {
		log.error(&quot;csvDataString is null or empty.&quot;)
		return
	}
	
	def now = LocalDateTime.now().format(DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd HH:mm:ss&quot;))
	def outputDir = props.get(&quot;outputDir&quot;)

	if (!Files.exists(Paths.get(outputDir))) {
		Files.createDirectories(Paths.get(outputDir))
	}

	def csvDataArray = csvDataString.split(&quot;,&quot;)  // CSV 데이터를 배열로 변환
	def fullThreadName = prev.getThreadName()
	def threadGroupName = fullThreadName.split(&quot; &quot;)[0] + fullThreadName.split(&quot; &quot;)[1]
	def controllerName = vars.get(&quot;currentControllerName&quot;)

	def resultFile = Paths.get(outputDir, &quot;${controllerName}.csv&quot;)

	def csvHeader = &quot;Group,Scenario,StartTime,EndTime,Patient ID,Encounter ID,baseDt,hasVital,hasKtas,hasLoc,hasCc,hasPi,hasAction,bres,cres,pres,Test Result\n&quot;
								
	if (!Files.exists(resultFile)) {
		Files.createDirectories(resultFile.parent)
		Files.write(resultFile, csvHeader.getBytes(StandardCharsets.UTF_8), StandardOpenOption.CREATE)
	}

	// 데이터 추가 (ThreadGroupName, SamplerName, csvDataString)
	def dataToWrite = &quot;${controllerName}, ${csvDataString}\n&quot;

	Files.write(resultFile, dataToWrite.getBytes(StandardCharsets.UTF_8), StandardOpenOption.APPEND)
}

vars.putObject(&quot;logResults&quot;, logResults)
</stringProp>
        </JSR223PreProcessor>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="setname Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">vars.put(&quot;currentControllerName&quot;, &quot;Group 1&quot;)

long currentTime = System.currentTimeMillis()
vars.put(&quot;startTimeThread&quot;, String.valueOf(currentTime))

String threadGroupName = ctx.getThreadGroup().getName()
def scenarioNum = threadGroupName.replaceAll(&quot;[^0-9]&quot;, &quot;&quot;)

vars.put(&quot;currentScenario&quot;, scenarioNum)

vars.put(&quot;hasVital_&quot; + scenarioNum, &quot;true&quot;)
vars.put(&quot;hasKtas_&quot;  + scenarioNum, &quot;true&quot;)
vars.put(&quot;hasLoc_&quot;   + scenarioNum, &quot;true&quot;)
vars.put(&quot;hasCc_&quot;    + scenarioNum, &quot;true&quot;)
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Flow Control Action_10sec" enabled="true">
          <intProp name="ActionProcessor.action">1</intProp>
          <intProp name="ActionProcessor.target">0</intProp>
          <stringProp name="ActionProcessor.duration">10000</stringProp>
          <stringProp name="TestPlan.comments">1 * 60 * 1000 = 60000</stringProp>
        </TestAction>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="ER_EMR_EMIHPTMI_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection
import java.sql.DriverManager
import java.sql.PreparedStatement
import java.sql.SQLException

String url = &quot;${JDBC_URL}&quot;
String user = &quot;${JDBC_USER}&quot;
String password = &quot;${JDBC_PW}&quot;

String query = &quot;INSERT INTO ROOT.EMR_EMIHPTMI (&quot; +
    &quot;VISIT_ID, PTMIIDNO, PTMIINDT, PTMIINTM, PTMINAME, PTMIBRTD, PTMISEXX, PTMIAKDT, PTMIAKTM, PTMIMNSY, &quot; +
    &quot;PTMIMSSR, PTMISYM2, PTMISYS2, PTMISYM3, PTMISYS3, PTMIETSY, PTMIRESP, PTMIHIBP, PTMILOBP, PTMIPULS, &quot; +
    &quot;PTMIBRTH, PTMIBDHT, PTMIVOXS, PTMIKPR1, PTMIKTS1, PTMIKTDT, PTMIKTTM, PTMIKPR2, PTMIKTS2, PTMIOTDT, PTMIOTTM, &quot; +
    &quot;AREA_NAME, BED_NO, SYMP_NAME1, SYMP_NAME2, SYMP_NAME3&quot; +
    &quot;) VALUES (&quot; + 
    &quot;?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?&quot; +
    &quot;)&quot;

Connection conn = null
PreparedStatement stmt = null

try {
    conn = DriverManager.getConnection(url, user, password)
    stmt = conn.prepareStatement(query)

    int repeatCount = Integer.parseInt(vars.get(&quot;PatientCount&quot;))

	def scenarioNum = vars.get(&quot;currentScenario&quot;)
	boolean hasVital = vars.get(&quot;hasVital_&quot;    + scenarioNum) == null? true: vars.get(&quot;hasVital_&quot; + scenarioNum).toBoolean()
	boolean hasKtas  = vars.get(&quot;hasKtas_&quot;    + scenarioNum) == null? true: vars.get(&quot;hasKtas_&quot; + scenarioNum).toBoolean()
	boolean hasLoc   = vars.get(&quot;hasLoc_&quot;    + scenarioNum) == null? true: vars.get(&quot;hasLoc_&quot; + scenarioNum).toBoolean()
	boolean hasCc    = vars.get(&quot;hasCc_&quot;    + scenarioNum) == null? true: vars.get(&quot;hasCc_&quot; + scenarioNum).toBoolean()

    for (int i = 0; i &lt; repeatCount; i++) {
        // Set parameters for the insert statement
        // ================================
	   // 1. patient
	   // ================================
        stmt.setString(1, vars.get(&quot;VisitID&quot; + i))                  // Visit ID &gt; VISIT_ID column
        stmt.setString(2, vars.get(&quot;PatientID&quot; + i))                // Patient ID &gt; PTMIIDNO column
        stmt.setString(3, vars.get(&quot;VisitDate&quot; + i))                // Admission Date &gt; PTMIINDT column
        stmt.setString(4, vars.get(&quot;VisitTime&quot; + i))                // Admission Time &gt; PTMIINTM column
        stmt.setString(5, vars.get(&quot;Name&quot; + i))                     // Patient Name &gt; PTMINAME column
        stmt.setString(6, vars.get(&quot;BirthDate&quot; + i))                // Patient Birthdate &gt; PTMIBRTD column
        stmt.setString(7, vars.get(&quot;PatientSex&quot; + i))               // Patient Sex &gt; PTMISEXX column
        // ================================
	   // 2. cc
	   // ================================
	   if (hasCc) {
        	stmt.setString(8, vars.get(&quot;OnsetDate&quot; + i))                // CC Onset Date &gt; PTMIAKDT column
        	stmt.setString(9, vars.get(&quot;OnsetTime&quot; + i))                // CC Onset Time &gt; PTMIAKTM column
        	stmt.setString(10, vars.get(&quot;SympCode_1_&quot; + i))             // Symptom Code 1 &gt; PTMIMNSY column
        	stmt.setString(11, vars.get(&quot;SympSR_1_&quot; + i))               // Serial Code 1 &gt; PTMIMSSR column
        	stmt.setString(12, vars.get(&quot;SympCode_2_&quot; + i))             // Symptom Code 2 &gt; PTMISYM2 column
        	stmt.setString(13, vars.get(&quot;SympSR_2_&quot; + i))               // Serial Code 2 &gt; PTMISYS2 column
        	stmt.setString(14, vars.get(&quot;SympCode_3_&quot; + i))             // Symptom Code 2 &gt; PTMISYM2 column
        	stmt.setString(15, vars.get(&quot;SympSR_3_&quot; + i))               // Serial Code 2 &gt; PTMISYS2 column
        	stmt.setNull(16, java.sql.Types.VARCHAR)
        	// Manual Symptom Code &gt; PTMIETSY column
        	stmt.setString(34, vars.get(&quot;SympName_1_&quot; + i))             // Symptom Name 1 &gt; SYMP_NAME1 column
        	stmt.setString(35, vars.get(&quot;SympName_2_&quot; + i))             // Symptom Name 2 &gt; SYMP_NAME2 column
        	stmt.setString(36, vars.get(&quot;SympName_3_&quot; + i))             // Symptom Name 3 &gt; SYMP_NAME3 column
	   } else {
        	stmt.setNull(8,  java.sql.Types.VARCHAR)
        	stmt.setNull(9,  java.sql.Types.VARCHAR)
        	stmt.setNull(10, java.sql.Types.VARCHAR)
        	stmt.setNull(11, java.sql.Types.VARCHAR)
        	stmt.setNull(12, java.sql.Types.VARCHAR)
        	stmt.setNull(13, java.sql.Types.VARCHAR)
        	stmt.setNull(14, java.sql.Types.VARCHAR)
        	stmt.setNull(15, java.sql.Types.VARCHAR)
        	stmt.setNull(16, java.sql.Types.VARCHAR)
        	stmt.setNull(34, java.sql.Types.VARCHAR)
        	stmt.setNull(35, java.sql.Types.VARCHAR)
        	stmt.setNull(36, java.sql.Types.VARCHAR)
	   }	

        // ================================
	   // 3. loc
	   // ================================
	   if (hasLoc) {
	   	stmt.setString(17, vars.get(&quot;INITIAL_LOC_Value&quot; + i))       // Initial GCS LOC &gt; PTMIRESP column	
	   } else {
	   	stmt.setNull(17, java.sql.Types.VARCHAR)
	   }
        
        // ================================
	   // 4. vital
	   // ================================
        if (hasVital) {
        	stmt.setString(18, vars.get(&quot;INITIAL_SBP_Value&quot; + i))       // Initial SBP &gt; PTMIHIBP column
        	stmt.setString(19, vars.get(&quot;INITIAL_DBP_Value&quot; + i))       // Initial DBP &gt; PTMILOBP column
        	stmt.setString(20, vars.get(&quot;INITIAL_PR_Value&quot; + i))        // Initial PR &gt; PTMIPULS column
        	stmt.setString(21, vars.get(&quot;INITIAL_RR_Value&quot; + i))        // Initial RR &gt; PTMIBRTH column
        	stmt.setString(22, vars.get(&quot;INITIAL_BT_Value&quot; + i))        // Initial BT &gt; PTMIBDHT column
        	stmt.setString(23, vars.get(&quot;INITIAL_SpO2_Value&quot; + i))      // Initial SpO2 &gt; PTMIVOXS column
        } else {
        	stmt.setNull(18, java.sql.Types.VARCHAR)
        	stmt.setNull(19, java.sql.Types.VARCHAR)
        	stmt.setNull(20, java.sql.Types.VARCHAR)
        	stmt.setNull(21, java.sql.Types.VARCHAR)
        	stmt.setNull(22, java.sql.Types.VARCHAR)
        	stmt.setNull(23, java.sql.Types.VARCHAR)
        }
        // ================================
	   // 5. ktas
	   // ================================
	   if (hasKtas) {
        	stmt.setString(24, vars.get(&quot;InitCode&quot; + i))                // Initial KTAS Process Code &gt; PTMIKPR1 column
        	stmt.setString(25, vars.get(&quot;InitLevel&quot; + i))               // Initial KTAS Level &gt; PTMIKTS1 column
        	stmt.setString(26, vars.get(&quot;InitTriagetDate&quot; + i))         // Initial KTAS Date &gt; PTMIKTDT column
        	stmt.setString(27, vars.get(&quot;InitTriagetTime&quot; + i))         // Initial KTAS Time &gt; PTMIKTTM column
        	stmt.setNull(28, java.sql.Types.VARCHAR)                    // Changed KTAS Process Code &gt; PTMIKPR2 column
        	stmt.setNull(29, java.sql.Types.VARCHAR)                    // Changed KTAS Level &gt; PTMIKTS2 column
	   } else {
	   	stmt.setNull(24, java.sql.Types.VARCHAR)
	   	stmt.setNull(25, java.sql.Types.VARCHAR)
	   	stmt.setNull(26, java.sql.Types.VARCHAR)
	   	stmt.setNull(27, java.sql.Types.VARCHAR)
	   	stmt.setNull(28, java.sql.Types.VARCHAR)                    // Changed KTAS Process Code &gt; PTMIKPR2 column
        	stmt.setNull(29, java.sql.Types.VARCHAR)                    // Changed KTAS Level &gt; PTMIKTS2 column
	   }
	   
        stmt.setNull(30, java.sql.Types.VARCHAR)                    // Discharge Date &gt; PTMIOTDT column
        stmt.setNull(31, java.sql.Types.VARCHAR)                    // Discharge Time &gt; PTMIOTTM column
        stmt.setString(32, vars.get(&quot;QA_AREA&quot; + i))                 // Area Name &gt; AREA_NAME column
        stmt.setString(33, vars.get(&quot;QA_BED&quot; + i))                  // Bed Number &gt; BED_NO column

        // Execute the insert
        stmt.executeUpdate()
        log.info(&quot;Inserted Patient_ID: &quot; + vars.get(&quot;PatientID&quot; + i))
        log.info(&quot;Inserted VISIT_ID: &quot; + vars.get(&quot;VisitID&quot; + i))

        // Clear parameters for the next iteration
        stmt.clearParameters()
    }
} catch (SQLException e) {
    log.error(&quot;SQL Error: &quot; + e.getMessage())
} finally {
    if (stmt != null) try { stmt.close() } catch (Exception ignore) {}
    if (conn != null) try { conn.close() } catch (Exception ignore) {}
}
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Patient Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount}  // Number of patients to generate
int observationCount = ${ObservationCount}  // Number of observations

// Iterate to create patient data
for (int i = 0; i &lt; repeatCount; i++) {
    
	// Create base Date objects
	Date PatientSet = new Date(timestampDefault)
	Date EncounterSet = new Date(timestampDefault)
	Date NameSet = new Date(timestampDefault)
	
	// Set up calendar based on default timestamp
	Calendar calendar = Calendar.getInstance()
	calendar.setTimeInMillis(timestampDefault)
	
	// Shift timestamp by observation interval to simulate past observations
	calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}))
	
	// --- Generate random birthdate for age between 19 and 110 ---
	int minAge = 19
	int maxAge = 110
	int randomAge = minAge + (int)(Math.random() * (maxAge - minAge + 1))
	
	// Copy current timestamp for age validation
	Calendar nowCal = Calendar.getInstance()
	nowCal.setTimeInMillis(timestampDefault)
	
	// Subtract random age in years
	calendar.setTimeInMillis(timestampDefault)
	calendar.add(Calendar.YEAR, -randomAge)
	
	// Randomize month and day
	int randomMonth = (int)(Math.random() * 12)  // 0-11
	calendar.set(Calendar.MONTH, randomMonth)
	int maxDay = calendar.getActualMaximum(Calendar.DAY_OF_MONTH)
	int randomDay = 1 + (int)(Math.random() * maxDay)
	calendar.set(Calendar.DAY_OF_MONTH, randomDay)
	
	// Ensure age is at least 19 (if birthday has not occurred yet, subtract one more year)
	Calendar checkCal = (Calendar) calendar.clone()
	checkCal.add(Calendar.YEAR, minAge)
	
	if (checkCal.after(nowCal)) {
	    calendar.add(Calendar.YEAR, -1)
	}
	
	// Final birthdate object
	long BirthDatetimeStamp = calendar.getTimeInMillis()
	Date BirthSet = new Date(BirthDatetimeStamp)
	
	// --- Generate PatientID ---
	def scenarioNum = vars.get(&quot;currentScenario&quot;)
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i + &quot;yyMMddHHmmss&quot; + scenarioNum + ${User_Thread})
	sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
	String PatientID = sdf_patient.format(PatientSet)
	
	// --- Generate Name ---
	SimpleDateFormat sdf_name = new SimpleDateFormat(i + &quot;ddHHmmss&quot; + scenarioNum + ${User_Thread})
	sdf_name.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
	String Name = sdf_name.format(NameSet)
	
	// --- Format BirthDate ---
	SimpleDateFormat sdf_birthdate = new SimpleDateFormat(&quot;yyyyMMdd&quot;)
	sdf_birthdate.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
	String BirthDate = sdf_birthdate.format(BirthSet)
	
	// --- Store variables ---
	vars.put(&quot;PatientID&quot; + i, PatientID)
	vars.put(&quot;Name&quot; + i, &quot;QA&quot; + Name)
	vars.put(&quot;BirthDate&quot; + i, BirthDate)
	vars.put(&quot;PatientSex&quot; + i, (Math.random() &lt; 0.5) ? &quot;1&quot; : &quot;2&quot;);
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Visit Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Number of repetitions
int repeatCount = ${PatientCount}

for (int i = 0; i &lt; repeatCount; i++) {
    // Initialize calendar with the default timestamp
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault)

    // Create Date object for the visit (admission)
    Date visitDateObj = new Date(calendar.getTimeInMillis())

    // Format VisitDate as yyMMdd
    SimpleDateFormat sdf_date = new SimpleDateFormat(&quot;yyyyMMdd&quot;)
    sdf_date.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    String VisitDate = sdf_date.format(visitDateObj)

    // Format VisitTime as HHmm
    SimpleDateFormat sdf_time = new SimpleDateFormat(&quot;HHmmss&quot;)
    sdf_time.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    String VisitTime = sdf_time.format(visitDateObj)

    // Generate VisitID as yyyyMMddHHmmss plus user thread number
    def scenarioNum = vars.get(&quot;currentScenario&quot;)
    SimpleDateFormat sdf_visitId1 = new SimpleDateFormat(i + &quot;yyyyMMddHHmmss&quot; + scenarioNum + ${User_Thread})
    sdf_visitId1.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    String VisitID1 = sdf_visitId1.format(visitDateObj)

    SimpleDateFormat sdf_visitId2 = new SimpleDateFormat(i + &quot;yyMMddHHmmss&quot; + scenarioNum + ${User_Thread})
    sdf_visitId2.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    String VisitID2 = sdf_visitId2.format(visitDateObj)

    // Store variables
    vars.put(&quot;VisitID&quot; + i, VisitID1 + &quot;|&quot; + VisitID2)
    vars.put(&quot;VisitDate&quot; + i, VisitDate)
    vars.put(&quot;VisitTime&quot; + i, VisitTime)
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Location Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount} // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate in reverse time intervals to set past timestamps and store in variables
for (int i = 0; i &lt; repeatCount; i++) {

    // Create Date objects
    Date LocationEndSet = new Date(timestampDefault)

    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault)
    calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}))

    long LocationStartSetTimestamp = calendar.getTimeInMillis()
    Date LocationStartSet = new Date(LocationStartSetTimestamp)

    // Format for LocationStart and LocationEnd
    SimpleDateFormat sdf_location = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    sdf_location.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    String LocationStart = sdf_location.format(LocationStartSet)
    String LocationEnd = sdf_location.format(LocationEndSet)

    // Store variables
    vars.put(&quot;LocationStart&quot; + i, LocationStart)
    vars.put(&quot;LocationEnd&quot; + i, LocationEnd)
    vars.put(&quot;QA_AREA&quot; + i, ${User_Thread} + &quot;A&quot; + i)
    vars.put(&quot;QA_BED&quot; + i, ${User_Thread} + &quot;B&quot; + i)
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET KTAS Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar
import java.util.Random
import java.nio.file.Files
import java.nio.file.Paths
import java.nio.charset.StandardCharsets

// Get the default timestamp (epoch millis) from JMeter variable
long timestampDefault = Long.parseLong(vars.get(&quot;timestamp_default&quot;))

// Get the number of patients and observations to generate
int repeatCount       = Integer.parseInt(vars.get(&quot;PatientCount&quot;))
int observationCount  = Integer.parseInt(vars.get(&quot;ObservationCount&quot;))

// Load KTAS code and level from CSV file
def csvPath = &quot;${KTASContentsPath}&quot;
def lines = Files.readAllLines(Paths.get(csvPath), StandardCharsets.UTF_8)

// Remove header row
lines.remove(0)

// Get timezone from JMeter variables
def timeZone  = vars.get(&quot;TimeZone&quot;)

// Initialize random number generator
def random = new Random()

// Generate data for each patient
for (int i = 0; i &lt; repeatCount; i++) {
    // Set triage datetime based on the default timestamp
    Date InitTriagetDTSet = new Date(timestampDefault)

    // Format triage date as yyyyMMdd
    def sdf_date = new SimpleDateFormat(&quot;yyyyMMdd&quot;)
    sdf_date.setTimeZone(TimeZone.getTimeZone(timeZone))
    String InitTriagetDate = sdf_date.format(InitTriagetDTSet)

    // Format triage time as HHmm
    def sdf_time = new SimpleDateFormat(&quot;HHmmss&quot;)
    sdf_time.setTimeZone(TimeZone.getTimeZone(timeZone))
    String InitTriagetTime = sdf_time.format(InitTriagetDTSet)

    // Pick a random KTAS row and parse code and level
    def randIndex = random.nextInt(lines.size())
    def row  = lines.get(randIndex)
    def parts  = row.split(&quot;,&quot;)
    def InitCode  = parts[0].trim()
    def InitLevel = parts[1].trim()

    // Save generated values into JMeter variables
    vars.put(&quot;InitTriagetDate&quot; + i, InitTriagetDate)
    vars.put(&quot;InitTriagetTime&quot; + i, InitTriagetTime)
    vars.put(&quot;InitCode&quot; + i, InitCode)
    vars.put(&quot;InitLevel&quot; + i, InitLevel)
}</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET KTAS Level 8, 9 Variables" enabled="false">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Random

// Get the default timestamp (epoch millis) from JMeter variable
long timestampDefault = Long.parseLong(vars.get(&quot;timestamp_default&quot;))

// Get the number of patients and observations to generate
int repeatCount       = Integer.parseInt(vars.get(&quot;PatientCount&quot;))
int observationCount  = Integer.parseInt(vars.get(&quot;ObservationCount&quot;))

// Get timezone from JMeter variables
def timeZone  = vars.get(&quot;TimeZone&quot;)

// Initialize random number generator
def random = new Random()

// Generate data for each patient
for (int i = 0; i &lt; repeatCount; i++) {
    // Set triage datetime based on the default timestamp
    Date InitTriagetDTSet = new Date(timestampDefault)

    // Format triage date as yyyyMMdd
    def sdf_date = new SimpleDateFormat(&quot;yyyyMMdd&quot;)
    sdf_date.setTimeZone(TimeZone.getTimeZone(timeZone))
    String InitTriagetDate = sdf_date.format(InitTriagetDTSet)

    // Format triage time as HHmm
    def sdf_time = new SimpleDateFormat(&quot;HHmm&quot;)
    sdf_time.setTimeZone(TimeZone.getTimeZone(timeZone))
    String InitTriagetTime = sdf_time.format(InitTriagetDTSet)

    // Always set InitCode to NULL (string) - will insert as &apos;NULL&apos;
    def InitCode = null

    // Randomly choose 8 or 9 for InitLevel
    def InitLevel = random.nextBoolean() ? &apos;8&apos; : &apos;9&apos;

    // Save generated values into JMeter variables
    vars.put(&quot;InitTriagetDate&quot; + i, InitTriagetDate)
    vars.put(&quot;InitTriagetTime&quot; + i, InitTriagetTime)
    vars.put(&quot;InitCode&quot;        + i, InitCode)
    vars.put(&quot;InitLevel&quot;       + i, InitLevel)
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET CC Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar
import java.util.Random
import java.nio.file.Files
import java.nio.file.Paths
import java.nio.charset.StandardCharsets

// Parse default timestamp
long timestampDefault = Long.parseLong(vars.get(&quot;timestamp_default&quot;))

// Parse the number of patients
int repeatCount = Integer.parseInt(vars.get(&quot;PatientCount&quot;))

// Load CC contents CSV
def csvPath = &quot;${CcContentsPath}&quot;
def lines = Files.readAllLines(Paths.get(csvPath), StandardCharsets.UTF_8)

// Remove header row
lines.remove(0)

// Random generator
Random random = new Random()

// Iterate for each patient
for (int i = 0; i &lt; repeatCount; i++) {
    int patientIndex = i

    // Calculate Onset DateTime: timestampDefault - 1 hour
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault)
    calendar.add(Calendar.HOUR, -1)
    Date OnsetDTSet = calendar.getTime()

    // Format OnsetDate as yyyyMMdd
    SimpleDateFormat sdfDate = new SimpleDateFormat(&quot;yyyyMMdd&quot;)
    sdfDate.setTimeZone(TimeZone.getTimeZone(vars.get(&quot;TimeZone&quot;)))
    String OnsetDate = sdfDate.format(OnsetDTSet)

    // Format OnsetTime as HHmmss
    SimpleDateFormat sdfTime = new SimpleDateFormat(&quot;HHmmss&quot;)
    sdfTime.setTimeZone(TimeZone.getTimeZone(vars.get(&quot;TimeZone&quot;)))
    String OnsetTime = sdfTime.format(OnsetDTSet)
	
    // Store OnsetDate / OnsetTime per patient only
    vars.put(&quot;OnsetDate&quot; + patientIndex, OnsetDate)
    vars.put(&quot;OnsetTime&quot; + patientIndex, OnsetTime)

    // Generate 3 sets of variables per patient
    for (int j = 1; j &lt;= 3; j++) {  // 세트 index도 1부터 시작
        // Priority: sequential 1, 2, 3
        String Priority = String.valueOf(j)

        // Pick a random row from CSV
        def randIndex = random.nextInt(lines.size())
        def row = lines.get(randIndex)
        def parts = row.split(&quot;,&quot;)

        // Assign CSV columns
        String SympCode = parts[0].trim()  // 1st column
        String SympSR   = parts[1].trim()  // 2nd column
        String SympName = parts[4].trim()  // 5th column

        // Store variables in JMeter: {VariableName}_{SetIndex}_{PatientIndex}
        vars.put(&quot;Priority_&quot;  + j + &quot;_&quot; + patientIndex, Priority)
        vars.put(&quot;SympCode_&quot;  + j + &quot;_&quot; + patientIndex, SympCode)
        vars.put(&quot;SympSR_&quot;    + j + &quot;_&quot; + patientIndex, SympSR)
        vars.put(&quot;SympName_&quot;  + j + &quot;_&quot; + patientIndex, SympName)
    }
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Observation Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar
import java.util.Random

int repeatCount = vars.get(&quot;PatientCount&quot;) as int
long timestampDefault = vars.get(&quot;timestamp_default&quot;) as long
int intervalMin = vars.get(&quot;Ob_Interval_Min&quot;) as int
String timeZone = vars.get(&quot;TimeZone&quot;)
Random random = new Random()

def LOC_OPTIONS = [&quot;1&quot;, &quot;2&quot;, &quot;3&quot;, &quot;4&quot;, &quot;5&quot;]

for (int i = 0; i &lt; repeatCount; i++) {
    Calendar calendar = Calendar.getInstance(TimeZone.getTimeZone(timeZone))
    calendar.setTimeInMillis(timestampDefault)
    calendar.add(Calendar.MINUTE, -(i * intervalMin))
    
    // Align minute to previous 10-minute mark
    int minute = calendar.get(Calendar.MINUTE)
    calendar.add(Calendar.MINUTE, -(minute % 10))
    calendar.set(Calendar.SECOND, 0)
    calendar.set(Calendar.MILLISECOND, 0)

    long ObservedDtSetTimestamp = calendar.getTimeInMillis()

    def sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    sdf.setTimeZone(TimeZone.getTimeZone(timeZone))
    String ObservedDt = sdf.format(new Date(ObservedDtSetTimestamp))

    String INITIAL_PR_Value   = &quot;${random.nextInt(300)}&quot;
    String INITIAL_RR_Value   = &quot;${random.nextInt(120)}&quot;
    String INITIAL_BT_Value   = &quot;${random.nextInt(25) + 25}.${random.nextInt(10)}&quot;
    String INITIAL_SBP_Value  = &quot;${random.nextInt(300)}&quot;
    String INITIAL_DBP_Value  = &quot;${random.nextInt(300)}&quot;
    String INITIAL_SpO2_Value = &quot;${random.nextInt(100)}&quot;
    String INITIAL_LOC_Value  = LOC_OPTIONS[random.nextInt(LOC_OPTIONS.size())]

    // Store variables (with INITIAL_ prefix for vital signs)
    vars.put(&quot;ObservedDate&quot; + i, ObservedDt.split(&quot; &quot;)[0])
    vars.put(&quot;ObservedTime&quot; + i, ObservedDt.split(&quot; &quot;)[1])
    vars.put(&quot;INITIAL_PR_Value&quot; + i, INITIAL_PR_Value)
    vars.put(&quot;INITIAL_RR_Value&quot; + i, INITIAL_RR_Value)
    vars.put(&quot;INITIAL_BT_Value&quot; + i, INITIAL_BT_Value)
    vars.put(&quot;INITIAL_SBP_Value&quot; + i, INITIAL_SBP_Value)
    vars.put(&quot;INITIAL_DBP_Value&quot; + i, INITIAL_DBP_Value)
    vars.put(&quot;INITIAL_SpO2_Value&quot; + i, INITIAL_SpO2_Value)
    vars.put(&quot;INITIAL_LOC_Value&quot; + i, INITIAL_LOC_Value)
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="ER_PI_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection
import java.sql.DriverManager
import java.sql.PreparedStatement
import java.sql.SQLException

// JDBC connection information
String url = &quot;${JDBC_URL}&quot;
String user = &quot;${JDBC_USER}&quot;
String password = &quot;${JDBC_PW}&quot;

// SQL insert query for all VARCHAR fields
String query = &quot;INSERT INTO ROOT.EMR_PRESENT_ILLNESS (PATIENT_ID, VISIT_ID, PI_TEXT) &quot; +
               &quot;VALUES (?, ?, ?)&quot;

// Create connection and prepare statement
Connection conn = DriverManager.getConnection(url, user, password)
PreparedStatement stmt = conn.prepareStatement(query)

// Repeat insert for each set of variables
int repeatCount = Integer.parseInt(vars.get(&quot;PatientCount&quot;))

for (int i = 0; i &lt; repeatCount; i++) {
    String patientId = vars.get(&quot;PatientID&quot; + i)
    String visitId = vars.get(&quot;VisitID&quot; + i)
    
    // Example: static or template text
    String piText = &quot;&quot;&quot;QA 테스트 –
 환자는 [증상 발생 시간] 전부터,
 [주요 증상]을(를) 호소하였으며,
 [발생 상황] 중 발생함.
 과거력: [과거 질환 또는 상태].&quot;&quot;&quot;

    int userThread = Integer.parseInt(vars.get(&quot;User_Thread&quot;))
    if (userThread % 2 == 0) {
    	stmt.setString(1, patientId)
     stmt.setString(2, visitId)
     stmt.setString(3, piText)
     stmt.executeUpdate()
     stmt.clearParameters()

     log.info(&quot;Inserted PI Patient_ID: &quot; + patientId)
     log.info(&quot;Inserted PI VISIT_ID: &quot; + visitId)
    } else {
     log.info(&quot;PI Patient_ID insert skipped: &quot; + patientId)
    }
}

// Close resources
stmt.close()
conn.close()
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Patient Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount}  // Number of patients to generate
int observationCount = ${ObservationCount}  // Number of observations

// Iterate to create patient data
for (int i = 0; i &lt; repeatCount; i++) {
    
	// Create base Date objects
	Date PatientSet = new Date(timestampDefault)
	Date EncounterSet = new Date(timestampDefault)
	Date NameSet = new Date(timestampDefault)
	
	// Set up calendar based on default timestamp
	Calendar calendar = Calendar.getInstance()
	calendar.setTimeInMillis(timestampDefault)
	
	// Shift timestamp by observation interval to simulate past observations
	calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}))
	
	// --- Generate random birthdate for age between 19 and 110 ---
	int minAge = 19
	int maxAge = 110
	int randomAge = minAge + (int)(Math.random() * (maxAge - minAge + 1))
	
	// Copy current timestamp for age validation
	Calendar nowCal = Calendar.getInstance()
	nowCal.setTimeInMillis(timestampDefault)
	
	// Subtract random age in years
	calendar.setTimeInMillis(timestampDefault)
	calendar.add(Calendar.YEAR, -randomAge)
	
	// Randomize month and day
	int randomMonth = (int)(Math.random() * 12)  // 0-11
	calendar.set(Calendar.MONTH, randomMonth)
	int maxDay = calendar.getActualMaximum(Calendar.DAY_OF_MONTH)
	int randomDay = 1 + (int)(Math.random() * maxDay)
	calendar.set(Calendar.DAY_OF_MONTH, randomDay)
	
	// Ensure age is at least 19 (if birthday has not occurred yet, subtract one more year)
	Calendar checkCal = (Calendar) calendar.clone()
	checkCal.add(Calendar.YEAR, minAge)
	
	if (checkCal.after(nowCal)) {
	    calendar.add(Calendar.YEAR, -1)
	}
	
	// Final birthdate object
	long BirthDatetimeStamp = calendar.getTimeInMillis()
	Date BirthSet = new Date(BirthDatetimeStamp)
	
	// --- Generate PatientID ---
	def scenarioNum = vars.get(&quot;currentScenario&quot;)
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i + &quot;yyMMddHHmmss&quot; + scenarioNum + ${User_Thread})
	sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
	String PatientID = sdf_patient.format(PatientSet)
	
	// --- Generate Name ---
	SimpleDateFormat sdf_name = new SimpleDateFormat(i + &quot;ddHHmmss&quot; + scenarioNum + ${User_Thread})
	sdf_name.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
	String Name = sdf_name.format(NameSet)
	
	// --- Format BirthDate ---
	SimpleDateFormat sdf_birthdate = new SimpleDateFormat(&quot;yyyyMMdd&quot;)
	sdf_birthdate.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
	String BirthDate = sdf_birthdate.format(BirthSet)
	
	// --- Store variables ---
	vars.put(&quot;PatientID&quot; + i, PatientID)
	vars.put(&quot;Name&quot; + i, &quot;QA&quot; + Name)
	vars.put(&quot;BirthDate&quot; + i, BirthDate)
	vars.put(&quot;PatientSex&quot; + i, (Math.random() &lt; 0.5) ? &quot;1&quot; : &quot;2&quot;);
}
</stringProp>
          </JSR223PreProcessor>
