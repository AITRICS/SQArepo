            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="false">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">// 응답 데이터 가져오기
def response = prev.getResponseDataAsString()

// JSON 파싱
def jsonResponse = new groovy.json.JsonSlurper().parseText(response)

// 조건 확인
if (jsonResponse.code == &apos;400013&apos;) {
    // 테스트 상태를 pass로 설정
    prev.setSuccessful(true)
    //prev.setResponseMessage(&quot;Test passed because code=200&quot;)
} else {
    // 테스트 상태를 fail로 설정
    prev.setSuccessful(false)
    //prev.setResponseMessage(&quot;Test failed because code is not 200&quot;)
}

def userHome = props.get(&quot;userHome&quot;)
def date = props.get(&quot;date&quot;)
def outputDir = props.get(&quot;outputDir&quot;)
def samplerName = ctx.getCurrentSampler().getName()
def controllerName = vars.get(&quot;currentControllerName&quot;)
def requestFile = Paths.get(outputDir, &quot;${controllerName}_request.log&quot;)
def responseFile = Paths.get(outputDir, &quot;${controllerName}_response.log&quot;)
def resultFile = Paths.get(outputDir, &quot;${controllerName}.csv&quot;)
def isSuccessful = prev.isSuccessful()
def statusMessage = isSuccessful ? &quot;PASS&quot; : &quot;FAIL&quot;
def threadName = prev.getThreadName() // 스레드 이름
def threadNameOnly = threadName.split(&quot; &quot;)[0]

import java.nio.file.*
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter
import java.nio.charset.StandardCharsets

// 폴더 생성
if (!Files.exists(Paths.get(outputDir))) {
    Files.createDirectories(Paths.get(outputDir))
}

// 현재 시간 포맷팅
def now = LocalDateTime.now().format(DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd HH:mm:ss&quot;))

// Test 결과 데이터 수집
def testResult = (prev.isSuccessful()) ? &quot;PASS&quot; : &quot;FAIL&quot; // 성공 여부
def httpResponseCode = prev.getResponseCode() // 응답 코드
def statusResponseCode = jsonResponse.code
def responseMessage = prev.getResponseMessage() // 응답 메시지
def requestURL = sampler.getUrl().toString() // 요청 URL
def requestBody = sampler.getArguments().getArgument(0)?.getValue() ?: &quot;&quot; // 값이 없으면 공백으로 처리
def responseData = prev.getResponseDataAsString() // 응답 데이터
def requestHeaders = prev.getRequestHeaders() // 요청 헤더
def responseHeaders = prev.getResponseHeaders() // 응답 헤더
def latency = prev.getLatency() // 지연 시간
def timestamp = prev.getTimeStamp() // 타임스탬프
def sampleLabel = prev.getSampleLabel() // 샘플러 이름
def elapsed = prev.getTime() // 경과 시간
def dataType = prev.getDataType() // 데이터 유형
def responseDataString = prev.getResponseDataAsString() // 응답 데이터 크기
def bytes = responseDataString.length()
//def requestDataString = prev.getRequestDataAsString() // 요청 데이터를 문자열로 가져옴
//def requestBytes = requestDataString.length() // 요청 데이터의 길이 (문자열 길이)
def idleTime = prev.getIdleTime() // 대기 시간
def connectTime = prev.getConnectTime() // 연결 시간

// 요청 본문을 별도 파일에 저장
def requestMetaInfo = [
    timestamp: now,
    samplerName: samplerName,
    requestBody: requestBody
]
def requestJsonString = new groovy.json.JsonBuilder(requestMetaInfo).toString()
Files.write(requestFile, (&quot;${requestJsonString}\n&quot;).getBytes(StandardCharsets.UTF_8), StandardOpenOption.CREATE, StandardOpenOption.APPEND)

// JSON 데이터를 포함한 메타 정보 생성
def metaInfo = [
    timestamp: now,
    samplerName: samplerName,
    responseBody: responseData
]
def jsonString = new groovy.json.JsonBuilder(metaInfo).toString()

// 파일에 JSON 형식으로 저장
Files.write(responseFile, (&quot;${jsonString}\n&quot;).getBytes(StandardCharsets.UTF_8), StandardOpenOption.CREATE, StandardOpenOption.APPEND)


// 테스트 결과를 .csv에 저장
def csvHeader = &quot;Timestamp,Thread Name,Controller Name,Sampler Name,Test Result,HTTP Response Code,Status Response Code, Response Message,Request URL,Latency,Bytes,Idle Time,Connect\n&quot;
if (!Files.exists(resultFile)) {
    Files.write(resultFile, csvHeader.getBytes(), StandardOpenOption.CREATE)
}
def csvData = &quot;${now},${threadNameOnly},${controllerName},${sampleLabel},${testResult},${httpResponseCode},${statusResponseCode},${responseMessage},${requestURL},${latency},${bytes},${idleTime},${connectTime}\n&quot;
Files.write(resultFile, csvData.getBytes(), StandardOpenOption.APPEND)</stringProp>
