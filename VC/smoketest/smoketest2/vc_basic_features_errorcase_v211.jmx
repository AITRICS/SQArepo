      <hashTree>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter
import java.nio.charset.StandardCharsets

def logResults = { prev, ctx, props, vars, expectedCode, type -&gt;

	if (expectedCode == null) {
		log.error(&quot;ExpectedCode is null. Please ensure it is properly passed to logResults.&quot;)
		return
	}
	
	if (type == null) {
		log.error(&quot;Type is null. Please ensure it is properly passed to logResults.&quot;)
		return
	}

	def now = LocalDateTime.now().format(DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd HH:mm:ss&quot;))
	def outputDir = props.get(&quot;outputDir&quot;)

	if (!Files.exists(Paths.get(outputDir))) {
		Files.createDirectories(Paths.get(outputDir))
	}

	def controllerName = vars.get(&quot;currentControllerName&quot;)
	def samplerName = ctx.getCurrentSampler().getName()
	def requestFile = Paths.get(outputDir, &quot;${controllerName}_request.log&quot;)
	def responseFile = Paths.get(outputDir, &quot;${controllerName}_response.log&quot;)
	def resultFile = Paths.get(outputDir, &quot;${controllerName}.csv&quot;)
	def threadName = prev.getThreadName().split(&quot; &quot;)[0]
	def jsonResponse = null

	// JSON 파싱은 JSON 응답일 때만 시도
	if (type == 1 || type == 4) {
		try {
			jsonResponse = new groovy.json.JsonSlurper().parseText(prev.getResponseDataAsString())
		} catch (Exception e) {
			log.error(&quot;Failed to parse JSON response: ${e.message}, ${samplerName}&quot;)
		}
	}

	def isSuccessful = false
	def statusResponseCode = &quot;N/A&quot;
	def responseDataString = &quot;&quot;   
	def bytes = 0                 

	switch (type) {
		case 1: 
			isSuccessful = (jsonResponse?.code == expectedCode)
			statusResponseCode = jsonResponse?.code ?: &quot;N/A&quot;
			responseDataString = prev.getResponseDataAsString()
			bytes = responseDataString.length()
			break
	
		case 2: 
			isSuccessful = (prev.getResponseCode() == expectedCode &amp;&amp; 
			             prev.getResponseHeaders()?.toLowerCase()?.contains(&quot;content-type: application/pdf&quot;))
			statusResponseCode = &quot;N/A&quot;
			responseDataString = &quot;&quot; 
			bytes = 0 
			break

		case 3: 
			isSuccessful = (prev.getResponseCode().toString() == expectedCode &amp;&amp;
			             prev.getResponseHeaders()?.toLowerCase()?.contains(&quot;content-type: application/vnd.openxml&quot;))
			statusResponseCode = &quot;N/A&quot;
			responseDataString = &quot;&quot; 
			bytes = 0 
			break
    
		case 4: 
			isSuccessful = (jsonResponse?.code?.toString() == expectedCode)
			statusResponseCode = jsonResponse?.code ?: &quot;N/A&quot;
			responseDataString = prev.getResponseDataAsString()
			bytes = responseDataString.length()
			break
	
		default: 
			log.error(&quot;Unknown type: ${type}. Please provide a valid type (1, 2, or 3).&quot;)
			return
	}

	prev.setSuccessful(isSuccessful)
	def testResult = isSuccessful ? &quot;PASS&quot; : &quot;FAIL&quot;
	def httpResponseCode = prev.getResponseCode()
	def responseMessage = prev.getResponseMessage()
	def requestURL = ctx.getCurrentSampler().getUrl().toString()
	def requestBody = sampler.getArguments().getArgument(0)?.getValue() ?: &quot;&quot;
	def responseData = prev.getResponseDataAsString()
	def requestHeaders = prev.getRequestHeaders() 
	def responseHeaders = prev.getResponseHeaders() 
	def latency = prev.getLatency()
	def idleTime = prev.getIdleTime()
	def connectTime = prev.getConnectTime()

    def requestMetaInfo = [
        timestamp   : now,
        samplerName : samplerName,
        requestBody : requestBody
    ]
    def requestJsonString = new groovy.json.JsonBuilder(requestMetaInfo).toString()
    Files.write(requestFile, (&quot;${requestJsonString}\n&quot;).getBytes(StandardCharsets.UTF_8), StandardOpenOption.CREATE, StandardOpenOption.APPEND)

    def metaInfo = [
        timestamp   : now,
        samplerName : samplerName,
        responseBody: responseDataString 
    ]
    def responseJsonString = new groovy.json.JsonBuilder(metaInfo).toString()
    Files.write(responseFile, (&quot;${responseJsonString}\n&quot;).getBytes(StandardCharsets.UTF_8), StandardOpenOption.CREATE, StandardOpenOption.APPEND)

	def csvHeader = &quot;Timestamp,Thread Name,Controller Name,Sampler Name,Test Result,HTTP Response Code,Status Response Code,Response Message,Request URL,Latency,Bytes,Idle Time,Connect\n&quot;
	if (!Files.exists(resultFile)) {
	   Files.createDirectories(resultFile.parent)
	   Files.write(resultFile, csvHeader.getBytes(StandardCharsets.UTF_8), StandardOpenOption.CREATE)
	}

	def csvData = &quot;${now},${threadName},${controllerName},${samplerName},${testResult},${httpResponseCode},${statusResponseCode},${responseMessage},${requestURL},${latency},${bytes},${idleTime},${connectTime}\n&quot;
	Files.write(resultFile, csvData.getBytes(StandardCharsets.UTF_8), StandardOpenOption.APPEND)
}

vars.putObject(&quot;logResults&quot;, logResults)
</stringProp>
        </JSR223PreProcessor>
