          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="set_JSR223 Sampler" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">// Set a flag when each thread completes its execution
int threadId = ctx.getThreadNum();
props.put(&quot;threadDone_&quot; + threadId, &quot;true&quot;);

// Get the total number of threads in the current thread group
int totalThreads = ctx.getThreadGroup().getNumThreads();

// Check if all threads have completed their execution
boolean allThreadsDone = true;
for (int i = 0; i &lt; totalThreads; i++) {
	if (!&quot;true&quot;.equals(props.get(&quot;threadDone_&quot; + i))) {
		allThreadsDone = false;
		break;
	}
}

// Log the status and set the &quot;firstGroupDone&quot; property if all threads are complete
if (allThreadsDone) {
	log.info(&quot;All threads have completed their execution.&quot;);
	props.put(&quot;firstGroupDone&quot;, &quot;true&quot;);
} else {
	log.info(&quot;Some threads are still running.&quot;);
}
</stringProp>
          </JSR223Sampler>
