              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">try {
	jsonResponse = new groovy.json.JsonSlurper().parseText(prev.getResponseDataAsString())
} catch (Exception e) {
	log.error(&quot;Failed to parse JSON response: ${e.message}&quot;)
}
def randomNum = new Random().nextInt(jsonResponse.data.screening.size())
def selectedPatient = jsonResponse.data.screening[randomNum]

def real_patient_id = selectedPatient.emr_id
def real_encounter_id = selectedPatient.encounter_id
def real_patient_name = URLEncoder.encode(selectedPatient.name, &quot;UTF-8&quot;)

vars.put(&quot;real_patient_id&quot;, real_patient_id)
vars.put(&quot;real_encounter_id&quot;, real_encounter_id)
vars.put(&quot;real_patient_name&quot;, real_patient_name)
log.info(&quot;random_patient_id: ${real_patient_id}&quot;)
log.info(&quot;real_encounter_id: ${real_encounter_id}&quot;)

// favorite=true
def favoritePatients = jsonResponse.data.screening.findAll { it.favorite == true }
if (favoritePatients) {
    log.info(&quot;Favorite 환자 목록: ${favoritePatients*.emr_id}&quot;)
} else {
    log.info(&quot;Favorite 환자가 없습니다.&quot;)
}

// DNR=true
def dnrPatients = jsonResponse.data.screening.findAll { it.dnr == true }
if (dnrPatients) {
    log.info(&quot;DNR 환자 목록: ${dnrPatients*.emr_id}&quot;)
} else {
    log.info(&quot;DNR 환자가 없습니다.&quot;)
}

// DNR=false
def nodnrPatients = jsonResponse.data.screening.findAll { it.dnr == false }

if (nodnrPatients &amp;&amp; nodnrPatients.size() &gt; 0) {
    def nodnrfirstEmrId = nodnrPatients[0].emr_id
    def nodnrfirstEncounterId = nodnrPatients[0].encounter_id
    vars.put(&quot;nodnrfirstEmrId&quot;, nodnrfirstEmrId)
    vars.put(&quot;nodnrfirstEncounterId&quot;, nodnrfirstEncounterId)
    log.info(&quot;첫 번째 noDNR 환자의 EMR ID: ${nodnrfirstEmrId}&quot;)
    log.info(&quot;첫 번째 noDNR 환자의 Encounter ID: ${nodnrfirstEncounterId}&quot;)
} else {
    log.info(&quot;DNR 아닌 환자가 없습니다.&quot;)
}</stringProp>
