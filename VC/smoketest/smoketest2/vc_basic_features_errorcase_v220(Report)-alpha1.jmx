          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="setname Sampler" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">vars.put(&quot;currentControllerName&quot;, &quot;09.vc_admin-expiredtoken&quot;)

// 랜덤 문자열 생성 함수
def generateRandomString(length) {
    def result = new StringBuilder()
    def characters = &apos;ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789&apos;
    def charactersLength = characters.length()
    def random = new Random()
    for (int i = 0; i &lt; length; i++) {
        result.append(characters[random.nextInt(charactersLength)])
    }
    return result.toString()
}

// 랜덤 문자열 생성 함수
def generateRandomUserName(length) {
    def result = new StringBuilder()
    def characters = &apos;ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789@-_.&apos;
    def charactersLength = characters.length()
    def random = new Random()
    for (int i = 0; i &lt; length; i++) {
        result.append(characters[random.nextInt(charactersLength)])
    }
    return result.toString()
}

// 랜덤 비밀번호 생성 함수 (특수문자 포함)
def generatePassword(length) {
    // 특수문자를 UTF-8 코드로 변환
    def charset = &quot;abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789&quot; +
                  &quot;\u007E&quot; +  // ~
                  &quot;\u0021&quot; +  // !
                  &quot;\u0040&quot; +  // @
                  &quot;\u0023&quot; +  // #
                  &quot;\u0024&quot; +  // $
                  &quot;\u005E&quot; +  // ^
                  &quot;\u0026&quot; +  // &amp;
                  &quot;\u002A&quot; +  // *
                  &quot;\u0028&quot; +  // (
                  &quot;\u0029&quot; +  // )
                  &quot;\u005F&quot; +  // _
                  &quot;\u002B&quot; +  // +
                  &quot;\u003D&quot; +  // =
                  &quot;\u007B&quot; +  // {
                  &quot;\u007D&quot; +  // }
                  &quot;\u005B&quot; +  // [
                  &quot;\u005D&quot; +  // ]
                  &quot;\u007C&quot; +  // |
                  &quot;\u003A&quot; +  // :
                  &quot;\u003B&quot; +  // ;
                  &quot;\u0027&quot; +  // &apos;
                  &quot;\u003C&quot; +  // &lt;
                  &quot;\u003E&quot; +  // &gt;
                  &quot;\u002C&quot; +  // ,
                  &quot;\u002E&quot; +  // .
                  &quot;\u003F&quot; +  // ?
                  &quot;\u002F&quot;    // /
                  
    def password = new StringBuilder()
    def random = new Random()
    for (int i = 0; i &lt; length; i++) {
        password.append(charset[random.nextInt(charset.length())])
    }
    return password.toString()
}

// 어제 UTC 시간을 가져오는 함수
def getYesterdayUTCTime() {
    def currentDate = new Date()
    currentDate.setTime(currentDate.getTime() - (3 * 24 * 60 * 60 * 1000)) // 3일 전
    def formattedDate = currentDate.format(&quot;yyyy-MM-dd HH:mm:ss&quot;, TimeZone.getTimeZone(&apos;UTC&apos;))
    return formattedDate.replace(&apos; &apos;, &apos;%20&apos;) // 공백을 %20으로 치환
}

// 현재 UTC 시간을 가져오는 함수
def getCurrentUTCTime() {
    def currentDate = new Date()
    def formattedDate = currentDate.format(&quot;yyyy-MM-dd HH:mm:ss&quot;, TimeZone.getTimeZone(&apos;UTC&apos;))
    return formattedDate.replace(&apos; &apos;, &apos;%20&apos;) // 공백을 %20으로 치환
}

// 랜덤 데이터 생성
def string_100 = generateRandomString(101)
def string_301 = generateRandomString(301)
def randomUserName = generateRandomUserName(10)
//def randomPassword = generatePassword(20)
def randomPassword = &quot;amelia01!&quot;
def randomID = String.format(&quot;%08d&quot;, new Random().nextInt(100000000))
def randomNum = String.format(&quot;%03d&quot;, new Random().nextInt(1000))
def phonenumber = String.format(&quot;%012d&quot;, Math.abs(new Random().nextLong() % 1000000000000))
def phonenumber_invalid = String.format(&quot;%013d&quot;, Math.abs(new Random().nextLong() % 10000000000000))
def startdt = getYesterdayUTCTime()
def enddt = getCurrentUTCTime()
def unit_type = generateRandomString(10)

// JMeter 변수에 저장
vars.put(&quot;randomString&quot;, string_100)
vars.put(&quot;randomString300&quot;, string_301)
vars.put(&quot;randomUserName&quot;, randomUserName)
vars.put(&quot;encount_id&quot;, randomID)
vars.put(&quot;phonenumber&quot;, phonenumber)
vars.put(&quot;phonenumber_invalid&quot;, phonenumber_invalid)
vars.put(&quot;username&quot;, &quot;amelia&quot; + randomNum)
vars.put(&quot;password&quot;, vars.get(&quot;username&quot;))
vars.put(&quot;username_invalid&quot;, &quot;amelia&quot; + randomNum + &quot;invalid&quot;)
vars.put(&quot;password_invalid&quot;, vars.get(&quot;username_invalid&quot;))
vars.put(&quot;password_randompassword&quot;, randomPassword)
vars.put(&quot;startdt&quot;, startdt)
vars.put(&quot;enddt&quot;, enddt)
vars.put(&quot;unit_type&quot;, unit_type)


// 로그 출력 (선택 사항)
log.info(&quot;Generated Variables: &quot;)
log.info(&quot;Random String 100: ${string_100}&quot;)
log.info(&quot;Random String 301: ${string_301}&quot;)
log.info(&quot;Random ID: ${randomID}&quot;)
log.info(&quot;Phone Number: ${phonenumber}&quot;)
log.info(&quot;Invalid Phone Number: ${phonenumber_invalid}&quot;)
log.info(&quot;Username: ${vars.get(&quot;randomUserName&quot;)}&quot;)
log.info(&quot;Password: ${vars.get(&quot;password_randompassword&quot;)}&quot;)
log.info(&quot;Start Date: ${startdt}&quot;)
log.info(&quot;End Date: ${enddt}&quot;)
log.info(&quot;unit_type: ${unit_type}&quot;)</stringProp>
