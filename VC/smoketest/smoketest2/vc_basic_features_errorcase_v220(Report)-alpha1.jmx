              <stringProp name="script">log.info(&quot;Extracted Wards: &quot; + vars.get(&quot;Screenedtype_LIST&quot;));
log.info(&quot;Extracted Wards: &quot; + vars.get(&quot;WARD_LIST&quot;));
log.info(&quot;Extracted Wards: &quot; + vars.get(&quot;Department_LIST&quot;));
log.info(&quot;Extracted Wards: &quot; + vars.get(&quot;Practitioner_LIST&quot;));
