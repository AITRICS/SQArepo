              <stringProp name="script">try {
    jsonResponse = new groovy.json.JsonSlurper().parseText(prev.getResponseDataAsString())
} catch (Exception e) {
    log.error(&quot;Failed to parse JSON response: ${e.message}&quot;)
}

// role=member
def memberUsers = jsonResponse.data.findAll { it.role == &apos;member&apos; }

if (memberUsers.size() &gt; 0) {
    def randomNum = new Random().nextInt(memberUsers.size())
    def selectedUser = memberUsers[randomNum]

    def userid = selectedUser.id.toString()
    vars.put(&quot;userid&quot;, userid)
    log.info(&quot;userid: ${userid}&quot;)
} else {
    log.warn(&quot;No member users found in the response.&quot;)
}
