              <stringProp name="script">try {
	jsonResponse = new groovy.json.JsonSlurper().parseText(prev.getResponseDataAsString())
} catch (Exception e) {
	log.error(&quot;Failed to parse JSON response: ${e.message}&quot;)
}

import java.util.concurrent.ThreadLocalRandom

def completedAndNotDownloadedHistories = []
def canceledHistories = []
def pendingHistories = []
def inprogressHistories = []
def failedHistories = []

if (jsonResponse.data.reportHistories &amp;&amp; jsonResponse.data.reportHistories.size() &gt; 0) {
    completedAndNotDownloadedHistories = jsonResponse.data.reportHistories.findAll { 
        it.fileStatus == &quot;COMPLETED&quot; &amp;&amp; !it.downloadComplete &amp;&amp; it.remainingDays &gt;= 0 
    }
    completedAndDownloadedHistories = jsonResponse.data.reportHistories.findAll { 
        it.fileStatus == &quot;COMPLETED&quot; &amp;&amp; it.downloadComplete 
    }
    canceledHistories = jsonResponse.data.reportHistories.findAll { it.fileStatus == &quot;CANCELED&quot; }
    pendingHistories = jsonResponse.data.reportHistories.findAll { it.fileStatus == &quot;PENDING&quot; }
    inprogressHistories = jsonResponse.data.reportHistories.findAll { it.fileStatus == &quot;IN_PROGRESS&quot; }
    failedHistories = jsonResponse.data.reportHistories.findAll { it.fileStatus == &quot;FAILED&quot; }

    if (completedAndNotDownloadedHistories) {
        def randomCompletedHistory = completedAndNotDownloadedHistories[
            ThreadLocalRandom.current().nextInt(0, completedAndNotDownloadedHistories.size())
        ]
        def completed_report_history_id = randomCompletedHistory.historyId.toString()
        vars.put(&quot;completed_report_history_id&quot;, completed_report_history_id)
        log.info(&quot;completed_report_history_id: ${completed_report_history_id}&quot;)
    }
    if (completedAndDownloadedHistories) {
        def randomDownloadedHistory = completedAndDownloadedHistories[
            ThreadLocalRandom.current().nextInt(0, completedAndDownloadedHistories.size())
        ]
        def downloaded_report_history_id = randomDownloadedHistory.historyId.toString()
        vars.put(&quot;downloaded_report_history_id&quot;, downloaded_report_history_id)
        log.info(&quot;downloaded_report_history_id: ${downloaded_report_history_id}&quot;)
    }
    if (canceledHistories) {
        def randomCanceledHistory = canceledHistories[
            ThreadLocalRandom.current().nextInt(0, canceledHistories.size())
        ]
        def canceled_report_history_id = randomCanceledHistory.historyId.toString()
        vars.put(&quot;canceled_report_history_id&quot;, canceled_report_history_id)
        log.info(&quot;canceled_report_history_id: ${canceled_report_history_id}&quot;)
    }
    if (pendingHistories) {
        def randomPendingHistory = pendingHistories[
            ThreadLocalRandom.current().nextInt(0, pendingHistories.size())
        ]
        def pending_report_history_id = randomPendingHistory.historyId.toString()
        vars.put(&quot;pending_report_history_id&quot;, pending_report_history_id)
        log.info(&quot;pending_report_history_id: ${pending_report_history_id}&quot;)
    }
    if (inprogressHistories) {
        def randomInProgressHistory = inprogressHistories[
            ThreadLocalRandom.current().nextInt(0, inprogressHistories.size())
        ]
        def inprogress_report_history_id = randomInProgressHistory.historyId.toString()
        vars.put(&quot;inprogress_report_history_id&quot;, inprogress_report_history_id)
        log.info(&quot;inprogress_report_history_id: ${inprogress_report_history_id}&quot;)
    }
    if (failedHistories) {
        def randomFailedHistory = failedHistories[
            ThreadLocalRandom.current().nextInt(0, failedHistories.size())
        ]
        def failed_report_history_id = randomFailedHistory.historyId.toString()
        vars.put(&quot;failed_report_history_id&quot;, failed_report_history_id)
        log.info(&quot;failed_report_history_id: ${failed_report_history_id}&quot;)
    }
} else {
    log.warn(&quot;reportHistories 배열이 비어있거나 존재하지 않습니다.&quot;)
}</stringProp>
