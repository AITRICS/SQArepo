  &quot;username&quot;: &quot;${ADMIN_USER}&quot;&#xd;
}</stringProp>
                  <stringProp name="Argument.metadata">=</stringProp>
                </elementProp>
              </collectionProp>
            </elementProp>
          </HTTPSamplerProxy>
          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 Login_Header_Handling_PreProcessor" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">// Restore Authorization header in PostProcessor
def savedAuthHeader = vars.get(&quot;USER_TOKEN&quot;)
if (savedAuthHeader != null &amp;&amp; !savedAuthHeader.isEmpty()) {
    def headerManager = sampler.getHeaderManager()
    
    if (headerManager != null) {
		// Restore the Authorization header
        headerManager.add(new org.apache.jmeter.protocol.http.control.Header(&quot;Authorization&quot;, &quot;Bearer &quot; + savedAuthHeader))        
		// Force apply the HeaderManager to the sampler
        sampler.setHeaderManager(headerManager)
    }
}
</stringProp>
            </JSR223PreProcessor>
            <hashTree/>
          </hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="set_JSR223 Sampler" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">// Set a flag when each thread completes its execution
int threadId = ctx.getThreadNum();
props.put(&quot;threadDone_&quot; + threadId, &quot;true&quot;);

// Get the total number of threads in the current thread group
int totalThreads = ctx.getThreadGroup().getNumThreads();

// Check if all threads have completed their execution
boolean allThreadsDone = true;
for (int i = 0; i &lt; totalThreads; i++) {
	if (!&quot;true&quot;.equals(props.get(&quot;threadDone_&quot; + i))) {
		allThreadsDone = false;
		break;
	}
}

// Log the status and set the &quot;firstGroupDone&quot; property if all threads are complete
if (allThreadsDone) {
	log.info(&quot;All threads have completed their execution.&quot;);
	props.put(&quot;firstGroupDone&quot;, &quot;true&quot;);
} else {
	log.info(&quot;Some threads are still running.&quot;);
}
</stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
      </hashTree>
      <PostThreadGroup guiclass="PostThreadGroupGui" testclass="PostThreadGroup" testname="tearDown Thread Group">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">false</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </PostThreadGroup>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="sleep_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">long timeout = System.currentTimeMillis() + 3600000; 
while (!props.get(&quot;firstGroupDone&quot;).equals(&quot;true&quot;)) {
	if (System.currentTimeMillis() &gt; timeout) {
 		log.error(&quot;Timeout exceeded while waiting for firstGroupDone to be true&quot;);
		break; 
	}
	Thread.sleep(10000); 
	log.info(&quot;sleep&quot;);
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(result)_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.io.File
import groovy.json.JsonSlurper
import java.nio.charset.StandardCharsets
import groovy.json.JsonOutput
import java.text.SimpleDateFormat

def userHome = props.get(&quot;userHome&quot;)
def date = props.get(&quot;date&quot;)
def outputDir = props.get(&quot;outputDir&quot;)
def outputVersion = vars.get(&quot;version&quot;)
def outputHtmlPath = outputDir + &quot;${outputVersion}_SmokeTest2_Result.html&quot;

def dateFormatter = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)


def htmlContent = &quot;&quot;&quot;
&lt;html&gt;
&lt;head&gt;
    &lt;meta charset=&quot;UTF-8&quot;&gt;
    &lt;title&gt;Smoke Test Report&lt;/title&gt;
    &lt;script src=&quot;https://cdn.jsdelivr.net/npm/chart.js&quot;&gt;&lt;/script&gt;
    &lt;style&gt;
       .chart-container {
           margin-top: 20px; 
           margin-bottom: 30px;
           width: 100% !important;       
           height: 400px;     
       }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th, td {
            padding: 10px;
            border: 1px solid #ddd;
        }
    &lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;
&lt;h1&gt;Jmeter SmokeTest2 Report&lt;/h1&gt;
&quot;&quot;&quot;

def csvFiles = Files.list(Paths.get(outputDir))
    .filter { it.toString().endsWith(&quot;result.csv&quot;) }
    .sorted()
    .collect()

def overallStats = [startTime: null, endTime: null, totalRequests: 0, passCount: 0, failCount: 0]
def threadGroupStats = []
def combinedData = new StringBuilder()

csvFiles.each { file -&gt;
    def stats = processCsvFile(file.toFile(), combinedData) 
    threadGroupStats &lt;&lt; stats
    updateOverallStats(overallStats, stats)
}


htmlContent += createSummaryTable(overallStats)
htmlContent += createThreadGroupTable(threadGroupStats)
htmlContent += createTotalRequestsChart(threadGroupStats)
htmlContent += createPassFailPieChart(overallStats.passCount, overallStats.failCount)
htmlContent += createRequestResponseDetails(csvFiles)
htmlContent += &quot;&lt;/body&gt;&lt;/html&gt;&quot;

def createSummaryTable(overallStats) {
    def html = &quot;&quot;&quot;
    &lt;h2&gt;Summary Statistics&lt;/h2&gt;
    &lt;table&gt;
        &lt;tr&gt;&lt;th&gt;Total Requests&lt;/th&gt;&lt;td&gt;${overallStats.totalRequests}&lt;/td&gt;&lt;/tr&gt;
        &lt;tr&gt;&lt;th&gt;Pass Count&lt;/th&gt;&lt;td&gt;${overallStats.passCount}&lt;/td&gt;&lt;/tr&gt;
        &lt;tr&gt;&lt;th&gt;Fail Count&lt;/th&gt;&lt;td&gt;${overallStats.failCount}&lt;/td&gt;&lt;/tr&gt;
        &lt;tr&gt;&lt;th&gt;Start Time&lt;/th&gt;&lt;td&gt;${overallStats.startTime ? overallStats.startTime : &apos;N/A&apos;}&lt;/td&gt;&lt;/tr&gt;
        &lt;tr&gt;&lt;th&gt;End Time&lt;/th&gt;&lt;td&gt;${overallStats.endTime ? overallStats.endTime : &apos;N/A&apos;}&lt;/td&gt;&lt;/tr&gt;
        &lt;tr&gt;&lt;th&gt;Duration (sec)&lt;/th&gt;&lt;td&gt;${overallStats.duration != null ? overallStats.duration : &apos;N/A&apos;}&lt;/td&gt;&lt;/tr&gt;
    &lt;/table&gt;
    &quot;&quot;&quot;
    return html
}

def createThreadGroupTable(threadGroupStats) {
    def html = &quot;&quot;&quot;
    &lt;h2&gt;Thread Group Statistics&lt;/h2&gt;
    &lt;table&gt;
        &lt;tr&gt;
            &lt;th&gt;Thread Group&lt;/th&gt;
            &lt;th&gt;Total Requests&lt;/th&gt;
            &lt;th&gt;Successful Requests&lt;/th&gt;
            &lt;th&gt;Failed Requests&lt;/th&gt;
            &lt;th&gt;Average Response Time (ms)&lt;/th&gt;
            &lt;th&gt;Max Response Time (ms)&lt;/th&gt;
            &lt;th&gt;Min Response Time (ms)&lt;/th&gt;
            &lt;th&gt;Start Time&lt;/th&gt;
            &lt;th&gt;End Time&lt;/th&gt;
            &lt;th&gt;Duration (sec)&lt;/th&gt;
        &lt;/tr&gt;
    &quot;&quot;&quot;
    
    threadGroupStats.each { stats -&gt;
        html += &quot;&quot;&quot;
        &lt;tr&gt;
            &lt;td&gt;${stats.name}&lt;/td&gt;
            &lt;td&gt;${stats.totalRequests}&lt;/td&gt;
            &lt;td&gt;${stats.passCount}&lt;/td&gt;
            &lt;td&gt;${stats.failCount}&lt;/td&gt;
            &lt;td&gt;${stats.averageResponseTime}&lt;/td&gt;
            &lt;td&gt;${stats.maxResponseTime}&lt;/td&gt;
            &lt;td&gt;${stats.minResponseTime}&lt;/td&gt;
            &lt;td&gt;${stats.startTime ?: &apos;n/a&apos;}&lt;/td&gt;
            &lt;td&gt;${stats.endTime ?: &apos;n/a&apos;}&lt;/td&gt;
            &lt;td&gt;${stats.duration}&lt;/td&gt;
        &lt;/tr&gt;
        &quot;&quot;&quot;
    }
    
    html += &quot;&lt;/table&gt;&quot;
    return html
}

// Total Requests per Thread Group
def createTotalRequestsChart(threadGroupStats) {
    def threadGroupNames = threadGroupStats.collect { it.name }
    def totalRequests = threadGroupStats.collect { it.totalRequests }

    def html = &quot;&quot;&quot;
    &lt;h2&gt;Visualizations&lt;/h2&gt;
    &lt;h3&gt;Total Requests per Thread Group&lt;/h3&gt;
    &lt;div class=&quot;chart-container&quot; style=&quot;margin-top: 50px; margin-bottom: 50px;&quot;&gt;
        &lt;canvas id=&quot;bar-chart&quot; style=&quot;height: 400px;&quot;&gt;&lt;/canvas&gt;
    &lt;/div&gt;

    &lt;script&gt;
        window.addEventListener(&apos;load&apos;, function() {
            setTimeout(function() {
                var ctxBar = document.getElementById(&apos;bar-chart&apos;).getContext(&apos;2d&apos;);
                if (ctxBar) {
                    new Chart(ctxBar, {
                        type: &apos;bar&apos;,
                        data: {
                            labels: ${JsonOutput.toJson(threadGroupNames)},
                            datasets: [{
                                label: &apos;Requests&apos;,
                                data: ${JsonOutput.toJson(totalRequests)},
                                backgroundColor: &apos;#4A90E2&apos;,
                                borderColor: &apos;#4A90E2&apos;,
                                borderWidth: 1
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            scales: {
                                x: {
                                    title: {
                                        display: true,
                                        text: &apos;Thread Group&apos;
                                    }
                                },
                                y: {
                                    title: {
                                        display: true,
                                        text: &apos;Requests&apos;
                                    }
                                }
                            }
                        }
                    });
                } else {
                    console.error(&quot;Canvas element with id &apos;bar-chart&apos; not found!&quot;);
                }
            }, 100);  
        });
    &lt;/script&gt;
    &quot;&quot;&quot;
    return html
}

// PASS vs FAIL 
def createPassFailPieChart(overallPassCount, overallFailCount) {
    def html = &quot;&quot;&quot;
    &lt;h3&gt;PASS vs FAIL&lt;/h3&gt;
    &lt;div class=&quot;chart-container&quot; style=&quot;margin-top: 50px; margin-bottom: 50px;&quot;&gt;
        &lt;canvas id=&quot;pie-chart&quot; style=&quot;height: 400px;&quot;&gt;&lt;/canvas&gt;
    &lt;/div&gt;

    &lt;script&gt;
        window.addEventListener(&apos;load&apos;, function() {
            setTimeout(function() {
                var ctxPie = document.getElementById(&apos;pie-chart&apos;).getContext(&apos;2d&apos;);
                if (ctxPie) {
                    new Chart(ctxPie, {
                        type: &apos;pie&apos;,
                        data: {
                            labels: [&apos;PASS&apos;, &apos;FAIL&apos;],
                            datasets: [{
                                data: [${overallPassCount}, ${overallFailCount}], 
                                backgroundColor: [&apos;#4A90E2&apos;, &apos;#D0021B&apos;] 
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    position: &apos;bottom&apos;,
                                    labels: {
                                        font: { size: 14 },
                                        generateLabels: function(chart) {
                                            var labels = chart.data.labels;
                                            var dataValues = chart.data.datasets[0].data;
                                            var total = dataValues.reduce((sum, value) =&gt; sum + value, 0);

                                            return labels.map(function(label, index) {
                                                var currentValue = dataValues[index];
                                                var percentage = ((currentValue / total) * 100).toFixed(2);
                                                return {
                                                    text: label + &apos; (&apos; + currentValue + &apos;, &apos; + percentage + &apos;%)&apos;,
                                                    fillStyle: chart.data.datasets[0].backgroundColor[index]
                                                };
                                            });
                                        }
                                    }
                                },
                                tooltip: {
                                    callbacks: {
                                        label: function(tooltipItem) {
                                            var dataValues = tooltipItem.chart.data.datasets[0].data;
                                            var total = dataValues.reduce((sum, val) =&gt; sum + val, 0);
                                            var currentValue = dataValues[tooltipItem.dataIndex];
                                            var percentage = ((currentValue / total) * 100).toFixed(2);
                                            return currentValue + &apos; (&apos; + percentage + &apos;%)&apos;;
                                        }
                                    }
                                }
                            }
                        }
                    });
                }
            }, 100);  
        });
    &lt;/script&gt;
    &quot;&quot;&quot;
    return html
}


// Request-Response Details 
def createRequestResponseDetails(csvFiles) {
    def content = &quot;&quot;
    if (csvFiles.isEmpty()) {
        content += &quot;&lt;h2&gt;No CSV Files Found&lt;/h2&gt;&quot;
    } else {
        content += &quot;&lt;h2&gt;Request-Response Details&lt;/h2&gt;&quot;
        csvFiles.each { csvFile -&gt;
            def threadGroupName = &quot;Unknown Thread Group&quot;
            try {
                def lines = Files.readAllLines(csvFile)
                if (lines.size() &gt; 1) {
                    threadGroupName = lines[1].split(&quot;,&quot;)[2].trim()
                }
            } catch (Exception e) {
                log.error(&quot;Failed to read CSV file: ${csvFile}, error: ${e.message}&quot;)
            }
            
            content += &quot;&lt;h3&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;${threadGroupName}&lt;/h3&gt;&quot;
            content += &quot;&quot;&quot;
            &lt;table&gt;
                &lt;tr&gt;
                    &lt;th&gt;#&lt;/th&gt;
                    &lt;th&gt;Timestamp&lt;/th&gt;
                    &lt;th&gt;Thread Name&lt;/th&gt;
                    &lt;th&gt;Label&lt;/th&gt;
                    &lt;th&gt;Result&lt;/th&gt;
                    &lt;th&gt;Response Code&lt;/th&gt;
                    &lt;th&gt;Status Code&lt;/th&gt;
                    &lt;th&gt;Response Message&lt;/th&gt;
                    &lt;th&gt;URL&lt;/th&gt;
                    &lt;th&gt;Response Time (ms)&lt;/th&gt;
                    &lt;th&gt;Bytes&lt;/th&gt;
                    &lt;th&gt;Idle Time&lt;/th&gt;
                    &lt;th&gt;Connect&lt;/th&gt;
                &lt;/tr&gt;
            &quot;&quot;&quot;
            def csvData = []
            try {
                Files.lines(csvFile).eachWithIndex { line, index -&gt;
                    if (index == 0) return 
                    csvData.add(line.split(&quot;,&quot;).collect { it.trim() })
                }
                csvData.eachWithIndex { row, index -&gt;
                    def resultClass = row[4] == &apos;PASS&apos; ? &apos;PASS&apos; : &apos;FAIL&apos;
   		          content += &quot;&lt;tr&gt;&quot;
    		          content += &quot;&lt;td&gt;${index + 1}&lt;/td&gt;&quot; 

		          
		          def timeStampValue = row[0]
		          def formattedTimeStamp = timeStampValue.isNumber() ? dateFormatter.format(new Date(Long.parseLong(timeStampValue))) : timeStampValue
		
		          content += &quot;&lt;td&gt;${formattedTimeStamp}&lt;/td&gt;&quot; 
		          content += &quot;&lt;td&gt;${row[2]}&lt;/td&gt;&quot;  
		          content += &quot;&lt;td&gt;${row[3]}&lt;/td&gt;&quot;  
		          content += &quot;&lt;td class=&apos;${resultClass}&apos;&gt;${resultClass}&lt;/td&gt;&quot; 
		          content += &quot;&lt;td&gt;${row[5]}&lt;/td&gt;&quot;  
		          content += &quot;&lt;td&gt;${row[6]}&lt;/td&gt;&quot;  
		          content += &quot;&lt;td&gt;${row[7]}&lt;/td&gt;&quot;  
		          content += &quot;&lt;td&gt;${row[8]}&lt;/td&gt;&quot;  
		          content += &quot;&lt;td&gt;${row[9]}&lt;/td&gt;&quot;  
		          content += &quot;&lt;td&gt;${row[10]}&lt;/td&gt;&quot; 
		          content += &quot;&lt;td&gt;${row[11]}&lt;/td&gt;&quot; 
		          content += &quot;&lt;td&gt;${row[12]}&lt;/td&gt;&quot; 
		          content += &quot;&lt;/tr&gt;&quot;
                }
            } catch (Exception e) {
                log.error(&quot;Failed to read CSV file: ${csvFile}, error: ${e.message}&quot;)
            }
            content += &quot;&lt;/table&gt;&quot;
        }
    }
    return content
}


try {
    Files.write(Paths.get(outputHtmlPath), htmlContent.getBytes(&quot;UTF-8&quot;))
    log.info(&quot;HTML report generated: ${outputHtmlPath}&quot;)
} catch (Exception e) {
    log.error(&quot;Failed to write HTML file: ${outputHtmlPath}, error: ${e.message}&quot;)
}


def escapeHtml(String input) {
    if (input == null) {
        return &quot;&quot;
    }
    return input.replaceAll(&quot;&lt;&quot;, &quot;&amp;lt;&quot;).replaceAll(&quot;&gt;&quot;, &quot;&amp;gt;&quot;)
}


def processCsvFile(File file, StringBuilder combinedData) {
    def stats = [name: file.getName(), totalRequests: 0, passCount: 0, failCount: 0, 
                 totalResponseTime: 0, maxResponseTime: 0, minResponseTime: Integer.MAX_VALUE, 
                 startTime: null, endTime: null, averageResponseTime: 0, duration: 0]
    
    file.eachLine { line, index -&gt;
        def columns = line.split(&quot;,&quot;).collect { it.trim() }
        if (index == 2) { 
            stats.name = columns[2]
        }
        if (columns.size() &gt; 0 &amp;&amp; !line.startsWith(&quot;Timestamp&quot;)) {
            stats.totalRequests++
            def responseTime = columns[9].toInteger() 
            stats.totalResponseTime += responseTime
            
            // Update max and min response times
            if (responseTime &gt; stats.maxResponseTime) {
                stats.maxResponseTime = responseTime
            }
            if (responseTime &lt; stats.minResponseTime) {
                stats.minResponseTime = responseTime
            }
            
            if (columns[4] == &quot;PASS&quot;) {
                stats.passCount++
            } else {
                stats.failCount++
            }
            
            
            def timestamp = columns[0]
            if (stats.startTime == null || timestamp &lt; stats.startTime) {
                stats.startTime = timestamp
            }
            if (stats.endTime == null || timestamp &gt; stats.endTime) {
                stats.endTime = timestamp
            }
            
            combinedData.append(line).append(&quot;\n&quot;)
        }
    }

    
    if (stats.totalRequests &gt; 0) {
    		stats.averageResponseTime = Math.round((stats.totalResponseTime / stats.totalRequests) * 100.0) / 100.0
	} else {
          stats.averageResponseTime = 0 
     }


    if (stats.startTime &amp;&amp; stats.endTime) {
        def startTimeDate = Date.parse(&quot;yyyy-MM-dd HH:mm:ss&quot;, stats.startTime)
        def endTimeDate = Date.parse(&quot;yyyy-MM-dd HH:mm:ss&quot;, stats.endTime)
        stats.duration = (endTimeDate.time - startTimeDate.time) / 1000 
    }
    
    return stats
}


def updateOverallStats(overallStats, stats) {
    overallStats.totalRequests += stats.totalRequests
    overallStats.passCount += stats.passCount
    overallStats.failCount += stats.failCount

    if (overallStats.startTime == null || stats.startTime &lt; overallStats.startTime) {
        overallStats.startTime = stats.startTime
    }
    if (overallStats.endTime == null || stats.endTime &gt; overallStats.endTime) {
        overallStats.endTime = stats.endTime
    }
    
    if (overallStats.startTime != null &amp;&amp; overallStats.endTime != null) {
        def startTimeDate = Date.parse(&quot;yyyy-MM-dd HH:mm:ss&quot;, overallStats.startTime) 
        def endTimeDate = Date.parse(&quot;yyyy-MM-dd HH:mm:ss&quot;, overallStats.endTime)
        
        overallStats.duration = (endTimeDate.time - startTimeDate.time) / 1000        
    }
}


</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(Result_Detail_Log)_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import groovy.json.JsonOutput
import groovy.json.JsonSlurper
import java.nio.charset.StandardCharsets
import org.apache.commons.lang3.StringEscapeUtils

def userHome = props.get(&quot;userHome&quot;)
def date = props.get(&quot;date&quot;)
def outputDir = props.get(&quot;outputDir&quot;)
def outputVersion = vars.get(&quot;version&quot;)
def outputHtmlPath = outputDir + &quot;${outputVersion}_SmokeTest2_Request_Response_Log.html&quot;

def htmlContent = &quot;&quot;&quot;
&lt;html&gt;
&lt;head&gt;
    &lt;title&gt;JMeter SmokeTest2 Request &amp; Response Log&lt;/title&gt;
    &lt;meta charset=&quot;UTF-8&quot;&gt;
    &lt;style&gt;
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th, td {
            padding: 10px;
            border: 1px solid #ddd;
        }
        .hidden {
            display: none;
        }
        .toggle-button {
            cursor: pointer;
            color: black;
            text-decoration: underline;
        }
    &lt;/style&gt;
    &lt;script&gt;
        function toggleTable(logFileName) {
            var table = document.getElementById(logFileName);
            if (table.classList.contains(&quot;hidden&quot;)) {
                table.classList.remove(&quot;hidden&quot;);
            } else {
                table.classList.add(&quot;hidden&quot;);
            }
        }
    &lt;/script&gt;
&lt;/head&gt;
&lt;body&gt;
&quot;&quot;&quot;

def detailLogFiles = Files.list(Paths.get(outputDir))
    .filter { it.toString().endsWith(&quot;detail.log&quot;) }
    .sorted { a, b -&gt; a.getFileName().toString() &lt;=&gt; b.getFileName().toString() }
    .collect()

if (detailLogFiles.isEmpty()) {
    htmlContent += &quot;&lt;h2&gt;No Request Log Files Found&lt;/h2&gt;&quot;
} else {
    htmlContent += &quot;&lt;h2&gt;API Log Report&lt;/h2&gt;&quot;
    detailLogFiles.eachWithIndex { logFile, idx -&gt;
        def logFileName = logFile.getFileName().toString().replace(&quot;_detail.log&quot;, &quot;&quot;)
        htmlContent += &quot;&quot;&quot;
        &lt;div&gt;
            &lt;span class=&quot;toggle-button&quot; onclick=&quot;toggleTable(&apos;${logFileName}&apos;)&quot;&gt;&lt;h3&gt; ${logFileName}&lt;/h3&gt;&lt;/span&gt;
        &lt;/div&gt;
        &lt;table id=&quot;${logFileName}&quot; class=&quot;hidden table-first-col&quot;&gt;
            &lt;tr&gt;
                &lt;th&gt;#&lt;/th&gt;
                &lt;th&gt;Sampler Name&lt;/th&gt;
                &lt;th&gt;Request Time&lt;/th&gt;
                &lt;th&gt;Request Body&lt;/th&gt;
                &lt;th&gt;Response Time&lt;/th&gt;
                &lt;th&gt;Response Body&lt;/th&gt;
            &lt;/tr&gt;
        &quot;&quot;&quot;

        def logData = []
        try {
            def jsonSlurper = new JsonSlurper()
            def jsonContent = new File(logFile.toString()).text

            
            def lines = jsonContent.split(&quot;\n&quot;)
            lines.drop(1).each { line -&gt;
                try {
                    def parsedJson = jsonSlurper.parseText(line)

                    
                    logData.add([
                        parsedJson.Sampler,
                        parsedJson.RequestTime,
                        parsedJson.RequestBody,
                        parsedJson.ResponseTime,
                        parsedJson.ResponseBody
                    ])
                } catch (Exception e) {
                    log.error(&quot;Failed to parse line: ${line}, error: ${e.message}&quot;)
                }
            }

            def maxLength = 1000
            
            logData.eachWithIndex { row, index -&gt;
                htmlContent += &quot;&lt;tr&gt;&quot;
                htmlContent += &quot;&lt;td&gt;${index + 1}&lt;/td&gt;&quot; 
                htmlContent += &quot;&lt;td&gt;${row[0]}&lt;/td&gt;&quot;  
                htmlContent += &quot;&lt;td&gt;${row[1]}&lt;/td&gt;&quot;  
                htmlContent += &quot;&lt;td&gt;&quot;

                def formattedRequest = escapeHtml(formatJson(row[2]))

                if (formattedRequest.length() &gt; maxLength) {
                    try {
                        def jsonRequest = new JsonSlurper().parseText(row[2])
                        if (jsonRequest instanceof Map) {		
	                        if (jsonRequest.containsKey(&quot;data&quot;) &amp;&amp; (jsonRequest[&quot;data&quot;] instanceof Map || jsonRequest[&quot;data&quot;] instanceof List)) {
	                            jsonRequest[&quot;data&quot;] = &quot;[{...}]&quot;
	                        }
                        }
                        formattedRequest = escapeHtml(formatJson(JsonOutput.toJson(jsonRequest)))
                        
                    } catch (Exception e) {
                        log.error(&quot;Failed to parse JSON for truncation: ${e.message}&quot;)
                    }
                }

//                htmlContent += formattedRequest
                htmlContent += formattedRequest.replaceAll(&quot;\n&quot;, &quot;&lt;br&gt;&quot;).replaceAll(&quot;\t&quot;, &quot;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&quot;)
                htmlContent += &quot;&lt;/td&gt;&quot; 
                htmlContent += &quot;&lt;td&gt;${row[3]}&lt;/td&gt;&quot;  
                htmlContent += &quot;&lt;td&gt;&quot;  
                
                def formattedResponse = escapeHtml(formatJson(row[4]))

                if (formattedResponse.length() &gt; maxLength) {
                    try {
                        def jsonResponse = new JsonSlurper().parseText(row[4])
                        if (jsonResponse.containsKey(&quot;data&quot;) &amp;&amp; (jsonResponse[&quot;data&quot;] instanceof Map || jsonResponse[&quot;data&quot;] instanceof List)) {
                            jsonResponse[&quot;data&quot;] = &quot;[{...}]&quot; 
                        }
                        formattedResponse = escapeHtml(formatJson(JsonOutput.toJson(jsonResponse)))
                        
                    } catch (Exception e) {
                        log.error(&quot;Failed to parse JSON for truncation: ${e.message}&quot;)
                    }
                }
//                htmlContent += formattedResponse
                htmlContent += formattedResponse.replaceAll(&quot;\n&quot;, &quot;&lt;br&gt;&quot;).replaceAll(&quot;\t&quot;, &quot;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&quot;)
                htmlContent += &quot;&lt;/td&gt;&quot;
                htmlContent += &quot;&lt;/tr&gt;&quot;
            }
        } catch (Exception e) {
            log.error(&quot;Failed to read log file: ${logFile}, error: ${e.message}&quot;)
        }
        htmlContent += &quot;&lt;/table&gt;&quot;
    }
}

htmlContent += &quot;&quot;&quot;
&lt;/body&gt;
&lt;/html&gt;
&quot;&quot;&quot;

try {
    Files.write(Paths.get(outputHtmlPath), htmlContent.getBytes(StandardCharsets.UTF_8))
    log.info(&quot;HTML report generated: ${outputHtmlPath}&quot;)
} catch (Exception e) {
    log.error(&quot;Failed to write HTML file: ${outputHtmlPath}, error: ${e.message}&quot;)
}

def escapeHtml(String input) {
    if (input == null) {
        return &quot;&quot;
    }
    return input.replaceAll(&quot;&amp;&quot;, &quot;&amp;amp;&quot;)
                .replaceAll(&quot;&lt;&quot;, &quot;&amp;lt;&quot;)
                .replaceAll(&quot;&gt;&quot;, &quot;&amp;gt;&quot;)
                .replaceAll(&quot;\&quot;&quot;, &quot;&amp;quot;&quot;)
                .replaceAll(&quot;&apos;&quot;, &quot;&amp;#39;&quot;)
}

def decodeUnicode(String input) {
    return StringEscapeUtils.unescapeJava(input)
}

def formatJson(String jsonString) {
    try {
        def jsonObj = new JsonSlurper().parseText(jsonString)
        return decodeUnicode(JsonOutput.prettyPrint(JsonOutput.toJson(jsonObj))) 
    } catch (Exception e) {
        return decodeUnicode(jsonString) 
    }
}
</stringProp>
