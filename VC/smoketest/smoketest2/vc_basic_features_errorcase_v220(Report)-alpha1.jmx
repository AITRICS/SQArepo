      <hashTree>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter
import java.nio.charset.StandardCharsets
import groovy.json.JsonSlurper
import groovy.json.JsonBuilder

def logResults = { prev, ctx, props, vars, expectedCode, type -&gt;

    if (expectedCode == null) {
        log.error(&quot;ExpectedCode is null. Please ensure it is properly passed to logResults.&quot;)
        return
    }

    if (type == null) {
        log.error(&quot;Type is null. Please ensure it is properly passed to logResults.&quot;)
        return
    }

    def now = LocalDateTime.now().format(DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd HH:mm:ss&quot;))
    def outputDir = props.get(&quot;outputDir&quot;)

    if (!Files.exists(Paths.get(outputDir))) {
        Files.createDirectories(Paths.get(outputDir))
    }

    def controllerName = vars.get(&quot;currentControllerName&quot;)
    def sampler = ctx.getCurrentSampler()
    def samplerName = sampler.getName()
    def requestFile = Paths.get(outputDir, &quot;${controllerName}_request.log&quot;)
    def responseFile = Paths.get(outputDir, &quot;${controllerName}_response.log&quot;)
    def resultDetailFile = Paths.get(outputDir, &quot;${controllerName}_detail.log&quot;)
    def resultFile = Paths.get(outputDir, &quot;${controllerName}_result.csv&quot;)
    def threadName = prev.getThreadName().split(&quot; &quot;)[0]
    def jsonResponse = null

    if (type == 1 || type == 4 || type == 5) {
        try {
            jsonResponse = new groovy.json.JsonSlurper().parseText(prev.getResponseDataAsString())
        } catch (Exception e) {
            log.error(&quot;Failed to parse JSON response: ${e.message}, ${samplerName}&quot;)
        }
    }

    def isSuccessful = false
    def statusResponseCode = &quot;N/A&quot;
    def responseBody = prev.getResponseDataAsString()          

    switch (type) {
        case 1: 
            isSuccessful = (jsonResponse?.code == expectedCode)
            statusResponseCode = jsonResponse?.code ?: &quot;N/A&quot;
            break
    
        case 2: 
            isSuccessful = (prev.getResponseCode() == expectedCode &amp;&amp; 
                         prev.getResponseHeaders()?.toLowerCase()?.contains(&quot;content-type: application/pdf&quot;))
            statusResponseCode = &quot;N/A&quot;
            responseBody = &quot;&quot; 
            bytes = 0 
            break

        case 3: 
            isSuccessful = (prev.getResponseCode().toString() == expectedCode &amp;&amp;
                         prev.getResponseHeaders()?.toLowerCase()?.contains(&quot;content-type: application/vnd.openxml&quot;))
            statusResponseCode = &quot;N/A&quot;
            responseBody = &quot;&quot; 
            bytes = 0 
            break
    
        case 4: 
            isSuccessful = (prev.getResponseCode() == expectedCode)
            statusResponseCode = jsonResponse?.code ?: &quot;N/A&quot;
            break

        case 5: 
            isSuccessful = (prev.getResponseCode() == expectedCode)
            statusResponseCode = jsonResponse?.code ?: &quot;N/A&quot;
            break
    
        default: 
            log.error(&quot;Unknown type: ${type}. Please provide a valid type (1 to 5).&quot;)
            return
    }

    def responseDataString = jsonResponse ? new JsonBuilder(jsonResponse).toString().replaceAll(&quot;\\r?\\n&quot;, &quot;&quot;) : responseBody 
    def bytes = responseBody.length() 
    prev.setSuccessful(isSuccessful)
    def testResult = isSuccessful ? &quot;PASS&quot; : &quot;FAIL&quot;
    def httpResponseCode = prev.getResponseCode()
    def responseMessage = prev.getResponseMessage()
    def requestURL = sampler.getUrl().toString()
    def requestTime = now
    def requestBody = sampler.getArguments().getArgument(0)?.getValue() ?: &quot;&quot;
    def responseTime = LocalDateTime.now().format(DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd HH:mm:ss&quot;))
    def requestHeaders = prev.getRequestHeaders()
    def responseHeaders = prev.getResponseHeaders()
    def latency = prev.getLatency()
    def idleTime = prev.getIdleTime()
    def connectTime = prev.getConnectTime()

    def requestJsonString = requestBody.replaceAll(&quot;\\r?\\n&quot;, &quot;&quot;) 
	def responseJsonString = responseDataString.replaceAll(&quot;\\r?\\n&quot;, &quot;&quot;)

     def jsonDetailBody = new JsonBuilder([Sampler: samplerName, RequestTime: requestTime, RequestBody: requestJsonString, ResponseTime: responseTime, ResponseBody: responseJsonString]).toString()
	
	def csvHeaderDetail = &quot;Request-ResponseDetails\n&quot;
	if (!Files.exists(resultDetailFile)) {
	    Files.write(resultDetailFile, csvHeaderDetail.getBytes(StandardCharsets.UTF_8), StandardOpenOption.CREATE)
	}
	
	def csvDataDetail = jsonDetailBody + &quot;\n&quot;
	Files.write(resultDetailFile, csvDataDetail.getBytes(StandardCharsets.UTF_8), StandardOpenOption.APPEND)


    def csvHeader = &quot;Timestamp,Thread Name,Controller Name,Sampler Name,Test Result,HTTP Response Code,Status Response Code,Response Message,Request URL,Latency,Bytes,Idle Time,Connect\n&quot;
    if (!Files.exists(resultFile)) {
        Files.createDirectories(resultFile.parent)
        Files.write(resultFile, csvHeader.getBytes(StandardCharsets.UTF_8), StandardOpenOption.CREATE)
    }

    def csvData = &quot;${now},${threadName},${controllerName},${samplerName},${testResult},${httpResponseCode},${statusResponseCode},${responseMessage},${requestURL},${latency},${bytes},${idleTime},${connectTime}\n&quot;
    Files.write(resultFile, csvData.getBytes(StandardCharsets.UTF_8), StandardOpenOption.APPEND)
}

vars.putObject(&quot;logResults&quot;, logResults)</stringProp>
        </JSR223PreProcessor>
        <hashTree/>
        <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">def logResults = vars.getObject(&quot;logResults&quot;)

if (logResults != null) {
    def sampler = ctx.getCurrentSampler()
    def samplerName = sampler.getName()

    def expectedCodeMatch = (samplerName =~ /\[(\d+)\]/)
    def expectedCode = expectedCodeMatch.find() ? expectedCodeMatch[0][1] : null

    if (expectedCode == null) {
        log.error(&quot;ExpectedCode could not be extracted from sampler name: ${samplerName}&quot;)
        return
    }

    def type
    if (expectedCode in [&quot;200&quot;, &quot;201&quot;]) {
        def responseHeaders = prev.getResponseHeaders()?.toLowerCase()
        if (responseHeaders?.contains(&quot;content-type: application/pdf&quot;)) {
            type = 2 //pdf
        } else if (responseHeaders?.startsWith(&quot;content-type: application/vnd.openxml&quot;)) {
            type = 3 //xls
        } else {
            try {
                new groovy.json.JsonSlurper().parseText(prev.getResponseDataAsString())
                type = 4 // JSON
            } catch (Exception e) {
                type = 0 // exception
            }
        }
    } else if (expectedCode in [&quot;422&quot;, &quot;401&quot;, &quot;404&quot;, &quot;405&quot;, &quot;400&quot;, &quot;403&quot;]) {
        type = 5 
    } else if (expectedCode ==~ /\d{6}/) { 
        type = 1 
    } else {
        type = 0 
    }
    logResults(prev, ctx, props, vars, expectedCode, type)
} else {
    log.error(&quot;The logResults function has not been initialized.&quot;)
}</stringProp>
        </JSR223PostProcessor>
