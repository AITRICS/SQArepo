        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(Result_Detail_Log)_JSR223 Sampler" enabled="false">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import groovy.json.JsonOutput
import groovy.json.JsonSlurper
import java.nio.charset.StandardCharsets
import org.apache.commons.lang3.StringEscapeUtils

// 경로 설정
def userHome = props.get(&quot;userHome&quot;)
def date = props.get(&quot;date&quot;)
def outputDir = props.get(&quot;outputDir&quot;)
def outputVersion = vars.get(&quot;version&quot;)
def outputHtmlPath = outputDir + &quot;${outputVersion}_SmokeTest2_Request_Response_Log.html&quot;

// HTML 파일 작성 시작
def htmlContent = &quot;&quot;&quot;
&lt;html&gt;
&lt;head&gt;
    &lt;title&gt;JMeter SmokeTest2 Request &amp; Response Log&lt;/title&gt;
    &lt;meta charset=&quot;UTF-8&quot;&gt;
    &lt;style&gt;
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th, td {
            padding: 10px;
            border: 1px solid #ddd;
        }
        .hidden {
            display: none;
        }
        .toggle-button {
            cursor: pointer;
            color: black;
            text-decoration: underline;
        }
    &lt;/style&gt;
    &lt;script&gt;
        function toggleTable(logFileName) {
            var table = document.getElementById(logFileName);
            if (table.classList.contains(&quot;hidden&quot;)) {
                table.classList.remove(&quot;hidden&quot;);
            } else {
                table.classList.add(&quot;hidden&quot;);
            }
        }
    &lt;/script&gt;
&lt;/head&gt;
&lt;body&gt;
&quot;&quot;&quot;

// 디렉토리 내 .json 파일 처리 및 정렬
def detailLogFiles = Files.list(Paths.get(outputDir))
    .filter { it.toString().endsWith(&quot;detail.log&quot;) } // .json 파일만 필터링
    .sorted { a, b -&gt; a.getFileName().toString() &lt;=&gt; b.getFileName().toString() } // 파일 이름으로 정렬
    .collect()

if (detailLogFiles.isEmpty()) {
    htmlContent += &quot;&lt;h2&gt;No Request Log Files Found&lt;/h2&gt;&quot;
} else {
    htmlContent += &quot;&lt;h2&gt;API Log Report&lt;/h2&gt;&quot;
    detailLogFiles.eachWithIndex { logFile, idx -&gt;
        def logFileName = logFile.getFileName().toString().replace(&quot;_detail.log&quot;, &quot;&quot;)
        htmlContent += &quot;&quot;&quot;
        &lt;div&gt;
            &lt;span class=&quot;toggle-button&quot; onclick=&quot;toggleTable(&apos;${logFileName}&apos;)&quot;&gt;&lt;h3&gt; ${logFileName}&lt;/h3&gt;&lt;/span&gt;
        &lt;/div&gt;
        &lt;table id=&quot;${logFileName}&quot; class=&quot;hidden table-first-col&quot;&gt;
            &lt;tr&gt;
                &lt;th&gt;#&lt;/th&gt;
                &lt;th&gt;Sampler Name&lt;/th&gt;
                &lt;th&gt;Request Time&lt;/th&gt;
                &lt;th&gt;Request Body&lt;/th&gt;
                &lt;th&gt;Response Time&lt;/th&gt;
                &lt;th&gt;Response Body&lt;/th&gt;
            &lt;/tr&gt;
        &quot;&quot;&quot;

        def logData = []
        try {
		    def jsonSlurper = new JsonSlurper()
		    def jsonContent = new File(logFile.toString()).text
		
		    // 첫 번째 줄을 건너뛰고 나머지 줄을 처리
		    def lines = jsonContent.split(&quot;\n&quot;)
		    lines.drop(1).each { line -&gt;
		        try {
		            def parsedJson = jsonSlurper.parseText(line)
		
		            // JSON 데이터 처리
		            logData.add([
		                parsedJson.Sampler,
		                parsedJson.RequestTime,
		                parsedJson.RequestBody,
		                parsedJson.ResponseTime,
		                parsedJson.ResponseBody
		            ])
		        } catch (Exception e) {
		            log.error(&quot;Failed to parse line: ${line}, error: ${e.message}&quot;)
		        }
		    }

            logData.eachWithIndex { row, index -&gt;
                htmlContent += &quot;&lt;tr&gt;&quot;
                htmlContent += &quot;&lt;td&gt;${index + 1}&lt;/td&gt;&quot; // 인덱스 추가
                htmlContent += &quot;&lt;td&gt;${row[0]}&lt;/td&gt;&quot;  // 샘플러 이름
                htmlContent += &quot;&lt;td&gt;${row[1]}&lt;/td&gt;&quot;  // 요청 시간
                htmlContent += &quot;&lt;td&gt;${escapeHtml(formatJson(row[2]))}&lt;/td&gt;&quot;  // 요청 본문 (JSON prettify + HTML 이스케이프 처리)
                htmlContent += &quot;&lt;td&gt;${row[3]}&lt;/td&gt;&quot;  // 응답 시간
                htmlContent += &quot;&lt;td&gt;${escapeHtml(formatJson(row[4]))}&lt;/td&gt;&quot;  // 응답 본문 (JSON prettify + HTML 이스케이프 처리)
                htmlContent += &quot;&lt;/tr&gt;&quot;
            }
        } catch (Exception e) {
            log.error(&quot;Failed to read log file: ${logFile}, error: ${e.message}&quot;)
        }
        htmlContent += &quot;&lt;/table&gt;&quot;
    }
}

htmlContent += &quot;&quot;&quot;
&lt;/body&gt;
&lt;/html&gt;
&quot;&quot;&quot;

// HTML 파일 저장
try {
    Files.write(Paths.get(outputHtmlPath), htmlContent.getBytes(StandardCharsets.UTF_8))
    log.info(&quot;HTML report generated: ${outputHtmlPath}&quot;)
} catch (Exception e) {
    log.error(&quot;Failed to write HTML file: ${outputHtmlPath}, error: ${e.message}&quot;)
}

// 특수 문자 HTML-Escape 함수 (JSON 데이터 보호 포함)
def escapeHtml(String input) {
    if (input == null) {
        return &quot;&quot;
    }
    return input.replaceAll(&quot;&amp;&quot;, &quot;&amp;amp;&quot;)
                .replaceAll(&quot;&lt;&quot;, &quot;&amp;lt;&quot;)
                .replaceAll(&quot;&gt;&quot;, &quot;&amp;gt;&quot;)
                .replaceAll(&quot;\&quot;&quot;, &quot;&amp;quot;&quot;)
                .replaceAll(&quot;&apos;&quot;, &quot;&amp;#39;&quot;)
}

// 유니코드 이스케이프 문자열을 한글로 변환
def decodeUnicode(String input) {
    return StringEscapeUtils.unescapeJava(input)
}

def formatJson(String jsonString) {
    try {
        def jsonObj = new JsonSlurper().parseText(jsonString)
        return decodeUnicode(JsonOutput.prettyPrint(JsonOutput.toJson(jsonObj))) // 🔥 유니코드 변환 추가
    } catch (Exception e) {
        return decodeUnicode(jsonString) // JSON이 아니어도 유니코드 변환 적용
    }
}




</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(Intergration)_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*;
import java.nio.charset.StandardCharsets;

def userHome = props.get(&quot;userHome&quot;);
def date = props.get(&quot;date&quot;);
def outputDir = props.get(&quot;outputDir&quot;);
def outputVersion = vars.get(&quot;version&quot;)
def outputHtmlPath = outputDir + &quot;${outputVersion}_SmokeTest2_Report.html&quot;;

def TestResult = Paths.get(outputDir, &quot;${outputVersion}_SmokeTest2_Result.html&quot;).toString();
def TestLog1 = Paths.get(outputDir, &quot;${outputVersion}_SmokeTest2_Request_Response_Log.html&quot;).toString();

def contentFile1 = new File(TestResult).text;
def contentFile2 = new File(TestLog1).text;

def combinedHtml = &quot;&quot;&quot;
&lt;html&gt;
&lt;head&gt;
    &lt;title&gt;${outputVersion}_SmokeTest2_Report&lt;/title&gt;
    &lt;meta charset=&quot;UTF-8&quot;&gt;
    &lt;style&gt;
        body {
            font-family: Arial, sans-serif;
            margin: 10px;
            background-color: #f4f4f9;
            padding: 2%;
            font-size: 16px;
        }
        h1, h2 {
            color: #333;
        }
        h1 {
            font-size: 2em;
        }
        h2 {
            font-size: 1.5em;
        }
        .PASS {
            font-weight: bold;
            color: blue;
        }
        .FAIL {
            font-weight: bold;
            color: red;
        }
        table {
	       width: 100%;
	       table-layout: fixed;
	       border-collapse: collapse;
	       margin-top: 20px;
            font-size: 1em;
        }
	   th, td {
	       padding: 10px;
            text-align: left;
            border: 1px solid #ddd;
            word-wrap: break-word;
            white-space: normal;
        }
        th {
            background-color: #f2f2f2;
        }
        tr:nth-child(even) {
            background-color: #f9f9f9;
        }
        .table-first-col th:first-child, .table-first-col td:first-child {
            width: 3%; 
        }
        .table-first-col th:nth-child(2), .table-first-col td:nth-child(2) {
            width: 12%; 
        }
        .table-first-col th:nth-child(3), .table-first-col td:nth-child(3) {
            width: 10%; 
        }
        .table-first-col th:nth-child(4), .table-first-col td:nth-child(4) {
            width: 20%; 
        }
        .table-first-col th:nth-child(5), .table-first-col td:nth-child(5) {
            width: 10%; 
        }
        .table-first-col th:nth-child(6), .table-first-col td:nth-child(6) {
            width: 40%; 
        }
        .tab {
            overflow: hidden;
            background-color: #f4f4f9;
            border-bottom: 2px solid #ddd;
            margin-bottom: 20px;
        }
        .tab button {
            background-color: #e9e9f3;
            color: #333;
            float: left;
            border: none;
            outline: none;
            cursor: pointer;
            padding: 14px 20px;
            transition: 0.3s;
            font-size: 16px;
            font-weight: bold;
            margin-right: 5px;
            border-radius: 5px 5px 0 0;
        }
        .tab button:hover {
            background-color: #d6d6ee;
        }
        .tab button.active {
            background-color: #b3b3dd;
            color: white;
            border-bottom: 3px solid #6c63ff;
        }
        .tabcontent {
            display: none;
            padding: 20px;
            border: 1px solid #ddd;
            border-top: none;
            border-radius: 0 0 5px 5px;
            background-color: white;
            width: 100vw; 
            max-width: 100%; 
        }
        .tabcontent.active {
            display: block;
        }
        .tabcontent .chart-container {
	       width: 100% !important; 
	       height: 35vh !important;
	       margin: 0 auto;
	       display: flex;
	       justify-content: center;
	       align-items: center;
	       position: relative; 
        }
        @media (max-width: 1024px) {
            body {
                font-size: 12px;
            }
            h1 {
                font-size: 1.6em;
            }
            table {
                font-size: 0.9em;
            }
        }
        @media print {
            body {
                font-size: 10px;
            }
            table {
                font-size: 0.8em;
            }
        }
    &lt;/style&gt;
    
    &lt;script&gt;
        function openTab(evt, tabName) {
            var i, tabcontent, tablinks;
            tabcontent = document.getElementsByClassName(&quot;tabcontent&quot;);
            for (i = 0; i &lt; tabcontent.length; i++) {
                tabcontent[i].classList.remove(&quot;active&quot;);
            }
            tablinks = document.getElementsByClassName(&quot;tablinks&quot;);
            for (i = 0; i &lt; tablinks.length; i++) {
                tablinks[i].classList.remove(&quot;active&quot;);
            }
            document.getElementById(tabName).classList.add(&quot;active&quot;);
            evt.currentTarget.classList.add(&quot;active&quot;);
        }
        document.addEventListener(&quot;DOMContentLoaded&quot;, function() {
            document.getElementsByClassName(&quot;tablinks&quot;)[0].click();
        });
        window.addEventListener(&quot;resize&quot;, function() {
	       Plotly.relayout(&apos;chart-container&apos;, {
	           width: window.innerWidth * 0.9, 
	           height: window.innerHeight * 0.4
	       });
	   });
    &lt;/script&gt;
&lt;/head&gt;
&lt;body&gt;
    &lt;h1&gt;${outputVersion}_SmokeTest2_Report&lt;/h1&gt;
    &lt;div class=&quot;tab&quot;&gt;
        &lt;button class=&quot;tablinks&quot; onclick=&quot;openTab(event, &apos;File1&apos;)&quot;&gt;Test Result&lt;/button&gt;
        &lt;button class=&quot;tablinks&quot; onclick=&quot;openTab(event, &apos;File2&apos;)&quot;&gt;Request-Response Log&lt;/button&gt;
    &lt;/div&gt;
    &lt;div id=&quot;File1&quot; class=&quot;tabcontent&quot;&gt;
        ${contentFile1}
    &lt;/div&gt;
    &lt;div id=&quot;File2&quot; class=&quot;tabcontent&quot;&gt;
        ${contentFile2}
    &lt;/div&gt;
&lt;/body&gt;
&lt;/html&gt;
&quot;&quot;&quot;;


Files.write(Paths.get(outputHtmlPath), combinedHtml.getBytes(StandardCharsets.UTF_8));


log.info(&quot;Combined HTML file saved at: ${outputHtmlPath}&quot;);</stringProp>
        </JSR223Sampler>
