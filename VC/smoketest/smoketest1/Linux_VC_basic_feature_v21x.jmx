long end_dt = ${timestamp_default} - 9 * 60 * 60 * 1000;
long version = ${timestamp_default} - 9 * 60 * 60 * 1000;
long last_version = ${timestamp_default} - 10 * 60 * 60 * 1000;

Date timestamp_start_dt = new Date(start_dt);
Date timestamp_end_dt = new Date(end_dt);
Date timestamp_version = new Date(version);
Date timestamp_last_version = new Date(last_version);

