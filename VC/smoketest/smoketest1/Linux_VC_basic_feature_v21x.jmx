          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">// Get the password from JMeter variables
def password = vars.get(&quot;USER_RESET_PW&quot;);

// Escape special characters for JSON compatibility
def escapedPassword = password.replaceAll(&apos;([&quot;\\\\])&apos;, &apos;\\\\$1&apos;);

// Save the escaped password back to JMeter variables
vars.put(&quot;USER_RESET_PW&quot;, escapedPassword);
</stringProp>
            </JSR223PreProcessor>
