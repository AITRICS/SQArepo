              <stringProp name="script">import java.time.YearMonth

// Get the current year and month
YearMonth currentYearMonth = YearMonth.now()

// Convert year to string and store in variable
String currentYear = String.valueOf(currentYearMonth.getYear())

// Convert month to string and store in variable
String currentMonth = String.valueOf(currentYearMonth.getMonthValue())

// Store in JMeter variables
vars.put(&quot;currentYear&quot;, currentYear)
vars.put(&quot;currentMonth&quot;, currentMonth)</stringProp>
