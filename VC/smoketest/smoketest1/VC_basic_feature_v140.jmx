          <stringProp name="BeanShellSampler.query">import java.text.*;
import java.io.*;
import java.util.*;

csvPath = vars.get(&quot;CSV_PATH&quot;);
File file1 = new File(csvPath);
log.info(&quot;to delete csv path = &quot; + csvPath);
if (file1.exists()) {
	log.info(&quot;csv already exists! - try to delete...&quot;);
	file1.delete(); 
}</stringProp>
