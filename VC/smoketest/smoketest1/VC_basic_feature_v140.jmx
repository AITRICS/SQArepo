            <stringProp name="filename"></stringProp>
            <stringProp name="script">log.info(&quot;path = &quot;+vars.get(&quot;CSV_PATH&quot;));
String path=vars.get(&quot;CSV_PATH&quot;);

log.info(&quot;path = &quot;+path);

FileWriter fileWriter = new FileWriter(new File(path), true);
BufferedWriter writer = new BufferedWriter(fileWriter);
writer.append(vars.get(&quot;ACCESS_TOKEN&quot;) + &quot;,\n&quot;);
log.info(&quot;token append - &quot;+vars.get(&quot;ACCESS_TOKEN&quot;) + &quot;,\n&quot;);
writer.close();
fileWriter.close();
</stringProp>
