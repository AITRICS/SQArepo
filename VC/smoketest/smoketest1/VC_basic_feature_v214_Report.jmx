                            }
                        },
                        y: {
                            title: {
                                display: true, // y축 타이틀을 표시
                                text: &apos;Total Requests&apos; // y축 타이틀
                            },
                            beginAtZero: true // y축 값이 0에서 시작하도록 설정
                        }
                    }
