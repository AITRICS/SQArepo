              <stringProp name="parameters"></stringProp>
              <stringProp name="script">import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.TimeZone;
import java.util.Calendar;

long timestampDefault = ${timestamp_default};

//Set Date
Calendar calendar = Calendar.getInstance();
calendar.setTimeInMillis(timestampDefault); // Set the default timestamp    
calendar.add(Calendar.DAY_OF_MONTH, -1);

long timestamp_start_dt = calendar.getTimeInMillis();

Date start_dt = new Date(timestamp_start_dt);
Date end_dt = new Date(timestampDefault);

SimpleDateFormat sdf_time = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
sdf_time.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

String start_dt_string = sdf_time.format(start_dt);
String end_dt_string = sdf_time.format(end_dt);

// Assuming vars is a map
vars.put(&quot;History_start_dt&quot;, start_dt_string);
vars.put(&quot;History_end_dt&quot;, end_dt_string);</stringProp>
