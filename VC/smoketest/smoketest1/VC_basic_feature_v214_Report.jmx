        <hashTree/>
        <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter
import java.nio.charset.StandardCharsets
import groovy.json.JsonSlurper
import groovy.json.JsonBuilder
import org.apache.commons.lang3.StringEscapeUtils

// 응답 데이터 가져오기
def response = prev.getResponseDataAsString()

// 요청 데이터 가져오기
def request = prev.getSamplerData() // 요청 데이터를 가져오는 메서드

// JSON 파싱 (조건부로 시도)
def jsonRequest
try {
    jsonRequest = new JsonSlurper().parseText(request) // 요청 데이터가 JSON일 경우 파싱
} catch (Exception e) {
    // 요청 데이터가 JSON이 아니면, 그대로 문자열로 처리
    jsonRequest = request
}

def jsonResponse
try {
    jsonResponse = new JsonSlurper().parseText(response) // 응답 데이터가 JSON일 경우 파싱
} catch (Exception e) {
    // 응답 데이터가 JSON이 아니면, 그대로 문자열로 처리
    jsonResponse = response
}

// 필요한 변수 정의
def outputDir = props.get(&quot;outputDir&quot;)
def samplerName = ctx.getCurrentSampler().getName()
def threadName = prev.getThreadName() // 스레드 이름
def timestamp = prev.getTimeStamp() // 타임스탬프
def resultFile = Paths.get(outputDir, vars.get(&quot;version&quot;) + &quot;.csv&quot;)
def now = LocalDateTime.now().format(DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd HH:mm:ss&quot;))

// 폴더 생성
if (!Files.exists(Paths.get(outputDir))) {
    Files.createDirectories(Paths.get(outputDir))
}

// Test 결과 데이터 수집
def testResult = (prev.isSuccessful()) ? &quot;PASS&quot; : &quot;FAIL&quot; // 성공 여부
def elapsed = prev.getTime() // 경과 시간
def label = prev.getSampleLabel() // 샘플러 이름
def responseCode = prev.getResponseCode() // 응답 코드
def responseMessage = prev.getResponseMessage() // 응답 메시지
def dataType = prev.getDataType() // 데이터 유형
def success = prev.isSuccessful() // 성공 여부
def failureMessage = success ? &quot;&quot; : &quot;Request failed: ${prev.getResponseMessage()}&quot; // 실패 메시지
def bytes = prev.getBytesAsLong() // 응답 바이트 크기
def sentBytes = prev.getSentBytes() // 요청 바이트 크기
def grpThreads = prev.getGroupThreads() // 그룹 스레드 수
def allThreads = prev.getAllThreads() // 전체 스레드 수
def URL = ctx.getCurrentSampler().getUrl()?.toString() ?: &quot;&quot; // 요청 URL
def latency = prev.getLatency() // 지연 시간
def idleTime = prev.getIdleTime() // 대기 시간
def connectTime = prev.getConnectTime() // 연결 시간

// 요청과 응답 데이터를 포함하는 JSON 객체 생성
def requestJson = [
    &quot;timestamp&quot;: timestamp,
    &quot;threadName&quot;: threadName,
    &quot;samplerName&quot;: samplerName,
    &quot;body&quot;: request
]

def responseJson = [
    &quot;timestamp&quot;: timestamp,
    &quot;threadName&quot;: threadName,
    &quot;samplerName&quot;: samplerName,
    &quot;body&quot;: response
]

// 파일 이름 정의
def requestFile = Paths.get(outputDir, &quot;request_${vars.get(&quot;version&quot;)}.json&quot;)
def responseFile = Paths.get(outputDir, &quot;response_${vars.get(&quot;version&quot;)}.json&quot;)

// 파일에 JSON 배열로 데이터를 저장하는 함수
def appendToJsonArray(file, jsonObject) {
    if (!Files.exists(file)) {
        // 파일이 없으면 새로 만들고 배열 형태로 초기화
        def initialContent = new JsonBuilder([jsonObject]).toPrettyString()
        Files.write(file, initialContent.getBytes(StandardCharsets.UTF_8), StandardOpenOption.CREATE)
    } else {
        // 파일이 존재하면 기존 내용을 읽고 배열에 추가
        def existingContent = new String(Files.readAllBytes(file), StandardCharsets.UTF_8).trim()
        def jsonArray = existingContent ? new JsonSlurper().parseText(existingContent) : []
        if (!(jsonArray instanceof List)) {
            throw new IllegalStateException(&quot;File content is not a JSON array: ${file}&quot;)
        }
        jsonArray &lt;&lt; jsonObject
        def updatedContent = new JsonBuilder(jsonArray).toPrettyString()
        Files.write(file, updatedContent.getBytes(StandardCharsets.UTF_8), StandardOpenOption.TRUNCATE_EXISTING)
    }
}

// 요청 및 응답 데이터를 파일에 추가
appendToJsonArray(requestFile, requestJson)
appendToJsonArray(responseFile, responseJson)

// CSV 헤더 작성
def csvHeader = &quot;timeStamp,elapsed,label,responseCode,responseMessage,threadName,dataType,success,failureMessage,bytes,sentBytes,grpThreads,allThreads,URL,Latency,IdleTime,Connect,requestFile,responseFile\n&quot;
if (!Files.exists(resultFile)) {
    Files.write(resultFile, csvHeader.getBytes(StandardCharsets.UTF_8), StandardOpenOption.CREATE)
}

// CSV 데이터 작성 (requestFile과 responseFile 경로 추가)
def csvData = &quot;${timestamp},${elapsed},${label},${responseCode},${responseMessage},${threadName},${dataType},${success},${failureMessage},${bytes},${sentBytes},${grpThreads},${allThreads},${URL},${latency},${idleTime},${connectTime},\&quot;${requestFile}\&quot;,\&quot;${responseFile}\&quot;\n&quot;
Files.write(resultFile, csvData.getBytes(StandardCharsets.UTF_8), StandardOpenOption.APPEND)
</stringProp>
        </JSR223PostProcessor>
        <hashTree/>
      </hashTree>
      <PostThreadGroup guiclass="PostThreadGroupGui" testclass="PostThreadGroup" testname="tearDown Thread Group" enabled="true">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </PostThreadGroup>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml_JSR223 Sampler" enabled="false">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import groovy.json.JsonSlurper
import java.nio.charset.StandardCharsets

// 경로 설정
def date = props.get(&quot;date&quot;)
def outputDir = props.get(&quot;outputDir&quot;)
def outputHtmlPath = outputDir + &quot;SanityTest1_Report.html&quot;

// HTML 파일 작성 시작
def htmlContent = &quot;&quot;&quot;
&lt;html&gt;
&lt;head&gt;
    &lt;title&gt;SanityTest1_Report&lt;/title&gt;
    &lt;meta charset=&quot;UTF-8&quot;&gt;
    &lt;style&gt;
        body {font-family: Arial, sans-serif;margin: 20px;color: #333;background-color: #f4f4f9;}
        h1, h2, h3, h4 {color: #333;}
        table {width: 90%;border-collapse: collapse;margin-bottom: 20px;font-size: 0.9em;color: #333;text-align: left;}
        th {background-color: #f2f2f2;font-weight: bold;padding: 10px;text-align: center;border: 1px solid #ddd;}
        td {background-color: #fff;padding: 10px;text-align: left;border: 1px solid #ddd;}
        tr:nth-child(even) {background-color: #f9f9f9;}
        tr:nth-child(odd) {background-color: #ffffff;}
        .information-table {width: 60%; margin-bottom: 20px;text-align: left;}
        .information-table th:first-child,
        .information-table td:first-child {width: 50%;}
        .empty-table { text-align: center; color: gray; }
    &lt;/style&gt;
    &lt;script charset=&quot;utf-8&quot; src=&quot;https://cdn.plot.ly/plotly-2.35.2.min.js&quot;&gt;&lt;/script&gt;
&lt;/head&gt;
&lt;body&gt;
    &lt;h1&gt;SanityTest2_Report&lt;/h1&gt;
    &lt;br&gt;
    &lt;hr&gt;
&quot;&quot;&quot;

// 디렉토리 내 CSV 파일 처리 및 정렬
def csvFiles = Files.list(Paths.get(outputDir))
    .filter { it.toString().endsWith(&quot;.csv&quot;) } // .csv 파일만 필터링
    .sorted { a, b -&gt; a.getFileName().toString() &lt;=&gt; b.getFileName().toString() } // 파일 이름으로 정렬
    .collect()

// 전체 테스트 통계 변수 초기화
def overallStartTime = null
def overallEndTime = null
def overallTotalRequests = 0
def overallPassCount = 0
def overallFailCount = 0

// Thread Group 통계용 데이터 구조
def threadGroupStats = []

// 각 CSV 파일에 대한 통계 수집
csvFiles.each { csvFile -&gt;
    def threadGroupName = csvFile.getFileName().toString()
    def startTime = null
    def endTime = null
    def totalRequests = 0
    def passCount = 0
    def failCount = 0
    def responseTimes = []

    try {
        Files.lines(csvFile).eachWithIndex { line, index -&gt;
            if (index == 0) return // 헤더 스킵
            def row = line.split(&quot;,&quot;).collect { it.trim() }
            def timestamp = row[0] // 첫 번째 컬럼이 timestamp라고 가정
            def result = row[4] // 다섯 번째 컬럼이 test result라고 가정
            // Response Time (ms) 처리: 빈 값이나 숫자가 아닐 경우 기본값 설정
            def responseTime = row[9]?.isEmpty() ? 0 : row[9].toInteger() // 빈 값일 경우 0으로 설정

            // Thread Group 시작/종료 시간 계산
            if (startTime == null || timestamp &lt; startTime) startTime = timestamp
            if (endTime == null || timestamp &gt; endTime) endTime = timestamp

            // 요청 수 및 통계 계산
            totalRequests++
            responseTimes &lt;&lt; responseTime
            if (result == &quot;PASS&quot;) passCount++
            else if (result == &quot;FAIL&quot;) failCount++
        }

        // Thread Group 통계 저장
        threadGroupStats &lt;&lt; [
            name           : threadGroupName,
            totalRequests  : totalRequests,
            passCount      : passCount,
            failCount      : failCount,
            avgResponseTime: responseTimes.sum() / responseTimes.size(),
            maxResponseTime: responseTimes.max(),
            minResponseTime: responseTimes.min(),
            startTime      : startTime,
            endTime        : endTime
        ]

        // 전체 통계 업데이트
        overallTotalRequests += totalRequests
        overallPassCount += passCount
        overallFailCount += failCount
        if (overallStartTime == null || startTime &lt; overallStartTime) overallStartTime = startTime
        if (overallEndTime == null || endTime &gt; overallEndTime) overallEndTime = endTime

    } catch (Exception e) {
        log.error(&quot;Failed to process CSV file: ${csvFile}, error: ${e.message}&quot;)
    }
}

def parseLocalDateTime(timeString) {
    return java.time.LocalDateTime.parse(
        timeString, 
        java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    )
}

// 전체 테스트 정보 표시
def overallDuration = overallStartTime &amp;&amp; overallEndTime ? 
    java.time.Duration.between(
        parseLocalDateTime(overallStartTime), 
        parseLocalDateTime(overallEndTime)
    ).toSeconds() : 0

def durationFormatted = &quot;${overallDuration} sec&quot;

htmlContent += &quot;&quot;&quot;
&lt;h2&gt;Overall Test Summary&lt;/h2&gt;
&lt;table class=&apos;information-table&apos;&gt;
    &lt;tr&gt;&lt;th&gt;Start Time&lt;/th&gt;&lt;td&gt;${overallStartTime ?: &quot;N/A&quot;}&lt;/td&gt;&lt;/tr&gt;
    &lt;tr&gt;&lt;th&gt;End Time&lt;/th&gt;&lt;td&gt;${overallEndTime ?: &quot;N/A&quot;}&lt;/td&gt;&lt;/tr&gt;
    &lt;tr&gt;&lt;th&gt;Total Duration (min)&lt;/th&gt;&lt;td&gt;${durationFormatted}&lt;/td&gt;&lt;/tr&gt;
    &lt;tr&gt;&lt;th&gt;Total Requests&lt;/th&gt;&lt;td&gt;${overallTotalRequests}&lt;/td&gt;&lt;/tr&gt;
    &lt;tr&gt;&lt;th&gt;Pass Count&lt;/th&gt;&lt;td&gt;${overallPassCount}&lt;/td&gt;&lt;/tr&gt;
    &lt;tr&gt;&lt;th&gt;Fail Count&lt;/th&gt;&lt;td&gt;${overallFailCount}&lt;/td&gt;&lt;/tr&gt;
&lt;/table&gt;
&lt;hr&gt;
&quot;&quot;&quot;

// Thread Group Summary 테이블 생성
htmlContent += &quot;&quot;&quot;
&lt;h2&gt;Thread Group Summary&lt;/h2&gt;
&lt;table&gt;
    &lt;tr&gt;
        &lt;th&gt;Thread Group&lt;/th&gt;
        &lt;th&gt;Total Requests&lt;/th&gt;
        &lt;th&gt;Successful Requests&lt;/th&gt;
        &lt;th&gt;Failed Requests&lt;/th&gt;
        &lt;th&gt;Average Response Time (ms)&lt;/th&gt;
        &lt;th&gt;Max Response Time (ms)&lt;/th&gt;
        &lt;th&gt;Min Response Time (ms)&lt;/th&gt;
        &lt;th&gt;Start Time&lt;/th&gt;
        &lt;th&gt;End Time&lt;/th&gt;
    &lt;/tr&gt;
&quot;&quot;&quot;

threadGroupStats.each { stats -&gt;
    htmlContent += &quot;&quot;&quot;
    &lt;tr&gt;
        &lt;td&gt;${stats.name}&lt;/td&gt;
        &lt;td&gt;${stats.totalRequests}&lt;/td&gt;
        &lt;td&gt;${stats.passCount}&lt;/td&gt;
        &lt;td&gt;${stats.failCount}&lt;/td&gt;
        &lt;td&gt;${stats.avgResponseTime.round(2)}&lt;/td&gt;
        &lt;td&gt;${stats.maxResponseTime}&lt;/td&gt;
        &lt;td&gt;${stats.minResponseTime}&lt;/td&gt;
        &lt;td&gt;${stats.startTime}&lt;/td&gt;
        &lt;td&gt;${stats.endTime}&lt;/td&gt;
    &lt;/tr&gt;
    &quot;&quot;&quot;
}

htmlContent += &quot;&lt;/table&gt;&lt;hr&gt;&quot;


// 원 차트 추가
htmlContent += &quot;&quot;&quot;
&lt;h2&gt;Visualizations&lt;/h2&gt;
&lt;h2&gt;PASS vs FAIL&lt;/h2&gt;
&lt;div class=&quot;chart-container&quot; style=&quot;display: flex; justify-content: center; align-items: center; width: 100%; height: 400px;&quot;&gt;
    &lt;div id=&quot;testResultChart&quot; style=&quot;width: 100%; height: 100%;&quot;&gt;&lt;/div&gt;
&lt;/div&gt;

&lt;script charset=&quot;utf-8&quot; src=&quot;https://cdn.plot.ly/plotly-2.35.2.min.js&quot;&gt;&lt;/script&gt;
&lt;script&gt;
    var data = [{
        values: [${overallPassCount}, ${overallFailCount}],
        labels: [&apos;PASS&apos;, &apos;FAIL&apos;],
        type: &apos;pie&apos;,
        textinfo: &apos;percent&apos;,
        textposition: &apos;inside&apos;,
        automargin: true,
        hovertemplate: &apos;Result = %{label}&lt;br&gt;Count = %{value}&lt;extra&gt;&lt;/extra&gt;&apos;,  // 마우스 오버 시 표시되는 텍스트 형식
        marker: {
            colors: [&apos;#636efa&apos;,&apos;#EF553B&apos;],  // 파이 차트 색상 (보라색, 빨간색)
            line: {
                color: [&apos;#388e3c&apos;, &apos;#d32f2f&apos;],  // 테두리 색상
                width: 0  // 테두리 두께
            }
        },
    }];
    
    var layout = {
        title: {
            text: &apos;PASS vs FAIL&apos;,
            font: {
                family: &apos;Arial, sans-serif&apos;,  // 제목 폰트
                size: 20,  // 제목 폰트 크기
                color: &apos;#2a3f5f&apos;  // 제목 색상
            },
            x: &apos;0.05&apos;,  // 제목을 왼쪽에 배치
            xanchor: &apos;left&apos;,  // 제목이 왼쪽에 정렬되도록
        },
        showlegend: true,
        legend: {
            x: 1,  // 범례 위치 X (오른쪽)
            y: 0.5,  // 범례 위치 Y (중앙)
            orientation: &apos;v&apos;,  // 수직 방향
            font: {
                family: &apos;Arial, sans-serif&apos;,
                size: 14,
                color: &apos;#2a3f5f&apos;
            },
            traceorder: &apos;normal&apos;,
            xanchor: &apos;left&apos;,  // 범례 텍스트 좌측 정렬
            borderwidth: 0
        },
        font: {
            family: &apos;Arial, sans-serif&apos;,  // 차트 폰트
            size: 16,
            color: &apos;#2a3f5f&apos;  // 기본 폰트 색상
        },
        plot_bgcolor: &apos;transparent&apos;,  // 차트 배경 색상
        paper_bgcolor: &apos;white&apos;,  // 종이 배경 색상
        colors:[&apos;#636efa&apos;,&apos;#EF553B&apos;],
        responsive: true
    };

    Plotly.newPlot(&apos;testResultChart&apos;, data, layout);
&lt;/script&gt;


&lt;hr&gt;
&quot;&quot;&quot;

// Total Requests per Thread Group 데이터 준비
def threadGroupNames = threadGroupStats.collect { it.name }
def totalRequestsPerThreadGroup = threadGroupStats.collect { it.totalRequests }
def passRequestsPerThreadGroup = threadGroupStats.collect { it.passCount }
def failRequestsPerThreadGroup = threadGroupStats.collect { it.failCount }

// Total Requests per Thread Group 막대 차트 추가
htmlContent += &quot;&quot;&quot;
&lt;h2&gt;Total Requests per Thread Group&lt;/h2&gt;
&lt;div class=&quot;chart-container&quot; style=&quot;display: flex; justify-content: center; align-items: center; width: 100%; height: 650px;&quot;&gt;
    &lt;div id=&quot;totalRequestsChart&quot; style=&quot;width: 100%; height: 100%;&quot;&gt;&lt;/div&gt;
&lt;/div&gt;

&lt;script charset=&quot;utf-8&quot; src=&quot;https://cdn.plot.ly/plotly-2.35.2.min.js&quot;&gt;&lt;/script&gt;
&lt;script&gt;
    
    var barData = [
    {
        x: ${threadGroupNames.collect { &quot;&apos;${it}&apos;&quot; }},
        y: ${totalRequestsPerThreadGroup},
        type: &apos;bar&apos;,
        text: ${totalRequestsPerThreadGroup},
        name: &apos;TOTAL&apos;,
        textposition: &apos;auto&apos;,
        hovertemplate: &apos;Thread Group = %{label}&lt;br&gt;Count = %{value}&lt;extra&gt;&lt;/extra&gt;&apos;,  // 마우스 오버 시 표시되는 텍스트 형식
        marker: {
            color: &apos;#636efa&apos;,
            line: {
                color: &apos;rgba(58, 71, 80, 1.0)&apos;,
                width: 0
            }
        }
    }
    ];
    
    var barLayout = {
        barmode: &apos;stack&apos;, // 스택형 막대 그래프
        title: {
            text: &apos;Total Requests per Thread Group&apos;,
            font: {
                family: &apos;Arial, sans-serif&apos;,
                size: 20,
                color: &apos;#2a3f5f&apos;
            },
            x: &apos;0.05&apos;,
            xanchor: &apos;left&apos;,
        },
        showlegend: false,
        legend: {
            x: 1,  // 범례 위치 X (오른쪽)
            y: 0.5,  // 범례 위치 Y (중앙)
            orientation: &apos;v&apos;,  // 수직 방향
            font: {
                family: &apos;Arial, sans-serif&apos;,
                size: 14,
                color: &apos;#2a3f5f&apos;
            },
            traceorder: &apos;normal&apos;,
            xanchor: &apos;left&apos;,  // 범례 텍스트 좌측 정렬
            borderwidth: 0
        },
        xaxis: {
            title: &apos;Thread Group&apos;,
            tickangle: 35,
            showgrid: false,
            zeroline: false,
            showline: true,
            linecolor: &apos;rgba(0, 0, 0, 0.2)&apos;,
            tickfont: {
                size: 12,
                color: &apos;rgba(58, 71, 80, 1.0)&apos;
            }
        },
        yaxis: {
            title: &apos;Total Requests&apos;,
            showgrid: true,
            zeroline: true,
            gridcolor: &apos;rgba(200, 200, 200, 0.5)&apos;,
            linecolor: &apos;rgba(0, 0, 0, 0.2)&apos;,
            tickfont: {
                size: 12,
                color: &apos;rgba(58, 71, 80, 1.0)&apos;
            }
        },
        plot_bgcolor: &apos;transparent&apos;,
        paper_bgcolor: &apos;white&apos;,
        responsive: true
    };
    Plotly.newPlot(&apos;totalRequestsChart&apos;, barData, barLayout);
&lt;/script&gt;
&lt;hr&gt;
&quot;&quot;&quot;



// Request-Response Details 섹션 추가
if (csvFiles.isEmpty()) {
    htmlContent += &quot;&lt;h2&gt;No CSV Files Found&lt;/h2&gt;&quot;
} else {
    htmlContent += &quot;&lt;h2&gt;Request-Response Details&lt;/h2&gt;&quot;
    csvFiles.each { csvFile -&gt;
        htmlContent += &quot;&lt;h3&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;${csvFile.getFileName()}&lt;/h3&gt;&quot;
        htmlContent += &quot;&quot;&quot;
        &lt;table&gt;
            &lt;tr&gt;
                &lt;th&gt;#&lt;/th&gt;
                &lt;th&gt;Timestamp&lt;/th&gt;
                &lt;th&gt;Thread Name&lt;/th&gt;
                &lt;th&gt;Thread Group&lt;/th&gt;
                &lt;th&gt;Label&lt;/th&gt;
                &lt;th&gt;Result&lt;/th&gt;
                &lt;th&gt;Response Code&lt;/th&gt;
                &lt;th&gt;Status Code&lt;/th&gt;
                &lt;th&gt;Response Message&lt;/th&gt;
                &lt;th&gt;URL&lt;/th&gt;
                &lt;th&gt;Response Time (ms)&lt;/th&gt;
                &lt;th&gt;Bytes&lt;/th&gt;
                &lt;th&gt;Idle Time&lt;/th&gt;
                &lt;th&gt;Connect&lt;/th&gt;
            &lt;/tr&gt;
        &quot;&quot;&quot;
        def csvData = []
        try {
            Files.lines(csvFile).eachWithIndex { line, index -&gt;
                if (index == 0) return // 헤더 스킵
                csvData.add(line.split(&quot;,&quot;).collect { it.trim() })
            }
            csvData.eachWithIndex { row, index -&gt;
                htmlContent += &quot;&lt;tr&gt;&quot;
                htmlContent += &quot;&lt;td&gt;${index + 1}&lt;/td&gt;&quot; // 인덱스 추가
                row.each { cell -&gt; htmlContent += &quot;&lt;td&gt;${cell}&lt;/td&gt;&quot; }
                htmlContent += &quot;&lt;/tr&gt;&quot;
            }
        } catch (Exception e) {
            log.error(&quot;Failed to read CSV file: ${csvFile}, error: ${e.message}&quot;)
        }
        htmlContent += &quot;&lt;/table&gt;&quot;
    }
}

// 디렉토리 내 Log 파일 처리 및 정렬
def requestLogFiles = Files.list(Paths.get(outputDir))
    .filter { it.toString().endsWith(&quot;request.log&quot;) } // .log 파일만 필터링
    .sorted { a, b -&gt; a.getFileName().toString() &lt;=&gt; b.getFileName().toString() } // 파일 이름으로 정렬
    .collect()

htmlContent += &quot;&lt;hr&gt;&quot;

if (requestLogFiles.isEmpty()) {
    htmlContent += &quot;&lt;h2&gt;No Request Log Files Found&lt;/h2&gt;&quot;
} else {
    htmlContent += &quot;&lt;h2&gt;API Request Data&lt;/h2&gt;&quot;
    requestLogFiles.each { logFile -&gt;
        htmlContent += &quot;&lt;h3&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;:${logFile.getFileName()}&lt;/h3&gt;&quot;
        htmlContent += &quot;&quot;&quot;
        &lt;table&gt;
            &lt;tr&gt;
                &lt;th&gt;#&lt;/th&gt;
                &lt;th&gt;Request Body&lt;/th&gt;
            &lt;/tr&gt;
        &quot;&quot;&quot;
        def requestJsonSlurper = new JsonSlurper()
        def requestDataList = []
        try {
            Files.lines(logFile, StandardCharsets.UTF_8).each { line -&gt;
                try {
                    def requestJsonData = requestJsonSlurper.parseText(line)
                    def requestBody = requestJsonData.requestBody
                    requestDataList.add(requestBody)
                } catch (Exception e) {
                    log.error(&quot;Failed to parse JSON line: ${line}, error: ${e.message}&quot;)
                }
            }
            requestDataList.eachWithIndex { request, index -&gt;
                htmlContent += &quot;&quot;&quot;
                    &lt;tr&gt;
                        &lt;td&gt;${index + 1}&lt;/td&gt;
                        &lt;td style=&quot;text-align: left;&quot;&gt;${escapeHtml(request.toString())}&lt;/td&gt;
                    &lt;/tr&gt;
                &quot;&quot;&quot;
            }
        } catch (Exception e) {
            log.error(&quot;Failed to read log file: ${logFile}, error: ${e.message}&quot;)
        }
        htmlContent += &quot;&lt;/table&gt;&quot;
    }
}

// 디렉토리 내 Log 파일 처리 및 정렬
def logFiles = Files.list(Paths.get(outputDir))
    .filter { it.toString().endsWith(&quot;response.log&quot;) } // .log 파일만 필터링
    .sorted { a, b -&gt; a.getFileName().toString() &lt;=&gt; b.getFileName().toString() } // 파일 이름으로 정렬
    .collect()

htmlContent += &quot;&lt;hr&gt;&quot;

if (logFiles.isEmpty()) {
    htmlContent += &quot;&lt;h2&gt;No Log Files Found&lt;/h2&gt;&quot;
} else {
    htmlContent += &quot;&lt;h2&gt;API Response Data&lt;/h2&gt;&quot;
    logFiles.each { logFile -&gt;
        htmlContent += &quot;&lt;h3&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;:${logFile.getFileName()}&lt;/h3&gt;&quot;
        htmlContent += &quot;&quot;&quot;
        &lt;table&gt;
            &lt;tr&gt;
                &lt;th&gt;#&lt;/th&gt;
                &lt;th&gt;Response Body&lt;/th&gt;
            &lt;/tr&gt;
        &quot;&quot;&quot;
        def jsonSlurper = new JsonSlurper()
        def responseDataList = []
        try {
            Files.lines(logFile, StandardCharsets.UTF_8).each { line -&gt;
                try {
                    def jsonData = jsonSlurper.parseText(line)
                    def responseBody = jsonSlurper.parseText(jsonData.responseBody)
                    responseDataList.add(responseBody)
                } catch (Exception e) {
                    log.error(&quot;Failed to parse JSON line: ${line}, error: ${e.message}&quot;)
                }
            }
            responseDataList.eachWithIndex { response, index -&gt;
                htmlContent += &quot;&quot;&quot;
                    &lt;tr&gt;
                        &lt;td&gt;${index + 1}&lt;/td&gt;
                        &lt;td style=&quot;text-align: left;&quot;&gt;${escapeHtml(response.toString())}&lt;/td&gt;
                    &lt;/tr&gt;
                &quot;&quot;&quot;
            }
        } catch (Exception e) {
            log.error(&quot;Failed to read log file: ${logFile}, error: ${e.message}&quot;)
        }
        htmlContent += &quot;&lt;/table&gt;&quot;
    }
}

htmlContent += &quot;&quot;&quot;
&lt;/body&gt;
&lt;/html&gt;
&quot;&quot;&quot;

// HTML 파일 저장
try {
    Files.write(Paths.get(outputHtmlPath), htmlContent.getBytes(&quot;UTF-8&quot;))
    log.info(&quot;HTML report generated: ${outputHtmlPath}&quot;)
} catch (Exception e) {
    log.error(&quot;Failed to write HTML file: ${outputHtmlPath}, error: ${e.message}&quot;)
}

// 특수 문자 HTML-Escape 함수
def escapeHtml(String input) {
    if (input == null) {
        return &quot;&quot;
    }
    return input.replaceAll(&quot;&lt;&quot;, &quot;&amp;lt;&quot;).replaceAll(&quot;&gt;&quot;, &quot;&amp;gt;&quot;)
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(result)_JSR223 Sampler" enabled="false">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import groovy.json.JsonOutput
import java.text.SimpleDateFormat
import java.nio.file.Paths

// ====== 사용자 정의 설정 ======
def inputFolder = props.get(&quot;outputDir&quot;)
def inputFilename = vars.get(&quot;version&quot;) + &quot;.csv&quot;
def outputFolder = props.get(&quot;outputDir&quot;)
def outputVersion = vars.get(&quot;version&quot;)
def outputFilename = &quot;${outputVersion}_SanityTest1_Result.html&quot;
def inputFile = Paths.get(inputFolder, inputFilename).toString()
def outputFile = Paths.get(outputFolder, outputFilename).toString()

// ====== CSV 파일 읽기 ======
def data = []
def headers = []

try {
    new File(inputFile).withReader { reader -&gt;
        headers = reader.readLine().split(&quot;,&quot;)
        reader.eachLine { line -&gt;
            data.add(line.split(&quot;,&quot;))
        }
    }
} catch (Exception e) {
    log.error(&quot;Error reading input file: ${e.message}&quot;)
    log.error(&quot;Stack trace: &quot;, e)
    return
}

if (data.isEmpty()) {
    log.error(&quot;Data from CSV file is empty.&quot;)
    return
}

// ====== 데이터 전처리 ======
def timeStampIdx = headers.findIndexOf { it == &quot;timeStamp&quot; }
def elapsedIdx = headers.findIndexOf { it == &quot;elapsed&quot; }
def successIdx = headers.findIndexOf { it == &quot;success&quot; }
def threadNameIdx = headers.findIndexOf { it == &quot;threadName&quot; }
def labelIdx = headers.findIndexOf { it == &quot;label&quot; }
def responseCodeIdx = headers.findIndexOf { it == &quot;responseCode&quot; }
def urlIdx = headers.findIndexOf { it == &quot;URL&quot; }

data = data.collect { row -&gt;
    def timeStamp = row[timeStampIdx] ? new Date(row[timeStampIdx].toLong()) : null
    def elapsed = row[elapsedIdx]?.toInteger() ?: 0
    def success = row[successIdx]?.toBoolean() ?: false
    def threadName = row[threadNameIdx]
    def label = row[labelIdx]
    def responseCode = row[responseCodeIdx]
    def url = row[urlIdx]

    return [
        timeStamp: timeStamp,
        elapsed: elapsed,
        success: success,
        threadName: threadName,
        label: label,
        responseCode: responseCode,
        url: url
    ]
}

// ====== 요약 데이터 생성 ======
def threadGroups = data.groupBy { it.threadName }
def thread_group_summary = threadGroups.collect { threadName, rows -&gt;
    if (rows.isEmpty()) {
        log.warn(&quot;Thread group ${threadName} has no data.&quot;)
        return null
    }
    def totalRequests = rows.size()
    def successfulRequests = rows.count { it.success }
    def failedRequests = totalRequests - successfulRequests
    def avgResponseTime = totalRequests &gt; 0 ? String.format(&quot;%.2f&quot;, rows*.elapsed.sum() / totalRequests) : &quot;N/A&quot;
    def maxResponseTime = rows*.elapsed.max() ?: &quot;N/A&quot;
    def minResponseTime = rows*.elapsed.min() ?: &quot;N/A&quot;
    def startTime = rows*.timeStamp.min() ? new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;).format(rows*.timeStamp.min()) : &quot;N/A&quot;
    def endTime = rows*.timeStamp.max() ? new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;).format(rows*.timeStamp.max()) : &quot;N/A&quot;

    // MAX, min 샘플러 이름 추출
    def ThreadMaxResponseTimeSampler = rows.find { it.elapsed == maxResponseTime }?.label ?: &quot;N/A&quot;
    def ThreadMinResponseTimeSampler = rows.find { it.elapsed == minResponseTime }?.label ?: &quot;N/A&quot;

    // Failed Requests 샘플러 이름 리스트 생성
    def failedSamplers = rows.findAll { !it.success }.collect { it.label }

    
    return [
        threadName: threadName,
        totalRequests: totalRequests,
        successfulRequests: successfulRequests,
        failedRequests: failedRequests,
        failedSamplers: failedSamplers,
        avgResponseTime: avgResponseTime,
        maxResponseTime: maxResponseTime,
        ThreadMaxResponseTimeSampler: ThreadMaxResponseTimeSampler,
        minResponseTime: minResponseTime,
        ThreadMinResponseTimeSampler: ThreadMinResponseTimeSampler,
        startTime: startTime,
        endTime: endTime
    ]
}.findAll { it != null }

if (thread_group_summary.isEmpty()) {
    log.error(&quot;No thread group data available after processing.&quot;)
    return
}

def totalRequests = data.size()
def successfulRequests = data.count { it.success }
def failedRequests = totalRequests - successfulRequests
def avgResponseTime = totalRequests &gt; 0 ? String.format(&quot;%.2f&quot;, data*.elapsed.sum() / totalRequests) : &quot;N/A&quot;
def maxResponseTime = data*.elapsed.max() ?: &quot;N/A&quot;
def minResponseTime = data*.elapsed.min() ?: &quot;N/A&quot;

// 전체 데이터에서 최대 응답 시간 샘플러와 최소 응답 시간 샘플러 추출
def maxResponseTimeSampler = data.find { it.elapsed == maxResponseTime }?.label ?: &quot;N/A&quot;
def minResponseTimeSampler = data.find { it.elapsed == minResponseTime }?.label ?: &quot;N/A&quot;

// 전체 실패 샘플러 이름 리스트 생성
def failedSamplersOverall = data.findAll { !it.success }.collect { it.label }

// 전체 성공률과 실패율 계산
def successRate = totalRequests &gt; 0 ? String.format(&quot;%.2f&quot;, (successfulRequests * 100.0 / totalRequests)) : &quot;0.00&quot;
def failureRate = totalRequests &gt; 0 ? String.format(&quot;%.2f&quot;, (failedRequests * 100.0 / totalRequests)) : &quot;0.00&quot;

// 시작 시간과 종료 시간 계산
def startTimeFormatted = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;).format(data*.timeStamp.min())
def endTimeFormatted = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;).format(data*.timeStamp.max())

// ====== 차트 생성 ======
def bar_chart = &quot;&quot;&quot;
&lt;script&gt;
    setTimeout(() =&gt; {
        var data = [{
            x: ${JsonOutput.toJson(thread_group_summary.collect { it.threadName })},
            y: ${JsonOutput.toJson(thread_group_summary.collect { it.avgResponseTime.toDouble() })},
            type: &apos;bar&apos;,
        }];
        var layout = { 
            title: {
                text: &apos;Average Response Time per Thread Group&apos;,
                font: {
                    size: 16,
                    color: &apos;#333&apos;
                },
            },
            autosize: true,
            responsive: true,
            xaxis: {
                title: &apos;Thread Group&apos;,
                titlefont: {
                    size: 13,
                    color: &apos;#333&apos;
                },
                automargin: true
            },
            yaxis: {
                title: &apos;Average Response Time (ms)&apos;,
                titlefont: {
                    size: 13,
                    color: &apos;#333&apos;
                },
                automargin: true
            }
        };
        Plotly.react(&apos;bar-chart&apos;, data, layout);
    }, 50);
&lt;/script&gt;
&quot;&quot;&quot;

def pie_chart = &quot;&quot;&quot;
&lt;script&gt;
    setTimeout(() =&gt; {
	    var data = [{
	        labels: [&apos;Success&apos;, &apos;Failure&apos;],
	        values: [${successfulRequests}, ${failedRequests}],
	        type: &apos;pie&apos;,
	        marker: {
	            colors: [&apos;#4A90E2&apos;, &apos;#D0021B&apos;]  // Success: 파란색, Failure: 빨간색
	        }
	    }];
	    var layout = { 
	        title: {
	            text: &apos;Success vs Failure&apos;,
	            font: {
	                size: 16,
	                color: &apos;#333&apos;
	            },
	        },
	        autosize: true,  // 크기를 자동으로 조정
	        responsive: true,
	        showlegend: true,  // 범례 표시
	        automargin: true,
		   legend: {
			    orientation: &apos;h&apos;,      // 범례를 수평(horizontal)으로 배치
			    x: 0.5,               // 범례를 수평으로 중앙 정렬
			    xanchor: &apos;center&apos;,    // 범례 기준을 중앙으로 설정
			    y: -0.3,              // 범례를 차트 아래로 배치 (엑셀처럼)
			    yanchor: &apos;top&apos;        // 범례의 기준을 상단으로 설정
			},
	    };
	    Plotly.react(&apos;pie-chart&apos;, data, layout);  // 기존 Plotly.newPlot을 Plotly.react로 변경
	}, 50);
&lt;/script&gt;
&quot;&quot;&quot;

def thread_group_chart = &quot;&quot;&quot;
&lt;script&gt;
    setTimeout(() =&gt; {
	    var data = [{
	        x: ${JsonOutput.toJson(thread_group_summary.collect { it.threadName })},
	        y: ${JsonOutput.toJson(thread_group_summary.collect { it.totalRequests })},
	        type: &apos;bar&apos;,
	    }];
	    var layout = { 
	        title: {
	            text: &apos;Total Requests per Thread Group&apos;,
	            font: {
	                size: 16,
	                color: &apos;#333&apos;
	            },
	        },
	        autosize: true,
	        responsive: true,
	        xaxis: {
	            title: &apos;Thread Group&apos;,
	            titlefont: {
	                size: 13,
	                color: &apos;#333&apos;
	            },
			automargin: true
	        },
	        yaxis: {
	            title: &apos;Total Requests&apos;,
	            titlefont: {
	                size: 13,
	                color: &apos;#333&apos;
	            },
			automargin: true
	        }
	    };
	    Plotly.react(&apos;thread-group-chart&apos;, data, layout);
	}, 50);
&lt;/script&gt;
&quot;&quot;&quot;

def request_details_html = data.collect { row -&gt;
    return &quot;&quot;&quot;
    &lt;tr&gt;
        &lt;td&gt;${new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;).format(row.timeStamp)}&lt;/td&gt;
        &lt;td&gt;${row.threadName}&lt;/td&gt;
        &lt;td&gt;${row.label}&lt;/td&gt;
        &lt;td&gt;${row.responseCode}&lt;/td&gt;
        &lt;td&gt;${row.elapsed}&lt;/td&gt;
        &lt;td class=&quot;${row.success ? &apos;PASS&apos; : &apos;FAIL&apos;}&quot;&gt;${row.success ? &apos;PASS&apos; : &apos;FAIL&apos;}&lt;/td&gt;
        &lt;td&gt;${row.url}&lt;/td&gt;
    &lt;/tr&gt;
    &quot;&quot;&quot;
}.join(&quot;&quot;)

// ====== HTML 리포트 생성 ======
def htmlContent = &quot;&quot;&quot;
&lt;!DOCTYPE html&gt;
&lt;html lang=&quot;en&quot;&gt;
&lt;head&gt;
    &lt;meta charset=&quot;UTF-8&quot;&gt;
    &lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no&quot;&gt;
    &lt;title&gt;JMeter SanityTest1 Report&lt;/title&gt;
    &lt;script src=&quot;https://cdn.plot.ly/plotly-latest.min.js&quot;&gt;&lt;/script&gt;
    &lt;style&gt;
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background-color: #f4f4f9;
            padding-left: 5%;
            padding-right: 5%;
            font-size: 16px; /* 기본 폰트 크기 설정 */
        }

        h1, h2 {
            color: #333;
        }

        h1 {
            font-size: 2em;
        }

        h2 {
            font-size: 1.5em;
        }
       .PASS{
           font-weight: bold;
           color: blue;
       }
       .FAIL{
           font-weight: bold;
           color: red;
       }    

        table {
            width: 100%;
            table-layout: fixed;
            border-collapse: collapse;
            margin-top: 20px;
            font-size: 1em;
        }

        th, td {
            padding: 10px;
            text-align: left;
            border: 1px solid #ddd;
            word-wrap: break-word;
            white-space: normal;
        }

        th {
            background-color: #f2f2f2;
        }

        tr:nth-child(even) {
            background-color: #f9f9f9;
        }

	    .chart-container {
	        width: 100%;
	        height: 400px; /* 차트 높이를 고정값으로 설정 */
	        margin-top: 30px;
	        display: flex;
	        justify-content: left;
	        align-items: center;
	    }

		/* 반응형 디자인을 위한 미디어 쿼리 */
		@media (max-width: 1920px) {
		  body {
		      font-size: 14px;
		  }
