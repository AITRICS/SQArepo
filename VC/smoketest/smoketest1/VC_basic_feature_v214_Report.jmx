              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonOutput

// Retrieve variables created by JSON Extractor
def historyIds = []
def i = 1
while (vars.get(&quot;REPORT_HISTORY_ID_&quot; + i) != null) {
    historyIds.add(vars.get(&quot;REPORT_HISTORY_ID_&quot; + i) as Integer)
    i++
}

// Create JSON object in the desired format
def outputJson = [historyIdList: historyIds]

// Convert JSON object to string
def outputJsonString = JsonOutput.toJson(outputJson)

// Store the JSON string in a JMeter variable (if needed)
vars.put(&apos;outputJsonString&apos;, outputJsonString)

// Log the output JSON string (for debugging purposes)
log.info(&apos;Output JSON: &apos; + outputJsonString)
</stringProp>
            </JSR223PreProcessor>
