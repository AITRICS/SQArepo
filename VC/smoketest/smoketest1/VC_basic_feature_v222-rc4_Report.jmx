            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor_RevertStatusEidSet" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">// Save ENCOUNTER_STATUS_ID_* to global props and log the values
(1..5).each { i -&gt;
    def varName = &quot;ENCOUNTER_STATUS_ID_${i}&quot;
    def propName = &quot;REVERT_ENCOUNTER_STATUS_ID_${i}&quot;
    def value = vars.get(varName)
    
    if (value != null) {
        props.put(propName, value)
        log.info(&quot;✅ Stored ${propName} = ${value}&quot;)
    } else {
        log.warn(&quot;⚠️ ${varName} is null, skipping props.put()&quot;)
    }
}
</stringProp>
            </JSR223PostProcessor>
