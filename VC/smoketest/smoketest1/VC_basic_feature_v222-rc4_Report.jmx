          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">// Get the original value from the variable
String rawDate = vars.get(&quot;MAES_TRIGGER_DATE&quot;)

// Check if the value is not null and contains &apos;T&apos;
if (rawDate != null &amp;&amp; rawDate.contains(&quot;T&quot;)) {
    // Replace &apos;T&apos; with a space to format as &quot;yyyy-MM-dd HH:mm:ss&quot;
    String formattedDate = rawDate.replace(&apos;T&apos;, &apos; &apos;)
    
    // Store the formatted date into a new variable
    vars.put(&quot;MAES_TRIGGER_DATE_FORMATTED&quot;, formattedDate)
} else {
    // If &apos;T&apos; is not found or value is null, store the original value
    vars.put(&quot;MAES_TRIGGER_DATE_FORMATTED&quot;, rawDate)
}
</stringProp>
            </JSR223PreProcessor>
