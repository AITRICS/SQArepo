        <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter
import java.nio.charset.StandardCharsets
import groovy.json.JsonSlurper
import groovy.json.JsonBuilder
import org.apache.commons.lang3.StringEscapeUtils

// Safe file write (retry up to 5 times)
public void safeWrite(Path path, byte[] data, List&lt;OpenOption&gt; options) {
    int maxRetry = 5
    int delayMs = 100
    int attempt = 0
    while (true) {
        try {
            Files.write(path, data, options as OpenOption[])
            break
        } catch (FileSystemException e) {
            if (++attempt &gt;= maxRetry) throw e
            Thread.sleep(delayMs)
        }
    }
}

// Safe file read (retry up to 5 times)
public byte[] safeReadAllBytes(Path path) {
    int maxRetry = 5
    int delayMs = 100
    int attempt = 0
    while (true) {
        try {
            return Files.readAllBytes(path)
        } catch (FileSystemException e) {
            if (++attempt &gt;= maxRetry) throw e
            Thread.sleep(delayMs)
        }
    }
}

// 응답 데이터 가져오기
def response = prev.getResponseDataAsString()

// 요청 데이터 가져오기
def request = prev.getSamplerData() // 요청 데이터를 가져오는 메서드

// JSON 파싱 (조건부로 시도)
def jsonRequest
try {
    jsonRequest = new JsonSlurper().parseText(request) // 요청 데이터가 JSON일 경우 파싱
} catch (Exception e) {
    // 요청 데이터가 JSON이 아니면, 그대로 문자열로 처리
    jsonRequest = request
}

def jsonResponse
try {
    jsonResponse = new JsonSlurper().parseText(response) // 응답 데이터가 JSON일 경우 파싱
} catch (Exception e) {
    // 응답 데이터가 JSON이 아니면, 그대로 문자열로 처리
    jsonResponse = response
}

// 필요한 변수 정의
def outputDir = props.get(&quot;outputDir&quot;)
def samplerName = ctx.getCurrentSampler().getName()
def threadName = prev.getThreadName() // 스레드 이름
def timestamp = prev.getTimeStamp() // 타임스탬프
def resultFile = Paths.get(outputDir, vars.get(&quot;version&quot;) + &quot;.csv&quot;)
def now = LocalDateTime.now().format(DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd HH:mm:ss&quot;))

// 폴더 생성
if (!Files.exists(Paths.get(outputDir))) {
    Files.createDirectories(Paths.get(outputDir))
}

// Test 결과 데이터 수집
def testResult = (prev.isSuccessful()) ? &quot;PASS&quot; : &quot;FAIL&quot; // 성공 여부
def elapsed = prev.getTime() // 경과 시간
def label = prev.getSampleLabel() // 샘플러 이름
def responseCode = prev.getResponseCode() // 응답 코드
def responseMessage = prev.getResponseMessage() // 응답 메시지
def dataType = prev.getDataType() // 데이터 유형
def success = prev.isSuccessful() // 성공 여부
def failureMessage = success ? &quot;&quot; : &quot;Request failed: ${prev.getResponseMessage()}&quot; // 실패 메시지
def bytes = prev.getBytesAsLong() // 응답 바이트 크기
def sentBytes = prev.getSentBytes() // 요청 바이트 크기
def grpThreads = prev.getGroupThreads() // 그룹 스레드 수
def allThreads = prev.getAllThreads() // 전체 스레드 수
def URL = ctx.getCurrentSampler().getUrl()?.toString() ?: &quot;&quot; // 요청 URL
def latency = prev.getLatency() // 지연 시간
def idleTime = prev.getIdleTime() // 대기 시간
def connectTime = prev.getConnectTime() // 연결 시간

// 요청과 응답 데이터를 포함하는 JSON 객체 생성
def requestJson = [
    &quot;timestamp&quot;: timestamp,
    &quot;threadName&quot;: threadName,
    &quot;samplerName&quot;: samplerName,
    &quot;body&quot;: request
]

def responseJson = [
    &quot;timestamp&quot;: timestamp,
    &quot;threadName&quot;: threadName,
    &quot;samplerName&quot;: samplerName,
    &quot;body&quot;: response
]

// 파일 이름 정의
def requestFile = Paths.get(outputDir, &quot;request_${vars.get(&quot;version&quot;)}.json&quot;)
def responseFile = Paths.get(outputDir, &quot;response_${vars.get(&quot;version&quot;)}.json&quot;)

// 파일에 JSON 배열로 데이터를 저장하는 함수
def appendToJsonArray(file, jsonObject) {
    if (!Files.exists(file)) {
        // 파일이 없으면 새로 만들고 배열 형태로 초기화
        def initialContent = new JsonBuilder([jsonObject]).toPrettyString()
        safeWrite(file, initialContent.getBytes(StandardCharsets.UTF_8), [StandardOpenOption.CREATE])
    } else {
        // 파일이 존재하면 기존 내용을 읽고 배열에 추가
        def existingContent = new String(safeReadAllBytes(file), StandardCharsets.UTF_8).trim()
        def jsonArray = existingContent ? new JsonSlurper().parseText(existingContent) : []
        if (!(jsonArray instanceof List)) {
            throw new IllegalStateException(&quot;File content is not a JSON array: ${file}&quot;)
        }
        jsonArray &lt;&lt; jsonObject
        def updatedContent = new JsonBuilder(jsonArray).toPrettyString()
        safeWrite(file, updatedContent.getBytes(StandardCharsets.UTF_8), [StandardOpenOption.TRUNCATE_EXISTING])
    }
}

// 요청 및 응답 데이터를 파일에 추가
appendToJsonArray(requestFile, requestJson)
appendToJsonArray(responseFile, responseJson)

// CSV 헤더 작성
def csvHeader = &quot;timeStamp,elapsed,label,responseCode,responseMessage,threadName,dataType,success,failureMessage,bytes,sentBytes,grpThreads,allThreads,URL,Latency,IdleTime,Connect,requestFile,responseFile\n&quot;
if (!Files.exists(resultFile)) {
    safeWrite(resultFile, csvHeader.getBytes(StandardCharsets.UTF_8), [StandardOpenOption.CREATE])
}

// CSV 데이터 작성 (requestFile과 responseFile 경로 추가)
def csvData = &quot;${timestamp},${elapsed},${label},${responseCode},${responseMessage},${threadName},${dataType},${success},${failureMessage},${bytes},${sentBytes},${grpThreads},${allThreads},${URL},${latency},${idleTime},${connectTime},\&quot;${requestFile}\&quot;,\&quot;${responseFile}\&quot;\n&quot;
safeWrite(resultFile, csvData.getBytes(StandardCharsets.UTF_8), [StandardOpenOption.APPEND])
</stringProp>
        </JSR223PostProcessor>
