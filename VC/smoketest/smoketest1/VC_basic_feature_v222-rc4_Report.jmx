calendar.setTimeInMillis(timestampDefault); // Set the default timestamp    

long timestamp_today = calendar.getTimeInMillis();

Date today = new Date(timestampDefault);

SimpleDateFormat sdf_time = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;);
sdf_time.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

