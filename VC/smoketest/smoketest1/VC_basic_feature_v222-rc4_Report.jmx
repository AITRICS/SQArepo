import java.util.TimeZone;
import java.util.Calendar;

long timestampDefault = ${timestamp_default};

//Set Date
Calendar calendar = Calendar.getInstance();
calendar.setTimeInMillis(timestampDefault); // Set the default timestamp    

long timestamp_today = calendar.getTimeInMillis();

Date today = new Date(timestampDefault);

SimpleDateFormat sdf_time = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;);
sdf_time.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

String today_string = sdf_time.format(today);

// Assuming vars is a map
vars.put(&quot;error_logging_today&quot;, today_string);</stringProp>
            </JSR223PreProcessor>
