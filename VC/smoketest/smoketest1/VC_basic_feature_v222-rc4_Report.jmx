            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonOutput

// Get the JSON response data
def response = prev.getResponseDataAsString()
def jsonResponse = new JsonSlurper().parseText(response)

// Initialize the results list
def results = []
// Define a function to process the data
def processData = { data -&gt;
    data.each { item -&gt;
        // Exclude subcategories that contain &quot;INITIAL&quot;
        if (!(item.subcategory =~ /INITIAL/)) {
            results &lt;&lt; [subcategory: item.subcategory, min: item.min, max: item.max]
        }
    }
}

// Process &apos;vitals&apos;, &apos;labs&apos;, &apos;consciousness&apos; data
if (jsonResponse.data?.vitals) {
    processData(jsonResponse.data.vitals)
}
if (jsonResponse.data?.labs) {
    processData(jsonResponse.data.labs)
}
if (jsonResponse.data?.consciousness) {
    processData(jsonResponse.data.consciousness)
}

// Convert to JSON
def jsonOutput = JsonOutput.toJson(results)
vars.put(&quot;Default_Outlier&quot;, jsonOutput)
</stringProp>
            </JSR223PostProcessor>
