        <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter
import java.nio.charset.StandardCharsets
import groovy.json.JsonSlurper
import groovy.json.JsonBuilder
import org.apache.commons.lang3.StringEscapeUtils

// Safe file write (retry up to 5 times)
public void safeWrite(Path path, byte[] data, List&lt;OpenOption&gt; options) {
    int maxRetry = 5
    int delayMs = 100
    int attempt = 0
    while (true) {
        try {
            Files.write(path, data, options as OpenOption[])
            break
        } catch (FileSystemException e) {
            if (++attempt &gt;= maxRetry) throw e
            Thread.sleep(delayMs)
        }
    }
}

// Safe file read (retry up to 5 times)
public byte[] safeReadAllBytes(Path path) {
    int maxRetry = 5
    int delayMs = 100
    int attempt = 0
    while (true) {
        try {
            return Files.readAllBytes(path)
        } catch (FileSystemException e) {
            if (++attempt &gt;= maxRetry) throw e
            Thread.sleep(delayMs)
        }
    }
}

// 응답 데이터 가져오기
def response = prev.getResponseDataAsString()

// 요청 데이터 가져오기
def request = prev.getSamplerData() // 요청 데이터를 가져오는 메서드

// JSON 파싱 (조건부로 시도)
def jsonRequest
try {
    jsonRequest = new JsonSlurper().parseText(request) // 요청 데이터가 JSON일 경우 파싱
} catch (Exception e) {
    // 요청 데이터가 JSON이 아니면, 그대로 문자열로 처리
    jsonRequest = request
}

def jsonResponse
try {
    jsonResponse = new JsonSlurper().parseText(response) // 응답 데이터가 JSON일 경우 파싱
} catch (Exception e) {
    // 응답 데이터가 JSON이 아니면, 그대로 문자열로 처리
    jsonResponse = response
}

// 필요한 변수 정의
def outputDir = props.get(&quot;outputDir&quot;)
def samplerName = ctx.getCurrentSampler().getName()
def threadName = prev.getThreadName() // 스레드 이름
def timestamp = prev.getTimeStamp() // 타임스탬프
def resultFile = Paths.get(outputDir, vars.get(&quot;version&quot;) + &quot;.csv&quot;)
def now = LocalDateTime.now().format(DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd HH:mm:ss&quot;))

// 폴더 생성
if (!Files.exists(Paths.get(outputDir))) {
    Files.createDirectories(Paths.get(outputDir))
}

// Test 결과 데이터 수집
def testResult = (prev.isSuccessful()) ? &quot;PASS&quot; : &quot;FAIL&quot; // 성공 여부
def elapsed = prev.getTime() // 경과 시간
def label = prev.getSampleLabel() // 샘플러 이름
def responseCode = prev.getResponseCode() // 응답 코드
def responseMessage = prev.getResponseMessage() // 응답 메시지
def dataType = prev.getDataType() // 데이터 유형
def success = prev.isSuccessful() // 성공 여부
def failureMessage = success ? &quot;&quot; : &quot;Request failed: ${prev.getResponseMessage()}&quot; // 실패 메시지
def bytes = prev.getBytesAsLong() // 응답 바이트 크기
def sentBytes = prev.getSentBytes() // 요청 바이트 크기
def grpThreads = prev.getGroupThreads() // 그룹 스레드 수
def allThreads = prev.getAllThreads() // 전체 스레드 수
def URL = ctx.getCurrentSampler().getUrl()?.toString() ?: &quot;&quot; // 요청 URL
def latency = prev.getLatency() // 지연 시간
def idleTime = prev.getIdleTime() // 대기 시간
def connectTime = prev.getConnectTime() // 연결 시간

// 요청과 응답 데이터를 포함하는 JSON 객체 생성
def requestJson = [
    &quot;timestamp&quot;: timestamp,
    &quot;threadName&quot;: threadName,
    &quot;samplerName&quot;: samplerName,
    &quot;body&quot;: request
]

def responseJson = [
    &quot;timestamp&quot;: timestamp,
    &quot;threadName&quot;: threadName,
    &quot;samplerName&quot;: samplerName,
    &quot;body&quot;: response
]

// 파일 이름 정의
def requestFile = Paths.get(outputDir, &quot;request_${vars.get(&quot;version&quot;)}.json&quot;)
def responseFile = Paths.get(outputDir, &quot;response_${vars.get(&quot;version&quot;)}.json&quot;)

// 파일에 JSON 배열로 데이터를 저장하는 함수
def appendToJsonArray(file, jsonObject) {
    if (!Files.exists(file)) {
        // 파일이 없으면 새로 만들고 배열 형태로 초기화
        def initialContent = new JsonBuilder([jsonObject]).toPrettyString()
        safeWrite(file, initialContent.getBytes(StandardCharsets.UTF_8), [StandardOpenOption.CREATE])
    } else {
        // 파일이 존재하면 기존 내용을 읽고 배열에 추가
        def existingContent = new String(safeReadAllBytes(file), StandardCharsets.UTF_8).trim()
        def jsonArray = existingContent ? new JsonSlurper().parseText(existingContent) : []
        if (!(jsonArray instanceof List)) {
            throw new IllegalStateException(&quot;File content is not a JSON array: ${file}&quot;)
        }
        jsonArray &lt;&lt; jsonObject
        def updatedContent = new JsonBuilder(jsonArray).toPrettyString()
        safeWrite(file, updatedContent.getBytes(StandardCharsets.UTF_8), [StandardOpenOption.TRUNCATE_EXISTING])
    }
}

// 요청 및 응답 데이터를 파일에 추가
appendToJsonArray(requestFile, requestJson)
appendToJsonArray(responseFile, responseJson)

// CSV 헤더 작성
def csvHeader = &quot;timeStamp,elapsed,label,responseCode,responseMessage,threadName,dataType,success,failureMessage,bytes,sentBytes,grpThreads,allThreads,URL,Latency,IdleTime,Connect,requestFile,responseFile\n&quot;
if (!Files.exists(resultFile)) {
    safeWrite(resultFile, csvHeader.getBytes(StandardCharsets.UTF_8), [StandardOpenOption.CREATE])
}

// CSV 데이터 작성 (requestFile과 responseFile 경로 추가)
def csvData = &quot;${timestamp},${elapsed},${label},${responseCode},${responseMessage},${threadName},${dataType},${success},${failureMessage},${bytes},${sentBytes},${grpThreads},${allThreads},${URL},${latency},${idleTime},${connectTime},\&quot;${requestFile}\&quot;,\&quot;${responseFile}\&quot;\n&quot;
safeWrite(resultFile, csvData.getBytes(StandardCharsets.UTF_8), [StandardOpenOption.APPEND])
</stringProp>
        </JSR223PostProcessor>
        <hashTree/>
      </hashTree>
      <PostThreadGroup guiclass="PostThreadGroupGui" testclass="PostThreadGroup" testname="tearDown Thread Group" enabled="true">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </PostThreadGroup>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(result)_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import groovy.json.JsonOutput
import java.text.SimpleDateFormat
import java.nio.file.Paths

// ====== 사용자 정의 설정 ======
def inputFolder = props.get(&quot;outputDir&quot;)
def inputFilename = vars.get(&quot;version&quot;) + &quot;.csv&quot;
def outputFolder = props.get(&quot;outputDir&quot;)
def outputVersion = vars.get(&quot;version&quot;)
def outputFilename = &quot;${outputVersion}_SmokeTest1_Result.html&quot;
def inputFile = Paths.get(inputFolder, inputFilename).toString()
def outputFile = Paths.get(outputFolder, outputFilename).toString()

// ====== CSV 파일 읽기 ======
def data = []
def headers = []

try {
    new File(inputFile).withReader { reader -&gt;
        headers = reader.readLine().split(&quot;,&quot;)
        reader.eachLine { line -&gt;
            data.add(line.split(&quot;,&quot;))
        }
    }
} catch (Exception e) {
    log.error(&quot;Error reading input file: ${e.message}&quot;)
    log.error(&quot;Stack trace: &quot;, e)
    return
}

if (data.isEmpty()) {
    log.error(&quot;Data from CSV file is empty.&quot;)
    return
}

// ====== 데이터 전처리 ======
def timeStampIdx = headers.findIndexOf { it == &quot;timeStamp&quot; }
def elapsedIdx = headers.findIndexOf { it == &quot;elapsed&quot; }
def successIdx = headers.findIndexOf { it == &quot;success&quot; }
def threadNameIdx = headers.findIndexOf { it == &quot;threadName&quot; }
def labelIdx = headers.findIndexOf { it == &quot;label&quot; }
def responseCodeIdx = headers.findIndexOf { it == &quot;responseCode&quot; }
def urlIdx = headers.findIndexOf { it == &quot;URL&quot; }

data = data.collect { row -&gt;
    def timeStamp = row[timeStampIdx] ? new Date(row[timeStampIdx].toLong()) : null
    def elapsed = row[elapsedIdx]?.toInteger() ?: 0
    def success = row[successIdx]?.toBoolean() ?: false
    def threadName = row[threadNameIdx]
    def label = row[labelIdx]
    def responseCode = row[responseCodeIdx]
    def url = row[urlIdx]

    return [
        timeStamp: timeStamp,
        elapsed: elapsed,
        success: success,
        threadName: threadName,
        label: label,
        responseCode: responseCode,
        url: url
    ]
}

// ====== 요약 데이터 생성 ======
def threadGroups = data.groupBy { it.threadName }
def thread_group_summary = threadGroups.collect { threadName, rows -&gt;
    if (rows.isEmpty()) {
        log.warn(&quot;Thread group ${threadName} has no data.&quot;)
        return null
    }
    def totalRequests = rows.size()
    def successfulRequests = rows.count { it.success }
    def failedRequests = totalRequests - successfulRequests
    def avgResponseTime = totalRequests &gt; 0 ? String.format(&quot;%.2f&quot;, rows*.elapsed.sum() / totalRequests) : &quot;N/A&quot;
    def maxResponseTime = rows*.elapsed.max() ?: &quot;N/A&quot;
    def minResponseTime = rows*.elapsed.min() ?: &quot;N/A&quot;
    def startTime = rows*.timeStamp.min() ? new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;).format(rows*.timeStamp.min()) : &quot;N/A&quot;
    def endTime = rows*.timeStamp.max() ? new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;).format(rows*.timeStamp.max()) : &quot;N/A&quot;

    // MAX, min 샘플러 이름 추출
    def ThreadMaxResponseTimeSampler = rows.find { it.elapsed == maxResponseTime }?.label ?: &quot;N/A&quot;
    def ThreadMinResponseTimeSampler = rows.find { it.elapsed == minResponseTime }?.label ?: &quot;N/A&quot;

    // Failed Requests 샘플러 이름 리스트 생성
    def failedSamplers = rows.findAll { !it.success }.collect { it.label }

    return [
        threadName: threadName,
        totalRequests: totalRequests,
        successfulRequests: successfulRequests,
        failedRequests: failedRequests,
        failedSamplers: failedSamplers,
        avgResponseTime: avgResponseTime,
        maxResponseTime: maxResponseTime,
        ThreadMaxResponseTimeSampler: ThreadMaxResponseTimeSampler,
        minResponseTime: minResponseTime,
        ThreadMinResponseTimeSampler: ThreadMinResponseTimeSampler,
        startTime: startTime,
        endTime: endTime
    ]
}.findAll { it != null }

if (thread_group_summary.isEmpty()) {
    log.error(&quot;No thread group data available after processing.&quot;)
    return
}

def totalRequests = data.size()
def successfulRequests = data.count { it.success }
def failedRequests = totalRequests - successfulRequests
def avgResponseTime = totalRequests &gt; 0 ? String.format(&quot;%.2f&quot;, data*.elapsed.sum() / totalRequests) : &quot;N/A&quot;
def maxResponseTime = data*.elapsed.max() ?: &quot;N/A&quot;
def minResponseTime = data*.elapsed.min() ?: &quot;N/A&quot;

// 전체 데이터에서 최대 응답 시간 샘플러와 최소 응답 시간 샘플러 추출
def maxResponseTimeSampler = data.find { it.elapsed == maxResponseTime }?.label ?: &quot;N/A&quot;
def minResponseTimeSampler = data.find { it.elapsed == minResponseTime }?.label ?: &quot;N/A&quot;

// 전체 실패 샘플러 이름 리스트 생성
def failedSamplersOverall = data.findAll { !it.success }.collect { it.label }

// 전체 성공률과 실패율 계산
def successRate = totalRequests &gt; 0 ? String.format(&quot;%.2f&quot;, (successfulRequests * 100.0 / totalRequests)) : &quot;0.00&quot;
def failureRate = totalRequests &gt; 0 ? String.format(&quot;%.2f&quot;, (failedRequests * 100.0 / totalRequests)) : &quot;0.00&quot;

// 시작 시간과 종료 시간 계산
def startTimeFormatted = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;).format(data*.timeStamp.min())
def endTimeFormatted = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;).format(data*.timeStamp.max())

// ====== 차트 생성 ======
def bar_chart = &quot;&quot;&quot;
&lt;script&gt;
    window.addEventListener(&apos;load&apos;, function() {
        setTimeout(function() {
            var ctxBar = document.getElementById(&apos;bar-chart&apos;).getContext(&apos;2d&apos;);
            if (ctxBar) {
                new Chart(ctxBar, {
                    type: &apos;bar&apos;,
                    data: {
                        labels: ${JsonOutput.toJson(thread_group_summary.collect { it.threadName })},
                        datasets: [{
                            label: &apos;Average Response Time per Thread Group&apos;,
                            data: ${JsonOutput.toJson(thread_group_summary.collect { it.avgResponseTime.toDouble() })},
                            backgroundColor: &apos;#4A90E2&apos;,
                            borderColor: &apos;#4A90E2&apos;,
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            x: {
                                title: {
                                    display: true,
                                    text: &apos;Thread Group&apos;
                                }
                            },
                            y: {
                                title: {
                                    display: true,
                                    text: &apos;Average Response Time (ms)&apos;
                                }
                            }
                        }
                    }
                });
            } else {
                console.error(&quot;Canvas element with id &apos;bar-chart&apos; not found!&quot;);
            }
        }, 100);  // 100ms 지연 후 차트 생성
    });
&lt;/script&gt;
&quot;&quot;&quot;

def pie_chart = &quot;&quot;&quot;
&lt;script&gt;
    window.addEventListener(&apos;load&apos;, function() {
        setTimeout(function() {
            var ctxPie = document.getElementById(&apos;pie-chart&apos;).getContext(&apos;2d&apos;);
            if (ctxPie) {
                new Chart(ctxPie, {
                    type: &apos;pie&apos;,
                    data: {
                        labels: [&apos;Success&apos;, &apos;Failure&apos;], // 성공 및 실패
                        datasets: [{
                            data: [${successfulRequests}, ${failedRequests}], // 요청 수 데이터
                            backgroundColor: [&apos;#4A90E2&apos;, &apos;#D0021B&apos;]
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: &apos;bottom&apos;,
                                labels: {
                                    font: {
                                        size: 14
                                    },
                                    generateLabels: function(chart) {
                                        var labels = chart.data.labels;
                                        var dataValues = chart.data.datasets[0].data;
                                        var total = dataValues.reduce(function(sum, value) {
                                            return sum + value;
                                        }, 0);
                                        
                                        return labels.map(function(label, index) {
                                            var currentValue = dataValues[index];
                                            var percentage = ((currentValue / total) * 100).toFixed(2);
                                            return {
                                                text: label + &apos; (&apos; + currentValue + &apos;, &apos; + percentage + &apos;%)&apos;,
                                                fillStyle: chart.data.datasets[0].backgroundColor[index]
                                            };
                                        });
                                    }
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(tooltipItem) {
                                        var dataValues = tooltipItem.chart.data.datasets[0].data;
                                        var total = dataValues.reduce((sum, val) =&gt; sum + val, 0);
                                        var currentValue = dataValues[tooltipItem.dataIndex];
                                        var percentage = ((currentValue / total) * 100).toFixed(2);
                                        return currentValue + &apos; (&apos; + percentage + &apos;%)&apos;;
                                    }
                                }
                            }
                        }
                    }
                });
            }
        }, 100);  // 100ms 지연 후 차트 생성
    });
&lt;/script&gt;
&quot;&quot;&quot;

def thread_group_chart = &quot;&quot;&quot;
&lt;script&gt;
    window.addEventListener(&apos;load&apos;, function() {
        setTimeout(function() {
            var ctxThreadGroup = document.getElementById(&apos;thread-group-chart&apos;).getContext(&apos;2d&apos;);
            
            new Chart(ctxThreadGroup, {
                type: &apos;bar&apos;,
                data: {
                    labels: ${JsonOutput.toJson(thread_group_summary.collect { it.threadName })}, // 쓰레드 그룹 이름
                    datasets: [{
                        label: &apos;Total Requests per Thread Group&apos;,
                        data: ${JsonOutput.toJson(thread_group_summary.collect { it.totalRequests })}, // 요청 수
                        backgroundColor: &apos;#4A90E2&apos;, // 바의 색상
                        borderColor: &apos;#4A90E2&apos;, // 바의 테두리 색상
                        borderWidth: 1 // 테두리 두께
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            title: {
                                display: true, // x축 타이틀을 표시
                                text: &apos;Thread Group&apos; // x축 타이틀
                            }
                        },
                        y: {
                            title: {
                                display: true, // y축 타이틀을 표시
                                text: &apos;Total Requests&apos; // y축 타이틀
                            },
                            beginAtZero: true // y축 값이 0에서 시작하도록 설정
                        }
                    }
                }
            });
        }, 100);  // 100ms 지연 후 차트 생성
    });
&lt;/script&gt;
&quot;&quot;&quot;

def request_details_html = data.collect { row -&gt;
    return &quot;&quot;&quot;
    &lt;tr&gt;
        &lt;td&gt;${new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;).format(row.timeStamp)}&lt;/td&gt;
        &lt;td&gt;${row.threadName}&lt;/td&gt;
        &lt;td&gt;${row.label}&lt;/td&gt;
        &lt;td&gt;${row.responseCode}&lt;/td&gt;
        &lt;td&gt;${row.elapsed}&lt;/td&gt;
        &lt;td class=&quot;${row.success ? &apos;PASS&apos; : &apos;FAIL&apos;}&quot;&gt;${row.success ? &apos;PASS&apos; : &apos;FAIL&apos;}&lt;/td&gt;
        &lt;td&gt;${row.url}&lt;/td&gt;
    &lt;/tr&gt;
    &quot;&quot;&quot;
}.join(&quot;&quot;)

// ====== HTML 리포트 생성 ======
def htmlContent = &quot;&quot;&quot;
&lt;!DOCTYPE html&gt;
&lt;html lang=&quot;en&quot;&gt;
&lt;head&gt;
    &lt;meta charset=&quot;UTF-8&quot;&gt;
    &lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no&quot;&gt;
    &lt;title&gt;JMeter SmokeTest1 Report&lt;/title&gt;
    &lt;script src=&quot;https://cdn.jsdelivr.net/npm/chart.js&quot;&gt;&lt;/script&gt;
    &lt;style&gt;
		body {
		  font-family: Arial, sans-serif;
		  margin: 20px;
		  background-color: #f4f4f9;
		  padding-left: 5%;
		  padding-right: 5%;
		  font-size: 16px; /* 기본 폰트 크기 설정 */
		}
		
		h1, h2 {
		  color: #333;
		}
		
		h1 {
		  font-size: 2em;
		}
		
		h2 {
		  font-size: 1.5em;
		}
		.PASS{
		 font-weight: bold;
		 color: blue;
		}
		.FAIL{
		 font-weight: bold;
		 color: red;
		}    
		
		table {
		  width: 100%;
		  table-layout: fixed;
		  border-collapse: collapse;
		  margin-top: 20px;
		  font-size: 1em;
		}
		
		th, td {
		  padding: 10px;
		  text-align: left;
		  border: 1px solid #ddd;
		  word-wrap: break-word;
		  white-space: normal;
		}
		
		th {
		  background-color: #f2f2f2;
		}
		
		tr:nth-child(even) {
		  background-color: #f9f9f9;
		}
		
		.chart-container {
		    width: 100%; /* 부모 컨테이너 너비에 맞춤 */
		    height: 35vh; /* 높이를 화면 높이의 70%로 설정 */
		    margin: 0 auto;
		    display: flex;
		    justify-content: center;
		    align-items: center;
		    position: relative; /* 캔버스 위치를 조정하기 위한 설정 */
		}

		canvas {
		    display: block; /* 캔버스의 기본 여백 제거 */
		    width: 100% !important; /* 부모 컨테이너 너비를 완전히 채움 */
		    height: 100% !important; /* 부모 컨테이너 높이를 완전히 채움 */
		}

		/* 반응형 디자인을 위한 미디어 쿼리 */
		@media (max-width: 1920px) {
			body {
			 font-size: 14px;
			}
			h1 {
			 font-size: 1.8em;
			}
			h2 {
			 font-size: 1.4em;
			}
			table {
			 font-size: 0.9em;
			}
		}
		
		@media (max-width: 1024px) {
			body {
			 font-size: 12px;
			}
			h1 {
			 font-size: 1.6em;
			}
			h2 {
			 font-size: 1.3em;
			}
			table {
			 font-size: 0.8em;
			}
		}
		
		@media (max-width: 960px) {
			body {
			 font-size: 10px;
			}
			h1 {
			 font-size: 1.4em;
			}
			h2 {
			 font-size: 1.2em;
			}
			table {
			 font-size: 0.7em;
			}
		}

		@media print {
			.chart-container {
			  width: 100%; /* 차트가 용지 폭에 맞게 조정 */
			  height: auto; /* 높이는 자동으로 조정 */
			  page-break-inside: avoid;
			}
			
			body {
			  font-size: 10px; /* 인쇄용 폰트 크기 조정 */
			}
			
			h1, h2 {
			  font-size: 1.2em; /* 헤더 크기 조정 */
			}
			h3 {
			   page-break-after: avoid;
			   page-break-before: avoid;
			}	
			table {
			  font-size: 0.8em; /* 테이블 폰트 크기 조정 */
			}
		}
    &lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;
    &lt;h1&gt;JMeter SmokeTest1 Report&lt;/h1&gt;
    &lt;h2&gt;Overall Summary&lt;/h2&gt;
    &lt;ul&gt;
        &lt;li&gt;Total Requests: ${totalRequests}&lt;/li&gt;
        &lt;li&gt;Successful Requests: ${successfulRequests} (${successRate}%)&lt;/li&gt;
        &lt;li&gt;Failed Requests: ${failedRequests} (${failureRate}%)
            ${failedRequests &gt; 0 ? &quot;&lt;ul&gt;&quot; + failedSamplersOverall.collect { &quot;&lt;li&gt;${it}&lt;/li&gt;&quot; }.join(&quot;&quot;) + &quot;&lt;/ul&gt;&quot; : &quot;&quot;}
        &lt;/li&gt;
        &lt;li&gt;Average Response Time: ${avgResponseTime} ms&lt;/li&gt;
        &lt;li&gt;Max Response Time: ${maxResponseTime} ms (Sampler: ${maxResponseTimeSampler})&lt;/li&gt;
        &lt;li&gt;Min Response Time: ${minResponseTime} ms (Sampler: ${minResponseTimeSampler})&lt;/li&gt;
        &lt;li&gt;Start Time: ${startTimeFormatted}&lt;/li&gt;
        &lt;li&gt;End Time: ${endTimeFormatted}&lt;/li&gt;
    &lt;/ul&gt;

    &lt;h2&gt;Thread Group Summary&lt;/h2&gt;
    &lt;table&gt;
        &lt;thead&gt;
            &lt;tr&gt;
                &lt;th&gt;Thread Group&lt;/th&gt;
                &lt;th&gt;Total Requests&lt;/th&gt;
                &lt;th&gt;Successful Requests&lt;/th&gt;
                &lt;th&gt;Failed Requests&lt;/th&gt;
                &lt;th&gt;Average Response Time&lt;/th&gt;
                &lt;th&gt;Max Response Time&lt;/th&gt;
                &lt;th&gt;Min Response Time&lt;/th&gt;
                &lt;th&gt;Start Time&lt;/th&gt;
                &lt;th&gt;End Time&lt;/th&gt;
            &lt;/tr&gt;
        &lt;/thead&gt;
		&lt;tbody&gt;
		    ${thread_group_summary.collect { &quot;&quot;&quot;
		        &lt;tr&gt;
		            &lt;td&gt;${it.threadName}&lt;/td&gt;
		            &lt;td&gt;${it.totalRequests}&lt;/td&gt;
		            &lt;td&gt;${it.successfulRequests}&lt;/td&gt;
		            &lt;td&gt;
		                ${it.failedRequests &gt; 0 ? &quot;&quot;&quot;
		                    ${it.failedRequests} &lt;br&gt; 
		                    ${it.failedSamplers.join(&quot;&lt;br&gt;&quot;)}
		                &quot;&quot;&quot; : it.failedRequests}
		            &lt;/td&gt;
		            &lt;td&gt;${it.avgResponseTime} ms&lt;/td&gt;
		            &lt;td&gt;
		                ${it.maxResponseTime} ms &lt;br&gt; 
		                (${it.ThreadMaxResponseTimeSampler})
		            &lt;/td&gt;
		            &lt;td&gt;
		                ${it.minResponseTime} ms &lt;br&gt; 
		                (${it.ThreadMinResponseTimeSampler})
		            &lt;/td&gt;
		            &lt;td&gt;${it.startTime}&lt;/td&gt;
		            &lt;td&gt;${it.endTime}&lt;/td&gt;
		        &lt;/tr&gt;
		    &quot;&quot;&quot; }.join(&quot;&quot;)}
		&lt;/tbody&gt;
    &lt;/table&gt;

    &lt;h2&gt;Visualizations&lt;/h2&gt;
	&lt;h3&gt;Average Response Time per Thread Group&lt;/h3&gt;
    &lt;div class=&quot;chart-container&quot;&gt;
        &lt;canvas id=&quot;bar-chart&quot;&gt;&lt;/canvas&gt;
    &lt;/div&gt;
    ${bar_chart}

	&lt;h3&gt;Success vs Failure&lt;/h3&gt;
    &lt;div class=&quot;chart-container&quot;&gt;
        &lt;canvas id=&quot;pie-chart&quot;&gt;&lt;/canvas&gt;
    &lt;/div&gt;
    ${pie_chart}

	&lt;h3&gt;Total Requests per Thread Group&lt;/h3&gt;
   &lt;div class=&quot;chart-container&quot;&gt;
        &lt;canvas id=&quot;thread-group-chart&quot;&gt;&lt;/canvas&gt;
    &lt;/div&gt;
    ${thread_group_chart}

    &lt;h2&gt;Request Details&lt;/h2&gt;
    &lt;table&gt;
        &lt;thead&gt;
            &lt;tr&gt;
                &lt;th&gt;Timestamp&lt;/th&gt;
                &lt;th&gt;Thread Name&lt;/th&gt;
                &lt;th&gt;Label&lt;/th&gt;
                &lt;th&gt;Response Code&lt;/th&gt;
                &lt;th&gt;Response Time&lt;/th&gt;
                &lt;th&gt;Status&lt;/th&gt;
                &lt;th&gt;URL&lt;/th&gt;
            &lt;/tr&gt;
        &lt;/thead&gt;
        &lt;tbody&gt;
            ${request_details_html}
        &lt;/tbody&gt;
    &lt;/table&gt;
&lt;/body&gt;
&lt;/html&gt;
&quot;&quot;&quot;

try {
    new File(outputFile).write(htmlContent)
    log.info(&quot;HTML report generated successfully: ${outputFile}&quot;)
} catch (Exception e) {
    log.error(&quot;Error writing HTML report: ${e.message}&quot;)
    log.error(&quot;Stack trace: &quot;, e)
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(log)_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.Paths
import java.nio.file.Files
import groovy.json.JsonSlurper
import java.time.Instant
import java.time.ZoneId
import java.time.format.DateTimeFormatter

// Set up file paths and output details
def inputFolder = props.get(&quot;outputDir&quot;)
def reqinputFilename = inputFolder + &quot;request_&quot; + vars.get(&quot;version&quot;) + &quot;.json&quot;
def resinputFilename = inputFolder + &quot;response_&quot; + vars.get(&quot;version&quot;) + &quot;.json&quot;
def outputFolder = props.get(&quot;outputDir&quot;)
def outputVersion = vars.get(&quot;version&quot;)
def outputFilename = &quot;${outputVersion}_SmokeTest1_Log.html&quot;
def outputFile = Paths.get(outputFolder, outputFilename).toString()

// Helper function to wrap JSON data in an array
def parseAsJsonArray(String filePath) {
    def fileContent = new File(filePath).text.trim()
    // Wrap the data in an array if it&apos;s not already an array
    if (!fileContent.startsWith(&quot;[&quot;)) {
        fileContent = &quot;[${fileContent}]&quot;
    }
    return new JsonSlurper().parseText(fileContent)
}

// Function to convert timestamp to human-readable time
def formatTimestamp(long timestamp) {
    def instant = Instant.ofEpochMilli(timestamp)
    def formatter = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd HH:mm:ss&quot;).withZone(ZoneId.systemDefault())
    return formatter.format(instant)
}

// Function to truncate text if it exceeds a limit
def escapeHtml(String text) {
    if (!text) return &quot;&quot;
    return text.replace(&quot;&amp;&quot;, &quot;&amp;amp;&quot;)
               .replace(&quot;&lt;&quot;, &quot;&amp;lt;&quot;)
               .replace(&quot;&gt;&quot;, &quot;&amp;gt;&quot;)
               .replace(&quot;\&quot;&quot;, &quot;&amp;quot;&quot;)
               .replace(&quot;&apos;&quot;, &quot;&amp;#39;&quot;)
}

def truncateText(String text, int maxLength = 1000) {
    text = escapeHtml(text)
    if (text.length() &gt; maxLength) {
        return text.substring(0, maxLength) + &quot;...&quot;
    }
    return text
}

// Read input JSON files
def reqData = parseAsJsonArray(reqinputFilename)
def resData = parseAsJsonArray(resinputFilename)

// Check data structure - ensure reqData is a list of maps
if (reqData instanceof List) {
    // Group data by thread name
    def groupedByThread = reqData.groupBy { it.threadName }

    // Create a map for matching requests with responses based on thread name and request samplers
    def responseMap = [:]
    resData.each { resEntry -&gt;
        def key = &quot;${resEntry.threadName}:${resEntry.samplerName}&quot; // Unique key based on thread name and sampler name
        responseMap[key] = resEntry
    }

    // Generate the HTML report with a table
    def htmlContent = &quot;&quot;&quot;
&lt;!DOCTYPE html&gt;
&lt;html lang=&quot;en&quot;&gt;
    &lt;head&gt;
        &lt;meta charset=&quot;UTF-8&quot;&gt;
        &lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no&quot;&gt;
        &lt;title&gt;JMeter SmokeTest1 Log&lt;/title&gt;
        &lt;script src=&quot;https://cdn.plot.ly/plotly-latest.min.js&quot;&gt;&lt;/script&gt;
        &lt;style&gt;
            body {
                font-family: Arial, sans-serif;
                margin: 20px;
                background-color: #f4f4f9;
                padding-left: 5%;
                padding-right: 5%;
                font-size: 16px;
            }

            h1, h2 {
                color: #333;
            }

            h1 {
                font-size: 2em;
            }

            h2.thread-header {
                font-size: 1.5em;
                cursor: pointer;
                text-decoration: underline;
            }

            h2.thread-header:hover {
                color: blue;
            }

            .PASS {
                font-weight: bold;
                color: blue;
            }

            .FAIL {
                font-weight: bold;
                color: red;
            }

            table {
                width: 100%;
                table-layout: fixed;
                border-collapse: collapse;
                margin-top: 20px;
                font-size: 1em;
            }

	        th, td {
	            padding: 10px;
	            text-align: left;
	            border: 1px solid #ddd;
	            word-wrap: break-word;
	            overflow-wrap: break-word;
	            white-space: normal;
	        }

            th {
                background-color: #f2f2f2;
            }

            tr:nth-child(even) {
                background-color: #f9f9f9;
            }

            .content {
                display: none;
            }

            .chart-container {
                width: 100%;
                height: 400px;
                margin-top: 30px;
                display: flex;
                justify-content: center;
                align-items: center;
            }

            /* Media queries for responsive design */
            @media (max-width: 1920px) {
                body {
                    font-size: 14px;
                }
                h1 {
                    font-size: 1.8em;
                }
                h2 {
                    font-size: 1.4em;
                }
                table {
                    font-size: 0.9em;
                }
            }

            @media (max-width: 1024px) {
                body {
                    font-size: 12px;
                }
                h1 {
                    font-size: 1.6em;
                }
                h2 {
                    font-size: 1.3em;
                }
                table {
                    font-size: 0.8em;
                }
            }

            @media (max-width: 960px) {
                body {
                    font-size: 10px;
                }
                h1 {
                    font-size: 1.4em;
                }
                h2 {
                    font-size: 1.2em;
                }
                table {
                    font-size: 0.7em;
                }
            }
        &lt;/style&gt;
        &lt;script&gt;
            function toggleContent(event) {
                const contentDiv = event.target.nextElementSibling;
                if (contentDiv.style.display === &quot;none&quot; || contentDiv.style.display === &quot;&quot;) {
                    contentDiv.style.display = &quot;block&quot;;
                } else {
                    contentDiv.style.display = &quot;none&quot;;
                }
            }
        &lt;/script&gt;
    &lt;/head&gt;
&lt;body&gt;
    &lt;h1&gt;API Log Report&lt;/h1&gt;&quot;&quot;&quot;

    // Loop through grouped data and generate tables for each thread
    groupedByThread.each { threadName, threadData -&gt;
        htmlContent += &quot;&quot;&quot;&lt;h2 class=&quot;thread-header&quot; onclick=&quot;toggleContent(event)&quot;&gt;Thread: ${threadName}&lt;/h2&gt;
        &lt;div class=&quot;content&quot;&gt;
            &lt;table&gt;
                &lt;thead&gt;
                    &lt;tr&gt;
                        &lt;th&gt;Sampler&lt;/th&gt;
                        &lt;th&gt;Request Time&lt;/th&gt;
                        &lt;th&gt;Request Body&lt;/th&gt;
                        &lt;th&gt;Response Time&lt;/th&gt;
                        &lt;th&gt;Response Body&lt;/th&gt;
                    &lt;/tr&gt;
                &lt;/thead&gt;
                &lt;tbody&gt;&quot;&quot;&quot;

        // Loop through samplers in each thread and display the request/response data
        threadData.each { reqEntry -&gt;
            def key = &quot;${reqEntry.threadName}:${reqEntry.samplerName}&quot; // Unique key for matching responses
            def resEntry = responseMap[key] // Find matching response based on the key

            // Truncate the request and response bodies if they exceed 1000 characters
            def truncatedReqBody = truncateText(reqEntry.body)
            def truncatedResBody = resEntry ? truncateText(resEntry.body) : &apos;No Response&apos;

            htmlContent += &quot;&quot;&quot;&lt;tr&gt;
                &lt;td&gt;${reqEntry.samplerName}&lt;/td&gt;
                &lt;td&gt;${formatTimestamp(reqEntry.timestamp as long)}&lt;/td&gt;
                &lt;td&gt;${truncatedReqBody}&lt;/td&gt;
                &lt;td&gt;${resEntry ? formatTimestamp(resEntry.timestamp as long) : &apos;No Response&apos;}&lt;/td&gt;
                &lt;td&gt;${truncatedResBody}&lt;/td&gt;
            &lt;/tr&gt;&quot;&quot;&quot;
        }

        htmlContent += &quot;&quot;&quot;
        &lt;/tbody&gt;
        &lt;/table&gt;
        &lt;/div&gt;&quot;&quot;&quot;
    }

    htmlContent += &quot;&quot;&quot;
&lt;/body&gt;
&lt;/html&gt;
&quot;&quot;&quot;
    log.info(&quot;Output file path: ${outputFile}&quot;)
    // Save the HTML content to the output file
    Files.write(Paths.get(outputFile), htmlContent.getBytes())
} else {
    log.error(&quot;Expected an array of requests, but found ${reqData.getClass()}&quot;)
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(Intergration)_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.Paths
import java.nio.file.Files
import groovy.json.JsonSlurper

// 입력 파일 경로 (예시)
def outputDir = props.get(&quot;outputDir&quot;)
def version = vars.get(&quot;version&quot;)

// TestResult와 TestLog 파일 경로
def TestResult = Paths.get(outputDir, &quot;${version}_SmokeTest1_Result.html&quot;).toString()
def TestLog = Paths.get(outputDir, &quot;${version}_SmokeTest1_Log.html&quot;).toString()

// 파일 내용 읽기
def contentFile1 = new File(TestResult).text
def contentFile2 = new File(TestLog).text

// HTML 템플릿 시작 부분
def htmlStart = &quot;&quot;&quot;
&lt;!DOCTYPE html&gt;
&lt;html lang=&quot;en&quot;&gt;
&lt;head&gt;
    &lt;meta charset=&quot;UTF-8&quot;&gt;
    &lt;title&gt;${version}_SmokeTest1_Report&lt;/title&gt;
	&lt;style&gt;
	    body {
	        font-family: Arial, sans-serif;
	        margin: 20px;
	        background-color: #f4f4f9;
	        padding-left: 5%;
	        padding-right: 5%;
	        font-size: 16px; /* 기본 폰트 크기 설정 */
	    }
	    
	    h1, h2 {
	        color: #333;
	    }
	    
	    h1 {
	        font-size: 2em;
	    }
	    
	    h2 {
	        font-size: 1.5em;
	    }
	    .PASS {
	        font-weight: bold;
	        color: blue;
	    }
	    .FAIL {
	        font-weight: bold;
	        color: red;
	    }    
	    
	    table {
	        width: 100%;
	        table-layout: fixed;
	        border-collapse: collapse;
	        margin-top: 20px;
	        font-size: 1em;
	    }
	    
	    th, td {
	        padding: 10px;
	        text-align: left;
	        border: 1px solid #ddd;
	        word-wrap: break-word;
	        white-space: normal;
	    }
	    
	    th {
	        background-color: #f2f2f2;
	    }
	    
	    tr:nth-child(even) {
	        background-color: #f9f9f9;
	    }
	    
	    .tab {
	        overflow: hidden;
	        background-color: #f4f4f9;
	        border-bottom: 2px solid #ddd;
	        margin-bottom: 20px;
	    }
	    /* 탭 관련 스타일 */
	    .tab button {
	        background-color: #e9e9f3;
	        color: #333;
	        float: left;
	        border: none;
	        outline: none;
	        cursor: pointer;
	        padding: 14px 20px;
	        transition: 0.3s;
	        font-size: 16px;
	        font-weight: bold;
	        margin-right: 5px;
	        border-radius: 5px 5px 0 0;
	    }
	
	    .tab button:hover {
	        background-color: #d6d6ee;
	        color: #000;
	    }
	
	    .tab button.active {
	        background-color: #b3b3dd;
	        color: white;
	        font-weight: bold;
	        border-bottom: 3px solid #6c63ff;
	    }
	
	    .tabcontent {
	        display: none;
	        padding: 20px;
	        border: 1px solid #ddd;
	        border-top: none;
	        border-radius: 0 0 5px 5px;
	        background-color: white;
	    }
	
	    .tabcontent.active {
	        display: block;
	    }
	    
	    /* 탭 콘텐츠에서 덮어쓰기 */
	    .tabcontent .chart-container {
	        width: 100% !important; 
	        height: 35vh !important;
	        margin: 0 auto;
	        display: flex;
	        justify-content: center;
	        align-items: center;
	        position: relative; /* 캔버스 위치를 조정 */
	    }
	
	    .tabcontent canvas {
	        max-width: 100% !important; /* 캔버스가 부모 너비를 넘지 않도록 제한 */
	        height: auto !important; /* 높이 자동 조정 */
	    }
	
		/* 반응형 디자인 */
		@media (max-width: 1920px) {
			body {
			  font-size: 14px;
			}
			h1 {
			  font-size: 1.8em;
			}
			h2 {
			  font-size: 1.4em;
			}
			table {
			  font-size: 0.9em;
			}
		}
		
		@media (max-width: 1024px) {
			body {
			  font-size: 12px;
			}
			h1 {
			  font-size: 1.6em;
			}
			h2 {
			  font-size: 1.3em;
			}
			table {
			  font-size: 0.8em;
			}
		}
		
		@media (max-width: 960px) {
			body {
			  font-size: 10px;
			}
			h1 {
			  font-size: 1.4em;
			}
			h2 {
			  font-size: 1.2em;
			}
			table {
			  font-size: 0.7em;
			}
		}
		
		/* 인쇄용 */
		@media print {
		    .tabcontent .chart-container {
		        width: 100% !important; /* 차트가 용지 폭에 맞게 조정 */
		        height: auto !important; /* 높이를 자동으로 조정 */
		        page-break-inside: avoid; /* 페이지 나누기 방지 */
		    }
		    
		    body {
		        font-size: 10px; /* 인쇄용 폰트 크기 조정 */
		    }
		    
		    h1, h2 {
		        font-size: 1.2em; /* 헤더 크기 조정 */
		    }
		    
		    h3 {
		        page-break-after: avoid;
		        page-break-before: avoid;
		    }
		    
		    table {
		        font-size: 0.8em; /* 테이블 폰트 크기 조정 */
		    }
		}
	&lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;
    &lt;h1&gt;${version} SmokeTest1 Report&lt;/h1&gt;
    &lt;div class=&quot;tab&quot;&gt;
        &lt;button class=&quot;tablinks&quot; onclick=&quot;openTab(event, &apos;File1&apos;)&quot;&gt;TestResult&lt;/button&gt;
        &lt;button class=&quot;tablinks&quot; onclick=&quot;openTab(event, &apos;File2&apos;)&quot;&gt;TestLog&lt;/button&gt;
    &lt;/div&gt;
    &lt;div id=&quot;File1&quot; class=&quot;tabcontent&quot;&gt;
        ${contentFile1}
    &lt;/div&gt;
&quot;&quot;&quot;

// HTML 파일 템플릿 끝 부분
def htmlEnd = &quot;&quot;&quot;    
    &lt;div id=&quot;File2&quot; class=&quot;tabcontent&quot;&gt;
        ${contentFile2}
    &lt;/div&gt;

	&lt;script&gt;
	    function openTab(evt, tabName) {
	        var i, tabcontent, tablinks;
	        tabcontent = document.getElementsByClassName(&quot;tabcontent&quot;);
	        for (i = 0; i &lt; tabcontent.length; i++) {
	            tabcontent[i].classList.remove(&quot;active&quot;);
	        }
	        tablinks = document.getElementsByClassName(&quot;tablinks&quot;);
	        for (i = 0; i &lt; tablinks.length; i++) {
	            tablinks[i].classList.remove(&quot;active&quot;);
	        }
	        document.getElementById(tabName).classList.add(&quot;active&quot;);
	        evt.currentTarget.classList.add(&quot;active&quot;);
	    }
	
	    // 기본적으로 첫 번째 탭을 열도록 설정
	    document.getElementsByClassName(&quot;tablinks&quot;)[0].click();
	&lt;/script&gt;
&lt;/body&gt;
&lt;/html&gt;
&quot;&quot;&quot;

// HTML 파일을 합쳐서 저장
def combinedHtml = htmlStart + htmlEnd

// 출력 파일 경로
def outputFile = Paths.get(outputDir, &quot;${version}_SmokeTest1_Report.html&quot;).toString()

// 합쳐진 HTML 저장
Files.write(Paths.get(outputFile), combinedHtml.getBytes())

// 로그 출력
log.info(&quot;Combined HTML file saved at: ${outputFile}&quot;)
</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
    </hashTree>
  </hashTree>
</jmeterTestPlan>
