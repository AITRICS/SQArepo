            <BeanShellPostProcessor guiclass="TestBeanGUI" testclass="BeanShellPostProcessor" testname="BeanShell PostProcessor" enabled="true">
              <boolProp name="resetInterpreter">false</boolProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="script">log.info(&quot;Extracted Wards: &quot; + vars.get(&quot;WARD_LIST&quot;));
log.info(&quot;Extracted Wards: &quot; + vars.get(&quot;Department_LIST&quot;));
log.info(&quot;Extracted Wards: &quot; + vars.get(&quot;Practitioner_LIST&quot;));
log.info(&quot;Extracted Wards: &quot; + vars.get(&quot;AlertItems_LIST&quot;));</stringProp>
            </BeanShellPostProcessor>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Department_JSR223 PostProcessor" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper

// Get the JSON string stored in the variable Department_LIST
def departmentJsonString = vars.get(&quot;Department_LIST&quot;);

// Parse the JSON string to a list (array)
def jsonSlurper = new JsonSlurper();
def departments = jsonSlurper.parseText(departmentJsonString);

// Initialize a list to hold the department keys
def departmentKeys = []

// Iterate over the entries in the departments list to extract keys
departments.each { department -&gt;
    // Extract the key and add it to the list
    departmentKeys.add(&quot;\&quot;${department.key}\&quot;&quot;)
}

// Log the keys to verify
log.info(&quot;Department Keys: &quot; + departmentKeys);

// Optionally, save the keys as a JMeter variable
vars.put(&quot;Department_KEYS&quot;, departmentKeys.join(&quot;,&quot;));
</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Practitioner_JSR223 PostProcessor" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper

// Get the JSON string stored in the variable Practitioner_LIST
def PractitionerJsonString = vars.get(&quot;Practitioner_LIST&quot;);

// Parse the JSON string to an object
def jsonSlurper = new JsonSlurper();
def practitioners = jsonSlurper.parseText(PractitionerJsonString);

// Initialize a list to hold the Practitioner keys
def PractitionerKeys = []

// Iterate over the entries in the practitioners list to extract keys
practitioners.each { practitioner -&gt;
    // Extract the key and add it to the list
    PractitionerKeys.add(&quot;\&quot;${practitioner.key}\&quot;&quot;);
}

// Log the keys to verify
log.info(&quot;Practitioner Keys: &quot; + PractitionerKeys);

// Optionally, save the keys as a JMeter variable
vars.put(&quot;Practitioner_KEYS&quot;, PractitionerKeys.join(&quot;,&quot;));
</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Alert_JSR223 PostProcessor" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper

// Get the JSON string stored in the variable AlertItems_LIST
def alertItemsJsonString = vars.get(&quot;AlertItems_LIST&quot;);

// Parse the JSON string to an object
def jsonSlurper = new JsonSlurper();
def jsonObject = jsonSlurper.parseText(alertItemsJsonString);

// Initialize a list to hold the keys
def AlertfilterKeys = []

// Access the &apos;alertItems&apos; object
def alertItems = jsonObject // Directly use the parsed object

// Iterate over the categories in &apos;alertItems&apos;
alertItems.each { category, items -&gt;
    // Iterate over the keys in each category
    items.each { key, value -&gt;
        AlertfilterKeys.add(&quot;\&quot;${key}\&quot;&quot;)
    }
}

// Log the keys to verify
log.info(&quot;AlertItems Keys: &quot; + AlertfilterKeys);

// Optionally, save the keys as a JMeter variable
vars.put(&quot;Alert_KEYS&quot;, AlertfilterKeys.join(&quot;,&quot;));
</stringProp>
            </JSR223PostProcessor>
