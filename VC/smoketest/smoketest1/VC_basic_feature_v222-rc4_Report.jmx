      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter

// 현재 날짜 형식
def date = LocalDateTime.now().format(DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;))
def outputDir = &quot;${baseDir}&quot; + &quot;/&quot; + &quot;${version}_&quot; + date + &quot;/&quot; // 결과를 저장할 폴더

// 프로퍼티에 날짜와 outputDir 추가
props.put(&quot;date&quot;, date)
props.put(&quot;outputDir&quot;, outputDir)
def version=vars.get(&quot;version&quot;)


// 폴더 내 파일 중 ${version}을 포함한 파일만 삭제하는 함수
def deleteFilesInDirectory(directoryPath, version) {
    Path dir = Paths.get(directoryPath)
    if (Files.exists(dir) &amp;&amp; Files.isDirectory(dir)) {
        Files.walk(dir)
            .filter { path -&gt; !Files.isDirectory(path) &amp;&amp; path.toString().contains(version) }  // ${version}이 포함된 파일만 선택
            .forEach { path -&gt; 
                try {
                    Files.delete(path)  // 파일 삭제
                    println(&quot;Deleted file: ${path}&quot;)
                } catch (IOException e) {
                    println(&quot;Error deleting file: ${path} - ${e.message}&quot;)
                }
            }
    }
}

// outputDir 내 ${version}이 포함된 파일만 삭제
deleteFilesInDirectory(outputDir, version)
</stringProp>
        </JSR223Sampler>
