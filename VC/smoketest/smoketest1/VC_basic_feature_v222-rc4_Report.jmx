          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223_screening_API_QueryParam_SET" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">import java.text.SimpleDateFormat;
import java.util.Date;

long timestampDefault = ${timestamp_default};

long start_dt = ${timestamp_default} - 33 * 60 * 60 * 1000;
long end_dt = ${timestamp_default} - 9 * 60 * 60 * 1000;
long version = ${timestamp_default} - 9 * 60 * 60 * 1000;
long last_version = ${timestamp_default} - 10 * 60 * 60 * 1000;

Date timestamp_start_dt = new Date(start_dt);
Date timestamp_end_dt = new Date(end_dt);
Date timestamp_version = new Date(version);
Date timestamp_last_version = new Date(last_version);

SimpleDateFormat sdf_time = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
SimpleDateFormat sdf_string = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);

String start_dt_string = sdf_time.format(timestamp_start_dt);
String end_dt_string = sdf_time.format(timestamp_end_dt);
String version_string = sdf_string.format(timestamp_version);
String last_screened_dt = sdf_string.format(timestamp_last_version);

vars.put(&quot;param_start_dt&quot;, start_dt_string);
vars.put(&quot;param_end_dt&quot;, end_dt_string);
vars.put(&quot;param_version&quot;, version_string);
vars.put(&quot;param_last_screened_dt&quot;, last_screened_dt);</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PreProcessor>
            <hashTree/>
          </hashTree>
