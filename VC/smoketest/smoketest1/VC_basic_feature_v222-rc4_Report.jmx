          <hashTree>
            <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="ACCESS_TOKEN JSON Extractor" enabled="true">
              <stringProp name="JSONPostProcessor.referenceNames">USER_TOKEN</stringProp>
              <stringProp name="JSONPostProcessor.jsonPathExprs">data.accessToken</stringProp>
              <stringProp name="JSONPostProcessor.match_numbers">1</stringProp>
