        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Vital_Data_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;
import java.util.Random;

// JDBC connection information
String url = &quot;${JDBC_URL_EMR}&quot;;
String user = &quot;${JDBC_USER_EMR}&quot;;
String password = &quot;${JDBC_PW_EMR}&quot;;

// JDBC connection &amp; Define the query
try (Connection conn = DriverManager.getConnection(url, user, password)) {
	String query = &quot;INSERT INTO ROOT.VITALS (PATIENT_ID, ENCOUNTER_ID, OBSERVED_DT, CODE, VALUE, DELETED_YN, INVALID) &quot; +
				&quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?, ?, ?, ?)&quot;;

	// Prepare the statement &amp; Repeat the process for multiple sets of parameters
	try (PreparedStatement stmt = conn.prepareStatement(query)) {
		String threadGroupName = ctx.getThreadGroup().getName();
		// Repeat the process for multiple sets of parameters
		int patientCount = Integer.parseInt(vars.get(&quot;PatientCount&quot;));
		int observationCount = Integer.parseInt(vars.get(&quot;ObservationCount&quot;));
		Random random = new Random();

		// Repeat the process for multiple sets of parameters
		for (int i = 0; i &lt; patientCount; i++) {
			String patientID = vars.get(&quot;PatientID&quot; + i);
			String encounterID = vars.get(&quot;EncounterID&quot; + i);

			for (int j = 0; j &lt; observationCount; j++) {
				String observedDateTime = vars.get(&quot;ObservedDt&quot; + j);

				def insertedCodes = []

				// Set parameters for the query
				String pulseRate = random.nextInt(300) + &quot;.&quot; + random.nextInt(10);
				String respiratoryRate = random.nextInt(120) + &quot;.&quot; + random.nextInt(10);
				String bodyTemperature = (random.nextInt(25) + 25) + &quot;.&quot; + random.nextInt(10);
				String systolicBP = random.nextInt(300) + &quot;.&quot; + random.nextInt(10);
				String diastolicBP = random.nextInt(300) + &quot;.&quot; + random.nextInt(10);

				// Insert Observation
				insertObservation(stmt, patientID, encounterID, observedDateTime, &quot;PULSE&quot;, pulseRate);
				insertedCodes &lt;&lt; &quot;PULSE&quot;
				insertObservation(stmt, patientID, encounterID, observedDateTime, &quot;RESP&quot;, respiratoryRate);
				insertedCodes &lt;&lt; &quot;RESP&quot;
				insertObservation(stmt, patientID, encounterID, observedDateTime, &quot;TEMP&quot;, bodyTemperature);
				insertedCodes &lt;&lt; &quot;TEMP&quot;
				insertObservation(stmt, patientID, encounterID, observedDateTime, &quot;SBP&quot;, systolicBP);
				insertedCodes &lt;&lt; &quot;SBP&quot;
				insertObservation(stmt, patientID, encounterID, observedDateTime, &quot;DBP&quot;, diastolicBP);
				insertedCodes &lt;&lt; &quot;DBP&quot;

//				def procedureLogs = vars.getObject(&quot;procedureLogs&quot;)
//				if (procedureLogs != null) {
//					procedureLogs.add(
//						&quot;INPUT: ${observedDateTime} [${insertedCodes.join(&apos;|&apos;)}]&quot;
//			        )
//			    }
			}
		}
	}
} catch (Exception e) {
	log.error(&quot;Exception: &quot;, e);
}

private void insertObservation(PreparedStatement stmt, String patientID, String encounterID, String observedDateTime, String code, String value) throws SQLException {
	stmt.setString(1, patientID);
	stmt.setString(2, encounterID);
	stmt.setString(3, observedDateTime);
	stmt.setString(4, code);
	stmt.setDouble(5, Double.parseDouble(value));
	stmt.setInt(6, 0); // DELETED_YN
	stmt.setInt(7, 1); // INVALID
	String threadGroupName = ctx.getThreadGroup().getName();
	// Execute the query
	stmt.executeUpdate();
	log.info(&quot;PatientID=&quot; + patientID + &quot;, EncounterID=&quot; + encounterID + &quot;, observedDateTime=&quot; + observedDateTime + &quot;, Code=&quot; + code + &quot;, Value=&quot; + value);
	stmt.clearParameters();
}
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Observation Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.TimeZone;
import java.util.Calendar;

// Default timestamp
long timestampDefault = ${timestamp_default};
//long timestampDefault = props.get(&quot;timestamp_default&quot;) as long;

// Repeat count
int repeatCount = ${ObservationCount}; // Number of repetitions set
int intervalMin = ${Ob_Interval_Min};

// Iterate to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
	// Create a Date object
	Date PatientSet = new Date(timestampDefault);
	Date EncounterSet = new Date(timestampDefault);

	// Set Observe Date
	Calendar calendar = Calendar.getInstance();
	calendar.setTimeInMillis(timestampDefault); // Set the default timestamp		
	calendar.add(Calendar.MINUTE, - ((repeatCount + 1) * intervalMin))

	long ObservedDtSetTimestamp = calendar.getTimeInMillis();
	Date ObservedDtSet = new Date(ObservedDtSetTimestamp);
	
	String threadGroupName = ctx.getThreadGroup().getName();
	String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1];

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i+&quot;yyMMddHHmmss&quot;+${User_Thread}+threadGroupNumber);
	sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the date to string
	String PatientID = sdf_patient.format(PatientSet);
	
	// Create a SimpleDateFormat object for EncounterID and set it to UTC Timezone
	SimpleDateFormat sdf_encounter = new SimpleDateFormat(i + &quot;yyyyMMddHHmmss&quot; + ${User_Thread}+threadGroupNumber);
	sdf_encounter.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the date to string
	String EncounterID = sdf_encounter.format(EncounterSet);
	
	// Create a SimpleDateFormat object for ObservedDt and set it to UTC Timezone
	SimpleDateFormat sdf_ObservedDt = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	sdf_ObservedDt.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the date to string
	String ObservedDt = sdf_ObservedDt.format(ObservedDtSet);
	
	// Calculate base_dt based on ObservedDt using time in minutes
	// Get the total minutes since the hour (0-59 minutes)
	Calendar observedCalendar = Calendar.getInstance();
	observedCalendar.setTime(ObservedDtSet);
	int totalMinutes = observedCalendar.get(Calendar.MINUTE);
	int totalSeconds = observedCalendar.get(Calendar.SECOND);
	
	// Determine base_dt based on the new rules
	int baseMinutes = 0; // Default baseMinutes
	if (totalMinutes &lt; 10) {
		baseMinutes = 10;
	} else if (totalMinutes &lt; 20 || (totalMinutes == 20 &amp;&amp; totalSeconds == 0)) {
		baseMinutes = 20;
	} else if (totalMinutes &lt; 30 || (totalMinutes == 30 &amp;&amp; totalSeconds == 0)) {
		baseMinutes = 30;
	} else if (totalMinutes &lt; 40 || (totalMinutes == 40 &amp;&amp; totalSeconds == 0)) {
		baseMinutes = 40;
	} else if (totalMinutes &lt; 50 || (totalMinutes == 50 &amp;&amp; totalSeconds == 0)) {
		baseMinutes = 50;
	} else {
		baseMinutes = 0; // 51-60 minutes
	}
	
	// Set the calculated baseMinutes to observedCalendar
	observedCalendar.set(Calendar.MINUTE, baseMinutes);
	observedCalendar.set(Calendar.SECOND, 0); // Reset seconds to 0
	observedCalendar.set(Calendar.MILLISECOND, 0); // Reset milliseconds to 0
	
	// Get the base_dt as Date
	Date baseDtSet = observedCalendar.getTime();
	
	// Create a SimpleDateFormat for base_dt
	SimpleDateFormat sdf_baseDt = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	sdf_baseDt.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the base_dt to string
	String baseDt = sdf_baseDt.format(baseDtSet);
	
	// Store in variables
	vars.put(&quot;PatientID&quot; + i, PatientID);
	vars.put(&quot;EncounterID&quot; + i, EncounterID + &quot;|&quot; + PatientID);
	vars.put(&quot;ObservedDt&quot; + i, ObservedDt);
	vars.put(&quot;baseDt&quot; + i, baseDt); // Store base_dt
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="LABORATORY_Data_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*
import java.util.Random

// 1. 접속 정보 유지
String url_emr = &quot;${JDBC_URL_EMR}&quot;
String user_emr = &quot;${JDBC_USER_EMR}&quot;
String pw_emr = &quot;${JDBC_PW_EMR}&quot;
String url_vc = &quot;${JDBC_URL_VC}&quot;
String user_vc = &quot;${JDBC_USER_VC}&quot;
String pw_vc = &quot;${JDBC_PW_VC}&quot;

Random random = new Random()
String subCategory = vars.get(&quot;subCategory&quot;) ?: &quot;&quot;

Float lowThreshold = null; Float highThreshold = null
boolean isLowInclusive = true; boolean isHighInclusive = true

// --- [STEP 1] VC DB 정책 조회 (값 크기순 정렬 방식) ---
String policySql = &quot;SELECT left_boundary, left_inclusive, right_boundary, right_inclusive, policy_desc FROM api_screening_policy WHERE UPPER(subcategory) = UPPER(?)&quot;;

try (Connection connVC = DriverManager.getConnection(url_vc, user_vc, pw_vc)) {
    try (PreparedStatement pstm = connVC.prepareStatement(policySql)) {
        pstm.setString(1, subCategory); 
        try (ResultSet rs = pstm.executeQuery()) {
            List parts = [];
            while (rs.next()) {
                String desc = rs.getString(&quot;policy_desc&quot;) ?: &quot;&quot;;
                
                // 값이 있는 쪽(left 혹은 right)의 수치를 가져옴
                Object leftObj = rs.getObject(&quot;left_boundary&quot;);
                float val = (leftObj != null) ? rs.getFloat(&quot;left_boundary&quot;) : rs.getFloat(&quot;right_boundary&quot;);
                boolean inc = (leftObj != null) ? rs.getBoolean(&quot;left_inclusive&quot;) : rs.getBoolean(&quot;right_inclusive&quot;);

                // [핵심] desc의 기호를 보고 상한/하한을 결정
                if (desc.contains(&quot;&gt;&quot;) || desc.contains(&quot;≥&quot;)) {
                    highThreshold = val;
                    isHighInclusive = (desc.contains(&quot;≥&quot;) || desc.contains(&quot;=&quot;));
                    parts &lt;&lt; &quot;${subCategory} ${isHighInclusive ? &apos;≥&apos; : &apos;&gt;&apos;} ${highThreshold}&quot; ;
                } 
                else if (desc.contains(&quot;&lt;&quot;) || desc.contains(&quot;≤&quot;)) {
                    lowThreshold = val;
                    isLowInclusive = (desc.contains(&quot;≤&quot;) || desc.contains(&quot;=&quot;));
                    parts &lt;&lt; &quot;${subCategory} ${isLowInclusive ? &apos;≤&apos; : &apos;&lt;&apos;} ${lowThreshold}&quot; ;
                }
            }
            
            // Snapshot 문자열 생성 및 저장
            if (!parts.isEmpty()) {
                thresholdSnapshotStr = parts.unique().sort().join(&quot; | &quot;);
                vars.put(&quot;thresholdSnapshot&quot;, thresholdSnapshotStr);
            }
        }
    }
} catch (Exception e) { log.error(&quot;정책 조회 실패: &quot; + e.getMessage()); }

// --- [STEP 2] 데이터 생성 로직 (전체 소수점 2자리 통일) ---
String fmt = &quot;%.2f&quot; // 모든 항목 소수점 2자리 적용

def availableCases = [&quot;NORMAL&quot;, &quot;NORMAL&quot;]
if (lowThreshold != null)  { availableCases += [&quot;LOW_ALARM&quot;, &quot;LOW_BOUNDARY&quot;] }
if (highThreshold != null) { availableCases += [&quot;HIGH_BOUNDARY&quot;, &quot;HIGH_ALARM&quot;] }

String testCase = availableCases[ctx.getThreadNum() % availableCases.size()]
String testValue = &quot;&quot;
String expectResult = &quot;NORMAL&quot;

switch(testCase) {
    case &quot;LOW_ALARM&quot;:
        testValue = String.format(fmt, lowThreshold - 0.05f) // 알람 확실히 발생하게 0.05 차이
        expectResult = &quot;ALARM&quot;
        break
    case &quot;LOW_BOUNDARY&quot;:
        float adjust = isLowInclusive ? 0 : -0.01f
        testValue = String.format(fmt, lowThreshold + adjust)
        expectResult = &quot;ALARM&quot;
        break
    case &quot;HIGH_BOUNDARY&quot;:
        float adjust = isHighInclusive ? 0 : 0.01f
        testValue = String.format(fmt, highThreshold + adjust)
        expectResult = &quot;ALARM&quot;
        break
    case &quot;HIGH_ALARM&quot;:
        testValue = String.format(fmt, highThreshold + 0.05f)
        expectResult = &quot;ALARM&quot;
        break
    default:
        float min = (lowThreshold ?: 70.0f) + 0.1f
        float max = (highThreshold ?: 110.0f) - 0.1f
        testValue = String.format(fmt, min + random.nextFloat() * (max - min))
        expectResult = &quot;NORMAL&quot;
}

// --- [STEP 3] EMR DB INSERT ---
def insertLabResult = { PreparedStatement stmt, String pId, String eId, String dDt, String oDt, String rDt, String code, String val -&gt;
    stmt.setString(1, pId)
    stmt.setString(2, eId)
    stmt.setString(3, dDt) // DRAWN_DT
    stmt.setString(4, oDt) // ORDERED_DT
    stmt.setString(5, rDt) // RESULT_DT
    stmt.setString(6, code)
    stmt.setDouble(7, Double.parseDouble(val))
    stmt.setInt(8, 0)      // DELETED_YN
    stmt.setInt(9, 1)      // INVALID
    
    stmt.executeUpdate();   // 실제 입력을 위해 주석 해제
    stmt.clearParameters()
}

def codeMap = [ SBP: &quot;SBP&quot;, DBP: &quot;DBP&quot;, PR: &quot;PULSE&quot;, RR: &quot;RESP&quot;, BT: &quot;TEMP&quot;, SpO2: &quot;SpO2&quot;, APH: &quot;APH&quot;, Hb: &quot;Hb&quot;, HCT: &quot;HEMATOCRIT&quot; ]
String query = &quot;INSERT INTO ROOT.LABORATORIES (PATIENT_ID, ENCOUNTER_ID, DRAWN_DT, ORDERED_DT, RESULT_DT, CODE, VALUE, DELETED_YN, INVALID) VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?, ?, ?, ?)&quot;

try (Connection connEMR = DriverManager.getConnection(url_emr, user_emr, pw_emr)) {
    try (PreparedStatement stmt = connEMR.prepareStatement(query)) {
        for (int i = 0; i &lt; (vars.get(&quot;PatientCount&quot;) as int ?: 1); i++) {
            String pId = vars.get(&quot;PatientID&quot; + i); String eId = vars.get(&quot;EncounterID&quot; + i)
            for (int j = 0; j &lt; (vars.get(&quot;ObservationCount&quot;) as int ?: 1); j++) {
                String dbCode = codeMap[subCategory] ?: subCategory
                insertLabResult(stmt, pId, eId, vars.get(&quot;DrawnDt&quot; + j), vars.get(&quot;OrderedDt&quot; + j), vars.get(&quot;ResultDt&quot; + j), dbCode, testValue);
                
                def logs = vars.getObject(&quot;procedureLogs&quot;) ?: []
                logs.add(&quot;INPUT: [${dbCode}] value=${testValue} (${testCase}) -&gt; Expect: ${expectResult}&quot;)
                vars.putObject(&quot;procedureLogs&quot;, logs)
            }
        }
    }
} catch (Exception e) { log.error(&quot;EMR DB 입력 에러: &quot; + e.getMessage()) }</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Observation Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.TimeZone;
import java.util.Calendar;

// Default timestamp
long timestampDefault = ${timestamp_default};
//long timestampDefault = props.get(&quot;timestamp_default&quot;) as long;

// Repeat count
int repeatCount = ${ObservationCount}; // Number of repetitions set
int intervalMin = ${Ob_Interval_Min};

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
	// Create a Date object
	Date PatientSet = new Date(timestampDefault);
	Date EncounterSet = new Date(timestampDefault);
	
	//Caculation Timestamp
	Calendar calendar = Calendar.getInstance();
	calendar.setTimeInMillis(timestampDefault); // Set the default timestamp		
	calendar.add(Calendar.MINUTE, -(repeatCount * intervalMin));
	calendar.add(Calendar.HOUR, +1);
	long OrderedDtSetTimestamp = calendar.getTimeInMillis();
	calendar.add(Calendar.HOUR, - 1);
	long DrawnDtSetTimestamp = calendar.getTimeInMillis();
	calendar.add(Calendar.HOUR, - 1);
	long ResultDtSetTimestamp = calendar.getTimeInMillis();

	//Set Timestamp
	Date OrderedDtSet = new Date(OrderedDtSetTimestamp); //observer use now
	Date DrawnDtSet = new Date(DrawnDtSetTimestamp); //observer use now
	Date ResultDtSet = new Date(ResultDtSetTimestamp); //observer use now

	String threadGroupName = ctx.getThreadGroup().getName();
	String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1];
	
	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i+&quot;yyMMddHHmmss&quot;+${User_Thread}+threadGroupNumber);
	sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the date to string
	String PatientID = sdf_patient.format(PatientSet);
	
	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_encounter = new SimpleDateFormat(i+&quot;yyyyMMddHHmmss&quot;+${User_Thread}+threadGroupNumber);
	sdf_encounter.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the date to string
	String EncounterID = sdf_encounter.format(EncounterSet);
	
	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_LabDt = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	sdf_LabDt.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the date to string
	String OrderedDt = sdf_LabDt.format(OrderedDtSet);
	String DrawnDt = sdf_LabDt.format(DrawnDtSet);
	String ResultDt = sdf_LabDt.format(ResultDtSet);
	
	// Store in variables
	vars.put(&quot;PatientID&quot; + i, PatientID);
	vars.put(&quot;EncounterID&quot; + i, EncounterID + &quot;|&quot; + PatientID);
	vars.put(&quot;OrderedDt&quot; + i, OrderedDt);
	vars.put(&quot;DrawnDt&quot; + i, DrawnDt);
	vars.put(&quot;ResultDt&quot; + i, ResultDt);
	vars.put(&quot;ObservedDt&quot; + i, DrawnDt);
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Wait_For_Score Sampler" enabled="true">
          <intProp name="ActionProcessor.action">1</intProp>
          <intProp name="ActionProcessor.target">0</intProp>
          <stringProp name="ActionProcessor.duration">${duration2}</stringProp>
          <stringProp name="TestPlan.comments">10 * 60 * 1000 = 600000</stringProp>
        </TestAction>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="vc_emr_screening_validation_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*
import java.text.SimpleDateFormat
import groovy.json.JsonSlurper
import java.math.BigDecimal

def logResults = vars.getObject(&quot;logResults&quot;)

// 1. 설정 및 변수 로드
String subCategory = vars.get(&quot;subCategory&quot;) ?: &quot;&quot;
String url = vars.get(&quot;JDBC_URL_VC&quot;)
String user = vars.get(&quot;JDBC_USER_VC&quot;)
String password = vars.get(&quot;JDBC_PW_VC&quot;)

// DB 정책 및 판정용 변수 (초기값 설정)
Float lowThreshold = null
Float highThreshold = null
boolean lowInc = true
boolean highInc = true
String thresholdSnapshotStr = &quot;&quot;

def convertTimestamp = { long ts -&gt; 
    new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;).with { 
        timeZone = TimeZone.getTimeZone(&quot;Asia/Seoul&quot;)
        format(new Date(ts))
    }
}

try (Connection conn = DriverManager.getConnection(url, user, password)) {
    // A. 암호화 키 설정
    try (Statement stmt = conn.createStatement()) {
        stmt.execute(&quot;SET @hashed_key = (SELECT UNHEX(SHA2(&apos;some_secret&apos;,256)))&quot;)
        stmt.execute(&quot;SET @secretkey = LEFT(@hashed_key,16)&quot;)
        stmt.execute(&quot;SET @iv = RIGHT(@hashed_key,16)&quot;)
    }

    // --- [STEP B 수정] bList.sort 방식으로 정책 로드 ---
// 1. 쿼리에 policy_desc 컬럼을 추가하여 기호를 판독합니다.
    String policySql = &quot;SELECT left_boundary, left_inclusive, right_boundary, right_inclusive, policy_desc FROM vitalcare.api_screening_policy WHERE UPPER(subcategory) = UPPER(?)&quot;;
    
    try (PreparedStatement pstm = conn.prepareStatement(policySql)) {
        pstm.setString(1, subCategory);
        try (ResultSet rs = pstm.executeQuery()) {
            List parts = [];
            
            while (rs.next()) {
                String desc = rs.getString(&quot;policy_desc&quot;) ?: &quot;&quot;;
                
                // left_boundary 혹은 right_boundary 중 값이 있는 컬럼의 숫자를 가져옴
                Object leftObj = rs.getObject(&quot;left_boundary&quot;);
                Object rightObj = rs.getObject(&quot;right_boundary&quot;);
                
                float val = (leftObj != null) ? rs.getFloat(&quot;left_boundary&quot;) : rs.getFloat(&quot;right_boundary&quot;);
                boolean inc = (leftObj != null) ? rs.getBoolean(&quot;left_inclusive&quot;) : rs.getBoolean(&quot;right_inclusive&quot;);

                // [핵심] desc 컬럼에 담긴 기호로 상한/하한을 결정 (POTASSIUM &gt;= 6.0 해결)
                if (desc.contains(&quot;&gt;&quot;) || desc.contains(&quot;≥&quot;)) {
                    // 기호가 &apos;크다&apos; 계열이면 상한선(High)으로 배정
                    highThreshold = val;
                    highInc = (desc.contains(&quot;≥&quot;) || desc.contains(&quot;=&quot;));
                    parts &lt;&lt; &quot;${subCategory} ${highInc ? &apos;≥&apos; : &apos;&gt;&apos;} ${highThreshold}&quot;;
                } 
                else if (desc.contains(&quot;&lt;&quot;) || desc.contains(&quot;≤&quot;)) {
                    // 기호가 &apos;작다&apos; 계열이면 하한선(Low)으로 배정
                    lowThreshold = val;
                    lowInc = (desc.contains(&quot;≤&quot;) || desc.contains(&quot;=&quot;));
                    parts &lt;&lt; &quot;${subCategory} ${lowInc ? &apos;≤&apos; : &apos;&lt;&apos;} ${lowThreshold}&quot;;
                }
            }
            
            // Snapshot 문자열 생성 (중복 제거 후 합치기)
            thresholdSnapshotStr = parts.unique().sort().join(&quot; | &quot;);
        }
    }
    vars.put(&quot;thresholdSnapshot&quot;, thresholdSnapshotStr);

    // C. 메인 검증 루프
    String startTime2 = convertTimestamp(Long.parseLong(vars.get(&quot;startTimeThread&quot;)))
    int patientCount = (vars.get(&quot;PatientCount&quot;) ?: &quot;0&quot;) as int
    int obsCount = (vars.get(&quot;ObservationCount&quot;) ?: &quot;0&quot;) as int

    for (int i = 0; i &lt; patientCount; i++) {
        String patientID = vars.get(&quot;PatientID&quot; + i)
        String encounterID = vars.get(&quot;EncounterID&quot; + i)

        for (int j = 0; j &lt; obsCount; j++) {
            String observedDt = vars.get(&quot;ObservedDt&quot; + j)
            
            SimpleDateFormat sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
            sdf.timeZone = TimeZone.getTimeZone(vars.get(&quot;TimeZone&quot;) ?: &quot;Asia/Seoul&quot;)
            java.util.Date parsedDate = sdf.parse(observedDt)
            sdf.timeZone = TimeZone.getTimeZone(&quot;UTC&quot;)
            String baseDtStr = sdf.format(parsedDate)

            // 1. vc_event 조회 (기존 로직 유지)
            String vcQuery = &quot;SELECT subcategory, observed_dt, value FROM vitalcare.vc_event WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),@secretkey,@iv) AS CHAR) = ? AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id),@secretkey,@iv) AS CHAR) = ? AND observed_dt = ? AND subcategory = ?&quot;
            List vcEvents = []
            try (PreparedStatement ps = conn.prepareStatement(vcQuery)) {
                ps.setString(1, patientID); ps.setString(2, encounterID); ps.setString(3, baseDtStr); ps.setString(4, subCategory)
                try (ResultSet rs = ps.executeQuery()) {
                    while (rs.next()) vcEvents.add([subcategory: rs.getString(1), observed_dt: rs.getString(2), value: rs.getString(3)])
                }
            }

            // --- [STEP C 판정 로직 핵심] BigDecimal 정밀 비교 반영 ---
            List matchedPolicies = []
            vcEvents.each { e -&gt;
                BigDecimal val = new BigDecimal(e.value)
                boolean isBelow = false
                boolean isAbove = false
                
                if (lowThreshold != null) {
                    BigDecimal low = new BigDecimal(lowThreshold.toString())
                    isBelow = lowInc ? (val.compareTo(low) &lt;= 0) : (val.compareTo(low) &lt; 0)
                }
                if (highThreshold != null) {
                    BigDecimal high = new BigDecimal(highThreshold.toString())
                    isAbove = highInc ? (val.compareTo(high) &gt;= 0) : (val.compareTo(high) &gt; 0)
                }

                if (isBelow) matchedPolicies &lt;&lt; &quot;LOW_POLICY&quot;
                else if (isAbove) matchedPolicies &lt;&lt; &quot;HIGH_POLICY&quot;
                else matchedPolicies &lt;&lt; &quot;NORMAL&quot;
            }

            // 3. api_screeningrecord 조회 및 결과 판정 (기존 로직 유지)
            String scQuery = &quot;SELECT screened_dt, type, value, policy_desc FROM vitalcare.api_screeningrecord WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),@secretkey,@iv) AS CHAR) = ? AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id),@secretkey,@iv) AS CHAR) = ? AND deleted = 0 AND screened_dt = ? AND type = ?&quot;
            List scRecords = []
            boolean expectAlarm = matchedPolicies.any { it.contains(&quot;POLICY&quot;) }
            
            // ... (Retry 로직 및 결과 판정 로직 동일) ...
            int retry = 0
            while (retry &lt; 5) {
                try (PreparedStatement ps = conn.prepareStatement(scQuery)) {
                    ps.setString(1, patientID); ps.setString(2, encounterID); ps.setString(3, baseDtStr); ps.setString(4, subCategory)
                    try (ResultSet rs = ps.executeQuery()) {
                        scRecords.clear()
                        while (rs.next()) scRecords.add([dt: rs.getString(1), type: rs.getString(2), val: rs.getString(3), desc: rs.getString(4)])
                    }
                }
                if (scRecords.isEmpty() &amp;&amp; expectAlarm) { retry++; Thread.sleep(1200) } 
                else break
            }

            // 최종 판정 로직
            String finalResultStr = &quot;&quot;
            String statusForLog = &quot;&quot;
            if (vcEvents.isEmpty()) { finalResultStr = &quot;N/A&quot;; statusForLog = &quot;N/A&quot; }
            else if (!expectAlarm) {
                if (scRecords.isEmpty()) { finalResultStr = &quot;PASS&quot;; statusForLog = &quot;NORMAL_OK&quot; }
                else { finalResultStr = &quot;FAIL&quot;; statusForLog = &quot;UNEXPECTED_ALARM&quot; }
            } else {
                if (!scRecords.isEmpty()) { finalResultStr = &quot;PASS&quot;; statusForLog = &quot;ALARM_OK&quot; }
                else { finalResultStr = &quot;FAIL&quot;; statusForLog = &quot;MISSING_ALARM&quot; }
            }

            // 5. CSV 기록 (가독성 처리 포함)
            String displayVCEvent = vcEvents.collect { &quot;[${it.observed_dt}|${it.subcategory}|${it.value}]&quot; }.join(&quot;|&quot;)
            String displayPolicy = matchedPolicies.join(&quot;|&quot;)
            String displayScreening = scRecords.collect { &quot;[${it.dt}|${it.type}|${it.val}|${it.desc}]&quot; }.join(&quot;|&quot;)

            String csvDataString = String.format(&quot;%s,%s,%s,%d,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s&quot;,
                vars.get(&quot;currentScenarioGroupName&quot;), 
                ctx.getThreadGroup().getName(),
                subCategory, 
                ctx.getThreadNum(),
                startTime2, convertTimestamp(System.currentTimeMillis()), 
                patientID, encounterID,
                (vars.getObject(&quot;procedureLogs&quot;) ?: []).join(&quot;||&quot;), 
                thresholdSnapshotStr, // 업데이트된 snapshot 사용
                displayVCEvent, displayPolicy, displayScreening, 
                statusForLog, finalResultStr)

            logResults(prev, ctx, props, vars, csvDataString)
            vars.putObject(&quot;procedureLogs&quot;, []) 
        }
    }
} catch (Exception e) { 
    log.error(&quot;Result Check Error: &quot;, e) 
}</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
      <PostThreadGroup guiclass="PostThreadGroupGui" testclass="PostThreadGroup" testname="tearDown Thread Group" enabled="true">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">10</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">false</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </PostThreadGroup>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(result)_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.io.File
import groovy.json.JsonSlurper
import groovy.json.JsonOutput
import java.text.SimpleDateFormat

// --- 기존 경로 및 변수 설정 ---
def userHome = props.get(&quot;userHome&quot;)
def date = props.get(&quot;date&quot;)
def outputDir = props.get(&quot;outputDir&quot;)
def outputVersion = vars.get(&quot;version&quot;)
def outputHtmlPath = outputDir + &quot;${outputVersion}_Screening_Service_Result.html&quot;

def dateFormatter = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
def failedPatients = [:].withDefault { [] }
def policyStats = [:].withDefault { 0 } // 정책 통계용 변수 추가


// --- 데이터 처리 로직 ---
def csvFiles = Files.list(Paths.get(outputDir)).filter { it.toString().endsWith(&quot;.csv&quot;) }.sorted().collect()
// skipCount 필드 추가
def overallStats = [startTime: null, endTime: null, totalTest: 0, passCount: 0, failCount: 0, skipCount: 0]
def threadGroupStats = []
def combinedData = new StringBuilder()

csvFiles.eachWithIndex { file, idx -&gt;
    def stats = processCsvFile(file.toFile(), combinedData, failedPatients, policyStats)
    threadGroupStats &lt;&lt; stats
    updateOverallStats(overallStats, stats)
}

def totalScenarios = threadGroupStats.size()
// Fail Rate는 검증이 수행된 totalTest(PASS+FAIL) 기준으로 계산
def failRate = overallStats.totalTest &gt; 0 ? sprintf(&quot;%.1f&quot;, (overallStats.failCount / overallStats.totalTest) * 100) : &quot;0&quot;

// --- HTML 작성 시작 ---
def htmlContent = &quot;&quot;&quot;
&lt;script src=&quot;https://cdn.jsdelivr.net/npm/chart.js&quot;&gt;&lt;/script&gt;

&lt;style&gt;
    .report-wrapper {
        font-family: -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, Roboto, Arial, sans-serif;
        color: #334155;
        background: #fff;
        padding: 10px;
    }
    .section-title {
        font-size: 11px; font-weight: 700; color: #64748b;
        text-transform: uppercase; letter-spacing: 0.5px;
        margin: 25px 0 12px 0; border-bottom: 1px solid #f1f5f9; padding-bottom: 5px;
    }
    .report-wrapper h2 { font-size: 18px; margin: 0 0 15px 0; color: #1e293b; }
    .summary-cards { display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
    .card {
        background: #f8fafc; border-radius: 12px; padding: 12px 18px;
        width: 130px; border: 1px solid #e2e8f0; box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }
    .card-title { font-size: 10px; color: #64748b; margin-bottom: 4px; font-weight: 600; }
    .card-value { font-size: 18px; font-weight: 700; }
    .text-pass { color: #16a34a !important; }
    .text-fail { color: #dc2626 !important; }
    .text-skip { color: #64748b !important; }
    .styled-table { width: 100%; border-collapse: collapse; font-size: 13px; margin-bottom: 20px; }
    .styled-table th {
        background: #f8fafc; padding: 10px 12px; text-align: left;
        color: #64748b; font-weight: 600; border-top: 1px solid #e2e8f0; border-bottom: 1px solid #e2e8f0;
    }
    .styled-table td { padding: 10px 12px; border-bottom: 1px solid #f1f5f9; color: #334155; }
    .info-table td:first-child { width: 150px; font-weight: 600; background: #f8fafc; color: #64748b; }
    .chart-row { display: flex; gap: 15px; margin-top: 10px; }
    .chart-box { flex: 1; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 15px; min-height: 300px; }
    .chart-box-title { font-size: 12px; font-weight: 600; color: #1e293b; margin-bottom: 10px; text-align: center; }
    .canvas-wrapper { height: 240px; position: relative; }

    /* Policy Distribution Bar Style */
    .policy-bar-bg { background: #e2e8f0; border-radius: 4px; height: 10px; width: 100%; overflow: hidden; margin-top: 4px; }
    .policy-bar-fill { background: #3b82f6; height: 100%; }
&lt;/style&gt;

&lt;div class=&quot;report-wrapper&quot;&gt;
    ${createSummaryTable(overallStats, totalScenarios, failRate)}
    ${createThresholdSnapshotFromApi()}

    ${createPolicySummaryTable(policyStats, overallStats.totalTest)}

    ${createThreadGroupTable(threadGroupStats)}
    ${createtotalTestChart(threadGroupStats)}
    ${createFailPatientTable(failedPatients)}
&lt;/div&gt;
&quot;&quot;&quot;

// --- 함수 정의부 ---

def createPolicySummaryTable(policyStats, totalTests) {
    def html = &quot;&quot;&quot;
    &lt;div class=&quot;section-title&quot;&gt;Matched Policy Distribution&lt;/div&gt;
    &lt;table class=&quot;styled-table&quot;&gt;
        &lt;thead&gt;
            &lt;tr&gt;
                &lt;th&gt;Policy Name&lt;/th&gt;
                &lt;th style=&quot;width: 40%;&quot;&gt;Distribution Ratio&lt;/th&gt;
                &lt;th&gt;Count&lt;/th&gt;
            &lt;/tr&gt;
        &lt;/thead&gt;
        &lt;tbody&gt;
    &quot;&quot;&quot;
    // 히트 수 높은 순으로 정렬
    def sortedPolicies = policyStats.sort { -it.value }
    
    sortedPolicies.each { name, count -&gt;
        def ratio = totalTests &gt; 0 ? (count / totalTests * 100).setScale(1, BigDecimal.ROUND_HALF_UP) : 0
        def displayName = (name == null || name == &quot;&quot; || name == &quot;null&quot;) ? &quot;NORMAL (No Policy)&quot; : name
        html += &quot;&quot;&quot;
        &lt;tr&gt;
            &lt;td style=&quot;font-weight: 600;&quot;&gt;${displayName}&lt;/td&gt;
            &lt;td&gt;
                &lt;div style=&quot;font-size: 10px; color: #64748b;&quot;&gt;${ratio}%&lt;/div&gt;
                &lt;div class=&quot;policy-bar-bg&quot;&gt;&lt;div class=&quot;policy-bar-fill&quot; style=&quot;width: ${ratio}%;&quot;&gt;&lt;/div&gt;&lt;/div&gt;
            &lt;/td&gt;
            &lt;td style=&quot;font-weight: 700;&quot;&gt;${count} hits&lt;/td&gt;
        &lt;/tr&gt;
        &quot;&quot;&quot;
    }
    html += &quot;&lt;/tbody&gt;&lt;/table&gt;&quot;
    return html
}

def createSummaryTable(overallStats, totalScenarios, failRate) {
    &quot;&quot;&quot;
    &lt;h2&gt;Test Summary&lt;/h2&gt;
    &lt;div class=&quot;summary-cards&quot;&gt;
        &lt;div class=&quot;card&quot;&gt;&lt;div class=&quot;card-title&quot;&gt;Scenarios&lt;/div&gt;&lt;div class=&quot;card-value&quot;&gt;${totalScenarios}&lt;/div&gt;&lt;/div&gt;
        &lt;div class=&quot;card&quot;&gt;&lt;div class=&quot;card-title&quot;&gt;Validated TCs&lt;/div&gt;&lt;div class=&quot;card-value&quot;&gt;${overallStats.totalTest}&lt;/div&gt;&lt;/div&gt;
        &lt;div class=&quot;card&quot;&gt;&lt;div class=&quot;card-title&quot;&gt;PASS&lt;/div&gt;&lt;div class=&quot;card-value text-pass&quot;&gt;${overallStats.passCount}&lt;/div&gt;&lt;/div&gt;
        &lt;div class=&quot;card&quot;&gt;&lt;div class=&quot;card-title&quot;&gt;FAIL&lt;/div&gt;&lt;div class=&quot;card-value text-fail&quot;&gt;${overallStats.failCount}&lt;/div&gt;&lt;/div&gt;
        &lt;div class=&quot;card&quot;&gt;&lt;div class=&quot;card-title&quot;&gt;SKIP (NO DATA)&lt;/div&gt;&lt;div class=&quot;card-value text-skip&quot;&gt;${overallStats.skipCount}&lt;/div&gt;&lt;/div&gt;
        &lt;div class=&quot;card&quot;&gt;&lt;div class=&quot;card-title&quot;&gt;FAIL RATE&lt;/div&gt;&lt;div class=&quot;card-value text-fail&quot;&gt;${failRate}%&lt;/div&gt;&lt;/div&gt;
    &lt;/div&gt;
    &lt;div class=&quot;section-title&quot;&gt;OVERALL&lt;/div&gt;
    &lt;table class=&quot;styled-table info-table&quot; style=&quot;margin-bottom: 5px;&quot;&gt;
        &lt;tr&gt;&lt;td&gt;Start Time&lt;/td&gt;&lt;td&gt;${overallStats.startTime ?: &apos;N/A&apos;}&lt;/td&gt;&lt;/tr&gt;
        &lt;tr&gt;&lt;td&gt;End Time&lt;/td&gt;&lt;td&gt;${overallStats.endTime ?: &apos;N/A&apos;}&lt;/td&gt;&lt;/tr&gt;
        &lt;tr&gt;&lt;td&gt;Duration (sec)&lt;/td&gt;&lt;td&gt;${overallStats.duration ?: &apos;N/A&apos;}&lt;/td&gt;&lt;/tr&gt;
    &lt;/table&gt;
    &quot;&quot;&quot;
}

def createThresholdSnapshotFromApi() {
    def apiResponse = props.get(&quot;apiResponse&quot;)
    if (!apiResponse) return &quot;&quot;
    try {
        def responseObj = new JsonSlurper().parseText(apiResponse)
        def data = responseObj.data
        if (!data) return &quot;&quot;
        def html = &quot;&quot;&quot;
        &lt;div class=&quot;section-title&quot;&gt;Threshold Snapshot&lt;/div&gt;
        &lt;div class=&quot;card&quot; style=&quot;width: 100%; box-sizing: border-box; margin-bottom: 20px; background: #fff; padding: 15px 20px;&quot;&gt;
            &lt;ul style=&quot;margin: 0; padding: 0; font-size: 13px; color: #475569; line-height: 2.0; list-style: none;&quot;&gt;
        &quot;&quot;&quot;
        [&quot;vitals&quot;, &quot;medicals&quot;, &quot;labs&quot;].each { category -&gt;
            data[category]?.each { item -&gt;
                def lineParts = []
                if (item.belowRange?.to?.value != null) lineParts &lt;&lt; &quot;&lt;b&gt;${item.subcategory}&lt;/b&gt; ≤ ${item.belowRange.to.value}&quot;
                if (item.aboveRange?.from?.value != null) lineParts &lt;&lt; &quot;&lt;b&gt;${item.subcategory}&lt;/b&gt; ≥ ${item.aboveRange.from.value}&quot;
                if (lineParts) html += &quot;&lt;li style=&apos;padding: 2px 0;&apos;&gt;&quot; + lineParts.join(&quot; | &quot;) + &quot;&lt;/li&gt;&quot;
            }
        }
        html += &quot;&lt;/ul&gt;&lt;/div&gt;&quot;
        return html
    } catch (Exception e) { return &quot;&quot; }
}

def createThreadGroupTable(threadGroupStats) {
    def html = &quot;&quot;&quot;
    &lt;div class=&quot;section-title&quot;&gt;SCENARIO BREAKDOWN STATISTICS&lt;/div&gt;
    &lt;table class=&quot;styled-table&quot;&gt;
        &lt;thead&gt;
            &lt;tr&gt;
                &lt;th&gt;SCENARIO&lt;/th&gt;
                &lt;th&gt;CATEGORY&lt;/th&gt;
                &lt;th&gt;VALIDATED&lt;/th&gt;
                &lt;th&gt;PASS&lt;/th&gt;
                &lt;th&gt;FAIL&lt;/th&gt;
                &lt;th&gt;SKIP(NO DATA)&lt;/th&gt;
                &lt;th&gt;Fail Rate&lt;/th&gt;
                &lt;th&gt;Duration(s)&lt;/th&gt;
            &lt;/tr&gt;
        &lt;/thead&gt;
        &lt;tbody&gt;
    &quot;&quot;&quot;
    threadGroupStats.each { stats -&gt;
        def fRate = stats.totalTest &gt; 0 ? sprintf(&quot;%.1f&quot;, (stats.failCount * 100.0 / stats.totalTest)) + &quot;%&quot; : &quot;0.0%&quot;
        def rowStyle = stats.failCount &gt; 0 ? &quot;style=&apos;background-color: #fff1f2;&apos;&quot; : &quot;&quot;
        html += &quot;&quot;&quot;
        &lt;tr ${rowStyle}&gt;
            &lt;td style=&quot;font-weight: 500;&quot;&gt;${stats.name}&lt;/td&gt;
            &lt;td style=&quot;font-weight: 500;&quot;&gt;${stats.category}&lt;/td&gt;
            &lt;td&gt;${stats.totalTest}&lt;/td&gt;
            &lt;td class=&quot;text-pass&quot; style=&quot;font-weight:bold&quot;&gt;${stats.passCount}&lt;/td&gt;
            &lt;td class=&quot;${stats.failCount &gt; 0 ? &apos;text-fail&apos; : &apos;&apos;}&quot; style=&quot;font-weight:bold&quot;&gt;${stats.failCount}&lt;/td&gt;
            &lt;td style=&quot;color: #94a3b8;&quot;&gt;${stats.skipCount}&lt;/td&gt;
            &lt;td class=&quot;${stats.failCount &gt; 0 ? &apos;text-fail&apos; : &apos;&apos;}&quot;&gt;${fRate}&lt;/td&gt;
            &lt;td&gt;${stats.duration}&lt;/td&gt;
        &lt;/tr&gt;
        &quot;&quot;&quot;
    }
    html += &quot;&lt;/tbody&gt;&lt;/table&gt;&quot;
    return html
}

def createtotalTestChart(threadGroupStats) {
    def threadGroupNames = threadGroupStats.collect { it.name }
    def passCounts = threadGroupStats.collect { it.passCount }
    def failCounts = threadGroupStats.collect { it.failCount }
    def labelsJson = groovy.json.JsonOutput.toJson(threadGroupNames)
    def passDataJson = groovy.json.JsonOutput.toJson(passCounts)
    def failDataJson = groovy.json.JsonOutput.toJson(failCounts)
    &quot;&quot;&quot;
    &lt;div class=&quot;section-title&quot;&gt;VISUALIZATIONS&lt;/div&gt;
    &lt;div class=&quot;chart-row&quot;&gt;
        &lt;div class=&quot;chart-box&quot;&gt;
            &lt;div class=&quot;chart-box-title&quot;&gt;PASS/FAIL per Scenario&lt;/div&gt;
            &lt;div class=&quot;canvas-wrapper&quot;&gt;&lt;canvas id=&quot;barChart&quot;&gt;&lt;/canvas&gt;&lt;/div&gt;
        &lt;/div&gt;
        &lt;div class=&quot;chart-box&quot; style=&quot;flex: 0.6;&quot;&gt;
            &lt;div class=&quot;chart-box-title&quot;&gt;Overall PASS vs FAIL&lt;/div&gt;
            &lt;div class=&quot;canvas-wrapper&quot;&gt;&lt;canvas id=&quot;pieChart&quot;&gt;&lt;/canvas&gt;&lt;/div&gt;
        &lt;/div&gt;
    &lt;/div&gt;
    &lt;script&gt;
    (function() {
        var initCharts = function() {
            new Chart(document.getElementById(&apos;barChart&apos;), {
                type: &apos;bar&apos;,
                data: {
                    labels: ${labelsJson},
                    datasets: [
                        { label: &apos;PASS&apos;, data: ${passDataJson}, backgroundColor: &apos;#4b89e8&apos; },
                        { label: &apos;FAIL&apos;, data: ${failDataJson}, backgroundColor: &apos;#ef4444&apos; }
                    ]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    scales: { x: { stacked: true, grid: { display: false } }, y: { stacked: true, beginAtZero: true } },
                    plugins: { legend: { position: &apos;bottom&apos;, labels: { boxWidth: 10, font: { size: 11 } } } }
                }
            });
            new Chart(document.getElementById(&apos;pieChart&apos;), {
                type: &apos;doughnut&apos;,
                data: {
                    labels: [&apos;PASS&apos;, &apos;FAIL&apos;],
                    datasets: [{
                        data: [${passCounts.sum() ?: 0}, ${failCounts.sum() ?: 0}],
                        backgroundColor: [&apos;#4b89e8&apos;, &apos;#ef4444&apos;],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    cutout: &apos;30%&apos;,
                    plugins: { legend: { position: &apos;bottom&apos;, labels: { boxWidth: 10, font: { size: 11 } } } }
                }
            });
        };
        setTimeout(initCharts, 300);
    })();
    &lt;/script&gt;
    &quot;&quot;&quot;
}

def createFailPatientTable(failedPatients) {
    if (!failedPatients || failedPatients.every { k, v -&gt; v.isEmpty() }) return &quot;&quot;
    def html = &quot;&quot;&quot;&lt;div class=&quot;section-title&quot;&gt;Failed Case Details&lt;/div&gt;
                  &lt;table class=&quot;styled-table&quot;&gt;
                  &lt;thead&gt;&lt;tr&gt;&lt;th&gt;Scenario Group&lt;/th&gt;&lt;th&gt;Failed Patient IDs&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;
                  &lt;tbody&gt;&quot;&quot;&quot;
    failedPatients.each { group, patients -&gt;
        if (patients &amp;&amp; !patients.isEmpty()) {
            html += &quot;&lt;tr&gt;&lt;td&gt;${group}&lt;/td&gt;&lt;td class=&apos;text-fail&apos; style=&apos;word-break:break-all&apos;&gt;${patients.unique().join(&apos;, &apos;)}&lt;/td&gt;&lt;/tr&gt;&quot;
        }
    }
    html += &quot;&lt;/tbody&gt;&lt;/table&gt;&quot;
    return html
}

def processCsvFile(File file, StringBuilder combinedData, Map failedPatients, Map policyStats) {
    def stats = [name: file.getName().replace(&quot;.csv&quot;, &quot;&quot;), totalTest: 0, passCount: 0, failCount: 0, skipCount: 0, startTime: null, endTime: null, duration: 0]
    def lines = file.readLines()
    if (lines.size() &lt; 2) return stats
    
    def dataLines = lines.drop(1)
    dataLines.eachWithIndex { line, index -&gt;
        // CSV가 탭이나 콤마로 구분될 수 있으므로 분리 (보통 JMeter CSV는 콤마)
        def columns = line.split(&quot;,&quot;).collect { it.trim() }
        if (index == 0 &amp;&amp; columns.size() &gt; 0) { 
        	stats.name = columns[1]
        	stats.category = columns[2]
        }
        
        // --- 정책(MatchedPolicy) 수집 (인덱스 11번) ---
        def policyName = columns[11]
        policyStats[policyName]++

        // 가장 마지막 컬럼을 가져옴 (Test Result 컬럼)
        def resultCol = columns[columns.size() - 1].toUpperCase() 
        
        // --- [수정된 판정 로직] ---
        if (resultCol.contains(&quot;N/A&quot;)) {
            // 로그에 SKIP가 포함되어 있으면 SKIP으로 간주
            stats.skipCount++
        } else if (resultCol.contains(&quot;PASS&quot;)) {
            stats.totalTest++
            stats.passCount++
        } else if (resultCol.contains(&quot;FAIL&quot;)) {
            stats.totalTest++
            stats.failCount++
            // Patient ID는 앞에서 3번째(인덱스 2) 또는 6번째(인덱스 5)에 위치하므로 안전하게 추출
            def patientId = columns.size() &gt; 2 ? columns[2] : &quot;N/A&quot;
            failedPatients[stats.name] &lt;&lt; patientId
        }
        // -------------------------

        // 시간 정보 추출 (인덱스 3, 4번이 시간이라고 가정)
        try {
            if (columns.size() &gt; 4) {
                if (stats.startTime == null || columns[4] &lt; stats.startTime) stats.startTime = columns[4]
                if (stats.endTime == null || columns[5] &gt; stats.endTime) stats.endTime = columns[5]
            }
        } catch(e) {}
    }
    
    // 시간 계산 로직
    if (stats.startTime &amp;&amp; stats.endTime) {
        try {
            def st = Date.parse(&quot;yyyy-MM-dd HH:mm:ss&quot;, stats.startTime)
            def et = Date.parse(&quot;yyyy-MM-dd HH:mm:ss&quot;, stats.endTime)
            stats.duration = (et.time - st.time) / 1000
        } catch(e) {}
    }
    return stats
}

def updateOverallStats(overallStats, stats) {
    overallStats.totalTest += stats.totalTest
    overallStats.passCount += stats.passCount
    overallStats.failCount += stats.failCount
    overallStats.skipCount += stats.skipCount
    if (overallStats.startTime == null || (stats.startTime &amp;&amp; stats.startTime &lt; overallStats.startTime)) overallStats.startTime = stats.startTime
    if (overallStats.endTime == null || (stats.endTime &amp;&amp; stats.endTime &gt; overallStats.endTime)) overallStats.endTime = stats.endTime
    if (overallStats.startTime &amp;&amp; overallStats.endTime) {
        try {
            def st = Date.parse(&quot;yyyy-MM-dd HH:mm:ss&quot;, overallStats.startTime)
            def et = Date.parse(&quot;yyyy-MM-dd HH:mm:ss&quot;, overallStats.endTime)
            overallStats.duration = (et.time - st.time) / 1000
        } catch(e) {}
    }
}

try {
    Files.write(Paths.get(outputHtmlPath), htmlContent.getBytes(&quot;UTF-8&quot;))
    log.info(&quot;Integrated Result HTML generated: ${outputHtmlPath}&quot;)
} catch (Exception e) {
    log.error(&quot;Write error: &quot; + e.message)
}</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="mmakeHtml(Result_Detail_Log)_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import groovy.json.JsonOutput
import groovy.json.JsonSlurper
import java.nio.charset.StandardCharsets
import org.apache.commons.lang3.StringEscapeUtils

// 경로 설정
def userHome = props.get(&quot;userHome&quot;)
def date = props.get(&quot;date&quot;)
def outputDir = props.get(&quot;outputDir&quot;)

// 디렉토리 내 .csv 파일 처리 및 정렬
def detailLogFiles = Files.list(Paths.get(outputDir))
    .filter { it.toString().endsWith(&quot;.csv&quot;) } // .csv 파일만 필터링
    .sorted { a, b -&gt; a.getFileName().toString() &lt;=&gt; b.getFileName().toString() } // 파일 이름으로 정렬
    .collect()

if (detailLogFiles.isEmpty()) {
    log.info(&quot;CSV files found count = ${detailLogFiles.size()}&quot;)
} else {
    detailLogFiles.eachWithIndex { logFile, idx -&gt;
        def logFileName = logFile.getFileName().toString().replace(&quot;.csv&quot;, &quot;&quot;)        
        def htmlContent = &quot;&quot;&quot;
        &lt;html&gt;
        &lt;head&gt;
            &lt;title&gt;${logFileName} - CSV to HTML Report&lt;/title&gt;
            &lt;meta charset=&quot;UTF-8&quot;&gt;
            &lt;style&gt;
                table {
                    width: 100%;
                    border-collapse: collapse;
                    font-size: 11px;          /* 전체 테이블 폰트 크기 조정 */
                    font-family: Arial, sans-serif;
                }
                th, td {
                    padding: 6px;             /* padding 약간 줄임 */
                    border: 1px solid #ddd;
                    font-size: 11px;          /* 개별 셀 폰트 크기 조정 */
                }
                .log-cell {
                    font-family: monospace;
                    font-size: 10px;          /* 로그용 monospace 글자 작게 */
                    line-height: 1.4;
                }
                .status-badge {
                    display: inline-block;
                    min-width: 30px;
                    padding: 1px 6px;
                    text-align: center;
                    border-radius: 999px;
                    font-weight: bold;
                    font-size: 10px;          /* PASS/FAIL 배지 폰트 축소 */
                }
                .input-label, .delete-label, .db-label, .threshold-label {
                    display: inline-block;
                    padding: 1px 4px;
                    font-size: 10px;          /* 라벨 폰트 축소 */
                    font-weight: bold;
                    border-radius: 4px;
                    margin-right: 4px;
                }
                /* 배경색/스타일 그대로 유지 */
                .status-pass { color: #4A90E2; border:1px solid #4A90E2; background-color:#F0F6FF; }
                .status-fail { color: #D0021B; border:1px solid #D0021B; background-color:#FFF1F1; }
                .input-label { background-color:#EEF2F7; color:#3A4A5B; }
                .delete-label { background-color:#F6F2EC; color:#6B4F2A; }
                .db-label { background-color:#E8F4FF; color:#1F5A8A; }
                .threshold-label { background-color:#F1F8E9; color:#4E7D2B; }
            &lt;/style&gt;
        &lt;/head&gt;
        &lt;body&gt;
        &lt;table&gt;
        &quot;&quot;&quot;

        try {
            def lines = Files.readAllLines(logFile, StandardCharsets.UTF_8)
            if (lines.size() &gt; 1) {
                // 첫 번째 줄을 헤더로 사용
                def headers = lines[0].split(&quot;,&quot;)
                
                def removeColumns = [&quot;Group&quot;, &quot;StartTime&quot;, &quot;EndTime&quot;] as Set
                def visibleHeaders = headers
                	.findAll { !(it in removeColumns) }

//                def visibleHeaders = headers.drop(1)
                htmlContent += &quot;&lt;tr&gt;&quot; + visibleHeaders.collect { &quot;&lt;th&gt;${escapeHtml(it)}&lt;/th&gt;&quot; }.join(&apos;&apos;) + &quot;&lt;/tr&gt;&quot;

                // 나머지 줄을 데이터로 사용 (두 번째 컬럼을 기준으로 정렬)
			def sortedLines = lines.drop(1).sort { a, b -&gt;
				try {
					def c1 = a.split(&quot;,&quot;)
					def c2 = b.split(&quot;,&quot;)

					def s1 = (c1[1] =~ /Scenario (\d+)/)[0][1].toInteger()
					def s2 = (c2[1] =~ /Scenario (\d+)/)[0][1].toInteger()

					if (s1 != s2) {
						return s1 &lt;=&gt; s2
					}

					def p1 = c1[5]?.trim()
					def p2 = c2[5]?.trim()

					return p1 &lt;=&gt; p2
				} catch (Exception ex) {
        				log.error(&quot;정렬 중 예외 발생 ▶ a=${a} / b=${b}&quot;, ex)
        				return 0   // 반드시 숫자 리턴
    				}
			}
                
			sortedLines.each { line -&gt;
				try {

				    def columns = line.split(&quot;,&quot;, -1)  // 마지막 빈 컬럼까지 배열에 포함

				    def visibleColumns = []
				    headers.eachWithIndex { h, i -&gt;
				    		if (!(h in removeColumns)) {
				    			visibleColumns &lt;&lt; columns[i]
				    		}
				    }
	                	   
//	                   def visibleColumns = columns.drop(1)
				    htmlContent += &quot;&lt;tr&gt;&quot; +
				        visibleColumns.collect { col -&gt;
				            def raw = col?.trim()              // 비교용 (원본)
						  def safe = escapeHtml(raw)         // 출력용
						  safe = safe.replace(&quot;||&quot;, &quot;&lt;br/&gt;&quot;)
						  safe = safe.replace(&quot;;&quot;, &quot; : &quot;)
	
						  if (raw.contains(&quot;INPUT:&quot;)) {
							  safe = safe.replaceAll(
								  &quot;INPUT:&quot;,
								  &quot;&lt;span class=&apos;input-label&apos;&gt;INPUT&lt;/span&gt;&lt;br/&gt;&quot;
							  )
						  }

						  if (raw.contains(&quot;DELETE:&quot;)) {
							  safe = safe.replaceAll(
								  &quot;DELETE:&quot;,
								  &quot;&lt;span class=&apos;delete-label&apos;&gt;DELETE&lt;/span&gt;&lt;br/&gt;&quot;
							  )
						  }
						  if (raw.contains(&quot;DB:&quot;)) {
							  safe = safe.replaceAll(
								  &quot;DB:&quot;,
								  &quot;&lt;span class=&apos;db-label&apos;&gt;DB&lt;/span&gt;&lt;br/&gt;&quot;
							  )
						  }
						  if (raw.contains(&quot;THRESHOLD:&quot;)) {
						      safe = safe.replaceAll(
						          &quot;THRESHOLD:&quot;,
						          &quot;&lt;span class=&apos;threshold-label&apos;&gt;THRESHOLD&lt;/span&gt;&lt;br/&gt;&quot;
						      )
						  }
						  
						  if (raw.equalsIgnoreCase(&quot;PASS&quot;)) {
							  return &quot;&lt;td&gt;&lt;span class=&apos;status-badge status-pass&apos;&gt;PASS&lt;/span&gt;&lt;/td&gt;&quot;
						  } else if (raw.equalsIgnoreCase(&quot;FAIL&quot;)) {
							  return &quot;&lt;td&gt;&lt;span class=&apos;status-badge status-fail&apos;&gt;FAIL&lt;/span&gt;&lt;/td&gt;&quot;
						  } else {
							  return &quot;&lt;td class=&apos;log-cell&apos; style=&apos;font-size: 10px !important;&apos;&gt;${safe}&lt;/td&gt;&quot;
						  }
				        }.join(&apos;&apos;) +
				        &quot;&lt;/tr&gt;&quot;
				} catch (Exception ex) {
					log.error(&quot;Row 처리 중 예외 발생 ▶ line=${line}&quot;, ex)
				}
			}

            }
        } catch (Exception e) {
            println &quot;Failed to read log file: ${logFile}, error: ${e.message}&quot;
        }

        htmlContent += &quot;&quot;&quot;
        &lt;/table&gt;
        &lt;/body&gt;
        &lt;/html&gt;
        &quot;&quot;&quot;

        // 각 CSV 파일에 대해 개별 HTML 파일 저장
        def outputHtmlPath = outputDir + &quot;${logFileName}.html&quot;
        try {
            Files.write(Paths.get(outputHtmlPath), htmlContent.getBytes(StandardCharsets.UTF_8))
            println &quot;HTML report generated for ${logFileName}: ${outputHtmlPath}&quot;
        } catch (Exception e) {
            println &quot;Failed to write HTML file: ${outputHtmlPath}, error: ${e.message}&quot;
        }
    }
}

// 특수 문자 HTML-Escape 함수 (JSON 데이터 보호 포함)
def escapeHtml(String input) {
    if (input == null) {
        return &quot;&quot;
    }
    return input.replaceAll(&quot;&amp;&quot;, &quot;&amp;amp;&quot;)
                .replaceAll(&quot;&lt;&quot;, &quot;&amp;lt;&quot;)
                .replaceAll(&quot;&gt;&quot;, &quot;&amp;gt;&quot;)
                .replaceAll(&quot;\&quot;&quot;, &quot;&amp;quot;&quot;)
                .replaceAll(&quot;&apos;&quot;, &quot;&amp;#39;&quot;)
}

// 유니코드 이스케이프 문자열을 한글로 변환
def decodeUnicode(String input) {
    return StringEscapeUtils.unescapeJava(input)
}

def formatJson(String jsonString) {
    try {
        def jsonObj = new JsonSlurper().parseText(jsonString)
        return decodeUnicode(JsonOutput.prettyPrint(JsonOutput.toJson(jsonObj))) 
    } catch (Exception e) {
        return decodeUnicode(jsonString) 
    }
}
</stringProp>
        </JSR223Sampler>
