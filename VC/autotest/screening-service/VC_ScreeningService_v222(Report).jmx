        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter
import java.nio.charset.StandardCharsets

def logResults = { prev, ctx, props, vars, csvDataString -&gt;

	if (csvDataString == null || csvDataString.trim().isEmpty()) {
		log.error(&quot;csvDataString is null or empty.&quot;)
		return
	}
	
	def now = LocalDateTime.now().format(DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd HH:mm:ss&quot;))
	def outputDir = props.get(&quot;outputDir&quot;)

	if (!Files.exists(Paths.get(outputDir))) {
		Files.createDirectories(Paths.get(outputDir))
	}

	def csvDataArray = csvDataString.split(&quot;,&quot;)  // CSV 데이터를 배열로 변환
	def fullThreadName = prev.getThreadName()
	def threadGroupName = fullThreadName.split(&quot; &quot;)[0] + fullThreadName.split(&quot; &quot;)[1]
	def scenarioGroupName = vars.get(&quot;currentScenarioGroupName&quot;)

	def resultFile = Paths.get(outputDir, &quot;${scenarioGroupName}.csv&quot;)

	//def csvHeader = &quot;Group,Scenario,StartTime,EndTime,Patient ID, Encounter ID, ICU, Vital Count, ObservedDt Count, base_dt, news, mews, mors, cared, seps, maes, Test Result\n&quot;
	def csvHeader = &quot;Group,Scenario,Category,Case,StartTime,EndTime,Patient ID,Encounter ID,ProcedureLog,ThresholdSnapshot,VC_Event,MatchedPolicy,ScreeningRecord,STATUS,Test Result\n&quot;

	if (!Files.exists(resultFile)) {
		Files.createDirectories(resultFile.parent)
		Files.write(resultFile, csvHeader.getBytes(StandardCharsets.UTF_8), StandardOpenOption.CREATE)
	}

	// 데이터 추가 (ThreadGroupName, SamplerName, csvDataString)
//	def dataToWrite = &quot;${scenarioGroupName}, ${csvDataString}\n&quot;
//
//	Files.write(resultFile, dataToWrite.getBytes(StandardCharsets.UTF_8), StandardOpenOption.APPEND)
	Files.write(
	    resultFile,
	    (csvDataString + &quot;\n&quot;).getBytes(StandardCharsets.UTF_8),
	    StandardOpenOption.APPEND
	)

}

vars.putObject(&quot;logResults&quot;, logResults)
</stringProp>
        </JSR223PreProcessor>
