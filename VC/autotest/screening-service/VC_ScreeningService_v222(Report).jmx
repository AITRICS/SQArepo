        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;
import java.time.ZoneId;
import java.nio.file.Files
import java.nio.file.Path
import java.nio.file.Paths
import java.io.IOException

def userHome = System.getProperty(&quot;user.home&quot;);
def date = LocalDateTime.now().format(DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;));
def outputVersion = vars.get(&quot;version&quot;)
def outputDir = userHome + &quot;/QA_Amelia/apache-jmeter-5.6.3/scripts/scripts_result/Screening_Service/&quot; + date + &quot;/&quot; + outputVersion + &quot;/&quot;
props.put(&quot;date&quot;, date);
props.put(&quot;outputDir&quot;, outputDir);

props.put(&quot;proceedFlag&quot;, &quot;true&quot;);



// 폴더 내 파일 중 ${version}을 포함한 파일만 삭제하는 함수
def deleteFilesInDirectory(directoryPath, version) {
    Path dir = Paths.get(directoryPath)
    if (Files.exists(dir) &amp;&amp; Files.isDirectory(dir)) {
        Files.walk(dir)
            .filter { path -&gt; !Files.isDirectory(path) &amp;&amp; path.toString().contains(version) }  // ${version}이 포함된 파일만 선택
            .forEach { path -&gt; 
                try {
                    Files.delete(path)  // 파일 삭제
                    println(&quot;Deleted file: ${path}&quot;)
                } catch (IOException e) {
                    println(&quot;Error deleting file: ${path} - ${e.message}&quot;)
                }
            }
    }
}

// outputDir 내 ${version}이 포함된 파일만 삭제
deleteFilesInDirectory(outputDir, outputVersion)</stringProp>
        </JSR223Sampler>
