        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="ICU_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;

// JDBC connection information
String url = &quot;${JDBC_URL_EMR}&quot;;
String user = &quot;${JDBC_USER_EMR}&quot;;
String password = &quot;${JDBC_PW_EMR}&quot;;

// JDBC connection &amp; Define the query
try (Connection conn = DriverManager.getConnection(url, user, password)) {
	String query = &quot;INSERT INTO ROOT.ICUS (PATIENT_ID, ENCOUNTER_ID, START_DT, END_DT, DELETED_YN)&quot; +
				&quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?)&quot;;

	// Prepare the statement &amp; Repeat the process for multiple sets of parameters
	try (PreparedStatement stmt = conn.prepareStatement(query)) {
		String threadGroupName = ctx.getThreadGroup().getName();
		// Repeat the process for multiple sets of parameters
		int repeatCount = ${PatientCount}; // Number of repetitions set
		for (int i = 0; i &lt; repeatCount; i++) {
			// Set parameters for the query
			String patientID = vars.get(&quot;PatientID&quot; + i);
			String encounterID = vars.get(&quot;EncounterID&quot; + i);
			String icuIn = vars.get(&quot;icuIn&quot; + i);
			String icuOut = vars.get(&quot;icuOut&quot; + i);

			// If User_Thread is even, insert into ICU
			if (${User_Thread} % 2 == 0) {			
				stmt.setString(1, patientID);
				stmt.setString(2, encounterID);
				stmt.setString(3, icuIn);
				stmt.setNull(4, java.sql.Types.DATE); // Set END_DT to NULL
				stmt.setInt(5, 0); // Set DELETED_YN to 0

				// Execute the query
				stmt.executeUpdate();
				log.info(&quot;PatientID=&quot; + patientID + &quot;, EncounterID=&quot; + encounterID + &quot;, icuIn=&quot; + icuIn + &quot;, icuOut=null&quot;);

//				def procedureLogs = vars.getObject(&quot;procedureLogs&quot;)
//				if (procedureLogs != null) {
//					procedureLogs.add(
//						&quot;INPUT: ${icuIn} [ICU-IN]&quot;
//					)
//				}

				// Clear parameters for reusing the statement
				stmt.clearParameters();
			} else {
				stmt.setString(1, patientID);
				stmt.setString(2, encounterID);
				stmt.setString(3, icuIn);
				stmt.setString(4, icuOut);
				stmt.setInt(5, 0); // Set DELETED_YN to 0

				// Execute the query
				stmt.executeUpdate();
				log.info(&quot;PatientID=&quot; + patientID + &quot;, EncounterID=&quot; + encounterID + &quot;, icuIn=&quot; + icuIn + &quot;, icuOut=&quot; + icuOut);

//				def procedureLogs = vars.getObject(&quot;procedureLogs&quot;)
//				if (procedureLogs != null) {
//					procedureLogs.add(
//						&quot;INPUT: ${icuIn} [ICU-IN] ${icuOut} [ICU-OUT]&quot;
//					)
//				}
				
				// Clear parameters for reusing the statement
				stmt.clearParameters();
			}
		}
	}
} catch (Exception e) {
	log.error(&quot;Exception: &quot;, e);
}</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET ICU Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.TimeZone;
import java.util.Calendar;

// Default timestamp
long timestampDefault = ${timestamp_default};
//long timestampDefault = props.get(&quot;timestamp_default&quot;) as long;

// Repeat count
int repeatCount = ${PatientCount}; // Number of repetitions set
int observationCount = ${ObservationCount};
int intervalMin = ${Ob_Interval_Min};

// Iterate in 8-hour intervals to set past timestamps and store them in variables			// Clear parameters for reusing the statement
for (int i = 0; i &lt; repeatCount; i++) {
	// Create a Date object
	Date PatientSet = new Date(timestampDefault);
	Date EncounterSet = new Date(timestampDefault);
	//Set icu In Date
	Calendar calendar = Calendar.getInstance();
	calendar.setTimeInMillis(timestampDefault); // Set the default timestamp		
	calendar.add(Calendar.MINUTE, - ((observationCount + 2) * intervalMin))

	long icuInSetTimestamp = calendar.getTimeInMillis();
	Date icuInSet= new Date(icuInSetTimestamp);

	//Set icu Out Date
	calendar.setTimeInMillis(icuInSetTimestamp); // Set the default timestamp		
	calendar.add(Calendar.HOUR, 3);

	long icuOutSetTimestamp = calendar.getTimeInMillis();
	Date icuOutSet= new Date(icuOutSetTimestamp);
	
	String threadGroupName = ctx.getThreadGroup().getName();
	String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1];

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i+&quot;yyMMddHHmmss&quot;+${User_Thread}+threadGroupNumber);
	sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the date to string
	String PatientID = sdf_patient.format(PatientSet);

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_encounter = new SimpleDateFormat(i+&quot;yyyyMMddHHmmss&quot;+${User_Thread}+threadGroupNumber);
	sdf_encounter.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

	// Format the date to string
	String EncounterID = sdf_encounter.format(EncounterSet);

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_icuIn = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	sdf_icuIn.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

	// Format the date to string
	String icuIn = sdf_icuIn.format(icuInSet);

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_icuOut = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	sdf_icuOut.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

	// Format the date to string
	String icuOut = sdf_icuOut.format(icuOutSet);

	// Store in variables
	vars.put(&quot;PatientID&quot; + i, PatientID);
	vars.put(&quot;EncounterID&quot; + i, EncounterID + &quot;|&quot; + PatientID);
	vars.put(&quot;icuIn&quot; + i, icuIn);
	vars.put(&quot;icuOut&quot; + i, icuOut);
}
</stringProp>
          </JSR223PreProcessor>
