        <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Wait_For_Score Sampler" enabled="true">
          <intProp name="ActionProcessor.action">1</intProp>
          <intProp name="ActionProcessor.target">0</intProp>
          <stringProp name="ActionProcessor.duration">${duration2}</stringProp>
