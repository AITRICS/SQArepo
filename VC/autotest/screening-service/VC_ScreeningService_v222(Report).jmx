        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Vital_Data_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;
import java.util.Random;

// JDBC connection information
String url = &quot;${JDBC_URL_EMR}&quot;;
String user = &quot;${JDBC_USER_EMR}&quot;;
String password = &quot;${JDBC_PW_EMR}&quot;;

// JDBC connection &amp; Define the query
try (Connection conn = DriverManager.getConnection(url, user, password)) {
	String query = &quot;INSERT INTO ROOT.VITALS (PATIENT_ID, ENCOUNTER_ID, OBSERVED_DT, CODE, VALUE, DELETED_YN, INVALID) &quot; +
				&quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?, ?, ?, ?)&quot;;

	// Prepare the statement &amp; Repeat the process for multiple sets of parameters
	try (PreparedStatement stmt = conn.prepareStatement(query)) {
		String threadGroupName = ctx.getThreadGroup().getName();
		// Repeat the process for multiple sets of parameters
		int patientCount = Integer.parseInt(vars.get(&quot;PatientCount&quot;));
		int observationCount = Integer.parseInt(vars.get(&quot;ObservationCount&quot;));
		Random random = new Random();

		// Repeat the process for multiple sets of parameters
		for (int i = 0; i &lt; patientCount; i++) {
			String patientID = vars.get(&quot;PatientID&quot; + i);
			String encounterID = vars.get(&quot;EncounterID&quot; + i);

			for (int j = 0; j &lt; observationCount; j++) {
				String observedDateTime = vars.get(&quot;ObservedDt&quot; + j);

				def insertedCodes = []

				// Set parameters for the query
				String pulseRate = random.nextInt(300) + &quot;.&quot; + random.nextInt(10);
				String respiratoryRate = random.nextInt(120) + &quot;.&quot; + random.nextInt(10);
				String bodyTemperature = (random.nextInt(25) + 25) + &quot;.&quot; + random.nextInt(10);
				String systolicBP = random.nextInt(300) + &quot;.&quot; + random.nextInt(10);
				String diastolicBP = random.nextInt(300) + &quot;.&quot; + random.nextInt(10);

				// Insert Observation
				insertObservation(stmt, patientID, encounterID, observedDateTime, &quot;PULSE&quot;, pulseRate);
				insertedCodes &lt;&lt; &quot;PULSE&quot;
				insertObservation(stmt, patientID, encounterID, observedDateTime, &quot;RESP&quot;, respiratoryRate);
				insertedCodes &lt;&lt; &quot;RESP&quot;
				insertObservation(stmt, patientID, encounterID, observedDateTime, &quot;TEMP&quot;, bodyTemperature);
				insertedCodes &lt;&lt; &quot;TEMP&quot;
				insertObservation(stmt, patientID, encounterID, observedDateTime, &quot;SBP&quot;, systolicBP);
				insertedCodes &lt;&lt; &quot;SBP&quot;
				insertObservation(stmt, patientID, encounterID, observedDateTime, &quot;DBP&quot;, diastolicBP);
				insertedCodes &lt;&lt; &quot;DBP&quot;

//				def procedureLogs = vars.getObject(&quot;procedureLogs&quot;)
//				if (procedureLogs != null) {
//					procedureLogs.add(
//						&quot;INPUT: ${observedDateTime} [${insertedCodes.join(&apos;|&apos;)}]&quot;
//			        )
//			    }
			}
		}
	}
} catch (Exception e) {
	log.error(&quot;Exception: &quot;, e);
}

private void insertObservation(PreparedStatement stmt, String patientID, String encounterID, String observedDateTime, String code, String value) throws SQLException {
	stmt.setString(1, patientID);
	stmt.setString(2, encounterID);
	stmt.setString(3, observedDateTime);
	stmt.setString(4, code);
	stmt.setDouble(5, Double.parseDouble(value));
	stmt.setInt(6, 0); // DELETED_YN
	stmt.setInt(7, 1); // INVALID
	String threadGroupName = ctx.getThreadGroup().getName();
	// Execute the query
	stmt.executeUpdate();
	log.info(&quot;PatientID=&quot; + patientID + &quot;, EncounterID=&quot; + encounterID + &quot;, observedDateTime=&quot; + observedDateTime + &quot;, Code=&quot; + code + &quot;, Value=&quot; + value);
	stmt.clearParameters();
}
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Observation Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.TimeZone;
import java.util.Calendar;

// Default timestamp
long timestampDefault = ${timestamp_default};
//long timestampDefault = props.get(&quot;timestamp_default&quot;) as long;

// Repeat count
int repeatCount = ${ObservationCount}; // Number of repetitions set
int intervalMin = ${Ob_Interval_Min};

// Iterate to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
	// Create a Date object
	Date PatientSet = new Date(timestampDefault);
	Date EncounterSet = new Date(timestampDefault);

	// Set Observe Date
	Calendar calendar = Calendar.getInstance();
	calendar.setTimeInMillis(timestampDefault); // Set the default timestamp		
	calendar.add(Calendar.MINUTE, - ((repeatCount + 1) * intervalMin))

	long ObservedDtSetTimestamp = calendar.getTimeInMillis();
	Date ObservedDtSet = new Date(ObservedDtSetTimestamp);
	
	String threadGroupName = ctx.getThreadGroup().getName();
	String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1];

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i+&quot;yyMMddHHmmss&quot;+${User_Thread}+threadGroupNumber);
	sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the date to string
	String PatientID = sdf_patient.format(PatientSet);
	
	// Create a SimpleDateFormat object for EncounterID and set it to UTC Timezone
	SimpleDateFormat sdf_encounter = new SimpleDateFormat(i + &quot;yyyyMMddHHmmss&quot; + ${User_Thread}+threadGroupNumber);
	sdf_encounter.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the date to string
	String EncounterID = sdf_encounter.format(EncounterSet);
	
	// Create a SimpleDateFormat object for ObservedDt and set it to UTC Timezone
	SimpleDateFormat sdf_ObservedDt = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	sdf_ObservedDt.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the date to string
	String ObservedDt = sdf_ObservedDt.format(ObservedDtSet);
	
	// Calculate base_dt based on ObservedDt using time in minutes
	// Get the total minutes since the hour (0-59 minutes)
	Calendar observedCalendar = Calendar.getInstance();
	observedCalendar.setTime(ObservedDtSet);
	int totalMinutes = observedCalendar.get(Calendar.MINUTE);
	int totalSeconds = observedCalendar.get(Calendar.SECOND);
	
	// Determine base_dt based on the new rules
	int baseMinutes = 0; // Default baseMinutes
	if (totalMinutes &lt; 10) {
		baseMinutes = 10;
	} else if (totalMinutes &lt; 20 || (totalMinutes == 20 &amp;&amp; totalSeconds == 0)) {
		baseMinutes = 20;
	} else if (totalMinutes &lt; 30 || (totalMinutes == 30 &amp;&amp; totalSeconds == 0)) {
		baseMinutes = 30;
	} else if (totalMinutes &lt; 40 || (totalMinutes == 40 &amp;&amp; totalSeconds == 0)) {
		baseMinutes = 40;
	} else if (totalMinutes &lt; 50 || (totalMinutes == 50 &amp;&amp; totalSeconds == 0)) {
		baseMinutes = 50;
	} else {
		baseMinutes = 0; // 51-60 minutes
	}
	
	// Set the calculated baseMinutes to observedCalendar
	observedCalendar.set(Calendar.MINUTE, baseMinutes);
	observedCalendar.set(Calendar.SECOND, 0); // Reset seconds to 0
	observedCalendar.set(Calendar.MILLISECOND, 0); // Reset milliseconds to 0
	
	// Get the base_dt as Date
	Date baseDtSet = observedCalendar.getTime();
	
	// Create a SimpleDateFormat for base_dt
	SimpleDateFormat sdf_baseDt = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	sdf_baseDt.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the base_dt to string
	String baseDt = sdf_baseDt.format(baseDtSet);
	
	// Store in variables
	vars.put(&quot;PatientID&quot; + i, PatientID);
	vars.put(&quot;EncounterID&quot; + i, EncounterID + &quot;|&quot; + PatientID);
	vars.put(&quot;ObservedDt&quot; + i, ObservedDt);
	vars.put(&quot;baseDt&quot; + i, baseDt); // Store base_dt
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="LABORATORY_Data_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*
import java.util.Random

// 1. 접속 정보 유지
String url_emr = &quot;${JDBC_URL_EMR}&quot;
String user_emr = &quot;${JDBC_USER_EMR}&quot;
String pw_emr = &quot;${JDBC_PW_EMR}&quot;
String url_vc = &quot;${JDBC_URL_VC}&quot;
String user_vc = &quot;${JDBC_USER_VC}&quot;
String pw_vc = &quot;${JDBC_PW_VC}&quot;

Random random = new Random()
String subCategory = vars.get(&quot;subCategory&quot;) ?: &quot;&quot;

Float lowThreshold = null; Float highThreshold = null
boolean isLowInclusive = true; boolean isHighInclusive = true

// --- [STEP 1] VC DB 정책 조회 (값 크기순 정렬 방식) ---
String policySql = &quot;SELECT left_boundary, left_inclusive, right_boundary, right_inclusive, policy_desc FROM api_screening_policy WHERE UPPER(subcategory) = UPPER(?)&quot;;

try (Connection connVC = DriverManager.getConnection(url_vc, user_vc, pw_vc)) {
    try (PreparedStatement pstm = connVC.prepareStatement(policySql)) {
        pstm.setString(1, subCategory); 
        try (ResultSet rs = pstm.executeQuery()) {
            List parts = [];
            while (rs.next()) {
                String desc = rs.getString(&quot;policy_desc&quot;) ?: &quot;&quot;;
                
                // 값이 있는 쪽(left 혹은 right)의 수치를 가져옴
                Object leftObj = rs.getObject(&quot;left_boundary&quot;);
                float val = (leftObj != null) ? rs.getFloat(&quot;left_boundary&quot;) : rs.getFloat(&quot;right_boundary&quot;);
                boolean inc = (leftObj != null) ? rs.getBoolean(&quot;left_inclusive&quot;) : rs.getBoolean(&quot;right_inclusive&quot;);

                // [핵심] desc의 기호를 보고 상한/하한을 결정
                if (desc.contains(&quot;&gt;&quot;) || desc.contains(&quot;≥&quot;)) {
                    highThreshold = val;
                    isHighInclusive = (desc.contains(&quot;≥&quot;) || desc.contains(&quot;=&quot;));
                    parts &lt;&lt; &quot;${subCategory} ${isHighInclusive ? &apos;≥&apos; : &apos;&gt;&apos;} ${highThreshold}&quot; ;
                } 
                else if (desc.contains(&quot;&lt;&quot;) || desc.contains(&quot;≤&quot;)) {
                    lowThreshold = val;
                    isLowInclusive = (desc.contains(&quot;≤&quot;) || desc.contains(&quot;=&quot;));
                    parts &lt;&lt; &quot;${subCategory} ${isLowInclusive ? &apos;≤&apos; : &apos;&lt;&apos;} ${lowThreshold}&quot; ;
                }
            }
            
            // Snapshot 문자열 생성 및 저장
            if (!parts.isEmpty()) {
                thresholdSnapshotStr = parts.unique().sort().join(&quot; | &quot;);
                vars.put(&quot;thresholdSnapshot&quot;, thresholdSnapshotStr);
            }
        }
    }
} catch (Exception e) { log.error(&quot;정책 조회 실패: &quot; + e.getMessage()); }

// --- [STEP 2] 데이터 생성 로직 (전체 소수점 2자리 통일) ---
String fmt = &quot;%.2f&quot; // 모든 항목 소수점 2자리 적용

def availableCases = [&quot;NORMAL&quot;, &quot;NORMAL&quot;]
if (lowThreshold != null)  { availableCases += [&quot;LOW_ALARM&quot;, &quot;LOW_BOUNDARY&quot;] }
if (highThreshold != null) { availableCases += [&quot;HIGH_BOUNDARY&quot;, &quot;HIGH_ALARM&quot;] }

String testCase = availableCases[ctx.getThreadNum() % availableCases.size()]
String testValue = &quot;&quot;
String expectResult = &quot;NORMAL&quot;

switch(testCase) {
    case &quot;LOW_ALARM&quot;:
        testValue = String.format(fmt, lowThreshold - 0.05f) // 알람 확실히 발생하게 0.05 차이
        expectResult = &quot;ALARM&quot;
        break
    case &quot;LOW_BOUNDARY&quot;:
        float adjust = isLowInclusive ? 0 : -0.01f
        testValue = String.format(fmt, lowThreshold + adjust)
        expectResult = &quot;ALARM&quot;
        break
    case &quot;HIGH_BOUNDARY&quot;:
        float adjust = isHighInclusive ? 0 : 0.01f
        testValue = String.format(fmt, highThreshold + adjust)
        expectResult = &quot;ALARM&quot;
        break
    case &quot;HIGH_ALARM&quot;:
        testValue = String.format(fmt, highThreshold + 0.05f)
        expectResult = &quot;ALARM&quot;
        break
    default:
        float min = (lowThreshold ?: 70.0f) + 0.1f
        float max = (highThreshold ?: 110.0f) - 0.1f
        testValue = String.format(fmt, min + random.nextFloat() * (max - min))
        expectResult = &quot;NORMAL&quot;
}

// --- [STEP 3] EMR DB INSERT ---
def insertLabResult = { PreparedStatement stmt, String pId, String eId, String dDt, String oDt, String rDt, String code, String val -&gt;
    stmt.setString(1, pId)
    stmt.setString(2, eId)
    stmt.setString(3, dDt) // DRAWN_DT
    stmt.setString(4, oDt) // ORDERED_DT
    stmt.setString(5, rDt) // RESULT_DT
    stmt.setString(6, code)
    stmt.setDouble(7, Double.parseDouble(val))
    stmt.setInt(8, 0)      // DELETED_YN
    stmt.setInt(9, 1)      // INVALID
    
    stmt.executeUpdate();   // 실제 입력을 위해 주석 해제
    stmt.clearParameters()
}

def codeMap = [ SBP: &quot;SBP&quot;, DBP: &quot;DBP&quot;, PR: &quot;PULSE&quot;, RR: &quot;RESP&quot;, BT: &quot;TEMP&quot;, SpO2: &quot;SpO2&quot;, APH: &quot;APH&quot;, Hb: &quot;Hb&quot;, HCT: &quot;HEMATOCRIT&quot; ]
String query = &quot;INSERT INTO ROOT.LABORATORIES (PATIENT_ID, ENCOUNTER_ID, DRAWN_DT, ORDERED_DT, RESULT_DT, CODE, VALUE, DELETED_YN, INVALID) VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?, ?, ?, ?)&quot;

try (Connection connEMR = DriverManager.getConnection(url_emr, user_emr, pw_emr)) {
    try (PreparedStatement stmt = connEMR.prepareStatement(query)) {
        for (int i = 0; i &lt; (vars.get(&quot;PatientCount&quot;) as int ?: 1); i++) {
            String pId = vars.get(&quot;PatientID&quot; + i); String eId = vars.get(&quot;EncounterID&quot; + i)
            for (int j = 0; j &lt; (vars.get(&quot;ObservationCount&quot;) as int ?: 1); j++) {
                String dbCode = codeMap[subCategory] ?: subCategory
                insertLabResult(stmt, pId, eId, vars.get(&quot;DrawnDt&quot; + j), vars.get(&quot;OrderedDt&quot; + j), vars.get(&quot;ResultDt&quot; + j), dbCode, testValue);
                
                def logs = vars.getObject(&quot;procedureLogs&quot;) ?: []
                logs.add(&quot;INPUT: [${dbCode}] value=${testValue} (${testCase}) -&gt; Expect: ${expectResult}&quot;)
                vars.putObject(&quot;procedureLogs&quot;, logs)
            }
        }
    }
} catch (Exception e) { log.error(&quot;EMR DB 입력 에러: &quot; + e.getMessage()) }</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Observation Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.TimeZone;
import java.util.Calendar;

// Default timestamp
long timestampDefault = ${timestamp_default};
//long timestampDefault = props.get(&quot;timestamp_default&quot;) as long;

// Repeat count
int repeatCount = ${ObservationCount}; // Number of repetitions set
int intervalMin = ${Ob_Interval_Min};

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
	// Create a Date object
	Date PatientSet = new Date(timestampDefault);
	Date EncounterSet = new Date(timestampDefault);
	
	//Caculation Timestamp
	Calendar calendar = Calendar.getInstance();
	calendar.setTimeInMillis(timestampDefault); // Set the default timestamp		
	calendar.add(Calendar.MINUTE, -(repeatCount * intervalMin));
	calendar.add(Calendar.HOUR, +1);
	long OrderedDtSetTimestamp = calendar.getTimeInMillis();
	calendar.add(Calendar.HOUR, - 1);
	long DrawnDtSetTimestamp = calendar.getTimeInMillis();
	calendar.add(Calendar.HOUR, - 1);
	long ResultDtSetTimestamp = calendar.getTimeInMillis();

	//Set Timestamp
	Date OrderedDtSet = new Date(OrderedDtSetTimestamp); //observer use now
	Date DrawnDtSet = new Date(DrawnDtSetTimestamp); //observer use now
	Date ResultDtSet = new Date(ResultDtSetTimestamp); //observer use now

	String threadGroupName = ctx.getThreadGroup().getName();
	String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1];
	
	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i+&quot;yyMMddHHmmss&quot;+${User_Thread}+threadGroupNumber);
	sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the date to string
	String PatientID = sdf_patient.format(PatientSet);
	
	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_encounter = new SimpleDateFormat(i+&quot;yyyyMMddHHmmss&quot;+${User_Thread}+threadGroupNumber);
	sdf_encounter.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the date to string
	String EncounterID = sdf_encounter.format(EncounterSet);
	
	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_LabDt = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	sdf_LabDt.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the date to string
	String OrderedDt = sdf_LabDt.format(OrderedDtSet);
	String DrawnDt = sdf_LabDt.format(DrawnDtSet);
	String ResultDt = sdf_LabDt.format(ResultDtSet);
	
	// Store in variables
	vars.put(&quot;PatientID&quot; + i, PatientID);
	vars.put(&quot;EncounterID&quot; + i, EncounterID + &quot;|&quot; + PatientID);
	vars.put(&quot;OrderedDt&quot; + i, OrderedDt);
	vars.put(&quot;DrawnDt&quot; + i, DrawnDt);
	vars.put(&quot;ResultDt&quot; + i, ResultDt);
	vars.put(&quot;ObservedDt&quot; + i, DrawnDt);
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Wait_For_Score Sampler" enabled="true">
          <intProp name="ActionProcessor.action">1</intProp>
          <intProp name="ActionProcessor.target">0</intProp>
          <stringProp name="ActionProcessor.duration">${duration2}</stringProp>
          <stringProp name="TestPlan.comments">10 * 60 * 1000 = 600000</stringProp>
        </TestAction>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="vc_emr_screening_validation_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*
import java.text.SimpleDateFormat
import groovy.json.JsonSlurper
import java.math.BigDecimal

def logResults = vars.getObject(&quot;logResults&quot;)

// 1. 설정 및 변수 로드
String subCategory = vars.get(&quot;subCategory&quot;) ?: &quot;&quot;
String url = vars.get(&quot;JDBC_URL_VC&quot;)
String user = vars.get(&quot;JDBC_USER_VC&quot;)
String password = vars.get(&quot;JDBC_PW_VC&quot;)

// DB 정책 및 판정용 변수 (초기값 설정)
Float lowThreshold = null
Float highThreshold = null
boolean lowInc = true
boolean highInc = true
String thresholdSnapshotStr = &quot;&quot;

def convertTimestamp = { long ts -&gt; 
    new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;).with { 
        timeZone = TimeZone.getTimeZone(&quot;Asia/Seoul&quot;)
        format(new Date(ts))
    }
}

try (Connection conn = DriverManager.getConnection(url, user, password)) {
    // A. 암호화 키 설정
    try (Statement stmt = conn.createStatement()) {
        stmt.execute(&quot;SET @hashed_key = (SELECT UNHEX(SHA2(&apos;some_secret&apos;,256)))&quot;)
        stmt.execute(&quot;SET @secretkey = LEFT(@hashed_key,16)&quot;)
        stmt.execute(&quot;SET @iv = RIGHT(@hashed_key,16)&quot;)
    }

    // --- [STEP B 수정] bList.sort 방식으로 정책 로드 ---
// 1. 쿼리에 policy_desc 컬럼을 추가하여 기호를 판독합니다.
    String policySql = &quot;SELECT left_boundary, left_inclusive, right_boundary, right_inclusive, policy_desc FROM vitalcare.api_screening_policy WHERE UPPER(subcategory) = UPPER(?)&quot;;
    
    try (PreparedStatement pstm = conn.prepareStatement(policySql)) {
        pstm.setString(1, subCategory);
        try (ResultSet rs = pstm.executeQuery()) {
            List parts = [];
            
            while (rs.next()) {
                String desc = rs.getString(&quot;policy_desc&quot;) ?: &quot;&quot;;
                
                // left_boundary 혹은 right_boundary 중 값이 있는 컬럼의 숫자를 가져옴
                Object leftObj = rs.getObject(&quot;left_boundary&quot;);
                Object rightObj = rs.getObject(&quot;right_boundary&quot;);
                
                float val = (leftObj != null) ? rs.getFloat(&quot;left_boundary&quot;) : rs.getFloat(&quot;right_boundary&quot;);
                boolean inc = (leftObj != null) ? rs.getBoolean(&quot;left_inclusive&quot;) : rs.getBoolean(&quot;right_inclusive&quot;);

                // [핵심] desc 컬럼에 담긴 기호로 상한/하한을 결정 (POTASSIUM &gt;= 6.0 해결)
                if (desc.contains(&quot;&gt;&quot;) || desc.contains(&quot;≥&quot;)) {
                    // 기호가 &apos;크다&apos; 계열이면 상한선(High)으로 배정
                    highThreshold = val;
                    highInc = (desc.contains(&quot;≥&quot;) || desc.contains(&quot;=&quot;));
                    parts &lt;&lt; &quot;${subCategory} ${highInc ? &apos;≥&apos; : &apos;&gt;&apos;} ${highThreshold}&quot;;
                } 
                else if (desc.contains(&quot;&lt;&quot;) || desc.contains(&quot;≤&quot;)) {
                    // 기호가 &apos;작다&apos; 계열이면 하한선(Low)으로 배정
                    lowThreshold = val;
                    lowInc = (desc.contains(&quot;≤&quot;) || desc.contains(&quot;=&quot;));
                    parts &lt;&lt; &quot;${subCategory} ${lowInc ? &apos;≤&apos; : &apos;&lt;&apos;} ${lowThreshold}&quot;;
                }
            }
            
            // Snapshot 문자열 생성 (중복 제거 후 합치기)
            thresholdSnapshotStr = parts.unique().sort().join(&quot; | &quot;);
        }
    }
    vars.put(&quot;thresholdSnapshot&quot;, thresholdSnapshotStr);

    // C. 메인 검증 루프
    String startTime2 = convertTimestamp(Long.parseLong(vars.get(&quot;startTimeThread&quot;)))
    int patientCount = (vars.get(&quot;PatientCount&quot;) ?: &quot;0&quot;) as int
    int obsCount = (vars.get(&quot;ObservationCount&quot;) ?: &quot;0&quot;) as int

    for (int i = 0; i &lt; patientCount; i++) {
        String patientID = vars.get(&quot;PatientID&quot; + i)
        String encounterID = vars.get(&quot;EncounterID&quot; + i)

        for (int j = 0; j &lt; obsCount; j++) {
            String observedDt = vars.get(&quot;ObservedDt&quot; + j)
            
            SimpleDateFormat sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
            sdf.timeZone = TimeZone.getTimeZone(vars.get(&quot;TimeZone&quot;) ?: &quot;Asia/Seoul&quot;)
            java.util.Date parsedDate = sdf.parse(observedDt)
            sdf.timeZone = TimeZone.getTimeZone(&quot;UTC&quot;)
            String baseDtStr = sdf.format(parsedDate)

            // 1. vc_event 조회 (기존 로직 유지)
            String vcQuery = &quot;SELECT subcategory, observed_dt, value FROM vitalcare.vc_event WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),@secretkey,@iv) AS CHAR) = ? AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id),@secretkey,@iv) AS CHAR) = ? AND observed_dt = ? AND subcategory = ?&quot;
            List vcEvents = []
            try (PreparedStatement ps = conn.prepareStatement(vcQuery)) {
                ps.setString(1, patientID); ps.setString(2, encounterID); ps.setString(3, baseDtStr); ps.setString(4, subCategory)
                try (ResultSet rs = ps.executeQuery()) {
                    while (rs.next()) vcEvents.add([subcategory: rs.getString(1), observed_dt: rs.getString(2), value: rs.getString(3)])
                }
            }

            // --- [STEP C 판정 로직 핵심] BigDecimal 정밀 비교 반영 ---
            List matchedPolicies = []
            vcEvents.each { e -&gt;
                BigDecimal val = new BigDecimal(e.value)
                boolean isBelow = false
                boolean isAbove = false
                
                if (lowThreshold != null) {
                    BigDecimal low = new BigDecimal(lowThreshold.toString())
                    isBelow = lowInc ? (val.compareTo(low) &lt;= 0) : (val.compareTo(low) &lt; 0)
                }
                if (highThreshold != null) {
                    BigDecimal high = new BigDecimal(highThreshold.toString())
                    isAbove = highInc ? (val.compareTo(high) &gt;= 0) : (val.compareTo(high) &gt; 0)
                }

                if (isBelow) matchedPolicies &lt;&lt; &quot;LOW_POLICY&quot;
                else if (isAbove) matchedPolicies &lt;&lt; &quot;HIGH_POLICY&quot;
                else matchedPolicies &lt;&lt; &quot;NORMAL&quot;
            }

            // 3. api_screeningrecord 조회 및 결과 판정 (기존 로직 유지)
            String scQuery = &quot;SELECT screened_dt, type, value, policy_desc FROM vitalcare.api_screeningrecord WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),@secretkey,@iv) AS CHAR) = ? AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id),@secretkey,@iv) AS CHAR) = ? AND deleted = 0 AND screened_dt = ? AND type = ?&quot;
            List scRecords = []
            boolean expectAlarm = matchedPolicies.any { it.contains(&quot;POLICY&quot;) }
            
            // ... (Retry 로직 및 결과 판정 로직 동일) ...
            int retry = 0
            while (retry &lt; 5) {
                try (PreparedStatement ps = conn.prepareStatement(scQuery)) {
                    ps.setString(1, patientID); ps.setString(2, encounterID); ps.setString(3, baseDtStr); ps.setString(4, subCategory)
                    try (ResultSet rs = ps.executeQuery()) {
                        scRecords.clear()
                        while (rs.next()) scRecords.add([dt: rs.getString(1), type: rs.getString(2), val: rs.getString(3), desc: rs.getString(4)])
                    }
                }
                if (scRecords.isEmpty() &amp;&amp; expectAlarm) { retry++; Thread.sleep(1200) } 
                else break
            }

            // 최종 판정 로직
            String finalResultStr = &quot;&quot;
            String statusForLog = &quot;&quot;
            if (vcEvents.isEmpty()) { finalResultStr = &quot;N/A&quot;; statusForLog = &quot;N/A&quot; }
            else if (!expectAlarm) {
                if (scRecords.isEmpty()) { finalResultStr = &quot;PASS&quot;; statusForLog = &quot;NORMAL_OK&quot; }
                else { finalResultStr = &quot;FAIL&quot;; statusForLog = &quot;UNEXPECTED_ALARM&quot; }
            } else {
                if (!scRecords.isEmpty()) { finalResultStr = &quot;PASS&quot;; statusForLog = &quot;ALARM_OK&quot; }
                else { finalResultStr = &quot;FAIL&quot;; statusForLog = &quot;MISSING_ALARM&quot; }
            }

            // 5. CSV 기록 (가독성 처리 포함)
            String displayVCEvent = vcEvents.collect { &quot;[${it.observed_dt}|${it.subcategory}|${it.value}]&quot; }.join(&quot;|&quot;)
            String displayPolicy = matchedPolicies.join(&quot;|&quot;)
            String displayScreening = scRecords.collect { &quot;[${it.dt}|${it.type}|${it.val}|${it.desc}]&quot; }.join(&quot;|&quot;)

            String csvDataString = String.format(&quot;%s,%s,%s,%d,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s&quot;,
                vars.get(&quot;currentScenarioGroupName&quot;), 
                ctx.getThreadGroup().getName(),
                subCategory, 
                ctx.getThreadNum(),
                startTime2, convertTimestamp(System.currentTimeMillis()), 
                patientID, encounterID,
                (vars.getObject(&quot;procedureLogs&quot;) ?: []).join(&quot;||&quot;), 
                thresholdSnapshotStr, // 업데이트된 snapshot 사용
                displayVCEvent, displayPolicy, displayScreening, 
                statusForLog, finalResultStr)

            logResults(prev, ctx, props, vars, csvDataString)
            vars.putObject(&quot;procedureLogs&quot;, []) 
        }
    }
} catch (Exception e) { 
    log.error(&quot;Result Check Error: &quot;, e) 
}</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Scenario 17" enabled="true">
        <intProp name="ThreadGroup.num_threads">6</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">false</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <UniformRandomTimer guiclass="UniformRandomTimerGui" testclass="UniformRandomTimer" testname="Uniform Random Timer" enabled="true">
          <stringProp name="ConstantTimer.delay">0</stringProp>
          <stringProp name="RandomTimer.range">${DelayTimer}</stringProp>
        </UniformRandomTimer>
        <hashTree/>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter
import java.nio.charset.StandardCharsets

def logResults = { prev, ctx, props, vars, csvDataString -&gt;

	if (csvDataString == null || csvDataString.trim().isEmpty()) {
		log.error(&quot;csvDataString is null or empty.&quot;)
		return
	}
	
	def now = LocalDateTime.now().format(DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd HH:mm:ss&quot;))
	def outputDir = props.get(&quot;outputDir&quot;)

	if (!Files.exists(Paths.get(outputDir))) {
		Files.createDirectories(Paths.get(outputDir))
	}

	def csvDataArray = csvDataString.split(&quot;,&quot;)  // CSV 데이터를 배열로 변환
	def fullThreadName = prev.getThreadName()
	def threadGroupName = fullThreadName.split(&quot; &quot;)[0] + fullThreadName.split(&quot; &quot;)[1]
	def scenarioGroupName = vars.get(&quot;currentScenarioGroupName&quot;)

	def resultFile = Paths.get(outputDir, &quot;${scenarioGroupName}.csv&quot;)

	//def csvHeader = &quot;Group,Scenario,StartTime,EndTime,Patient ID, Encounter ID, ICU, Vital Count, ObservedDt Count, base_dt, news, mews, mors, cared, seps, maes, Test Result\n&quot;
	def csvHeader = &quot;Group,Scenario,Category,Case,StartTime,EndTime,Patient ID,Encounter ID,ProcedureLog,ThresholdSnapshot,VC_Event,MatchedPolicy,ScreeningRecord,STATUS,Test Result\n&quot;

	if (!Files.exists(resultFile)) {
		Files.createDirectories(resultFile.parent)
		Files.write(resultFile, csvHeader.getBytes(StandardCharsets.UTF_8), StandardOpenOption.CREATE)
	}

	// 데이터 추가 (ThreadGroupName, SamplerName, csvDataString)
//	def dataToWrite = &quot;${scenarioGroupName}, ${csvDataString}\n&quot;
//
//	Files.write(resultFile, dataToWrite.getBytes(StandardCharsets.UTF_8), StandardOpenOption.APPEND)
	Files.write(
	    resultFile,
	    (csvDataString + &quot;\n&quot;).getBytes(StandardCharsets.UTF_8),
	    StandardOpenOption.APPEND
	)

}

vars.putObject(&quot;logResults&quot;, logResults)
</stringProp>
        </JSR223PreProcessor>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="setname Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
