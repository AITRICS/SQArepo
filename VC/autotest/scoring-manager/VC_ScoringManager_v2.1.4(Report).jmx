          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">long timeout = System.currentTimeMillis() + 1 * 60 * 60 * 1000; // Maximum wait time (1 hour)
while (!props.get(&quot;proceedFlag&quot;).equals(&quot;true&quot;)) {
	if (System.currentTimeMillis() &gt; timeout) {
 		log.error(&quot;Timeout exceeded while waiting for proceedFlag to become true.&quot;);
		break; 
	}
	Thread.sleep(30000);  // Check every 30 seconds 
	log.info(&quot;Waiting for proceedFlag to become true...&quot;);
}
