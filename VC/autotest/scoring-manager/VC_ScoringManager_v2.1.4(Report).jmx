        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="LABORATORY_Data_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;
import java.util.Random;

// JDBC connection information
String url = &quot;${JDBC_URL_EMR}&quot;;
String user = &quot;${JDBC_USER_EMR}&quot;;
String password = &quot;${JDBC_PW_EMR}&quot;;

// JDBC connection &amp; Define the query
try (Connection conn = DriverManager.getConnection(url, user, password)) {
	String query = &quot;INSERT INTO ROOT.LABORATORIES (PATIENT_ID, ENCOUNTER_ID, DRAWN_DT, ORDERED_DT, RESULT_DT, CODE, VALUE, DELETED_YN, INVALID) &quot; +
				&quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?, ?, ?, ?)&quot;;

	// Prepare the statement &amp; Repeat the process for multiple sets of parameters
	try (PreparedStatement stmt = conn.prepareStatement(query)) {
		String threadGroupName = ctx.getThreadGroup().getName();
		// Repeat the process for multiple sets of parameters
		int patientCount = Integer.parseInt(vars.get(&quot;PatientCount&quot;));
		int labRepeatCount = Integer.parseInt(vars.get(&quot;ObservationCount&quot;));
		Random random = new Random();

		// Repeat the process for multiple sets of parameters
		for (int i = 0; i &lt; patientCount; i++) {
			String patientID = vars.get(&quot;PatientID&quot; + i);
			String encounterID = vars.get(&quot;EncounterID&quot; + i);

			for (int j = 0; j &lt; labRepeatCount; j++) {
				String drawnDt = vars.get(&quot;DrawnDt&quot; + j);
				String orderedDt = vars.get(&quot;OrderedDt&quot; + j);
				String resultDt = vars.get(&quot;ResultDt&quot; + j);	

				// Generate an Acute Physiology and Chronic Health Evaluation (APACHE) value ranging from 0.0 to 13.9
				String APH_Value = random.nextInt(14) + &quot;.&quot; + random.nextInt(10);			
				// Generate a Bilirubin value ranging from 0.0 to 74.9
				String BILIRUBIN_Value = random.nextInt(75) + &quot;.&quot; + random.nextInt(10);			
				// Generate a Creatinine value ranging from 0.0 to 19.9
				String CREATININE_Value = random.nextInt(20) + &quot;.&quot; + random.nextInt(10);			
				// Generate a C-reactive protein (CRP) value ranging from 0.0 to 899.9
				String CRP_Value = random.nextInt(900) + &quot;.&quot; + random.nextInt(10);			
				// Generate a bicarbonate (HCO3) value ranging from 0.0 to 99.9
				String HCO3_Value = random.nextInt(100) + &quot;.&quot; + random.nextInt(10);			
				// Generate a hematocrit (HCT) value ranging from 0.0 to 99.9
				String HCT_Value = random.nextInt(100) + &quot;.&quot; + random.nextInt(10);			
				// Generate a lactate value ranging from 0.0 to 19.9
				String LACTATE_Value = random.nextInt(20) + &quot;.&quot; + random.nextInt(10);			
				// Generate a platelet count value ranging from 0.0 to 999.9
				String PLATELET_Value = random.nextInt(1000) + &quot;.&quot; + random.nextInt(10);			
				// Generate a potassium value ranging from 0.0 to 14.9
				String POTASSIUM_Value = random.nextInt(15) + &quot;.&quot; + random.nextInt(10);			
				// Generate a sodium value ranging from 0.0 to 499.9
				String SODIUM_Value = random.nextInt(500) + &quot;.&quot; + random.nextInt(10);			
				// Generate a white blood cell (WBC) count value ranging from 0.0 to 99.9
				String WBC_Value = random.nextInt(100) + &quot;.&quot; + random.nextInt(10);

				// Insert Observation
				// insertObservation(stmt, patientID, encounterID, drawnDt, orderedDt, resultDt, &quot;APH&quot;, APH_Value);
				// insertObservation(stmt, patientID, encounterID, drawnDt, orderedDt, resultDt, &quot;BILIRUBIN&quot;, BILIRUBIN_Value);
				insertObservation(stmt, patientID, encounterID, drawnDt, orderedDt, resultDt, &quot;CREATININE&quot;, CREATININE_Value);
				// insertObservation(stmt, patientID, encounterID, drawnDt, orderedDt, resultDt, &quot;CRP&quot;, CRP_Value);
				// insertObservation(stmt, patientID, encounterID, drawnDt, orderedDt, resultDt, &quot;HCO3&quot;, HCO3_Value);
				// insertObservation(stmt, patientID, encounterID, drawnDt, orderedDt, resultDt, &quot;HEMATOCRIT&quot;, HCT_Value);
				// insertObservation(stmt, patientID, encounterID, drawnDt, orderedDt, resultDt, &quot;LACTATE&quot;, LACTATE_Value);
				// insertObservation(stmt, patientID, encounterID, drawnDt, orderedDt, resultDt, &quot;PLATELET&quot;, PLATELET_Value);
				// insertObservation(stmt, patientID, encounterID, drawnDt, orderedDt, resultDt, &quot;POTASSIUM&quot;, POTASSIUM_Value);
				// insertObservation(stmt, patientID, encounterID, drawnDt, orderedDt, resultDt, &quot;SODIUM&quot;, SODIUM_Value);
				// insertObservation(stmt, patientID, encounterID, drawnDt, orderedDt, resultDt, &quot;WBC&quot;, WBC_Value);
			}
		}
	}
} catch (Exception e) {
	log.error(&quot;Exception: &quot;, e);
}

private void insertObservation(PreparedStatement stmt, String patientID, String encounterID, String drawnDt, String orderedDt, String resultDt, String code, String value) throws SQLException {
	stmt.setString(1, patientID);
	stmt.setString(2, encounterID);
	stmt.setString(3, drawnDt);
	stmt.setString(4, orderedDt);
	stmt.setString(5, resultDt);	
	stmt.setString(6, code);
	stmt.setDouble(7, Double.parseDouble(value));
	stmt.setInt(8, 0); // DELETED_YN
	stmt.setInt(9, 1); // INVALID
	String threadGroupName = ctx.getThreadGroup().getName();
	// Execute the query
	int rowsInserted = stmt.executeUpdate();
	log.info(&quot;PatientID=&quot; + patientID + &quot;, EncounterID=&quot; + encounterID + &quot;, drawnDt=&quot; + drawnDt + &quot;, orderedDt=&quot; + orderedDt + &quot;, resultDt=&quot; + resultDt + &quot;, Code=&quot; + code + &quot;, Value=&quot; + value);
	stmt.clearParameters();
}
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Observation Dateime Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.TimeZone;
import java.util.Calendar;

// Default timestamp
long timestampDefault = ${timestamp_default};
//long timestampDefault = props.get(&quot;timestamp_default&quot;) as long;

// Repeat count
int repeatCount = ${ObservationCount}; // Number of repetitions set

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
	// Create a Date object
	Date PatientSet = new Date(timestampDefault);
	Date EncounterSet = new Date(timestampDefault);
	
	//Caculation Timestamp
	Calendar calendar = Calendar.getInstance();
	calendar.setTimeInMillis(timestampDefault); // Set the default timestamp		
	//calendar.add(Calendar.MINUTE, -((i * ${Ob_Interval_Min}) + 60));
	long OrderedDtSetTimestamp = calendar.getTimeInMillis();
	calendar.add(Calendar.HOUR, - 1);
	long DrawnDtSetTimestamp = calendar.getTimeInMillis();
	calendar.add(Calendar.HOUR, - 1);
	long ResultDtSetTimestamp = calendar.getTimeInMillis();

	//Set Timestamp
	Date OrderedDtSet = new Date(OrderedDtSetTimestamp); //observer use now
	Date DrawnDtSet = new Date(DrawnDtSetTimestamp); //observer use now
	Date ResultDtSet = new Date(ResultDtSetTimestamp); //observer use now

	String threadGroupName = ctx.getThreadGroup().getName();
	String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1];
	
	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i+&quot;yyMMddHHmmss&quot;+${User_Thread}+threadGroupNumber);
	sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the date to string
	String PatientID = sdf_patient.format(PatientSet);
	
	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_encounter = new SimpleDateFormat(i+&quot;yyyyMMddHHmmss&quot;+${User_Thread}+threadGroupNumber);
	sdf_encounter.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the date to string
	String EncounterID = sdf_encounter.format(EncounterSet);
	
	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_LabDt = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	sdf_LabDt.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the date to string
	String OrderedDt = sdf_LabDt.format(OrderedDtSet);
	String DrawnDt = sdf_LabDt.format(DrawnDtSet);
	String ResultDt = sdf_LabDt.format(ResultDtSet);
	
	// Store in variables
	vars.put(&quot;PatientID&quot; + i, PatientID);
	vars.put(&quot;EncounterID&quot; + i, EncounterID);
	vars.put(&quot;OrderedDt&quot; + i, OrderedDt);
	vars.put(&quot;DrawnDt&quot; + i, DrawnDt);
	vars.put(&quot;ResultDt&quot; + i, ResultDt);
}
</stringProp>
