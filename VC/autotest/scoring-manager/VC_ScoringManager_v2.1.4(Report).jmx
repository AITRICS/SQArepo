        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Vital_Data_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;
import java.util.Random;

// JDBC connection information
String url = &quot;${JDBC_URL_EMR}&quot;;
String user = &quot;${JDBC_USER_EMR}&quot;;
String password = &quot;${JDBC_PW_EMR}&quot;;

// JDBC connection &amp; Define the query
try (Connection conn = DriverManager.getConnection(url, user, password)) {
	String query = &quot;INSERT INTO ROOT.VITALS (PATIENT_ID, ENCOUNTER_ID, OBSERVED_DT, CODE, VALUE, DELETED_YN, INVALID) &quot; +
				&quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?, ?, ?, ?)&quot;;

	// Prepare the statement &amp; Repeat the process for multiple sets of parameters
	try (PreparedStatement stmt = conn.prepareStatement(query)) {
		String threadGroupName = ctx.getThreadGroup().getName();
		// Repeat the process for multiple sets of parameters
		int patientCount = Integer.parseInt(vars.get(&quot;PatientCount&quot;));
		int observationCount = Integer.parseInt(vars.get(&quot;ObservationCount&quot;));
		Random random = new Random();

		// Repeat the process for multiple sets of parameters
		for (int i = 0; i &lt; patientCount; i++) {
			String patientID = vars.get(&quot;PatientID&quot; + i);
			String encounterID = vars.get(&quot;EncounterID&quot; + i);

			for (int j = 0; j &lt; observationCount; j++) {
				String observedDateTime = vars.get(&quot;ObservedDt&quot; + j);

				// Set parameters for the query
				String pulseRate = random.nextInt(300);
				String respiratoryRate = random.nextInt(120) ;
				String bodyTemperature = (random.nextInt(25) + 25) + &quot;.&quot; + random.nextInt(10);
				String systolicBP = random.nextInt(300);
				String diastolicBP = random.nextInt(300);

				// Insert Observation
				insertObservation(stmt, patientID, encounterID, observedDateTime, &quot;PULSE&quot;, pulseRate);
				insertObservation(stmt, patientID, encounterID, observedDateTime, &quot;RESP&quot;, respiratoryRate);
				insertObservation(stmt, patientID, encounterID, observedDateTime, &quot;TEMP&quot;, bodyTemperature);
				insertObservation(stmt, patientID, encounterID, observedDateTime, &quot;SBP&quot;, systolicBP);
				insertObservation(stmt, patientID, encounterID, observedDateTime, &quot;DBP&quot;, diastolicBP);
			}
		}
	}
} catch (Exception e) {
	log.error(&quot;Exception: &quot;, e);
}

private void insertObservation(PreparedStatement stmt, String patientID, String encounterID, String observedDateTime, String code, String value) throws SQLException {
	stmt.setString(1, patientID);
	stmt.setString(2, encounterID);
	stmt.setString(3, observedDateTime);
	stmt.setString(4, code);
	stmt.setDouble(5, Double.parseDouble(value));
	stmt.setInt(6, 0); // DELETED_YN
	stmt.setInt(7, 1); // INVALID
	String threadGroupName = ctx.getThreadGroup().getName();
	// Execute the query
	int rowsInserted = stmt.executeUpdate();
	log.info(&quot;PatientID=&quot; + patientID + &quot;, EncounterID=&quot; + encounterID + &quot;, observedDateTime=&quot; + observedDateTime + &quot;, Code=&quot; + code + &quot;, Value=&quot; + value);
	stmt.clearParameters();
}
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Observation Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.TimeZone;
import java.util.Calendar;

// Default timestamp
long timestampDefault = ${timestamp_default};
//long timestampDefault = props.get(&quot;timestamp_default&quot;) as long;

// Repeat count
int repeatCount = ${ObservationCount}; // Number of repetitions set

// Iterate to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
	// Create a Date object
	Date PatientSet = new Date(timestampDefault);
	Date EncounterSet = new Date(timestampDefault);

	// Set Observe Date
	Calendar calendar = Calendar.getInstance();
	calendar.setTimeInMillis(timestampDefault); // Set the default timestamp		
	calendar.add(Calendar.MINUTE, -(1 * ${Ob_Interval_Min}));

	long ObservedDtSetTimestamp = calendar.getTimeInMillis();
	Date ObservedDtSet = new Date(ObservedDtSetTimestamp);
	
	String threadGroupName = ctx.getThreadGroup().getName();
	String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1];

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i+&quot;yyMMddHHmmss&quot;+${User_Thread}+threadGroupNumber);
	sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the date to string
	String PatientID = sdf_patient.format(PatientSet);
	
	// Create a SimpleDateFormat object for EncounterID and set it to UTC Timezone
	SimpleDateFormat sdf_encounter = new SimpleDateFormat(i + &quot;yyyyMMddHHmmss&quot; + ${User_Thread}+threadGroupNumber);
	sdf_encounter.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the date to string
	String EncounterID = sdf_encounter.format(EncounterSet);
	
	// Create a SimpleDateFormat object for ObservedDt and set it to UTC Timezone
	SimpleDateFormat sdf_ObservedDt = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	sdf_ObservedDt.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the date to string
	String ObservedDt = sdf_ObservedDt.format(ObservedDtSet);
	
	// Calculate base_dt based on ObservedDt using time in minutes
	// Get the total minutes since the hour (0-59 minutes)
	Calendar observedCalendar = Calendar.getInstance();
	observedCalendar.setTime(ObservedDtSet);
	int totalMinutes = observedCalendar.get(Calendar.MINUTE);
	int totalSeconds = observedCalendar.get(Calendar.SECOND);
	
	// Determine base_dt based on the new rules
	int baseMinutes = 0; // Default baseMinutes
	if (totalMinutes &lt; 10) {
		baseMinutes = 10;
	} else if (totalMinutes &lt; 20 || (totalMinutes == 20 &amp;&amp; totalSeconds == 0)) {
		baseMinutes = 20;
	} else if (totalMinutes &lt; 30 || (totalMinutes == 30 &amp;&amp; totalSeconds == 0)) {
		baseMinutes = 30;
	} else if (totalMinutes &lt; 40 || (totalMinutes == 40 &amp;&amp; totalSeconds == 0)) {
		baseMinutes = 40;
	} else if (totalMinutes &lt; 50 || (totalMinutes == 50 &amp;&amp; totalSeconds == 0)) {
		baseMinutes = 50;
	} else {
		baseMinutes = 0; // 51-60 minutes
	}
	
	// Set the calculated baseMinutes to observedCalendar
	observedCalendar.set(Calendar.MINUTE, baseMinutes);
	observedCalendar.set(Calendar.SECOND, 0); // Reset seconds to 0
	observedCalendar.set(Calendar.MILLISECOND, 0); // Reset milliseconds to 0
	
	// Get the base_dt as Date
	Date baseDtSet = observedCalendar.getTime();
	
	// Create a SimpleDateFormat for base_dt
	SimpleDateFormat sdf_baseDt = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	sdf_baseDt.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
	
	// Format the base_dt to string
	String baseDt = sdf_baseDt.format(baseDtSet);
	
	// Store in variables
	vars.put(&quot;PatientID&quot; + i, PatientID);
	vars.put(&quot;EncounterID&quot; + i, EncounterID);
	vars.put(&quot;ObservedDt&quot; + i, ObservedDt);
	vars.put(&quot;baseDt&quot; + i, baseDt); // Store base_dt
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
