        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">long timeout = System.currentTimeMillis() + 1 * 60 * 60 * 1000; // Maximum wait time (1 hours)
boolean proceed = false;

while (!proceed) {
	Calendar cal = Calendar.getInstance();
	int currentMinute = cal.get(Calendar.MINUTE);

	// Check if the current minute meets the criteria
	if ((currentMinute % 10) &gt; 0 &amp;&amp; (currentMinute % 10) &lt;= 8) {
		// x1 ~ x8: Proceed immediately
		proceed = true;
	} else if (currentMinute % 10 == 9) {
		// If the minute is 9, wait for the next time cycle (1 minutes max)
		log.info(&quot;Minute is 9, waiting for the next minute...&quot;);
		while (cal.get(Calendar.MINUTE) == 9) {
			if (System.currentTimeMillis() &gt; timeout) {
				throw new RuntimeException(&quot;Timeout waiting for the next cycle.&quot;);
			}
			Thread.sleep(30000); // Check every 30 seconds
			cal = Calendar.getInstance(); // Update calendar instance
		}
		proceed = true;
	} else {
		Thread.sleep(30000); // Wait 30 seconds
		log.info(&quot;Waiting... Current minute: &quot; + currentMinute);
	}
}
</stringProp>
