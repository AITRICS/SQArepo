        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="vc_emr_score_validation_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.sql.SQLException;
import java.sql.Statement;
import java.text.ParseException;
import java.text.SimpleDateFormat;
import java.util.*;
import java.util.concurrent.atomic.AtomicBoolean;
import org.apache.jmeter.threads.JMeterContextService;
import java.nio.file.Files;
import java.nio.file.Paths;
import java.nio.file.StandardOpenOption;
import java.nio.file.Path;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import java.util.concurrent.locks.ReentrantLock;

def logResults = vars.getObject(&quot;logResults&quot;)
AtomicBoolean isHeaderWritten = new AtomicBoolean(false);
String url = vars.get(&quot;JDBC_URL_VC&quot;);
String user = vars.get(&quot;JDBC_USER_VC&quot;);
String password = vars.get(&quot;JDBC_PW_VC&quot;);

String convertTimestamp(long timestamp) {
	SimpleDateFormat formatter = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	formatter.setTimeZone(TimeZone.getTimeZone(&quot;Asia/Seoul&quot;));
	return formatter.format(new Date(timestamp));
}

try (Connection conn = DriverManager.getConnection(url, user, password)) {
	try (Statement setStmt = conn.createStatement()) {
		setStmt.execute(&quot;SET @hashed_key = (SELECT UNHEX(SHA2(&apos;some_secret&apos;, 256)))&quot;);
		setStmt.execute(&quot;SET @secretkey = LEFT(@hashed_key, 16)&quot;);
		setStmt.execute(&quot;SET @iv = RIGHT(@hashed_key, 16)&quot;);
	}
//	long startTime = JMeterContextService.getTestStartTime();
	String startTime = vars.get(&quot;startTimeThread&quot;);
	String startTime2 = convertTimestamp(Long.parseLong(startTime));
	int PatientRepeatCount = Integer.parseInt(vars.get(&quot;PatientCount&quot;));
	int VitalRepeatCount = Integer.parseInt(vars.get(&quot;ObservationCount&quot;));
	String threadGroupName = ctx.getThreadGroup().getName();
//	String pattern = &quot;yyyy-MM-dd_HH&quot;; //csv filename format: &quot;2024-10-25_11&quot;
//	SimpleDateFormat simpleDateFormat = new SimpleDateFormat(pattern);
//	String date = simpleDateFormat.format(new Date());
//	String userHome = System.getProperty(&quot;user.home&quot;);
//	String specificDir = &quot;QA_Amelia/apache-jmeter-5.6.3/scripts/scripts_result/Scoring_Manager/&quot;;
//	String filePath = userHome + &quot;/&quot; + specificDir + date;
	String filePath = props.get(&quot;filePath&quot;);
	String csvFilePathPerThreadGroup = filePath + &quot;_&quot; + threadGroupName.replaceAll(&quot;\\s+&quot;, &quot;&quot;) + &quot;.csv&quot;;
	String csvFilePath = filePath + &quot;.csv&quot;;
	String htmlFilePath = filePath + &quot;.html&quot;;
	boolean isTestSuccess = true;
	boolean isICU = false;
	if (${User_Thread} % 2 == 0) {
		isICU = true;
	} else {
		isICU = false;
	}

	String queryBase = &quot;SELECT * FROM vitalcare.emr_score WHERE &quot; +
						&quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id), @secretkey, @iv) AS CHAR) = ? &quot; +
						// &quot;AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR) = ? &quot; +
						&quot;AND DELETED=0 &quot; +
						&quot;AND base_dt IN (&quot;;

	for (int i = 0; i &lt; PatientRepeatCount; i++) {
		String patientID = vars.get(&quot;PatientID&quot; + i);
		String encounterID = vars.get(&quot;EncounterID&quot; + i);
		List&lt;String&gt; baseDtList = new ArrayList&lt;&gt;();

		// Get base_dt value from the observed_dt
		for (int j = 0; j &lt; VitalRepeatCount; j++) {
			String ObservedDt = vars.get(&quot;DrawnDt&quot; + j);
			SimpleDateFormat sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
			sdf.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
			Date observedDate = sdf.parse(ObservedDt);
			Calendar calendar = Calendar.getInstance();
			calendar.setTime(observedDate);
			int minute = calendar.get(Calendar.MINUTE);
			int baseMinute = minute &lt;= 10 ? 10 : (minute &lt;= 20 ? 20 : (minute &lt;= 30 ? 30 : (minute &lt;= 40 ? 40 : (minute &lt;= 50 ? 50 : 0))));
			if (minute &gt; 50) {
				calendar.add(Calendar.HOUR_OF_DAY, 1);
			}
			calendar.set(Calendar.MINUTE, baseMinute);
			calendar.set(Calendar.SECOND, 0);
			SimpleDateFormat utcSdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
			utcSdf.setTimeZone(TimeZone.getTimeZone(&quot;UTC&quot;));
			String baseDt = utcSdf.format(calendar.getTime());
			baseDtList.add(baseDt);
			log.info(&quot;PatientID=&quot; + patientID + &quot;, EncounterID=&quot; + encounterID + &quot;, baseDt=&quot; + baseDt);
		}
		
		String inClause = String.join(&quot;,&quot;, Collections.nCopies(baseDtList.size(), &quot;?&quot;));
		String query = queryBase + inClause + &quot;)&quot;;
		int validObservedDtCount = baseDtList.size();

		try (PreparedStatement stmt = conn.prepareStatement(query)) {
			stmt.setString(1, patientID);
			// stmt.setString(2, encounterID);
			for (int k = 0; k &lt; baseDtList.size(); k++) {
				stmt.setString(2 + k, baseDtList.get(k));
			}
			try (ResultSet resultSet = stmt.executeQuery()) {
				int caredScoreCount = 0;
				int sepsScoreCount = 0;
				int maesScoreCount = 0;
				int morsScoreCount = 0;
				int newsScoreCount = 0;
				int mewsScoreCount = 0;
				while (resultSet.next()) {
					String type = resultSet.getString(&quot;type&quot;);
					switch (type) {
						case &quot;CARED&quot;:
							caredScoreCount++;
							break;
						case &quot;SEPS&quot;:
							sepsScoreCount++;
							break;
						case &quot;MAES&quot;:
							maesScoreCount++;
							break;
						case &quot;MORS&quot;:
							morsScoreCount++;
							break;
						case &quot;NEWS&quot;:
							newsScoreCount++;
							break;
						case &quot;MEWS&quot;:
							mewsScoreCount++;
							break;
					}
				}
				if (isICU) {
					// Compare the counts of base_dt and score when ICU
					if (0 == morsScoreCount &amp;&amp; 0 == newsScoreCount &amp;&amp; 0 == mewsScoreCount) {
						isTestSuccess = true;
					} else {
						isTestSuccess = false;
					}
				} else {
					// Compare the counts of base_dt and score when GW
					if (0 == caredScoreCount &amp;&amp; 0 == sepsScoreCount &amp;&amp; 0 == maesScoreCount &amp;&amp;
						0 == newsScoreCount &amp;&amp; 0 == mewsScoreCount) {
						isTestSuccess = true;
					} else {
						isTestSuccess = false;
					}
				}
				long endTime = System.currentTimeMillis();
				String endTime2 = convertTimestamp(endTime);
				Collections.reverse(baseDtList);
				String baseDtString = String.join(&quot;&lt;br&gt;&quot;, baseDtList);
				log.info(&quot;baseDtString=&quot; + baseDtString);
				String csvDataString = String.format(&quot;%s, %s, %s, %s, %s, %s, %d, %d, %s, %d, %d, %d, %d, %d, %d, %s&quot;,
									threadGroupName, startTime2, endTime2, patientID, encounterID, isICU ? &quot;ICU&quot; : &quot;GW&quot;, VitalRepeatCount, validObservedDtCount,baseDtString,
									newsScoreCount, mewsScoreCount, morsScoreCount, caredScoreCount, sepsScoreCount, maesScoreCount,
									isTestSuccess ? &quot;PASS&quot; : &quot;FAIL&quot;);
				logResults(prev, ctx, props, vars, csvDataString)
			}
		}
	}
} catch (SQLException | ParseException e) {
	log.error(&quot;Exception: &quot;, e);
}
</stringProp>
        </JSR223Sampler>
