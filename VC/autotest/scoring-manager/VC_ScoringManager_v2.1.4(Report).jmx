	SimpleDateFormat sdf_admission = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	sdf_admission.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

	// Format the date to string
	String AdmissionDate = sdf_admission.format(AdmissionSet);

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_discharge = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	sdf_discharge.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

	// Format the date to string
	String DischargeDate = sdf_discharge.format(DischargeSet);
	
	// Store in variables
	vars.put(&quot;PatientID&quot; + i, PatientID);
	vars.put(&quot;EncounterID&quot; + i, EncounterID);
	vars.put(&quot;AdmissionDate&quot; + i, AdmissionDate);
	vars.put(&quot;DischargeDate&quot; + i, DischargeDate);
}
