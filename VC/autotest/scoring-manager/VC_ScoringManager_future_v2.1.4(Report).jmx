        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="vc_emr_score_validation_JSR223 Sampler" enabled="false">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.sql.SQLException;
import java.sql.Statement;
import java.text.ParseException;
import java.text.SimpleDateFormat;
import java.util.*;
import java.util.concurrent.atomic.AtomicBoolean;
import org.apache.jmeter.threads.JMeterContextService;
import java.nio.file.Files;
import java.nio.file.Paths;
import java.nio.file.StandardOpenOption;
import java.nio.file.Path;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import java.util.concurrent.locks.ReentrantLock;

def logResults = vars.getObject(&quot;logResults&quot;)
AtomicBoolean isHeaderWritten = new AtomicBoolean(false);
String url = vars.get(&quot;JDBC_URL_VC&quot;);
String user = vars.get(&quot;JDBC_USER_VC&quot;);
String password = vars.get(&quot;JDBC_PW_VC&quot;);

String convertTimestamp(long timestamp) {
	SimpleDateFormat formatter = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	formatter.setTimeZone(TimeZone.getTimeZone(&quot;Asia/Seoul&quot;));
	return formatter.format(new Date(timestamp));
}

try (Connection conn = DriverManager.getConnection(url, user, password)) {
	try (Statement setStmt = conn.createStatement()) {
		setStmt.execute(&quot;SET @hashed_key = (SELECT UNHEX(SHA2(&apos;some_secret&apos;, 256)))&quot;);
		setStmt.execute(&quot;SET @secretkey = LEFT(@hashed_key, 16)&quot;);
		setStmt.execute(&quot;SET @iv = RIGHT(@hashed_key, 16)&quot;);
	}
//	long startTime = JMeterContextService.getTestStartTime();
	String startTime = vars.get(&quot;startTimeThread&quot;);
	String startTime2 = convertTimestamp(Long.parseLong(startTime));
	int PatientRepeatCount = Integer.parseInt(vars.get(&quot;PatientCount&quot;));
	int VitalRepeatCount = Integer.parseInt(vars.get(&quot;ObservationCount&quot;));
	String threadGroupName = ctx.getThreadGroup().getName();
//	String pattern = &quot;yyyy-MM-dd_HH&quot;; //csv filename format: &quot;2024-10-25_11&quot;
//	SimpleDateFormat simpleDateFormat = new SimpleDateFormat(pattern);
//	String date = simpleDateFormat.format(new Date());
//	String userHome = System.getProperty(&quot;user.home&quot;);
//	String specificDir = &quot;QA_Amelia/apache-jmeter-5.6.3/scripts/scripts_result/Scoring_Manager/&quot;;
//	String filePath = userHome + &quot;/&quot; + specificDir + date;
	String filePath = props.get(&quot;filePath&quot;);
	String csvFilePathPerThreadGroup = filePath + &quot;_&quot; + threadGroupName.replaceAll(&quot;\\s+&quot;, &quot;&quot;) + &quot;.csv&quot;;
	String csvFilePath = filePath + &quot;.csv&quot;;
	String htmlFilePath = filePath + &quot;.html&quot;;
	boolean isTestSuccess = true;
	boolean isICU = false;
	if (${User_Thread} % 2 == 0) {
		isICU = true;
	} else {
		isICU = false;
	}

	String queryBase = &quot;SELECT * FROM vitalcare.emr_score WHERE &quot; +
						&quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id), @secretkey, @iv) AS CHAR) = ? &quot; +
						&quot;AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR) = ? &quot; +
						&quot;AND DELETED=0 &quot; +
						&quot;AND base_dt IN (&quot;;

	for (int i = 0; i &lt; PatientRepeatCount; i++) {
		String patientID = vars.get(&quot;PatientID&quot; + i);
		String encounterID = vars.get(&quot;EncounterID&quot; + i);
		List&lt;String&gt; baseDtList = new ArrayList&lt;&gt;();

		// Get base_dt value from the observed_dt
		for (int j = 0; j &lt; VitalRepeatCount; j++) {
			String ObservedDt = vars.get(&quot;ObservedDt&quot; + j);
			SimpleDateFormat sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
			sdf.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
			Date observedDate = sdf.parse(ObservedDt);
			Calendar calendar = Calendar.getInstance();
			calendar.setTime(observedDate);
//			int minute = calendar.get(Calendar.MINUTE);
//			int baseMinute = minute &lt;= 10 ? 10 : (minute &lt;= 20 ? 20 : (minute &lt;= 30 ? 30 : (minute &lt;= 40 ? 40 : (minute &lt;= 50 ? 50 : 0))));
//			if (minute &gt; 50) {
//				calendar.add(Calendar.HOUR_OF_DAY, 1);
//			}

			int totalMinutes = calendar.get(Calendar.MINUTE);
			int totalSeconds = calendar.get(Calendar.SECOND);
			int baseMinutes = 0;
			if (totalMinutes &lt; 10) {
				baseMinutes = 10;
			} else if (totalMinutes &lt; 20 || (totalMinutes == 20 &amp;&amp; totalSeconds == 0)) {
				baseMinutes = 20;
			} else if (totalMinutes &lt; 30 || (totalMinutes == 30 &amp;&amp; totalSeconds == 0)) {
				baseMinutes = 30;
			} else if (totalMinutes &lt; 40 || (totalMinutes == 40 &amp;&amp; totalSeconds == 0)) {
				baseMinutes = 40;
			} else if (totalMinutes &lt; 50 || (totalMinutes == 50 &amp;&amp; totalSeconds == 0)) {
				baseMinutes = 50;
			} else {
				baseMinutes = 0; // 51-60 minutes
			}
			if (baseMinutes == 0) {
			    calendar.add(Calendar.HOUR_OF_DAY, 1);
			}
			calendar.set(Calendar.MINUTE, baseMinutes);
			calendar.set(Calendar.SECOND, 0);
			SimpleDateFormat utcSdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
			utcSdf.setTimeZone(TimeZone.getTimeZone(&quot;UTC&quot;));
			String baseDt = utcSdf.format(calendar.getTime());
			baseDtList.add(baseDt);
			log.info(&quot;PatientID=&quot; + patientID + &quot;, EncounterID=&quot; + encounterID + &quot;, baseDt=&quot; + baseDt);
		}

		String inClause = String.join(&quot;,&quot;, Collections.nCopies(baseDtList.size(), &quot;?&quot;));
		String query = queryBase + inClause + &quot;)&quot;;
		int validObservedDtCount = baseDtList.size();

		try (PreparedStatement stmt = conn.prepareStatement(query)) {
			stmt.setString(1, patientID);
			stmt.setString(2, encounterID);
			for (int k = 0; k &lt; baseDtList.size(); k++) {
				stmt.setString(3 + k, baseDtList.get(k));
			}
			try (ResultSet resultSet = stmt.executeQuery()) {
				int capsScoreCount = 0;
				int sepsScoreCount = 0;
				int maesScoreCount = 0;
				int morsScoreCount = 0;
				int newsScoreCount = 0;
				int mewsScoreCount = 0;
				while (resultSet.next()) {
					String type = resultSet.getString(&quot;type&quot;);
					switch (type) {
						case &quot;CAPS&quot;:
							capsScoreCount++;
							break;
						case &quot;SEPS&quot;:
							sepsScoreCount++;
							break;
						case &quot;MAES&quot;:
							maesScoreCount++;
							break;
						case &quot;MORS&quot;:
							morsScoreCount++;
							break;
						case &quot;NEWS&quot;:
							newsScoreCount++;
							break;
						case &quot;MEWS&quot;:
							mewsScoreCount++;
							break;
					}
				}
				if (isICU) {
					// Compare the counts of base_dt and score when ICU
					if (baseDtList.size() == morsScoreCount &amp;&amp; baseDtList.size() == newsScoreCount &amp;&amp; baseDtList.size() == mewsScoreCount) {
						isTestSuccess = true;
					} else {
						isTestSuccess = false;
					}
				} else {
					// Compare the counts of base_dt and score when GW
					if (baseDtList.size() == capsScoreCount &amp;&amp; baseDtList.size() == sepsScoreCount &amp;&amp; baseDtList.size() == maesScoreCount &amp;&amp;
						baseDtList.size() == newsScoreCount &amp;&amp; baseDtList.size() == mewsScoreCount) {
						isTestSuccess = true;
					} else {
						isTestSuccess = false;
					}
				}
				long endTime = System.currentTimeMillis();
				String endTime2 = convertTimestamp(endTime);
				Collections.reverse(baseDtList);
				String baseDtString = String.join(&quot;&lt;br&gt;&quot;, baseDtList);
				log.info(&quot;baseDtString=&quot; + baseDtString);
				String csvDataString = String.format(&quot;%s, %s, %s, %s, %s, %s, %d, %d, %s, %d, %d, %d, %d, %d, %d, %s&quot;,
									threadGroupName, startTime2, endTime2, patientID, encounterID, isICU ? &quot;ICU&quot; : &quot;GW&quot;, VitalRepeatCount, validObservedDtCount,baseDtString,
									newsScoreCount, mewsScoreCount, morsScoreCount, capsScoreCount, sepsScoreCount, maesScoreCount,
									isTestSuccess ? &quot;PASS&quot; : &quot;FAIL&quot;);
				logResults(prev, ctx, props, vars, csvDataString)
			}
		}
	}
} catch (SQLException | ParseException e) {
	log.error(&quot;Exception: &quot;, e);
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="false">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.TimeZone;
import java.util.Calendar;
import java.util.Random;
import java.nio.file.*
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter
import java.nio.charset.StandardCharsets

// 기본 타임스탬프
long timestampDefault = ${timestamp_default};

// 반복 횟수
int repeatCount = ${PatientCount}; // 환자 수
int observationCount = ${ObservationCount};

// 랜덤 객체 생성 (성별을 랜덤으로 설정)
Random random = new Random();

for (int i = 0; i &lt; repeatCount; i++) {
    // 날짜 객체 생성
    Date currentDate = new Date(timestampDefault);
    
    Calendar calendar = Calendar.getInstance();
    calendar.setTimeInMillis(timestampDefault);
    calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}));
    calendar.add(Calendar.YEAR, -i - 19);
    long birthTimestamp = calendar.getTimeInMillis();
    Date birthDate = new Date(birthTimestamp);
    
    calendar.setTimeInMillis(timestampDefault);
    calendar.add(Calendar.HOUR, -1);
    long dischargeTimestamp = calendar.getTimeInMillis();
    Date dischargeDate = new Date(dischargeTimestamp);
    
    calendar.setTimeInMillis(timestampDefault);
    calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}));
    calendar.add(Calendar.MONTH, -(i+1));
    long admissionTimestamp = calendar.getTimeInMillis();
    Date admissionDate = new Date(admissionTimestamp);
    long locationStartTimestamp = admissionTimestamp;
    Date locationStartDate = new Date(locationStartTimestamp);
    
    // ICU In 설정 (현재 시간 기준 4시간 전)
    calendar.setTimeInMillis(timestampDefault);
    calendar.add(Calendar.MINUTE, - (i * ${Ob_Interval_Min} + 240));
    long icuInTimestamp = calendar.getTimeInMillis();
    Date icuInDate = new Date(icuInTimestamp);
    
    // ICU Out 설정 (ICU In 이후 4시간 뒤)
    calendar.setTimeInMillis(icuInTimestamp);
    calendar.add(Calendar.HOUR, 4);
    long icuOutTimestamp = calendar.getTimeInMillis();
    Date icuOutDate = new Date(icuOutTimestamp);
    
    String threadGroupName = ctx.getThreadGroup().getName();
    String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1];
    
    SimpleDateFormat sdf = new SimpleDateFormat(i + &quot;789yyMMddHHmmss&quot; + ${User_Thread} + threadGroupNumber);
    sdf.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
    String patientID = sdf.format(currentDate);
    String encounterID = sdf.format(currentDate);
    String name = sdf.format(currentDate);
    
    SimpleDateFormat sdfDate = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
    sdfDate.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));
    String admissionDateStr = sdfDate.format(admissionDate);
    String dischargeDateStr = sdfDate.format(dischargeDate);
    String birthDateStr = sdfDate.format(birthDate);
    String locationStartStr = sdfDate.format(locationStartDate);
    String locationEndStr = sdfDate.format(currentDate);
    String icuInStr = sdfDate.format(icuInDate);
    String icuOutStr = sdfDate.format(icuOutDate);
    
    String gender = random.nextBoolean() ? &quot;M&quot; : &quot;F&quot;;
    
    // 추가 정보 생성
    String ward = (${User_Thread} % 2 == 0) ? &quot;QA_ICU&quot; : &quot;QA_GW&quot;; // ICU 또는 일반병동
    String room = ${User_Thread} + &quot;QA_ROOM&quot; + i;
    String bed = ${User_Thread} + &quot;QA_BED&quot; + i;
    String practitionerID = ${User_Thread} + &quot;QAP&quot; + i;
    String practitionerName = ${User_Thread} + &quot;테스트&quot; + i;
    String departmentCode = ${User_Thread} + &quot;QAD&quot; + i;
    String departmentName = ${User_Thread} + &quot;Quality Assurance&quot; + i;

    // 변수 저장
    vars.put(&quot;PatientID&quot; + i, patientID);
    vars.put(&quot;EncounterID&quot; + i, encounterID);
    vars.put(&quot;Name&quot; + i, name);
    vars.put(&quot;BirthDate&quot; + i, birthDateStr);
    vars.put(&quot;Gender&quot; + i, gender);
    vars.put(&quot;AdmissionDate&quot; + i, admissionDateStr);
    vars.put(&quot;DischargeDate&quot; + i, dischargeDateStr);
    vars.put(&quot;LocationStart&quot; + i, locationStartStr);
    vars.put(&quot;LocationEnd&quot; + i, locationEndStr);
    vars.put(&quot;ICUIn&quot; + i, icuInStr);
    vars.put(&quot;ICUOut&quot; + i, icuOutStr);
    vars.put(&quot;Ward&quot; + i, ward);
    vars.put(&quot;Room&quot; + i, room);
    vars.put(&quot;Bed&quot; + i, bed);
    vars.put(&quot;PractitionerID&quot; + i, practitionerID);
    vars.put(&quot;PractitionerName&quot; + i, practitionerName);
    vars.put(&quot;DepartmentCode&quot; + i, departmentCode);
    vars.put(&quot;DepartmentName&quot; + i, departmentName);
    
    log.info(&quot;Generated PatientID=&quot; + patientID + &quot;, Name=&quot; + name + &quot;, BirthDate=&quot; + birthDateStr + &quot;, Gender=&quot; + gender 
        + &quot;, EncounterID=&quot; + encounterID + &quot;, AdmissionDate=&quot; + admissionDateStr + &quot;, DischargeDate=&quot; + dischargeDateStr
        + &quot;, ICU In=&quot; + icuInStr + &quot;, ICU Out=&quot; + icuOutStr
        + &quot;, Ward=&quot; + ward + &quot;, Room=&quot; + room + &quot;, Bed=&quot; + bed
        + &quot;, PractitionerID=&quot; + practitionerID + &quot;, PractitionerName=&quot; + practitionerName
        + &quot;, DepartmentCode=&quot; + departmentCode + &quot;, DepartmentName=&quot; + departmentName);
}


def logResults = { prev, ctx, props, vars, csvDataString -&gt;

	if (csvDataString == null || csvDataString.trim().isEmpty()) {
		log.error(&quot;csvDataString is null or empty.&quot;)
		return
	}
	
	def now = LocalDateTime.now().format(DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd HH:mm:ss&quot;))
	def outputDir = props.get(&quot;outputDir&quot;)

	if (!Files.exists(Paths.get(outputDir))) {
		Files.createDirectories(Paths.get(outputDir))
	}

	def csvDataArray = csvDataString.split(&quot;,&quot;)  // CSV 데이터를 배열로 변환
	def fullThreadName = prev.getThreadName()
	def threadGroupName = fullThreadName.split(&quot; &quot;)[0] + fullThreadName.split(&quot; &quot;)[1]
	def controllerName = vars.get(&quot;currentControllerName&quot;)

	def resultFile = Paths.get(outputDir, &quot;${controllerName}.csv&quot;)

	def csvHeader = &quot;Group,Scenario,StartTime,EndTime,Patient ID, Encounter ID, ICU, Vital Count, ObservedDt Count, base_dt, news, mews, mors, caps, seps, maes, Test Result\n&quot;
	if (!Files.exists(resultFile)) {
		Files.createDirectories(resultFile.parent)
		Files.write(resultFile, csvHeader.getBytes(StandardCharsets.UTF_8), StandardOpenOption.CREATE)
	}

	// 데이터 추가 (ThreadGroupName, SamplerName, csvDataString)
	def dataToWrite = &quot;${controllerName}, ${csvDataString}\n&quot;

	Files.write(resultFile, dataToWrite.getBytes(StandardCharsets.UTF_8), StandardOpenOption.APPEND)
}

vars.putObject(&quot;logResults&quot;, logResults)
</stringProp>
        </JSR223PreProcessor>
