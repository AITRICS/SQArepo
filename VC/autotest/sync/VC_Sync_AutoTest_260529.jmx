        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Vital_Data_JSR223 Sampler-GCS_TOTAL" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;
import java.util.Random;

	// JDBC connection information
	String url = &quot;${JDBC_URL}&quot;;
	String user = &quot;${JDBC_USER}&quot;;
	String password = &quot;${JDBC_PW}&quot;;
	
	// Define the query
	String query = &quot;INSERT INTO ROOT.VITALS (PATIENT_ID, ENCOUNTER_ID, OBSERVED_DT, CODE, VALUE, DELETED_YN, INVALID) &quot; +
           &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?, ?, ?, ?)&quot;;

	Connection conn = DriverManager.getConnection(url, user, password);
	PreparedStatement stmt = conn.prepareStatement(query);
	int rowsInsert;

	// Repeat the process for multiple sets of parameters
	int PatientRepeatCount = ${PatientCount} // Number of repetitions set
	int VitalRepeatCount = ${ObservationCount}; // Number of repetitions set
	for (int i = 0; i &lt; PatientRepeatCount; i++) {
         String PatientID = vars.get(&quot;PatientID&quot; + i);
	    String EncounterID = vars.get(&quot;EncounterID&quot; + i);
		for (int j = 0; j &lt;= VitalRepeatCount; j++) {
			String ObserverdDt = vars.get(&quot;ObservedDt&quot; + j);
			// Assigning random values to variables within the loop
			Random random = new Random();
			// Generate a Pulse Rate (PR) value ranging from 0 to 299
			String PR_Value = String.valueOf(random.nextInt(300));
			
			// Generate a Respiratory Rate (RR) value ranging from 0 to 119
			String RR_Value = String.valueOf(random.nextInt(120));
			
			// Generate a Body Temperature (BT) value ranging from 25.0 to 49.9 (1 decimal place)
			String BT_Value = String.format(&quot;%.1f&quot;, 25 + random.nextInt(25) + random.nextDouble());
			
			// Generate a Systolic Blood Pressure (SBP) value ranging from 0 to 299
			String SBP_Value = String.valueOf(random.nextInt(300));
			
			// Generate a Diastolic Blood Pressure (DBP) value ranging from 0 to 299
			String DBP_Value = String.valueOf(random.nextInt(300));
			
			// Generate an Oxygen Saturation (SpO2) value ranging from 0 to 99
			String SpO2_Value = String.valueOf(random.nextInt(100));
			
			// Generate a Glasgow Coma Scale (GCS) value ranging from 3 to 15
			String GCS_Value = String.valueOf(new Random().nextInt(13) + 3);
			
			// Generate an oxygen saturation (O2) value ranging from 0 to 29
			String O2_Value = String.valueOf(new Random().nextInt(30));
			
			// Generate a fraction of inspired oxygen (FiO2) value ranging from 0 to 29
			String FiO2_Value = String.valueOf(new Random().nextInt(30));
		
		    insertObservation(conn, stmt, PatientID, EncounterID, ObserverdDt, &quot;PULSE&quot;, PR_Value, j);
		    insertObservation(conn, stmt, PatientID, EncounterID, ObserverdDt, &quot;RESP&quot;, RR_Value, j);
		    insertObservation(conn, stmt, PatientID, EncounterID, ObserverdDt, &quot;TEMP&quot;, BT_Value, j);
		    insertObservation(conn, stmt, PatientID, EncounterID, ObserverdDt, &quot;SBP&quot;, SBP_Value, j);
		    insertObservation(conn, stmt, PatientID, EncounterID, ObserverdDt, &quot;DBP&quot;, DBP_Value, j);
		    insertObservation(conn, stmt, PatientID, EncounterID, ObserverdDt, &quot;SpO2&quot;, SpO2_Value, j);
		    insertObservation(conn, stmt, PatientID, EncounterID, ObserverdDt, &quot;GCS&quot;, GCS_Value, j);
		    insertObservation(conn, stmt, PatientID, EncounterID, ObserverdDt, &quot;O2&quot;, O2_Value, j);
		    insertObservation(conn, stmt, PatientID, EncounterID, ObserverdDt, &quot;FiO2&quot;, FiO2_Value, j);
		}
	}

public void insertObservation(Connection conn, PreparedStatement stmt, String patientID, 
				         String encounterID, String observerdDt, String code, String value, int j){
    stmt.setString(1, patientID);
    stmt.setString(2, encounterID);
    stmt.setString(3, observerdDt);
    stmt.setString(4, code);
    stmt.setDouble(5, Double.parseDouble(value));
    stmt.setInt(6, 0);
    stmt.setInt(7, 0);
    
    int rowsInsert = stmt.executeUpdate();
    // Clear parameters for reusing the statement
    stmt.clearParameters();
}
// Close the connection
conn.close();
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Observation Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${ObservationCount}

SimpleDateFormat sdfObserved = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
sdfObserved.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

for (int i = 0; i &lt;= repeatCount; i++) {

    long observedTs

    if (i == repeatCount - 1) {
        Calendar last = Calendar.getInstance(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
        last.setTimeInMillis(System.currentTimeMillis())
        last.add(Calendar.MINUTE, -(i * ${Ob_Interval_Min}))

        int minute = last.get(Calendar.MINUTE)
        int mod = minute % 10
        if (mod != 0) last.add(Calendar.MINUTE, 10 - mod)
        else last.add(Calendar.MINUTE, 10)

        last.set(Calendar.SECOND, 0)
        last.set(Calendar.MILLISECOND, 0)
        observedTs = last.getTimeInMillis()
    } else {
        Calendar cal = Calendar.getInstance(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
        cal.setTimeInMillis(timestampDefault)
        cal.add(Calendar.MINUTE, -(i * ${Ob_Interval_Min}))
        observedTs = cal.getTimeInMillis()
    }

    String observedDt = sdfObserved.format(new Date(observedTs))
    vars.put(&quot;ObservedDt&quot; + i, observedDt)
}

log.info(&quot;[OBS_VARS] ObservationCount=&quot; + repeatCount
        + &quot; first=&quot; + vars.get(&quot;ObservedDt0&quot;)
        + &quot; last=&quot; + vars.get(&quot;ObservedDt&quot; + repeatCount))
</stringProp>
          </JSR223PreProcessor>
