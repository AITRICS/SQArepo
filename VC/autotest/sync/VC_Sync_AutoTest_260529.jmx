        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(Result)_JSR223 Sampler" enabled="false">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.nio.charset.StandardCharsets

def baseDir = Paths.get(&quot;C:/Users/김민지/sync_result&quot;)
def version = vars.get(&quot;version&quot;) ?: &quot;unknown&quot;
def csvPath = baseDir.resolve(&quot;${version}_Sync.csv&quot;)

if (!Files.exists(csvPath)) {
    log.error(&quot;CSV not found: ${csvPath}&quot;)
    return
}

def lines = Files.readAllLines(csvPath, StandardCharsets.UTF_8)
if (lines.size() &lt;= 1) {
    log.warn(&quot;No data rows in CSV: ${csvPath}&quot;)
}

def rows = lines.drop(1).collect { it.split(&quot;\\|&quot;, -1) }

int total = rows.size()
int passCnt = rows.count { it.size() &gt;= 7 &amp;&amp; it[6].trim().equalsIgnoreCase(&quot;PASS&quot;) }
int failCnt = total - passCnt

def starts = rows.collect { it.size() &gt;= 3 ? it[2].trim() : &quot;&quot; }.findAll { it }
def ends   = rows.collect { it.size() &gt;= 4 ? it[3].trim() : &quot;&quot; }.findAll { it }

def startTime = starts ? starts.min() : &quot;N/A&quot;
def endTime   = ends   ? ends.max()   : &quot;N/A&quot;

def html = &quot;&quot;&quot;
&lt;h2&gt;Test Summary&lt;/h2&gt;
&lt;h3&gt;Total Summary Statistics&lt;/h3&gt;
&lt;table&gt;
&lt;tr&gt;&lt;th&gt;Total TestCases&lt;/th&gt;&lt;td&gt;${total}&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;th&gt;PASS (Count)&lt;/th&gt;&lt;td&gt;${passCnt}&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;th&gt;FAIL (Count)&lt;/th&gt;&lt;td&gt;${failCnt}&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;th&gt;Start Time&lt;/th&gt;&lt;td&gt;${startTime}&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;th&gt;End Time&lt;/th&gt;&lt;td&gt;${endTime}&lt;/td&gt;&lt;/tr&gt;
&lt;/table&gt;
&quot;&quot;&quot;

def out = baseDir.resolve(&quot;${version}_Sync_Result.html&quot;)
Files.write(out, html.getBytes(&quot;UTF-8&quot;))
log.info(&quot;SYNC Result HTML generated: ${out}&quot;)
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(Result_Detail_Log)_JSR223 Sampler" enabled="false">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.nio.charset.StandardCharsets

def baseDir = Paths.get(&quot;C:/Users/김민지/sync_result&quot;)
def version = vars.get(&quot;version&quot;) ?: &quot;unknown&quot;
def csvPath = baseDir.resolve(&quot;${version}_Sync.csv&quot;)

if (!Files.exists(csvPath)) {
    log.error(&quot;CSV not found: ${csvPath}&quot;)
    return
}

def lines = Files.readAllLines(csvPath, StandardCharsets.UTF_8)
if (lines.size() &lt;= 1) {
    log.warn(&quot;No data rows in CSV&quot;)
    return
}

def header = lines[0].split(&quot;\\|&quot;, -1)                     
def rows   = lines.drop(1).collect { it.split(&quot;\\|&quot;, -1) }

def groups = rows.groupBy { it.size() &gt; 0 ? it[0] : &quot;Unknown&quot; }

// html escape
def esc = { s -&gt;
    if (s == null) return &quot;&quot;
    return s.replace(&quot;&amp;&quot;,&quot;&amp;amp;&quot;).replace(&quot;&lt;&quot;,&quot;&amp;lt;&quot;).replace(&quot;&gt;&quot;,&quot;&amp;gt;&quot;)
}

groups.each { groupName, rs -&gt;
    def safeGroupName = groupName.replaceAll(&quot;[^a-zA-Z0-9_-]&quot;, &quot;_&quot;)

    def html = new StringBuilder()
    html &lt;&lt; &quot;&lt;table&gt;\n&lt;tr&gt;&quot;
    header.each { h -&gt; html &lt;&lt; &quot;&lt;th&gt;${esc(h)}&lt;/th&gt;&quot; }
    html &lt;&lt; &quot;&lt;/tr&gt;\n&quot;

    rs.each { cols -&gt;
        html &lt;&lt; &quot;&lt;tr&gt;&quot;
        cols.eachWithIndex { v, i -&gt;
            if (i == 4 || i == 5) { // Source/Destination
                html &lt;&lt; &quot;&lt;td&gt;&lt;pre&gt;${esc(v)}&lt;/pre&gt;&lt;/td&gt;&quot;
            } else if (i == 6) { // Result
                def cls = (v?.trim()?.equalsIgnoreCase(&quot;PASS&quot;)) ? &quot;PASS&quot; : &quot;FAIL&quot;
                html &lt;&lt; &quot;&lt;td class=&apos;${cls}&apos;&gt;${esc(v)}&lt;/td&gt;&quot;
            } else {
                html &lt;&lt; &quot;&lt;td&gt;${esc(v)}&lt;/td&gt;&quot;
            }
        }
        html &lt;&lt; &quot;&lt;/tr&gt;\n&quot;
    }

    html &lt;&lt; &quot;&lt;/table&gt;&quot;

    def outPath = baseDir.resolve(&quot;${safeGroupName}.html&quot;)
    Files.write(outPath, html.toString().getBytes(StandardCharsets.UTF_8))
    log.info(&quot;SYNC Detail HTML generated: ${outPath}&quot;)
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(Integration_JSR223 Sampler" enabled="false">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">// ============================
// Case 1-2 SetVars (numeric only)
// ============================

import java.text.SimpleDateFormat
import java.util.Date
import java.util.concurrent.ThreadLocalRandom

vars.put(&quot;scenario_id&quot;, &quot;1-2&quot;)
vars.put(&quot;expect_mode&quot;, &quot;SYNC_NOT_EXPECTED&quot;)
vars.put(&quot;PatientCount&quot;, &quot;1&quot;)

// 리포트 정렬키 (1-1 -&gt; 1-2 -&gt; 1-3 원하면 120)
vars.put(&quot;order_key&quot;, &quot;120&quot;)

def fmt = new SimpleDateFormat(&quot;yyMMddHHmmssSSS&quot;) // ✅ SSS
def base = fmt.format(new Date())                 // 예: 260130132455123

def tid = ctx.getThreadNum()                      // 예: 1
def rnd = ThreadLocalRandom.current().nextInt(0, 1000) // 0~999
def rnd3 = String.format(&quot;%03d&quot;, rnd)             // 예: 042

// ✅ 숫자만, pid != eid 보장 (맨 앞자리만 다르게)
def pid = &quot;2&quot; + base + tid + rnd3                 // 예: 2260130132455123142
def eid = &quot;3&quot; + base + tid + rnd3                 // 예: 3260130132455123142

vars.put(&quot;patient_id&quot;, pid)
vars.put(&quot;encounter_id&quot;, eid)

vars.put(&quot;verify_patient_id&quot;, pid)
vars.put(&quot;verify_encounter_id&quot;, eid)

log.info(&quot;[1-2 SetVars] order_key=&quot; + vars.get(&quot;order_key&quot;)
        + &quot;, patient_id=&quot; + pid
        + &quot;, encounter_id=&quot; + eid
        + &quot;, threadNum=&quot; + tid)
</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
    </hashTree>
  </hashTree>
</jmeterTestPlan>
