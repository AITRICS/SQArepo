        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Patient_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;

def pidLog = (vars.get(&quot;patient_id&quot;) ?: vars.get(&quot;PatientID&quot;) ?: vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString()
log.info(&quot;[PAT INSERT DBG] scenario_id=&quot; + (vars.get(&quot;scenario_id&quot;) ?: &quot;&quot;)
        + &quot; thread=&quot; + ctx.getThreadNum()
        + &quot; pid=&quot; + pidLog)


// Scenario(Thread) start time: set once
if (!vars.get(&quot;startTimeThread&quot;)) {
    vars.put(&quot;startTimeThread&quot;, String.valueOf(System.currentTimeMillis()))
}

	// JDBC connection information
	String url = &quot;${JDBC_URL}&quot;;
	String user = &quot;${JDBC_USER}&quot;;
	String password = &quot;${JDBC_PW}&quot;;

	// Define the query
	String query = &quot;INSERT INTO ROOT.PATIENTS (PATIENT_ID, NAME, BIRTHDATE, SEX) &quot; +
	                &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?)&quot;;

	// JDBC connection
	Connection conn = DriverManager.getConnection(url, user, password);

	// Prepare the statement
	PreparedStatement stmt = conn.prepareStatement(query);

	// Repeat the process for multiple sets of parameters
	int repeatCount = ${PatientCount}; // Number of repetitions set
		for (int i = 0; i &lt; repeatCount; i++) {
		    // Set String parameters for the query
		    String PatientID = vars.get(&quot;PatientID&quot; + i);
		    String Name = vars.get(&quot;Name&quot; + i);
		    String BirthDate = vars.get(&quot;BirthDate&quot; + i);
		    
		    // Set parameters for the query
		    stmt.setString(1, PatientID);
		    stmt.setString(2, &quot;QA&quot;+Name);
		    stmt.setString(3, BirthDate);
		    // Set gender based on whether i is odd or even
		    if (${User_Thread} % 2 == 0) {
		        stmt.setString(4, &quot;female&quot;);
		    } else {
		        stmt.setString(4, &quot;male&quot;);
		    }
		    
		    // Execute the query
		    int rowsInsert = stmt.executeUpdate();
		    
		    // Log
		    log.info(&quot;Inserted patientID: &quot; + PatientID);

		    vars.put(&quot;patient_id&quot;, PatientID)
			//log.info(&quot;[ID_MAP] patient_id=&quot; + vars.get(&quot;patient_id&quot;))

		    
		    // Clear parameters for reusing the statement
		    stmt.clearParameters();

		}
// Close the connection
conn.close();
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Patient Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount} // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
    
    // Create a Date object
    Date PatientSet = new Date(timestampDefault)
    Date EncounterSet = new Date(timestampDefault)
    Date NameSet = new Date(timestampDefault)

    // Set Date
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault) // Set the default timestamp    
    calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}))

    // --- Generate random birthdate for age between 19 and 150 ---
    int minAge = 19
    int maxAge = 110
    int randomAge = minAge + (int)(Math.random() * (maxAge - minAge + 1))
    
    // Copy current timestamp for age validation
    Calendar nowCal = Calendar.getInstance()
    nowCal.setTimeInMillis(timestampDefault)
    
    // Subtract random age in years
    calendar.add(Calendar.YEAR, -randomAge)
    
    // Randomize month and day
    int randomMonth = (int)(Math.random() * 12)  // 0-11
    calendar.set(Calendar.MONTH, randomMonth)
    int maxDay = calendar.getActualMaximum(Calendar.DAY_OF_MONTH)
    int randomDay = 1 + (int)(Math.random() * maxDay)
    calendar.set(Calendar.DAY_OF_MONTH, randomDay)
    
    // Ensure age is at least 19 (if birthday is in the future, subtract one more year)
    if (calendar.after(nowCal)) {
        calendar.add(Calendar.YEAR, -1)
    }
    
    // Final birthdate object
    long BirthDatetimeStamp = calendar.getTimeInMillis()
    Date BirthSet = new Date(BirthDatetimeStamp)
    
    String threadGroupName = ctx.getThreadGroup().getName()
    String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1]

    // Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i + &quot;yyMMddHHmmss&quot; + ${User_Thread} + threadGroupNumber)
    sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string
    String PatientID = sdf_patient.format(PatientSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_name = new SimpleDateFormat(i+&quot;ddHHmmss&quot;+${User_Thread})
    sdf_name.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String Name = sdf_name.format(NameSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_birthdate = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;)
    sdf_birthdate.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String BirthDate = sdf_birthdate.format(BirthSet)

    // Store in variables
    vars.put(&quot;PatientID&quot; + i, PatientID)
    vars.put(&quot;Name&quot; + i, Name)
    vars.put(&quot;BirthDate&quot; + i, BirthDate)
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Encounter_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;

	// JDBC connection information
	String url = &quot;${JDBC_URL}&quot;;
	String user = &quot;${JDBC_USER}&quot;;
	String password = &quot;${JDBC_PW}&quot;;

	// Define the query
	String query = &quot;INSERT INTO ROOT.ENCOUNTERS (ENCOUNTER_ID, PATIENT_ID, ADMISSION_DATE, DISCHARGE_DATE) &quot; +
	                &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;))&quot;;

    Connection conn = DriverManager.getConnection(url, user, password);
    PreparedStatement stmt = conn.prepareStatement(query);

	// Repeat the process for multiple sets of parameters
	int repeatCount = ${PatientCount}; // Number of repetitions set
		for (int i = 0; i &lt; repeatCount; i++) {
		    // Set parameters for the query
		    String EncounterID=vars.get(&quot;EncounterID&quot; + i);
		    String PatientID=vars.get(&quot;PatientID&quot; + i);
		    String AdmissionDate=vars.get(&quot;AdmissionDate&quot; + i);
		    String DisChargeDate=vars.get(&quot;DischargeDate&quot; + i);
		    stmt.setString(1, EncounterID);
		    stmt.setString(2, PatientID);
		    stmt.setString(3, AdmissionDate);
	         if (i == 9) {
		        stmt.setString(4, DisChargeDate);
		    } else {
		        stmt.setNull(4, java.sql.Types.DATE); // Set NULL value
		    }
		    
		    // Execute the query
		    int rowsInsert = stmt.executeUpdate();
		    
		    // Log the number of inserted rows
		    log.info(&quot;Inserted EncounterID: &quot; + EncounterID);

		    vars.put(&quot;encounter_id&quot;, EncounterID)  
			//log.info(&quot;[ID_MAP] encounter_id=&quot; + vars.get(&quot;encounter_id&quot;))

		    
		    // Clear parameters for reusing the statement
		    stmt.clearParameters();
		}
// Close the connection
conn.close();

 
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Encounter Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount} // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
    
    // Create a Date object
    Date PatientSet = new Date(timestampDefault)
    Date EncounterSet = new Date(timestampDefault)

    // Set Date
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault) // Set the default timestamp    
    calendar.add(Calendar.HOUR, -1)

    long DischargeDateTimestamp = calendar.getTimeInMillis()
    Date DischargeSet = new Date(DischargeDateTimestamp)

    calendar.setTimeInMillis(timestampDefault) // Reset timestamp    
    calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}))
    calendar.add(Calendar.MONTH, -(i+1))
    long AdmissionDatetimeStamp = calendar.getTimeInMillis()
    Date AdmissionSet = new Date(AdmissionDatetimeStamp)
    
    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_patient = new SimpleDateFormat(i+&quot;yyMMddHHmmss&quot;+${User_Thread})
    sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    
    // Format the date to string
    String PatientID = vars.get(&quot;PatientID&quot; + i)

    String threadGroupName = ctx.getThreadGroup().getName()
    String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1]

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_encounter = new SimpleDateFormat(i + &quot;yyyyMMddHHmmss&quot; + ${User_Thread} + threadGroupNumber)
    sdf_encounter.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String EncounterID = sdf_encounter.format(EncounterSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_admission = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    sdf_admission.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String AdmissionDate = sdf_admission.format(AdmissionSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_discharge = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    sdf_discharge.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String DischargeDate = sdf_discharge.format(DischargeSet)
    
    // Store in variables
    vars.put(&quot;EncounterID&quot; + i, EncounterID + &quot;|&quot; + PatientID)
    vars.put(&quot;AdmissionDate&quot; + i, AdmissionDate)
    vars.put(&quot;DischargeDate&quot; + i, DischargeDate)
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Location_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection
import java.sql.DriverManager
import java.sql.PreparedStatement
import java.sql.Types

String url = &quot;${JDBC_URL}&quot;
String user = &quot;${JDBC_USER}&quot;
String password = &quot;${JDBC_PW}&quot;

String query =
    &quot;INSERT INTO ROOT.LOCATIONS (PATIENT_ID, ENCOUNTER_ID, START_DT, END_DT, WARD, ROOM, BED, &quot; +
    &quot;practitioner_id, practitioner_name, department_code, department_name) &quot; +
    &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?, ?, ?, ?, ?, ?, ?)&quot;

Connection conn = null
PreparedStatement stmt = null

try {

    conn = DriverManager.getConnection(url, user, password)
    stmt = conn.prepareStatement(query)

    int repeatCount = ${PatientCount}

    for (int i = 0; i &lt; repeatCount; i++) {
        String PatientID = vars.get(&quot;PatientID&quot; + i)
        String EncounterID = vars.get(&quot;EncounterID&quot; + i)
        String LocationStart = vars.get(&quot;LocationStart&quot; + i)
        String LocationEnd = vars.get(&quot;LocationEnd&quot; + i)

        stmt.setString(1, PatientID)
        stmt.setString(2, EncounterID)
        stmt.setString(3, LocationStart)

        // 원본 로직 유지: END_DT는 NULL로 넣고 싶으면 NULL
        stmt.setNull(4, Types.VARCHAR)

        if (${User_Thread} % 2 == 0) {
            stmt.setString(5, &quot;QA_ICU&quot;)
        } else {
            stmt.setString(5, &quot;QA_GW&quot;)
        }

        stmt.setString(6, ${User_Thread} + &quot;QA_ROOM&quot; + i)
        stmt.setString(7, ${User_Thread} + &quot;QA_BED&quot; + i)
        stmt.setString(8, ${User_Thread} + &quot;QAP&quot; + i)
        stmt.setString(9, ${User_Thread} + &quot;테스트&quot; + i)
        stmt.setString(10, ${User_Thread} + &quot;QAD&quot; + i)
        stmt.setString(11, ${User_Thread} + &quot;Quality Assurance&quot; + i)

        int rowsInsert = stmt.executeUpdate()
        log.info(&quot;[LOC] affectedRows=&quot; + rowsInsert)

        stmt.clearParameters()
    }

} catch (Exception e) {
    // 여기서 ORA-00001 / ORA-xxxx 같은 핵심이 반드시 로그로 찍힘
    log.error(&quot;[LOC] insert failed&quot;, e)
    throw e
} finally {
    try { if (stmt != null) stmt.close() } catch (ignored) {}
    try { if (conn != null) conn.close() } catch (ignored) {}
}
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Location Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.TimeZone;
import java.util.Calendar;

// Default timestamp
long timestampDefault = ${timestamp_default};
//long timestampDefault = props.get(&quot;timestamp_default&quot;) as long;

// Repeat count
int repeatCount = ${PatientCount}; // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
	// Create a Date object
	Date PatientSet = new Date(timestampDefault);
	Date EncounterSet = new Date(timestampDefault);
	Date LocationEndSet= new Date(timestampDefault);
	// Set Date
	Calendar calendar = Calendar.getInstance();
	calendar.setTimeInMillis(timestampDefault); // Set the default timestamp		
	calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}));
	calendar.add(Calendar.MONTH, -(i+1));

	long LocationStartSetTimestamp = calendar.getTimeInMillis();
	Date LocationStartSet= new Date(LocationStartSetTimestamp);

	String threadGroupName = ctx.getThreadGroup().getName();
	String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1];

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i+&quot;yyMMddHHmmss&quot;+${User_Thread}+threadGroupNumber);
	sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

	// Format the date to string
	String PatientID = sdf_patient.format(PatientSet);

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_encounter = new SimpleDateFormat(i+&quot;yyyyMMddHHmmss&quot;+${User_Thread}+threadGroupNumber);
	sdf_encounter.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

	// Format the date to string
	String EncounterID = sdf_encounter.format(EncounterSet);

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_LocationStartSet = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	sdf_LocationStartSet.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

	// Format the date to string
	String LocationStart = sdf_LocationStartSet.format(LocationStartSet);

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_LocationEndSet = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	sdf_LocationEndSet.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

	// Format the date to string
	String LocationEnd = sdf_LocationEndSet.format(LocationEndSet);

// Store ONLY location time variables (do NOT override Patient/Encounter IDs)
vars.put(&quot;LocationStart&quot; + i, LocationStart)
vars.put(&quot;LocationEnd&quot; + i, LocationEnd)

}
</stringProp>
          </JSR223PreProcessor>
