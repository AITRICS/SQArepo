        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Patient_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;

def pidLog = (vars.get(&quot;patient_id&quot;) ?: vars.get(&quot;PatientID&quot;) ?: vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString()
log.info(&quot;[PAT INSERT DBG] scenario_id=&quot; + (vars.get(&quot;scenario_id&quot;) ?: &quot;&quot;)
        + &quot; thread=&quot; + ctx.getThreadNum()
        + &quot; pid=&quot; + pidLog)


// Scenario(Thread) start time: set once
if (!vars.get(&quot;startTimeThread&quot;)) {
    vars.put(&quot;startTimeThread&quot;, String.valueOf(System.currentTimeMillis()))
}

	// JDBC connection information
	String url = &quot;${JDBC_URL}&quot;;
	String user = &quot;${JDBC_USER}&quot;;
	String password = &quot;${JDBC_PW}&quot;;

	// Define the query
	String query = &quot;INSERT INTO ROOT.PATIENTS (PATIENT_ID, NAME, BIRTHDATE, SEX) &quot; +
	                &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?)&quot;;

	// JDBC connection
	Connection conn = DriverManager.getConnection(url, user, password);

	// Prepare the statement
	PreparedStatement stmt = conn.prepareStatement(query);

	// Repeat the process for multiple sets of parameters
	int repeatCount = ${PatientCount}; // Number of repetitions set
		for (int i = 0; i &lt; repeatCount; i++) {
		    // Set String parameters for the query
		    String PatientID = vars.get(&quot;PatientID&quot; + i);
		    String Name = vars.get(&quot;Name&quot; + i);
		    String BirthDate = vars.get(&quot;BirthDate&quot; + i);
		    
		    // Set parameters for the query
		    stmt.setString(1, PatientID);
		    stmt.setString(2, &quot;QA&quot;+Name);
		    stmt.setString(3, BirthDate);
		    // Set gender based on whether i is odd or even
		    if (${User_Thread} % 2 == 0) {
		        stmt.setString(4, &quot;female&quot;);
		    } else {
		        stmt.setString(4, &quot;male&quot;);
		    }
		    
		    // Execute the query
		    int rowsInsert = stmt.executeUpdate();
		    
		    // Log
		    log.info(&quot;Inserted patientID: &quot; + PatientID);

		    vars.put(&quot;patient_id&quot;, PatientID)
			//log.info(&quot;[ID_MAP] patient_id=&quot; + vars.get(&quot;patient_id&quot;))

		    
		    // Clear parameters for reusing the statement
		    stmt.clearParameters();

		}
// Close the connection
conn.close();
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Patient Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount} // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
    
    // Create a Date object
    Date PatientSet = new Date(timestampDefault)
    Date EncounterSet = new Date(timestampDefault)
    Date NameSet = new Date(timestampDefault)

    // Set Date
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault) // Set the default timestamp    
    calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}))

    // --- Generate random birthdate for age between 19 and 150 ---
    int minAge = 19
    int maxAge = 110
    int randomAge = minAge + (int)(Math.random() * (maxAge - minAge + 1))
    
    // Copy current timestamp for age validation
    Calendar nowCal = Calendar.getInstance()
    nowCal.setTimeInMillis(timestampDefault)
    
    // Subtract random age in years
    calendar.add(Calendar.YEAR, -randomAge)
    
    // Randomize month and day
    int randomMonth = (int)(Math.random() * 12)  // 0-11
    calendar.set(Calendar.MONTH, randomMonth)
    int maxDay = calendar.getActualMaximum(Calendar.DAY_OF_MONTH)
    int randomDay = 1 + (int)(Math.random() * maxDay)
    calendar.set(Calendar.DAY_OF_MONTH, randomDay)
    
    // Ensure age is at least 19 (if birthday is in the future, subtract one more year)
    if (calendar.after(nowCal)) {
        calendar.add(Calendar.YEAR, -1)
    }
    
    // Final birthdate object
    long BirthDatetimeStamp = calendar.getTimeInMillis()
    Date BirthSet = new Date(BirthDatetimeStamp)
    
    String threadGroupName = ctx.getThreadGroup().getName()
    String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1]

    // Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i + &quot;yyMMddHHmmss&quot; + ${User_Thread} + threadGroupNumber)
    sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string
    String PatientID = sdf_patient.format(PatientSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_name = new SimpleDateFormat(i+&quot;ddHHmmss&quot;+${User_Thread})
    sdf_name.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String Name = sdf_name.format(NameSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_birthdate = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;)
    sdf_birthdate.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String BirthDate = sdf_birthdate.format(BirthSet)

    // Store in variables
    vars.put(&quot;PatientID&quot; + i, PatientID)
    vars.put(&quot;Name&quot; + i, Name)
    vars.put(&quot;BirthDate&quot; + i, BirthDate)
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Encounter_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;

	// JDBC connection information
	String url = &quot;${JDBC_URL}&quot;;
	String user = &quot;${JDBC_USER}&quot;;
	String password = &quot;${JDBC_PW}&quot;;

	// Define the query
	String query = &quot;INSERT INTO ROOT.ENCOUNTERS (ENCOUNTER_ID, PATIENT_ID, ADMISSION_DATE, DISCHARGE_DATE) &quot; +
	                &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;))&quot;;

    Connection conn = DriverManager.getConnection(url, user, password);
    PreparedStatement stmt = conn.prepareStatement(query);

	// Repeat the process for multiple sets of parameters
	int repeatCount = ${PatientCount}; // Number of repetitions set
		for (int i = 0; i &lt; repeatCount; i++) {
		    // Set parameters for the query
		    String EncounterID=vars.get(&quot;EncounterID&quot; + i);
		    String PatientID=vars.get(&quot;PatientID&quot; + i);
		    String AdmissionDate=vars.get(&quot;AdmissionDate&quot; + i);
		    String DisChargeDate=vars.get(&quot;DischargeDate&quot; + i);
		    stmt.setString(1, EncounterID);
		    stmt.setString(2, PatientID);
		    stmt.setString(3, AdmissionDate);
	         if (i == 9) {
		        stmt.setString(4, DisChargeDate);
		    } else {
		        stmt.setNull(4, java.sql.Types.DATE); // Set NULL value
		    }
		    
		    // Execute the query
		    int rowsInsert = stmt.executeUpdate();
		    
		    // Log the number of inserted rows
		    log.info(&quot;Inserted EncounterID: &quot; + EncounterID);

		    vars.put(&quot;encounter_id&quot;, EncounterID)  
			//log.info(&quot;[ID_MAP] encounter_id=&quot; + vars.get(&quot;encounter_id&quot;))

		    
		    // Clear parameters for reusing the statement
		    stmt.clearParameters();
		}
// Close the connection
conn.close();

 
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Encounter Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount} // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
    
    // Create a Date object
    Date PatientSet = new Date(timestampDefault)
    Date EncounterSet = new Date(timestampDefault)

    // Set Date
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault) // Set the default timestamp    
    calendar.add(Calendar.HOUR, -1)

    long DischargeDateTimestamp = calendar.getTimeInMillis()
    Date DischargeSet = new Date(DischargeDateTimestamp)

    calendar.setTimeInMillis(timestampDefault) // Reset timestamp    
    calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}))
    calendar.add(Calendar.MONTH, -(i+1))
    long AdmissionDatetimeStamp = calendar.getTimeInMillis()
    Date AdmissionSet = new Date(AdmissionDatetimeStamp)
    
    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_patient = new SimpleDateFormat(i+&quot;yyMMddHHmmss&quot;+${User_Thread})
    sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    
    // Format the date to string
    String PatientID = vars.get(&quot;PatientID&quot; + i)

    String threadGroupName = ctx.getThreadGroup().getName()
    String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1]

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_encounter = new SimpleDateFormat(i + &quot;yyyyMMddHHmmss&quot; + ${User_Thread} + threadGroupNumber)
    sdf_encounter.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String EncounterID = sdf_encounter.format(EncounterSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_admission = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    sdf_admission.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String AdmissionDate = sdf_admission.format(AdmissionSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_discharge = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    sdf_discharge.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String DischargeDate = sdf_discharge.format(DischargeSet)
    
    // Store in variables
    vars.put(&quot;EncounterID&quot; + i, EncounterID + &quot;|&quot; + PatientID)
    vars.put(&quot;AdmissionDate&quot; + i, AdmissionDate)
    vars.put(&quot;DischargeDate&quot; + i, DischargeDate)
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Location_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection
import java.sql.DriverManager
import java.sql.PreparedStatement
import java.sql.Types

String url = &quot;${JDBC_URL}&quot;
String user = &quot;${JDBC_USER}&quot;
String password = &quot;${JDBC_PW}&quot;

String query =
    &quot;INSERT INTO ROOT.LOCATIONS (PATIENT_ID, ENCOUNTER_ID, START_DT, END_DT, WARD, ROOM, BED, &quot; +
    &quot;practitioner_id, practitioner_name, department_code, department_name) &quot; +
    &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?, ?, ?, ?, ?, ?, ?)&quot;

Connection conn = null
PreparedStatement stmt = null

try {

    conn = DriverManager.getConnection(url, user, password)
    stmt = conn.prepareStatement(query)

    int repeatCount = ${PatientCount}

    for (int i = 0; i &lt; repeatCount; i++) {
        String PatientID = vars.get(&quot;PatientID&quot; + i)
        String EncounterID = vars.get(&quot;EncounterID&quot; + i)
        String LocationStart = vars.get(&quot;LocationStart&quot; + i)
        String LocationEnd = vars.get(&quot;LocationEnd&quot; + i)

        stmt.setString(1, PatientID)
        stmt.setString(2, EncounterID)
        stmt.setString(3, LocationStart)

        // 원본 로직 유지: END_DT는 NULL로 넣고 싶으면 NULL
        stmt.setNull(4, Types.VARCHAR)

        if (${User_Thread} % 2 == 0) {
            stmt.setString(5, &quot;QA_ICU&quot;)
        } else {
            stmt.setString(5, &quot;QA_GW&quot;)
        }

        stmt.setString(6, ${User_Thread} + &quot;QA_ROOM&quot; + i)
        stmt.setString(7, ${User_Thread} + &quot;QA_BED&quot; + i)
        stmt.setString(8, ${User_Thread} + &quot;QAP&quot; + i)
        stmt.setString(9, ${User_Thread} + &quot;테스트&quot; + i)
        stmt.setString(10, ${User_Thread} + &quot;QAD&quot; + i)
        stmt.setString(11, ${User_Thread} + &quot;Quality Assurance&quot; + i)

        int rowsInsert = stmt.executeUpdate()
        log.info(&quot;[LOC] affectedRows=&quot; + rowsInsert)

        stmt.clearParameters()
    }

} catch (Exception e) {
    // 여기서 ORA-00001 / ORA-xxxx 같은 핵심이 반드시 로그로 찍힘
    log.error(&quot;[LOC] insert failed&quot;, e)
    throw e
} finally {
    try { if (stmt != null) stmt.close() } catch (ignored) {}
    try { if (conn != null) conn.close() } catch (ignored) {}
}
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Location Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.TimeZone;
import java.util.Calendar;

// Default timestamp
long timestampDefault = ${timestamp_default};
//long timestampDefault = props.get(&quot;timestamp_default&quot;) as long;

// Repeat count
int repeatCount = ${PatientCount}; // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
	// Create a Date object
	Date PatientSet = new Date(timestampDefault);
	Date EncounterSet = new Date(timestampDefault);
	Date LocationEndSet= new Date(timestampDefault);
	// Set Date
	Calendar calendar = Calendar.getInstance();
	calendar.setTimeInMillis(timestampDefault); // Set the default timestamp		
	calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}));
	calendar.add(Calendar.MONTH, -(i+1));

	long LocationStartSetTimestamp = calendar.getTimeInMillis();
	Date LocationStartSet= new Date(LocationStartSetTimestamp);

	String threadGroupName = ctx.getThreadGroup().getName();
	String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1];

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i+&quot;yyMMddHHmmss&quot;+${User_Thread}+threadGroupNumber);
	sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

	// Format the date to string
	String PatientID = sdf_patient.format(PatientSet);

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_encounter = new SimpleDateFormat(i+&quot;yyyyMMddHHmmss&quot;+${User_Thread}+threadGroupNumber);
	sdf_encounter.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

	// Format the date to string
	String EncounterID = sdf_encounter.format(EncounterSet);

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_LocationStartSet = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	sdf_LocationStartSet.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

	// Format the date to string
	String LocationStart = sdf_LocationStartSet.format(LocationStartSet);

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_LocationEndSet = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	sdf_LocationEndSet.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

	// Format the date to string
	String LocationEnd = sdf_LocationEndSet.format(LocationEndSet);

// Store ONLY location time variables (do NOT override Patient/Encounter IDs)
vars.put(&quot;LocationStart&quot; + i, LocationStart)
vars.put(&quot;LocationEnd&quot; + i, LocationEnd)

}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Wait_for_Sync" enabled="true">
          <intProp name="ActionProcessor.action">1</intProp>
          <intProp name="ActionProcessor.target">0</intProp>
          <stringProp name="ActionProcessor.duration">180000</stringProp>
        </TestAction>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Update_EMR" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">/**
 * Update_PracDepLoc (verify_target=PDL)
 * - slot0: practitioner_id / practitioner_name update
 * - slot1: department_code / department_name update
 * - slot2: room / bed update (ward 유지)
 * - baseline: VC emr_encounter.location_id_ope (update 전) 저장
 *
 * Prereq:
 * - vars: JDBC_URL/JDBC_USER/JDBC_PW (EMR), JDBC_URL_VC/JDBC_USER_VC/JDBC_PW_VC (VC)
 * - vars: PatientID0~2, EncounterID0~2
 * - VC secret: vars/props/env &quot;VC_SECRET&quot; (없으면 some_secret 사용)
 */

import java.sql.*
import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone

// -----------------------------------------------------
// Helpers
// -----------------------------------------------------
def closeQuietly = { AutoCloseable c -&gt;
    try { if (c != null) c.close() } catch (ignored) {}
}

def setVcKey = { Connection c -&gt;
    def vcSecretVars  = (vars.get(&quot;VC_SECRET&quot;) ?: &quot;&quot;).toString().trim()
    def vcSecretProps = (props.get(&quot;VC_SECRET&quot;) ?: &quot;&quot;).toString().trim()
    def vcSecretEnv   = (System.getenv(&quot;VC_SECRET&quot;) ?: &quot;&quot;).toString().trim()
    def vcSecret = vcSecretVars ?: vcSecretProps ?: vcSecretEnv ?: &quot;some_secret&quot;

    Statement st = null
    try {
        st = c.createStatement()
        def esc = vcSecret.replace(&quot;&apos;&quot;, &quot;\\&apos;&quot;)
        st.execute(&quot;SET @hashed_key = (SELECT UNHEX(SHA2(&apos;${esc}&apos;, 256)))&quot;)
        st.execute(&quot;SET @secretkey = LEFT(@hashed_key, 16)&quot;)
        st.execute(&quot;SET @iv = RIGHT(@hashed_key, 16)&quot;)
    } finally {
        closeQuietly(st)
    }
}


def fetchEncounterLocOpeAsString = { Connection c, String pid, String eid -&gt;
    PreparedStatement ps = null
    ResultSet rs = null
    try {
        ps = c.prepareStatement(&quot;&quot;&quot;
            SELECT location_id_ope
            FROM vitalcare.emr_encounter
            WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id), @secretkey, @iv) AS CHAR) = ?
              AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id),     @secretkey, @iv) AS CHAR) = ?
            LIMIT 1
        &quot;&quot;&quot;)
        ps.setString(1, pid)
        ps.setString(2, eid)
        rs = ps.executeQuery()
        if (!rs.next()) return &quot;&quot;
        def obj = rs.getObject(1)
        return (obj == null) ? &quot;&quot; : obj.toString()
    } finally {
        closeQuietly(rs); closeQuietly(ps)
    }
}

// -----------------------------------------------------
// 0) Basics
// -----------------------------------------------------
vars.put(&quot;verify_target&quot;, &quot;PDL&quot;)

def TZ = (vars.get(&quot;TimeZone&quot;) ?: &quot;Asia/Seoul&quot;).toString().trim()
def tz = TimeZone.getTimeZone(TZ)

def sdfMmdd = new SimpleDateFormat(&quot;MMddHHmm&quot;); sdfMmdd.setTimeZone(tz)
def mmddhhmm = sdfMmdd.format(new Date())

def sdfLog = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss,SSS&quot;); sdfLog.setTimeZone(tz)

long now = System.currentTimeMillis()
[&quot;0&quot;,&quot;1&quot;,&quot;2&quot;].each { s -&gt;
    vars.putObject(&quot;slot_start_ms_&quot; + s, now as Long)
    vars.put(&quot;slot_start_ts_&quot; + s, sdfLog.format(new Date(now)))
}

// -----------------------------------------------------
// 1) pid/eid (3 sets)
// -----------------------------------------------------
def pid0 = (vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString().trim()
def eid0 = (vars.get(&quot;EncounterID0&quot;) ?: &quot;&quot;).toString().trim()
def pid1 = (vars.get(&quot;PatientID1&quot;) ?: &quot;&quot;).toString().trim()
def eid1 = (vars.get(&quot;EncounterID1&quot;) ?: &quot;&quot;).toString().trim()
def pid2 = (vars.get(&quot;PatientID2&quot;) ?: &quot;&quot;).toString().trim()
def eid2 = (vars.get(&quot;EncounterID2&quot;) ?: &quot;&quot;).toString().trim()

if (!pid0 || !eid0 || !pid1 || !eid1 || !pid2 || !eid2) {
    throw new RuntimeException(&quot;[PDL UPDATE] PatientID/EncounterID 0~2 missing. &quot; +
        &quot;pid0=${pid0},eid0=${eid0} pid1=${pid1},eid1=${eid1} pid2=${pid2},eid2=${eid2}&quot;)
}

// (optional) Common에서 쓰는 key로 맞추고 싶으면 유지
vars.put(&quot;patient_id&quot;, pid0)
vars.put(&quot;encounter_id&quot;, eid0)

log.info(&quot;[PDL IDS] 0(pid=${pid0},eid=${eid0}) 1(pid=${pid1},eid=${eid1}) 2(pid=${pid2},eid=${eid2})&quot;)

// -----------------------------------------------------
// 2) New values (unique codes)
// -----------------------------------------------------
def pracId   = &quot;1AUTOp&quot; + mmddhhmm
def pracName = &quot;0Auto Test&quot; + mmddhhmm

def deptCode = &quot;1AUTOd&quot; + mmddhhmm
def deptName = &quot;0Auto Test&quot; + mmddhhmm

def room = &quot;1QA_AUTO_ROOM_&quot; + mmddhhmm
def bed  = &quot;1QA_AUTO_BED_&quot;  + mmddhhmm

// expect 저장 (검증에서 사용)
vars.put(&quot;expect_practitioner_id_0&quot;, pracId)
vars.put(&quot;expect_practitioner_name_0&quot;, pracName)

vars.put(&quot;expect_department_code_1&quot;, deptCode)
vars.put(&quot;expect_department_name_1&quot;, deptName)

vars.put(&quot;expect_room_2&quot;, room)
vars.put(&quot;expect_bed_2&quot;, bed)

vars.put(&quot;expect_note_0&quot;, &quot;new practitioner&quot;)
vars.put(&quot;expect_note_1&quot;, &quot;new department&quot;)
vars.put(&quot;expect_note_2&quot;, &quot;new location&quot;)

// -----------------------------------------------------
// 3) DB config
// -----------------------------------------------------
def emrUrl  = (vars.get(&quot;JDBC_URL&quot;) ?: &quot;&quot;).toString().trim()
def emrUser = (vars.get(&quot;JDBC_USER&quot;) ?: &quot;&quot;).toString().trim()
def emrPw   = (vars.get(&quot;JDBC_PW&quot;) ?: &quot;&quot;).toString()

def vcUrl   = (vars.get(&quot;JDBC_URL_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcUser  = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw    = (vars.get(&quot;JDBC_PW_VC&quot;) ?: &quot;&quot;).toString()

if (!emrUrl || !emrUser) throw new RuntimeException(&quot;[PDL UPDATE] EMR JDBC_URL/JDBC_USER empty&quot;)
if (!vcUrl  || !vcUser)  throw new RuntimeException(&quot;[PDL UPDATE] VC JDBC_URL_VC/JDBC_USER_VC empty&quot;)

Connection connEmr = null
Connection connVc  = null

PreparedStatement psEmr = null
ResultSet rsEmr = null

try {
    // -----------------------------
    // 4) Connect VC first (baseline needs it)
    // -----------------------------
    connVc = DriverManager.getConnection(vcUrl, vcUser, vcPw)
    setVcKey(connVc)

    // -----------------------------
    // 5) Connect EMR + ward read for slot2
    // -----------------------------
    connEmr = DriverManager.getConnection(emrUrl, emrUser, emrPw)
    connEmr.setAutoCommit(false)

    // ward 조회 (slot2는 ward 유지)
    psEmr = connEmr.prepareStatement(&quot;SELECT WARD FROM ROOT.LOCATIONS WHERE PATIENT_ID=? AND ENCOUNTER_ID=?&quot;)
    psEmr.setString(1, pid2)
    psEmr.setString(2, eid2)
    rsEmr = psEmr.executeQuery()

    def ward2 = &quot;&quot;
    if (rsEmr.next()) ward2 = (rsEmr.getString(&quot;WARD&quot;) ?: &quot;&quot;).toString().trim()
    vars.put(&quot;expect_ward_2&quot;, ward2)

    closeQuietly(rsEmr); rsEmr = null
    closeQuietly(psEmr); psEmr = null


    // -----------------------------
    // 6) VC baseline before update
    // -----------------------------
    def baselineHex = &quot;&quot;
def baselineLen = 0

PreparedStatement psb = null
ResultSet rsb = null
try {
    psb = connVc.prepareStatement(&quot;&quot;&quot;
        SELECT
          LENGTH(location_id_ope) AS loc_len,
          HEX(location_id_ope)    AS loc_hex
        FROM vitalcare.emr_encounter
        WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id), @secretkey, @iv) AS CHAR) = ?
          AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id),     @secretkey, @iv) AS CHAR) = ?
        LIMIT 1
    &quot;&quot;&quot;)
    psb.setString(1, pid2)
    psb.setString(2, eid2)
    rsb = psb.executeQuery()
    if (rsb.next()) {
        baselineLen = rsb.getInt(&quot;loc_len&quot;)
        baselineHex = (rsb.getString(&quot;loc_hex&quot;) ?: &quot;&quot;).trim()
    }
} finally {
    closeQuietly(rsb); closeQuietly(psb)
}

vars.put(&quot;baseline_loc_len_2&quot;, String.valueOf(baselineLen))
vars.put(&quot;baseline_loc_hex_2&quot;, baselineHex)

log.info(&quot;[PDL BASELINE] slot2 ward=${ward2} loc_ope_before=len=${baselineLen}&quot;)


    // -----------------------------
    // 7) EMR updates (3 slots)
    // -----------------------------
    // slot0 - practitioner
    psEmr = connEmr.prepareStatement(&quot;&quot;&quot;
        UPDATE ROOT.LOCATIONS
        SET UPDATED_DT=SYSTIMESTAMP, PRACTITIONER_ID=?, PRACTITIONER_NAME=?
        WHERE PATIENT_ID=? AND ENCOUNTER_ID=?
    &quot;&quot;&quot;)
    psEmr.setString(1, pracId)
    psEmr.setString(2, pracName)
    psEmr.setString(3, pid0)
    psEmr.setString(4, eid0)
    int a0 = psEmr.executeUpdate()
    closeQuietly(psEmr); psEmr = null

    // slot1 - department
    psEmr = connEmr.prepareStatement(&quot;&quot;&quot;
        UPDATE ROOT.LOCATIONS
        SET UPDATED_DT=SYSTIMESTAMP, DEPARTMENT_CODE=?, DEPARTMENT_NAME=?
        WHERE PATIENT_ID=? AND ENCOUNTER_ID=?
    &quot;&quot;&quot;)
    psEmr.setString(1, deptCode)
    psEmr.setString(2, deptName)
    psEmr.setString(3, pid1)
    psEmr.setString(4, eid1)
    int a1 = psEmr.executeUpdate()
    closeQuietly(psEmr); psEmr = null

    // slot2 - location (ward 유지, room/bed만 변경)
    psEmr = connEmr.prepareStatement(&quot;&quot;&quot;
        UPDATE ROOT.LOCATIONS
        SET UPDATED_DT=SYSTIMESTAMP, ROOM=?, BED=?
        WHERE PATIENT_ID=? AND ENCOUNTER_ID=?
    &quot;&quot;&quot;)
    psEmr.setString(1, room)
    psEmr.setString(2, bed)
    psEmr.setString(3, pid2)
    psEmr.setString(4, eid2)
    int a2 = psEmr.executeUpdate()
    closeQuietly(psEmr); psEmr = null

    connEmr.commit()

    log.info(&quot;[PDL UPDATE] slot0 practitioner affected=${a0} id=${pracId} name=${pracName}&quot;)
    log.info(&quot;[PDL UPDATE] slot1 department   affected=${a1} code=${deptCode} name=${deptName}&quot;)
    log.info(&quot;[PDL UPDATE] slot2 location     affected=${a2} ward=${ward2} room=${room} bed=${bed}&quot;)

} catch (Throwable t) {
    try { if (connEmr != null) connEmr.rollback() } catch (ignored) {}
    throw t
} finally {
    closeQuietly(rsEmr)
    closeQuietly(psEmr)
    closeQuietly(connEmr)
    closeQuietly(connVc)
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Wait_for_Sync" enabled="true">
          <intProp name="ActionProcessor.action">1</intProp>
          <intProp name="ActionProcessor.target">0</intProp>
          <stringProp name="ActionProcessor.duration">180000</stringProp>
        </TestAction>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Verify_PracDepLoc" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*

/**
 * Verify_PDL (Scenario 5)
 *
 * 목적(본질):
 *  - EMR(ROOT.LOCATIONS)의 변경값이 VC로 정상 반영되었는지 &quot;EMR ↔ VC&quot; 정합성 검증
 *  - VC 코드테이블(emr_practitioner / emr_department / emr_location) 신규 생성/연결까지 확인
 *
 * 실행 방식:
 *  - 한 Sampler에서 3개 케이스를 검증하고 CSV 3줄(writeCsv9 3회) 기록
 *    ${scenario_id}-1 : practitioner (slot0)
 *    ${scenario_id}-2 : department   (slot1)
 *    ${scenario_id}-3 : location     (slot2)
 */

def U = props.get(&quot;CommonUtils&quot;)
if (!(U instanceof Map)) throw new RuntimeException(&quot;[S5 PDL] CommonUtils not found&quot;)

def closeQ     = U.closeQuietly
def setVcKey   = U.setVcKey
def dumpPretty = U.dumpPretty
def writeCsv9  = U.writeCsv9
def nowStr     = U.nowStr
def startFrom  = U.startStrFromPrev

// -----------------------------
// 0) Vars
// -----------------------------
def scenarioId = (vars.get(&quot;scenario_id&quot;) ?: &quot;5&quot;).toString().trim()

def baseOrderKey = (vars.get(&quot;order_key&quot;) ?: &quot;300&quot;).toString().trim()
int okBase = 300
try { okBase = Integer.parseInt(baseOrderKey) } catch (ignored) { okBase = 300 }

def emrUrl  = (vars.get(&quot;JDBC_URL&quot;) ?: &quot;&quot;).toString().trim()
def emrUser = (vars.get(&quot;JDBC_USER&quot;) ?: &quot;&quot;).toString().trim()
def emrPw   = (vars.get(&quot;JDBC_PW&quot;) ?: &quot;&quot;).toString()

def vcUrl   = (vars.get(&quot;JDBC_URL_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcUser  = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw    = (vars.get(&quot;JDBC_PW_VC&quot;) ?: &quot;&quot;).toString()

if (!emrUrl || !emrUser) throw new RuntimeException(&quot;[S5 PDL] EMR JDBC vars empty&quot;)
if (!vcUrl  || !vcUser)  throw new RuntimeException(&quot;[S5 PDL] VC JDBC vars empty&quot;)

def EMR_TBL_LOC = (vars.get(&quot;EMR_LOCATION_TABLE&quot;) ?: &quot;ROOT.LOCATIONS&quot;).toString().trim()
def VC_TBL_ENC  = (vars.get(&quot;VC_TBL_EMR_ENCOUNTER&quot;) ?: &quot;vitalcare.emr_encounter&quot;).toString().trim()
def VC_TBL_PRAC = (vars.get(&quot;VC_TBL_EMR_PRACTITIONER&quot;) ?: &quot;vitalcare.emr_practitioner&quot;).toString().trim()
def VC_TBL_DEPT = (vars.get(&quot;VC_TBL_EMR_DEPARTMENT&quot;) ?: &quot;vitalcare.emr_department&quot;).toString().trim()
def VC_TBL_LOC  = (vars.get(&quot;VC_TBL_EMR_LOCATION&quot;) ?: &quot;vitalcare.emr_location&quot;).toString().trim()

// ids (required)
def pid0 = (vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString().trim()
def eid0 = (vars.get(&quot;EncounterID0&quot;) ?: &quot;&quot;).toString().trim()
def pid1 = (vars.get(&quot;PatientID1&quot;) ?: &quot;&quot;).toString().trim()
def eid1 = (vars.get(&quot;EncounterID1&quot;) ?: &quot;&quot;).toString().trim()
def pid2 = (vars.get(&quot;PatientID2&quot;) ?: &quot;&quot;).toString().trim()
def eid2 = (vars.get(&quot;EncounterID2&quot;) ?: &quot;&quot;).toString().trim()

if (!pid0 || !eid0 || !pid1 || !eid1 || !pid2 || !eid2) {
  throw new RuntimeException(&quot;[S5 PDL] PatientID/EncounterID 0~2 missing&quot;)
}

def startStr = (vars.get(&quot;verify_startTime&quot;) ?: startFrom(prev)).toString()

// -----------------------------
// 1) Helpers
// -----------------------------
def vcPidExpr = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id), @secretkey, @iv) AS CHAR)&quot;
def vcEidExpr = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id),     @secretkey, @iv) AS CHAR)&quot;

def dumpEmrLoc = { Connection eConn, String pid, String eid, String kind -&gt;
  PreparedStatement ps=null; ResultSet rs=null
  try {
    String sql =
      (kind == &quot;PRAC&quot;) ? &quot;&quot;&quot;
        SELECT CREATED_DT, UPDATED_DT, PATIENT_ID, ENCOUNTER_ID, START_DT,
               PRACTITIONER_ID, PRACTITIONER_NAME
        FROM ${EMR_TBL_LOC}
        WHERE PATIENT_ID=? AND ENCOUNTER_ID=?
      &quot;&quot;&quot; :
      (kind == &quot;DEPT&quot;) ? &quot;&quot;&quot;
        SELECT CREATED_DT, UPDATED_DT, PATIENT_ID, ENCOUNTER_ID, START_DT,
               DEPARTMENT_CODE, DEPARTMENT_NAME
        FROM ${EMR_TBL_LOC}
        WHERE PATIENT_ID=? AND ENCOUNTER_ID=?
      &quot;&quot;&quot; :
      &quot;&quot;&quot;
        SELECT CREATED_DT, UPDATED_DT, PATIENT_ID, ENCOUNTER_ID, START_DT,
               WARD, ROOM, BED
        FROM ${EMR_TBL_LOC}
        WHERE PATIENT_ID=? AND ENCOUNTER_ID=?
      &quot;&quot;&quot;

    ps = eConn.prepareStatement(sql)
    ps.setString(1, pid)
    ps.setString(2, eid)
    rs = ps.executeQuery()
    def s = dumpPretty(&quot;${EMR_TBL_LOC}&quot;, rs, 10)
    return (s?.trim()) ? s : &quot;${EMR_TBL_LOC}\n(0 rows)\n&quot;
  } finally { closeQ(rs); closeQ(ps) }
}

def readEmrLoc = { Connection eConn, String pid, String eid, String kind -&gt;
  PreparedStatement ps=null; ResultSet rs=null
  try {
    String sql =
      (kind == &quot;PRAC&quot;) ? &quot;&quot;&quot;
        SELECT PRACTITIONER_ID, PRACTITIONER_NAME
        FROM ${EMR_TBL_LOC}
        WHERE PATIENT_ID=? AND ENCOUNTER_ID=?
      &quot;&quot;&quot; :
      (kind == &quot;DEPT&quot;) ? &quot;&quot;&quot;
        SELECT DEPARTMENT_CODE, DEPARTMENT_NAME
        FROM ${EMR_TBL_LOC}
        WHERE PATIENT_ID=? AND ENCOUNTER_ID=?
      &quot;&quot;&quot; :
      &quot;&quot;&quot;
        SELECT WARD, ROOM, BED
        FROM ${EMR_TBL_LOC}
        WHERE PATIENT_ID=? AND ENCOUNTER_ID=?
      &quot;&quot;&quot;

    ps = eConn.prepareStatement(sql)
    ps.setString(1, pid)
    ps.setString(2, eid)
    rs = ps.executeQuery()
    if (!rs.next()) return null

    if (kind == &quot;PRAC&quot;) {
      return [
        pracId  : (rs.getString(1) ?: &quot;&quot;).toString().trim(),
        pracName: (rs.getString(2) ?: &quot;&quot;).toString().trim()
      ]
    }
    if (kind == &quot;DEPT&quot;) {
      return [
        deptCode: (rs.getString(1) ?: &quot;&quot;).toString().trim(),
        deptName: (rs.getString(2) ?: &quot;&quot;).toString().trim()
      ]
    }
    return [
      ward: (rs.getString(1) ?: &quot;&quot;).toString().trim(),
      room: (rs.getString(2) ?: &quot;&quot;).toString().trim(),
      bed : (rs.getString(3) ?: &quot;&quot;).toString().trim()
    ]
  } finally { closeQ(rs); closeQ(ps) }
}

def dumpVcEncounterByKind = { Connection vConn, String pid, String eid, String kind -&gt;
  PreparedStatement ps=null; ResultSet rs=null
  try {
    String selectCols =
      (kind == &quot;PRAC&quot;) ? &quot;&quot;&quot;
        created_dt, updated_dt,
        ${vcPidExpr} AS patient_id,
        ${vcEidExpr} AS encounter_id,
        practitioner_id
      &quot;&quot;&quot; :
      (kind == &quot;DEPT&quot;) ? &quot;&quot;&quot;
        created_dt, updated_dt,
        ${vcPidExpr} AS patient_id,
        ${vcEidExpr} AS encounter_id,
        department_id
      &quot;&quot;&quot; :
      &quot;&quot;&quot;
        created_dt, updated_dt,
        ${vcPidExpr} AS patient_id,
        ${vcEidExpr} AS encounter_id,
        LENGTH(location_id_ope) AS location_id_ope_len
      &quot;&quot;&quot;

    ps = vConn.prepareStatement(&quot;&quot;&quot;
      SELECT ${selectCols}
      FROM ${VC_TBL_ENC}
      WHERE ${vcPidExpr}=? AND ${vcEidExpr}=?
      LIMIT 1
    &quot;&quot;&quot;)
    ps.setString(1, pid)
    ps.setString(2, eid)
    rs = ps.executeQuery()

    def s = dumpPretty(&quot;${VC_TBL_ENC}&quot;, rs, 5)
    return (s?.trim()) ? s : &quot;${VC_TBL_ENC}\n(0 rows)\n&quot;
  } finally { closeQ(rs); closeQ(ps) }
}

def readVcEncounter = { Connection vConn, String pid, String eid -&gt;
  PreparedStatement ps=null; ResultSet rs=null
  try {
    ps = vConn.prepareStatement(&quot;&quot;&quot;
      SELECT
        ${vcPidExpr} AS patient_id,
        ${vcEidExpr} AS encounter_id,
        practitioner_id,
        department_id,
        location_id_ope
      FROM ${VC_TBL_ENC}
      WHERE ${vcPidExpr}=? AND ${vcEidExpr}=?
      LIMIT 1
    &quot;&quot;&quot;)
    ps.setString(1, pid)
    ps.setString(2, eid)
    rs = ps.executeQuery()
    if (!rs.next()) return null

    return [
      pid : (rs.getString(&quot;patient_id&quot;) ?: &quot;&quot;).toString().trim(),
      eid : (rs.getString(&quot;encounter_id&quot;) ?: &quot;&quot;).toString().trim(),
      prac: (rs.getString(&quot;practitioner_id&quot;) ?: &quot;&quot;).toString().trim(),
      dept: (rs.getString(&quot;department_id&quot;) ?: &quot;&quot;).toString().trim(),
      loc : rs.getObject(&quot;location_id_ope&quot;)   // keep as Object (null-safe)
    ]
  } finally { closeQ(rs); closeQ(ps) }
}

def dumpVcPractitioner = { Connection vConn, String code -&gt;
  PreparedStatement ps=null; ResultSet rs=null
  try {
    ps = vConn.prepareStatement(&quot;&quot;&quot;
      SELECT
        emr_id, created_dt, updated_dt, code,
        CAST(AES_DECRYPT(FROM_BASE64(encrypted_name), @secretkey, @iv) AS CHAR) AS name
      FROM ${VC_TBL_PRAC}
      WHERE code=?
      LIMIT 1
    &quot;&quot;&quot;)
    ps.setString(1, code)
    rs = ps.executeQuery()
    def s = dumpPretty(&quot;${VC_TBL_PRAC}&quot;, rs, 5)
    return (s?.trim()) ? s : &quot;${VC_TBL_PRAC}\n(0 rows)\n&quot;
  } finally { closeQ(rs); closeQ(ps) }
}

def readVcPractitionerName = { Connection vConn, String code -&gt;
  PreparedStatement ps=null; ResultSet rs=null
  try {
    ps = vConn.prepareStatement(&quot;&quot;&quot;
      SELECT CAST(AES_DECRYPT(FROM_BASE64(encrypted_name), @secretkey, @iv) AS CHAR) AS name
      FROM ${VC_TBL_PRAC}
      WHERE code=?
      LIMIT 1
    &quot;&quot;&quot;)
    ps.setString(1, code)
    rs = ps.executeQuery()
    if (!rs.next()) return null
    return (rs.getString(&quot;name&quot;) ?: &quot;&quot;).toString().trim()
  } finally { closeQ(rs); closeQ(ps) }
}

def dumpVcDepartment = { Connection vConn, String code -&gt;
  PreparedStatement ps=null; ResultSet rs=null
  try {
    ps = vConn.prepareStatement(&quot;&quot;&quot;
      SELECT emr_id, created_dt, updated_dt, code, name
      FROM ${VC_TBL_DEPT}
      WHERE code=?
      LIMIT 1
    &quot;&quot;&quot;)
    ps.setString(1, code)
    rs = ps.executeQuery()
    def s = dumpPretty(&quot;${VC_TBL_DEPT}&quot;, rs, 5)
    return (s?.trim()) ? s : &quot;${VC_TBL_DEPT}\n(0 rows)\n&quot;
  } finally { closeQ(rs); closeQ(ps) }
}

def readVcDepartmentName = { Connection vConn, String code -&gt;
  PreparedStatement ps=null; ResultSet rs=null
  try {
    ps = vConn.prepareStatement(&quot;&quot;&quot;
      SELECT name
      FROM ${VC_TBL_DEPT}
      WHERE code=?
      LIMIT 1
    &quot;&quot;&quot;)
    ps.setString(1, code)
    rs = ps.executeQuery()
    if (!rs.next()) return null
    return (rs.getString(&quot;name&quot;) ?: &quot;&quot;).toString().trim()
  } finally { closeQ(rs); closeQ(ps) }
}

def dumpVcLocationLinked = { Connection vConn, String pid, String eid -&gt;
  PreparedStatement ps=null; ResultSet rs=null
  try {
    ps = vConn.prepareStatement(&quot;&quot;&quot;
      SELECT
        el.created_dt,
        el.updated_dt,
        el.ward,
        CAST(AES_DECRYPT(FROM_BASE64(el.room), @secretkey, @iv) AS CHAR) AS room,
        CAST(AES_DECRYPT(FROM_BASE64(el.bed),  @secretkey, @iv) AS CHAR) AS bed,
        el.type,
        LENGTH(el.emr_id_ope) AS emr_id_ope_len
      FROM ${VC_TBL_LOC} el
      WHERE el.emr_id_ope = (
        SELECT ee.location_id_ope
        FROM ${VC_TBL_ENC} ee
        WHERE ${vcPidExpr}=? AND ${vcEidExpr}=?
        LIMIT 1
      )
      LIMIT 1
    &quot;&quot;&quot;)
    ps.setString(1, pid)
    ps.setString(2, eid)
    rs = ps.executeQuery()
    def s = dumpPretty(&quot;${VC_TBL_LOC}&quot;, rs, 5)
    return (s?.trim()) ? s : &quot;${VC_TBL_LOC}\n(0 rows)\n&quot;
  } finally { closeQ(rs); closeQ(ps) }
}

def readVcLocationLinkedRow = { Connection vConn, String pid, String eid -&gt;
  PreparedStatement ps=null; ResultSet rs=null
  try {
    ps = vConn.prepareStatement(&quot;&quot;&quot;
      SELECT
        el.ward AS ward,
        CAST(AES_DECRYPT(FROM_BASE64(el.room), @secretkey, @iv) AS CHAR) AS room,
        CAST(AES_DECRYPT(FROM_BASE64(el.bed),  @secretkey, @iv) AS CHAR) AS bed
      FROM ${VC_TBL_LOC} el
      WHERE el.emr_id_ope = (
        SELECT ee.location_id_ope
        FROM ${VC_TBL_ENC} ee
        WHERE ${vcPidExpr}=? AND ${vcEidExpr}=?
        LIMIT 1
      )
      LIMIT 1
    &quot;&quot;&quot;)
    ps.setString(1, pid)
    ps.setString(2, eid)
    rs = ps.executeQuery()
    if (!rs.next()) return null
    return [
      ward: (rs.getString(&quot;ward&quot;) ?: &quot;&quot;).toString().trim(),
      room: (rs.getString(&quot;room&quot;) ?: &quot;&quot;).toString().trim(),
      bed : (rs.getString(&quot;bed&quot;)  ?: &quot;&quot;).toString().trim()
    ]
  } finally { closeQ(rs); closeQ(ps) }
}

// -----------------------------
// 2) Run 3 cases
// -----------------------------
Connection eConn=null
Connection vConn=null
boolean allPass = true

try {
  eConn = DriverManager.getConnection(emrUrl, emrUser, emrPw)
  vConn = DriverManager.getConnection(vcUrl,  vcUser,  vcPw)
  setVcKey(vConn, &quot;S5_PDL&quot;)

  def writeOne = { int orderKey, String label, String emrDump, String vcDump, String result, String notes -&gt;
    writeCsv9(prev, ctx, props, vars,
      String.valueOf(orderKey),
      label,
      startStr, nowStr(),
      (emrDump ?: &quot;&quot;), (vcDump ?: &quot;&quot;),
      (result ?: &quot;FAIL&quot;), (notes ?: &quot;&quot;)
    )
    log.info(&quot;[S5 PDL] ${label} result=${result}&quot; + (notes ? &quot; | ${notes}&quot; : &quot;&quot;))
  }

  def runCase = { String kind, int orderKey, String label, String pid, String eid -&gt;
    def fails = []

    // dumps (always)
    def emrDump = dumpEmrLoc(eConn, pid, eid, kind)
    def vcEncDump = dumpVcEncounterByKind(vConn, pid, eid, kind)

    // EMR truth (required)
    def emr = readEmrLoc(eConn, pid, eid, kind)
    if (emr == null) {
      fails &lt;&lt; &quot;EMR location not found&quot;
      writeOne(orderKey, label, emrDump, vcEncDump, &quot;FAIL&quot;, fails.join(&quot; | &quot;))
      allPass = false
      return
    }

    // VC encounter (required)
    def enc = readVcEncounter(vConn, pid, eid)
    if (enc == null) {
      fails &lt;&lt; &quot;VC row not found&quot;
      writeOne(orderKey, label, emrDump, vcEncDump, &quot;FAIL&quot;, fails.join(&quot; | &quot;))
      allPass = false
      return
    }

    if ((enc.pid ?: &quot;&quot;) != pid) fails &lt;&lt; &quot;patient_id mismatch&quot;
    if ((enc.eid ?: &quot;&quot;) != eid) fails &lt;&lt; &quot;encounter_id mismatch&quot;

    if (kind == &quot;PRAC&quot;) {
      def emrPracId = (emr.pracId ?: &quot;&quot;)
      def emrPracNm = (emr.pracName ?: &quot;&quot;)

      if (!emrPracId) fails &lt;&lt; &quot;EMR practitioner_id empty&quot;
      if (emrPracId &amp;&amp; (enc.prac ?: &quot;&quot;) != emrPracId) fails &lt;&lt; &quot;practitioner_id mismatch (emr=${emrPracId}, vc=${enc.prac})&quot;

      // VC practitioner row + name (decrypted)
      def pracName = emrPracId ? readVcPractitionerName(vConn, emrPracId) : null
      if (emrPracId &amp;&amp; pracName == null) fails &lt;&lt; &quot;practitioner row not found (code=${emrPracId})&quot;
      if (emrPracId &amp;&amp; emrPracNm &amp;&amp; pracName != null &amp;&amp; pracName != emrPracNm) {
        fails &lt;&lt; &quot;practitioner_name mismatch (emr=${emrPracNm}, vc=${pracName})&quot;
      }

      def vcDump = (vcEncDump.trim() + &quot;\n\n&quot; + (emrPracId ? dumpVcPractitioner(vConn, emrPracId).trim() : &quot;${VC_TBL_PRAC}\n(0 rows)\n&quot;)).trim()
      def result = fails.isEmpty() ? &quot;PASS&quot; : &quot;FAIL&quot;
      def notes  = fails.isEmpty() ? &quot;new practitioner&quot; : fails.join(&quot; | &quot;)
      writeOne(orderKey, label, emrDump, vcDump, result, notes)
      if (!fails.isEmpty()) allPass = false
      return
    }

    if (kind == &quot;DEPT&quot;) {
      def emrDeptCd = (emr.deptCode ?: &quot;&quot;)
      def emrDeptNm = (emr.deptName ?: &quot;&quot;)

      if (!emrDeptCd) fails &lt;&lt; &quot;EMR department_code empty&quot;
      if (emrDeptCd &amp;&amp; (enc.dept ?: &quot;&quot;) != emrDeptCd) fails &lt;&lt; &quot;department_id mismatch (emr=${emrDeptCd}, vc=${enc.dept})&quot;

      // VC department row + name
      def deptName = emrDeptCd ? readVcDepartmentName(vConn, emrDeptCd) : null
      if (emrDeptCd &amp;&amp; deptName == null) fails &lt;&lt; &quot;department row not found (code=${emrDeptCd})&quot;
      if (emrDeptCd &amp;&amp; emrDeptNm &amp;&amp; deptName != null &amp;&amp; deptName != emrDeptNm) {
        fails &lt;&lt; &quot;department_name mismatch (emr=${emrDeptNm}, vc=${deptName})&quot;
      }

      def vcDump = (vcEncDump.trim() + &quot;\n\n&quot; + (emrDeptCd ? dumpVcDepartment(vConn, emrDeptCd).trim() : &quot;${VC_TBL_DEPT}\n(0 rows)\n&quot;)).trim()
      def result = fails.isEmpty() ? &quot;PASS&quot; : &quot;FAIL&quot;
      def notes  = fails.isEmpty() ? &quot;new department&quot; : fails.join(&quot; | &quot;)
      writeOne(orderKey, label, emrDump, vcDump, result, notes)
      if (!fails.isEmpty()) allPass = false
      return
    }

    // LOC
    def locObj = enc.loc
    if (locObj == null || locObj.toString().trim().isEmpty()) fails &lt;&lt; &quot;location_id_ope empty&quot;

    def locRow = readVcLocationLinkedRow(vConn, pid, eid)
    if (locRow == null) fails &lt;&lt; &quot;linked emr_location not found&quot;
    else {
      if ((emr.ward ?: &quot;&quot;) &amp;&amp; locRow.ward != (emr.ward ?: &quot;&quot;)) fails &lt;&lt; &quot;ward mismatch (emr=${emr.ward}, vc=${locRow.ward})&quot;
      if ((emr.room ?: &quot;&quot;) &amp;&amp; locRow.room != (emr.room ?: &quot;&quot;)) fails &lt;&lt; &quot;room mismatch (emr=${emr.room}, vc=${locRow.room})&quot;
      if ((emr.bed  ?: &quot;&quot;) &amp;&amp; locRow.bed  != (emr.bed  ?: &quot;&quot;)) fails &lt;&lt; &quot;bed mismatch (emr=${emr.bed}, vc=${locRow.bed})&quot;
    }

    def vcDump = (vcEncDump.trim() + &quot;\n\n&quot; + dumpVcLocationLinked(vConn, pid, eid).trim()).trim()
    def result = fails.isEmpty() ? &quot;PASS&quot; : &quot;FAIL&quot;
    def notes  = fails.isEmpty() ? &quot;new location&quot; : fails.join(&quot; | &quot;)
    writeOne(orderKey, label, emrDump, vcDump, result, notes)
    if (!fails.isEmpty()) allPass = false
  }

  runCase(&quot;PRAC&quot;, okBase + 1, scenarioId + &quot;-1&quot;, pid0, eid0)
  runCase(&quot;DEPT&quot;, okBase + 2, scenarioId + &quot;-2&quot;, pid1, eid1)
  runCase(&quot;LOC&quot;,  okBase + 3, scenarioId + &quot;-3&quot;, pid2, eid2)

} catch (Throwable t) {
  log.error(&quot;[S5 PDL] Exception&quot;, t)
  allPass = false
} finally {
  closeQ(eConn)
  closeQ(vConn)
  prev.setSuccessful(allPass)
  prev.setResponseMessage(allPass ? &quot;SYNC PASS | PDL(3 cases)&quot; : &quot;SYNC FAIL | PDL(3 cases)&quot;)
}

return</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Scenario 6" enabled="true">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <OnceOnlyController guiclass="OnceOnlyControllerGui" testclass="OnceOnlyController" testname="Once Only Controller" enabled="true"/>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Setname Sampler" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">vars.put(&quot;currentControllerName&quot;, &quot;Scenario 4&quot;)

vars.put(&quot;scenario_id&quot;, &quot;Vital 데이터&quot;)
vars.put(&quot;expect_mode&quot;, &quot;SYNC_OK&quot;)
vars.put(&quot;order_key&quot;, &quot;400&quot;)
vars.put(&quot;verify_target&quot;, &quot;VITAL&quot;)

vars.put(&quot;PatientCount&quot;, &quot;1&quot;)


String tgName = ctx.getThreadGroup().getName()
String tgNum = &quot;0&quot;
try { tgNum = tgName.split(&quot; &quot;)[1] } catch (ignored) { tgNum = &quot;0&quot; }
vars.put(&quot;tgNum&quot;, tgNum)

log.info(&quot;[INIT] parent=${vars.get(&apos;currentControllerName&apos;)}, scenario_id=${vars.get(&apos;scenario_id&apos;)}, label=${vars.get(&apos;scenario_label&apos;)}, expect_mode=${vars.get(&apos;expect_mode&apos;)}, order_key=${vars.get(&apos;order_key&apos;)}, verify_target=${vars.get(&apos;verify_target&apos;)}, PatientCount=${vars.get(&apos;PatientCount&apos;)}, tgNum=${vars.get(&apos;tgNum&apos;)}&quot;)
</stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Mark StartTime" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.text.SimpleDateFormat
import java.util.TimeZone
import java.util.Date

def tz = (vars.get(&quot;TimeZone&quot;) ?: &quot;Asia/Seoul&quot;).toString()
def sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss,SSS&quot;)
sdf.setTimeZone(TimeZone.getTimeZone(tz))

long startMs = System.currentTimeMillis()
vars.putObject(&quot;caseStartMillis&quot;, startMs)

def startTs = sdf.format(new Date(startMs))
vars.put(&quot;case_start_ts&quot;, startTs)

// CSV/HTML이 기존 키를 쓰면 호환용으로 같이 세팅
vars.put(&quot;verify_startTime&quot;, startTs)

log.info(&quot;[CASE_START] scenario_id=${vars.get(&apos;scenario_id&apos;)} start_ts=${startTs} TZ=${tz}&quot;)
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Patient_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;

def pidLog = (vars.get(&quot;patient_id&quot;) ?: vars.get(&quot;PatientID&quot;) ?: vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString()
log.info(&quot;[PAT INSERT DBG] scenario_id=&quot; + (vars.get(&quot;scenario_id&quot;) ?: &quot;&quot;)
        + &quot; thread=&quot; + ctx.getThreadNum()
        + &quot; pid=&quot; + pidLog)


// Scenario(Thread) start time: set once
if (!vars.get(&quot;startTimeThread&quot;)) {
    vars.put(&quot;startTimeThread&quot;, String.valueOf(System.currentTimeMillis()))
}

	// JDBC connection information
	String url = &quot;${JDBC_URL}&quot;;
	String user = &quot;${JDBC_USER}&quot;;
	String password = &quot;${JDBC_PW}&quot;;

	// Define the query
	String query = &quot;INSERT INTO ROOT.PATIENTS (PATIENT_ID, NAME, BIRTHDATE, SEX) &quot; +
	                &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?)&quot;;

	// JDBC connection
	Connection conn = DriverManager.getConnection(url, user, password);

	// Prepare the statement
	PreparedStatement stmt = conn.prepareStatement(query);

	// Repeat the process for multiple sets of parameters
	int repeatCount = ${PatientCount}; // Number of repetitions set
		for (int i = 0; i &lt; repeatCount; i++) {
		    // Set String parameters for the query
		    String PatientID = vars.get(&quot;PatientID&quot; + i);
		    String Name = vars.get(&quot;Name&quot; + i);
		    String BirthDate = vars.get(&quot;BirthDate&quot; + i);
		    
		    // Set parameters for the query
		    stmt.setString(1, PatientID);
		    stmt.setString(2, &quot;QA&quot;+Name);
		    stmt.setString(3, BirthDate);
		    // Set gender based on whether i is odd or even
		    if (${User_Thread} % 2 == 0) {
		        stmt.setString(4, &quot;female&quot;);
		    } else {
		        stmt.setString(4, &quot;male&quot;);
		    }
		    
		    // Execute the query
		    int rowsInsert = stmt.executeUpdate();
		    
		    // Log
		    log.info(&quot;Inserted patientID: &quot; + PatientID);

		    vars.put(&quot;patient_id&quot;, PatientID)
			//log.info(&quot;[ID_MAP] patient_id=&quot; + vars.get(&quot;patient_id&quot;))

		    
		    // Clear parameters for reusing the statement
		    stmt.clearParameters();

		}
// Close the connection
conn.close();
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Patient Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount} // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
    
    // Create a Date object
    Date PatientSet = new Date(timestampDefault)
    Date EncounterSet = new Date(timestampDefault)
    Date NameSet = new Date(timestampDefault)

    // Set Date
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault) // Set the default timestamp    
    calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}))

    // --- Generate random birthdate for age between 19 and 150 ---
    int minAge = 19
    int maxAge = 110
    int randomAge = minAge + (int)(Math.random() * (maxAge - minAge + 1))
    
    // Copy current timestamp for age validation
    Calendar nowCal = Calendar.getInstance()
    nowCal.setTimeInMillis(timestampDefault)
    
    // Subtract random age in years
    calendar.add(Calendar.YEAR, -randomAge)
    
    // Randomize month and day
    int randomMonth = (int)(Math.random() * 12)  // 0-11
    calendar.set(Calendar.MONTH, randomMonth)
    int maxDay = calendar.getActualMaximum(Calendar.DAY_OF_MONTH)
    int randomDay = 1 + (int)(Math.random() * maxDay)
    calendar.set(Calendar.DAY_OF_MONTH, randomDay)
    
    // Ensure age is at least 19 (if birthday is in the future, subtract one more year)
    if (calendar.after(nowCal)) {
        calendar.add(Calendar.YEAR, -1)
    }
    
    // Final birthdate object
    long BirthDatetimeStamp = calendar.getTimeInMillis()
    Date BirthSet = new Date(BirthDatetimeStamp)
    
    String threadGroupName = ctx.getThreadGroup().getName()
    String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1]

    // Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i + &quot;yyMMddHHmmss&quot; + ${User_Thread} + threadGroupNumber)
    sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string
    String PatientID = sdf_patient.format(PatientSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_name = new SimpleDateFormat(i+&quot;ddHHmmss&quot;+${User_Thread})
    sdf_name.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String Name = sdf_name.format(NameSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_birthdate = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;)
    sdf_birthdate.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String BirthDate = sdf_birthdate.format(BirthSet)

    // Store in variables
    vars.put(&quot;PatientID&quot; + i, PatientID)
    vars.put(&quot;Name&quot; + i, Name)
    vars.put(&quot;BirthDate&quot; + i, BirthDate)
}
</stringProp>
