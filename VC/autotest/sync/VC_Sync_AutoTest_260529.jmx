        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Setup_Discharge_5Patients">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import com.jcraft.jsch.*
import java.sql.*
import java.time.*
import java.time.format.DateTimeFormatter

def U = props.get(&quot;CommonUtils&quot;)
def closeQ = U.closeQuietly
def setVcKey = U.setVcKey

// ── 1. 스케줄 시간 계산 ──────────────────────────────────────
def tz = ZoneId.of(&quot;Asia/Seoul&quot;)
def now = LocalDateTime.now(tz)
int bufferMin = 1; int syncIntervalMin = 3
int nowTotalMin = now.getHour() * 60 + now.getMinute()
int targetMin = (int)(Math.ceil((nowTotalMin + bufferMin) / (double)syncIntervalMin)) * syncIntervalMin
targetMin = targetMin % (24 * 60)
int hh = targetMin / 60; int mm = targetMin % 60
String scheduledHHMM = String.format(&quot;%02d%02d&quot;, hh, mm)
log.info(&quot;Setup_211: scheduledHHMM=${scheduledHHMM}&quot;)

// ── 2. SSH: 스케줄 설정 + sync 재시작 ──────────────────────────
def host       = vars.get(&quot;SSH_HOST&quot;)
def port       = Integer.parseInt(vars.get(&quot;SSH_PORT&quot;) ?: &quot;22&quot;)
def sshUser    = vars.get(&quot;SSH_USER&quot;)
def sshPw      = vars.get(&quot;SSH_PW&quot;)
def composeDir = vars.get(&quot;SSH_COMPOSE_DIR&quot;)
def filePath   = &quot;${composeDir}/envs/vc-sync-v220.env&quot;

def jsch = new JSch()
def session = jsch.getSession(sshUser, host, port)
session.setPassword(sshPw)
session.setConfig(&quot;StrictHostKeyChecking&quot;, &quot;no&quot;)
session.connect(10000)
def execCmd = { String cmd -&gt;
    def ch = session.openChannel(&quot;exec&quot;); ch.setCommand(cmd)
    def out = new java.io.ByteArrayOutputStream()
    ch.setOutputStream(out); ch.connect(5000)
    while (!ch.isClosed()) { Thread.sleep(200) }
    ch.disconnect(); return out.toString(&quot;UTF-8&quot;).trim()
}
execCmd(&quot;sed -i &apos;s/VCSYNC_DAILY_SCHEDULED_TIME_HHMM=.*/VCSYNC_DAILY_SCHEDULED_TIME_HHMM=${scheduledHHMM}/&apos; ${filePath}&quot;)
execCmd(&quot;cd ${composeDir} &amp;&amp; docker compose up -d sync&quot;)
session.disconnect()
log.info(&quot;Setup_211: SSH done, schedule=${scheduledHHMM}&quot;)

// ── 3. VC: status 업데이트 + accounts_pin 삽입 ─────────────────
def vConn = null
try {
    vConn = DriverManager.getConnection(
        vars.get(&quot;JDBC_URL_VC&quot;), vars.get(&quot;JDBC_USER_VC&quot;), vars.get(&quot;JDBC_PW_VC&quot;))
    setVcKey(vConn, &quot;TAG&quot;)

    def VC_TBL_ENC = (vars.get(&quot;VC_TBL_EMR_ENCOUNTER&quot;) ?: &quot;vitalcare.emr_encounter&quot;).toString().trim()
    def VC_TBL_AP  = (vars.get(&quot;VC_TBL_ACCOUNTS_PIN&quot;)  ?: &quot;vitalcare.accounts_pin&quot;).toString().trim()
    def statusList = [&quot;SCREENED&quot;, &quot;OBSERVING&quot;, &quot;ERROR&quot;, &quot;DISMISSED&quot;, &quot;DONE&quot;]
    def vcPidCond  = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),@secretkey,@iv) AS CHAR)=?&quot;

    (0..4).each { i -&gt;
        def pid = vars.get(&quot;PatientID${i}&quot;)

        def selPs = vConn.prepareStatement(
            &quot;SELECT encrypted_emr_id FROM ${VC_TBL_ENC} WHERE ${vcPidCond}&quot; as String)
        selPs.setString(1, pid)
        def rs = selPs.executeQuery()
        if (!rs.next()) throw new Exception(&quot;pid${i} VC row not found: ${pid}&quot;)
        def encEid = rs.getString(&quot;encrypted_emr_id&quot;)
        rs.close(); closeQ(selPs)
        vars.put(&quot;encEid${i}&quot;, encEid)

        def updPs = vConn.prepareStatement(
            &quot;UPDATE ${VC_TBL_ENC} SET status=? WHERE ${vcPidCond}&quot; as String)
        updPs.setString(1, statusList[i]); updPs.setString(2, pid)
        updPs.executeUpdate(); closeQ(updPs)

        def insPs = vConn.prepareStatement(
            &quot;INSERT INTO ${VC_TBL_AP} (username, encrypted_encounter_id, created_dt, updated_dt) VALUES (?, ?, NOW(), NOW())&quot; as String)
        insPs.setString(1, &quot;jmetersync&quot;); insPs.setString(2, encEid)
        insPs.executeUpdate(); closeQ(insPs)

        log.info(&quot;Setup_211 pid${i}: status=${statusList[i]}, encEid=${encEid}&quot;)
    }
} finally {
    closeQ(vConn)
}

// ── 4. EMR: 어제 날짜로 DISCHARGE_DATE 설정 ────────────────────
def emrConn = null
try {
    emrConn = DriverManager.getConnection(
        vars.get(&quot;JDBC_URL&quot;), vars.get(&quot;JDBC_USER&quot;), vars.get(&quot;JDBC_PW&quot;))
    def yesterdayStr = LocalDate.now(tz).minusDays(1).toString() + &quot; 10:00:00&quot;
    vars.put(&quot;discDate_211&quot;, yesterdayStr)

    def pids = (0..4).collect { vars.get(&quot;PatientID${it}&quot;) }
    def inClause = pids.collect { &quot;?&quot; }.join(&quot;,&quot;)
    def ps = emrConn.prepareStatement(
        &quot;UPDATE ENCOUNTERS SET DISCHARGE_DATE=TO_DATE(?,&apos;YYYY-MM-DD HH24:MI:SS&apos;) WHERE PATIENT_ID IN (${inClause})&quot; as String)
    ps.setString(1, yesterdayStr)
    pids.eachWithIndex { pid, i -&gt; ps.setString(i + 2, pid) }
    ps.executeUpdate(); closeQ(ps)
    
    log.info(&quot;Setup_211: EMR DISCHARGE_DATE=${yesterdayStr}&quot;)
} finally {
    closeQ(emrConn)
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Capture_Before" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*
def U = props.get(&quot;CommonUtils&quot;)
def closeQ = U.closeQuietly; def setVcKey = U.setVcKey; def dumpPretty = U.dumpPretty

def vcUrl  = (vars.get(&quot;JDBC_URL_VC&quot;)  ?: &quot;&quot;).toString().trim()
def vcUser = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw   = (vars.get(&quot;JDBC_PW_VC&quot;)   ?: &quot;&quot;).toString()
def pids    = (0..4).collect { (vars.get(&quot;PatientID${it}&quot;) ?: &quot;&quot;).toString().trim() }
def encEids = (0..4).collect { (vars.get(&quot;encEid${it}&quot;) ?: &quot;&quot;).toString().trim() }
def VC_TBL_ENC = (vars.get(&quot;VC_TBL_EMR_ENCOUNTER&quot;) ?: &quot;vitalcare.emr_encounter&quot;).toString().trim()
def VC_TBL_AP  = (vars.get(&quot;VC_TBL_ACCOUNTS_PIN&quot;)  ?: &quot;vitalcare.accounts_pin&quot;).toString().trim()

def encDecExpr    = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),@secretkey,@iv) AS CHAR)&quot;
def encEidDecExpr = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id),@secretkey,@iv) AS CHAR)&quot;
def vcPidCond     = &quot;${encDecExpr}=?&quot;
def vcDumpSb      = new StringBuilder()

Connection vConn = null
try {
    vConn = DriverManager.getConnection(vcUrl, vcUser, vcPw)
    setVcKey(vConn, &quot;TAG&quot;)
    def inClause   = pids.collect { &quot;?&quot; }.join(&quot;,&quot;)
    def apInClause = encEids.collect { &quot;?&quot; }.join(&quot;,&quot;)

    vcDumpSb.append(&quot;퇴원 처리 전\n&quot;)

    PreparedStatement psEnc = null; ResultSet rsEnc = null
    try {
        psEnc = vConn.prepareStatement(&quot;&quot;&quot;
            SELECT 
            created_dt, updated_dt,
            ${encDecExpr} AS patient_id,
            CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id),@secretkey,@iv) AS CHAR) AS encounter_id,
            status, admission_dt, discharge_dt
            FROM ${VC_TBL_ENC}
            WHERE ${encDecExpr} IN (${inClause})
            ORDER BY ${encDecExpr}&quot;&quot;&quot;)
        pids.eachWithIndex { pid, i -&gt; psEnc.setString(i + 1, pid) }
        rsEnc = psEnc.executeQuery()
        vcDumpSb.append(dumpPretty(VC_TBL_ENC, rsEnc, 10) ?: &quot;(no rows)&quot;).append(&quot;\n&quot;)
    } finally { closeQ(rsEnc); closeQ(psEnc) }

    PreparedStatement psAp = null; ResultSet rsAp = null
    try {
        psAp = vConn.prepareStatement(&quot;&quot;&quot;
            SELECT created_dt, updated_dt, username,
           ${encEidDecExpr} AS encounter_id
    FROM ${VC_TBL_AP}
            WHERE encrypted_encounter_id IN (${apInClause})&quot;&quot;&quot;)
        encEids.eachWithIndex { eid, i -&gt; psAp.setString(i + 1, eid) }
        rsAp = psAp.executeQuery()
        vcDumpSb.append(dumpPretty(VC_TBL_AP, rsAp, 10) ?: &quot;(no rows)&quot;).append(&quot;\n&quot;)
    } finally { closeQ(rsAp); closeQ(psAp) }

    // Verify_211에서 before vs after 비교용 status 저장
    (0..4).each { i -&gt;
        PreparedStatement psChk = null; ResultSet rsChk = null
        try {
            psChk = vConn.prepareStatement(
                &quot;SELECT status FROM ${VC_TBL_ENC} WHERE ${vcPidCond} LIMIT 1&quot;)
            psChk.setString(1, pids[i])
            rsChk = psChk.executeQuery()
            vars.put(&quot;before211_status${i}&quot;, rsChk.next() ? (rsChk.getString(&quot;status&quot;) ?: &quot;&quot;) : &quot;&quot;)
        } finally { closeQ(rsChk); closeQ(psChk) }
    }
} catch (Throwable t) {
    log.error(&quot;[Verify_Before_211] Exception&quot;, t)
    throw t
} finally {
    closeQ(vConn)
    vars.put(&quot;vcDump_before211&quot;, vcDumpSb.toString())
}
</stringProp>
        </JSR223Sampler>
