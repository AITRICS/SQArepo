        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Verify_DNR_Off" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*

def U = props.get(&quot;CommonUtils&quot;)
if (!(U instanceof Map)) throw new RuntimeException(&quot;[DNR_OFF] CommonUtils not found in props.&quot;)
def closeQ     = U.closeQuietly
def setVcKey   = U.setVcKey
def dumpPretty = U.dumpPretty
def finishFn   = U.finish

def scenarioId = (vars.get(&quot;scenario_id&quot;) ?: &quot;12&quot;).toString().trim()
def orderKey   = (vars.get(&quot;order_key&quot;)   ?: &quot;800&quot;).toString().trim()
def emrUrl  = (vars.get(&quot;JDBC_URL&quot;)     ?: &quot;&quot;).toString().trim()
def emrUser = (vars.get(&quot;JDBC_USER&quot;)    ?: &quot;&quot;).toString().trim()
def emrPw   = (vars.get(&quot;JDBC_PW&quot;)      ?: &quot;&quot;).toString()
def vcUrl   = (vars.get(&quot;JDBC_URL_VC&quot;)  ?: &quot;&quot;).toString().trim()
def vcUser  = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw    = (vars.get(&quot;JDBC_PW_VC&quot;)   ?: &quot;&quot;).toString()

def pid0 = (vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString().trim()
def pid1 = (vars.get(&quot;PatientID1&quot;) ?: &quot;&quot;).toString().trim()

def EMR_TBL_PAT     = (vars.get(&quot;EMR_PATIENT_TABLE&quot;)  ?: &quot;ROOT.PATIENTS&quot;).toString().trim()
def VC_TBL_PAT      = (vars.get(&quot;VC_TBL_EMR_PATIENT&quot;) ?: &quot;vitalcare.emr_patient&quot;).toString().trim()
def VC_TBL_DNR_HIST = (vars.get(&quot;VC_TBL_DNR_HISTORY&quot;) ?: &quot;vitalcare.emr_dnr_history&quot;).toString().trim()

[pid0, pid1].eachWithIndex { v, i -&gt;
    if (!v?.trim()) throw new RuntimeException(&quot;[DNR_OFF] PatientID${i} is empty&quot;)
}
if (!emrUrl || !emrUser) throw new RuntimeException(&quot;[DNR_OFF] EMR JDBC vars empty&quot;)
if (!vcUrl  || !vcUser)  throw new RuntimeException(&quot;[DNR_OFF] VC JDBC vars empty&quot;)

def cases = [
    [pid: pid0, label: &quot;PID1&quot;],
    [pid: pid1, label: &quot;PID2&quot;]
]

def allFails = []
String emrDumpStr = &quot;&quot;
String vcDumpStr  = &quot;&quot;

Connection eConn = null
Connection vConn = null

try {
    // ===== EMR dump =====
    eConn = DriverManager.getConnection(emrUrl, emrUser, emrPw)
    PreparedStatement psEd = null; ResultSet rsEd = null
    try {
        psEd = eConn.prepareStatement(&quot;&quot;&quot;
            SELECT CREATED_DT, UPDATED_DT, PATIENT_ID, DNR
            FROM ${EMR_TBL_PAT}
            WHERE PATIENT_ID IN (?, ?)
            ORDER BY PATIENT_ID
        &quot;&quot;&quot;)
        psEd.setString(1, pid0); psEd.setString(2, pid1)
        rsEd = psEd.executeQuery()
        emrDumpStr = dumpPretty(&quot;${EMR_TBL_PAT}&quot;, rsEd, 50)
        if (!emrDumpStr?.trim()) emrDumpStr = &quot;${EMR_TBL_PAT}\n(0 rows)\n&quot;
    } finally { closeQ(rsEd); closeQ(psEd) }

    // ===== VC 연결 =====
    vConn = DriverManager.getConnection(vcUrl, vcUser, vcPw)
    setVcKey(vConn, &quot;DNR_OFF&quot;)

    def vcPidCond   = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id),@secretkey,@iv) AS CHAR)=?&quot;
    def histPidCond = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),@secretkey,@iv) AS CHAR)=?&quot;

    // ===== VC dump: emr_patient =====
    def patDumps = []
    [pid0, pid1].each { p -&gt;
        PreparedStatement ps = null; ResultSet rs = null
        try {
            ps = vConn.prepareStatement(&quot;&quot;&quot;
                SELECT created_dt, updated_dt,
                       CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id), @secretkey,@iv) AS CHAR) AS patient_id,
                       emr_dnr, manual_dnr
                FROM ${VC_TBL_PAT}
                WHERE ${vcPidCond}
                LIMIT 10
            &quot;&quot;&quot;)
            ps.setString(1, p); rs = ps.executeQuery()
            def d = dumpPretty(&quot;${VC_TBL_PAT}&quot;, rs, 10)
            patDumps &lt;&lt; (d?.trim() ?: &quot;${VC_TBL_PAT}\n(0 rows)\n&quot;)
        } finally { closeQ(rs); closeQ(ps) }
    }

    // ===== VC dump: emr_dnr_history =====
    def histDumps = []
    [pid0, pid1].each { p -&gt;
        PreparedStatement ps = null; ResultSet rs = null
        try {
            ps = vConn.prepareStatement(&quot;&quot;&quot;
                SELECT created_dt, updated_dt,
                       CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id), @secretkey,@iv) AS CHAR) AS patient_id,
                       reason, is_dnr
                FROM ${VC_TBL_DNR_HIST}
                WHERE ${histPidCond}
                ORDER BY created_dt ASC
                LIMIT 10
            &quot;&quot;&quot;)
            ps.setString(1, p); rs = ps.executeQuery()
            def d = dumpPretty(&quot;${VC_TBL_DNR_HIST}&quot;, rs, 10)
            histDumps &lt;&lt; (d?.trim() ?: &quot;${VC_TBL_DNR_HIST}\n(0 rows)\n&quot;)
        } finally { closeQ(rs); closeQ(ps) }
    }

    vcDumpStr = (
        &quot;[PID1]\n&quot; + patDumps[0].trim() + &quot;\n\n&quot; + histDumps[0].trim() + &quot;\n\n&quot; +
        &quot;[PID2]\n&quot; + patDumps[1].trim() + &quot;\n\n&quot; + histDumps[1].trim()
    ).trim() + &quot;\n&quot;

    // ===== 검증 =====
    cases.each { c -&gt;
        def caseFails = []

        // ① emr_patient 존재 &amp; emr_dnr = NULL/NONE
        int vcCnt = 0
        PreparedStatement psCnt = null; ResultSet rsCnt = null
        try {
            psCnt = vConn.prepareStatement(&quot;SELECT COUNT(*) FROM ${VC_TBL_PAT} WHERE ${vcPidCond}&quot;)
            psCnt.setString(1, c.pid); rsCnt = psCnt.executeQuery()
            if (rsCnt.next()) vcCnt = rsCnt.getInt(1)
        } finally { closeQ(rsCnt); closeQ(psCnt) }

        if (vcCnt == 0) {
            caseFails &lt;&lt; &quot;VC row not found&quot;
        } else {
            if (vcCnt &gt; 1) caseFails &lt;&lt; &quot;VC row duplicated (count=${vcCnt})&quot;
            PreparedStatement psVf = null; ResultSet rsVf = null
            try {
                psVf = vConn.prepareStatement(&quot;SELECT emr_dnr FROM ${VC_TBL_PAT} WHERE ${vcPidCond} LIMIT 1&quot;)
                psVf.setString(1, c.pid); rsVf = psVf.executeQuery()
                if (rsVf.next()) {
                    def raw = rsVf.getObject(1)
                    def s = raw?.toString()?.trim()?.toLowerCase() ?: &quot;&quot;
                    boolean isUnset = (raw == null || s in [&quot;&quot;, &quot;null&quot;, &quot;none&quot;])
                    if (s != &quot;none&quot;) caseFails &lt;&lt; &quot;emr_dnr synced&quot;
                }
            } finally { closeQ(rsVf); closeQ(psVf) }
        }

        // ② emr_dnr_history = 0건
        int histCnt = 0
        PreparedStatement psH = null; ResultSet rsH = null
        try {
            psH = vConn.prepareStatement(&quot;SELECT COUNT(*) FROM ${VC_TBL_DNR_HIST} WHERE ${histPidCond}&quot;)
            psH.setString(1, c.pid); rsH = psH.executeQuery()
            if (rsH.next()) histCnt = rsH.getInt(1)
        } finally { closeQ(rsH); closeQ(psH) }

        if (histCnt != 0) caseFails &lt;&lt; &quot;history count=${histCnt}&quot;

        if (caseFails) allFails &lt;&lt; &quot;${c.label}: &quot; + caseFails.join(&quot;, &quot;)
    }

} catch (Throwable t) {
    log.error(&quot;[DNR_OFF] Exception&quot;, t)
    allFails &lt;&lt; &quot;exception: &quot; + t.getClass().getSimpleName() + &quot; - &quot; + (t.getMessage() ?: &quot;&quot;)
} finally {
    closeQ(eConn); closeQ(vConn)
    String result = allFails.isEmpty() ? &quot;PASS&quot; : &quot;FAIL&quot;
    String notes  = allFails.isEmpty() ? &quot;&quot; : allFails.join(&quot; | &quot;)
    finishFn(prev, ctx, props, vars, orderKey, scenarioId, result, notes, emrDumpStr, vcDumpStr)
}

return
</stringProp>
        </JSR223Sampler>
