        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Verify_Lab" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*
import java.math.BigDecimal

/**
 * Verify_Lab_AndWriteCsv (Scenario 5 only) - CLEAN
 * - 기준: &quot;최신 DRAWN_DT 6세트&quot; 전체(기대 66건) 정합성 검증
 * - Dump: 최신 DRAWN_DT 1세트(11row)만 출력
 * - VC 시간 보정: VC = EMR - 9h  (비교 시 VC에 +9h 해서 EMR과 비교)
 * - Destination dump 순서: vc_observation -&gt; emr_observation -&gt; vc_event
 * - 마무리: CommonUtils.finish() (CSV 9컬럼 + verify_* + prev)
 */

// -----------------------------
// 0) load common utils
// -----------------------------
def U = props.get(&quot;CommonUtils&quot;)
if (!(U instanceof Map)) throw new RuntimeException(&quot;[LAB] CommonUtils not found in props. setUp(Register_CommonUtils) 확인&quot;)

def closeQ    = U.closeQuietly
def setVcKey   = U.setVcKey
def dumpPretty = U.dumpPretty

// -----------------------------
// 1) vars / config
// -----------------------------
def scenarioId = (vars.get(&quot;scenario_id&quot;) ?: &quot;7&quot;).toString().trim()

def orderKey   = (vars.get(&quot;order_key&quot;) ?: &quot;500&quot;).toString().trim()
def expectMode = (vars.get(&quot;expect_mode&quot;) ?: &quot;SYNC_OK&quot;).toString().trim()

def emrUrl  = (vars.get(&quot;JDBC_URL&quot;) ?: &quot;&quot;).toString().trim()
def emrUser = (vars.get(&quot;JDBC_USER&quot;) ?: &quot;&quot;).toString().trim()
def emrPw   = (vars.get(&quot;JDBC_PW&quot;) ?: &quot;&quot;).toString()

def vcUrl   = (vars.get(&quot;JDBC_URL_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcUser  = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw    = (vars.get(&quot;JDBC_PW_VC&quot;) ?: &quot;&quot;).toString()

def pid = (vars.get(&quot;patient_id&quot;) ?: &quot;&quot;).toString().trim()
def eid = (vars.get(&quot;encounter_id&quot;) ?: &quot;&quot;).toString().trim()

def must = { String name, String v -&gt;
    if (!v || v.trim().isEmpty()) throw new RuntimeException(&quot;[LAB] ${name} is empty&quot;)
    v.trim()
}
must(&quot;JDBC_URL&quot;, emrUrl); must(&quot;JDBC_USER&quot;, emrUser)
must(&quot;JDBC_URL_VC&quot;, vcUrl); must(&quot;JDBC_USER_VC&quot;, vcUser)
must(&quot;patient_id&quot;, pid); must(&quot;encounter_id&quot;, eid)

// tables (필요하면 vars로 override)
def EMR_LAB_TABLE   = (vars.get(&quot;EMR_LAB_TABLE&quot;) ?: &quot;ROOT.LABORATORIES&quot;).toString().trim()
def VC_TBL_VC_OBS   = (vars.get(&quot;VC_TBL_VC_OBS&quot;)  ?: &quot;vitalcare.vc_observation&quot;).toString().trim()
def VC_TBL_EMR_OBS  = (vars.get(&quot;VC_TBL_EMR_OBS&quot;) ?: &quot;vitalcare.emr_observation&quot;).toString().trim()
def VC_TBL_VC_EVENT = (vars.get(&quot;VC_TBL_VC_EVENT&quot;) ?: &quot;vitalcare.vc_event&quot;).toString().trim()

int EXPECT_TOTAL = ((vars.get(&quot;lab_expected_total&quot;) ?: &quot;66&quot;).toString().trim() as int)
int SET_COUNT    = ((vars.get(&quot;lab_set_count&quot;) ?: &quot;6&quot;).toString().trim() as int)   // drawn_dt 세트 개수

// EMR codes (11개) + VC type 매핑
def emrCodes = [&quot;APH&quot;,&quot;BILIRUBIN&quot;,&quot;CREATININE&quot;,&quot;CRP&quot;,&quot;HCO3&quot;,&quot;HEMATOCRIT&quot;,&quot;LACTATE&quot;,&quot;PLATELET&quot;,&quot;POTASSIUM&quot;,&quot;SODIUM&quot;,&quot;WBC&quot;]

def mapType = { String emrCode -&gt;
    if (!emrCode) return &quot;&quot;
    switch (emrCode.trim()) {
        case &quot;HEMATOCRIT&quot;: return &quot;HCT&quot;
        default:           return emrCode.trim()
    }
}
def vcTypes = emrCodes.collect { mapType(it) }.findAll { it }.unique()

// 출력 정렬(VC type 기준)
def LAB_ORDER = [&quot;CRP&quot;,&quot;SODIUM&quot;,&quot;LACTATE&quot;,&quot;WBC&quot;,&quot;PLATELET&quot;,&quot;HCO3&quot;,&quot;POTASSIUM&quot;,&quot;BILIRUBIN&quot;,&quot;CREATININE&quot;,&quot;APH&quot;,&quot;HCT&quot;]

def orderCaseForEmrCode = {
    // EMR은 HEMATOCRIT인데, 정렬은 HCT 위치로 가야함
    def sb = new StringBuilder(&quot;CASE CODE &quot;)
    LAB_ORDER.eachWithIndex { t, idx -&gt;
        if (t == &quot;HCT&quot;) sb.append(&quot; WHEN &apos;HEMATOCRIT&apos; THEN ${idx+1} &quot;)
        else sb.append(&quot; WHEN &apos;${t}&apos; THEN ${idx+1} &quot;)
    }
    sb.append(&quot; ELSE 99 END&quot;)
    sb.toString()
}

def orderCaseForVcTypeCol = { String col -&gt;
    def sb = new StringBuilder(&quot;CASE ${col} &quot;)
    LAB_ORDER.eachWithIndex { t, idx -&gt; sb.append(&quot; WHEN &apos;${t}&apos; THEN ${idx+1} &quot;) }
    sb.append(&quot; ELSE 99 END&quot;)
    sb.toString()
}

// 숫자 비교(문자열/소수점 .0 차이 허용)
def numEq = { Object a, Object b -&gt;
    if (a == null &amp;&amp; b == null) return true
    if (a == null || b == null) return false
    try {
        new BigDecimal(a.toString().trim()) == new BigDecimal(b.toString().trim())
    } catch (ignored) {
        a.toString().trim() == b.toString().trim()
    }
}

// -----------------------------
// 2) holders
// -----------------------------
def fails = []
String result = &quot;ERROR&quot;
String notes  = &quot;&quot;
String emrDumpStr = &quot;&quot;
String vcDumpStr  = &quot;&quot;

Connection eConn = null
Connection vConn = null

try {
    // =====================================================
    // 3) connect EMR
    // =====================================================
    eConn = DriverManager.getConnection(emrUrl, emrUser, emrPw)
    if (eConn == null) throw new RuntimeException(&quot;[LAB] EMR connection is null&quot;)

    // =====================================================
    // 4) EMR: 최신 DRAWN_DT 6세트 뽑기
    // =====================================================
    List&lt;Timestamp&gt; emrDrawnSet = []
    PreparedStatement psSet = null
    ResultSet rsSet = null
    try {
        psSet = eConn.prepareStatement(&quot;&quot;&quot;
            SELECT drawn_dt
            FROM (
              SELECT DISTINCT drawn_dt
              FROM ${EMR_LAB_TABLE}
              WHERE patient_id = ?
                AND encounter_id = ?
                AND code IN (${emrCodes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
                AND deleted_yn = 0
                AND invalid = 0
              ORDER BY drawn_dt DESC
            )
            WHERE ROWNUM &lt;= ${SET_COUNT}
        &quot;&quot;&quot;)
        int i=1
        psSet.setString(i++, pid)
        psSet.setString(i++, eid)
        emrCodes.each { c -&gt; psSet.setString(i++, c) }
        rsSet = psSet.executeQuery()
        while (rsSet.next()) emrDrawnSet &lt;&lt; rsSet.getTimestamp(1)
    } finally { closeQ(rsSet); closeQ(psSet) }

    if (emrDrawnSet.isEmpty()) {
        result = &quot;FAIL&quot;
        notes  = &quot;EMR latest DRAWN_DT set not found (0 rows)&quot;
        emrDumpStr = &quot;${EMR_LAB_TABLE} (latest drawn_dt set)\n(0 rows)\n&quot;
        vcDumpStr  = &quot;&quot;
        return
    }

    Timestamp emrLatestDrawn = emrDrawnSet[0]

    // =====================================================
    // 5) EMR: 6세트 전체 count(기대 66) + 맵 구성
    // =====================================================
    def inDrawn = emrDrawnSet.collect { &quot;?&quot; }.join(&quot;,&quot;)
    PreparedStatement psAll = null
    ResultSet rsAll = null

    // key = drawn_dt|CODE
    Map&lt;String, Map&gt; emrMap = [:]
    int emrCnt = 0

    try {
        psAll = eConn.prepareStatement(&quot;&quot;&quot;
            SELECT drawn_dt, ordered_dt, result_dt, code, value
            FROM ${EMR_LAB_TABLE}
            WHERE patient_id = ?
              AND encounter_id = ?
              AND drawn_dt IN (${inDrawn})
              AND code IN (${emrCodes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
              AND deleted_yn = 0
              AND invalid = 0
        &quot;&quot;&quot;)
        int i=1
        psAll.setString(i++, pid)
        psAll.setString(i++, eid)
        emrDrawnSet.each { ts -&gt; psAll.setTimestamp(i++, ts) }
        emrCodes.each { c -&gt; psAll.setString(i++, c) }

        rsAll = psAll.executeQuery()
        while (rsAll.next()) {
            def drawn  = rsAll.getTimestamp(&quot;drawn_dt&quot;)
            def ord    = rsAll.getTimestamp(&quot;ordered_dt&quot;)
            def res    = rsAll.getTimestamp(&quot;result_dt&quot;)
            def code   = rsAll.getString(&quot;code&quot;)
            def value  = rsAll.getObject(&quot;value&quot;)

            def k = &quot;${drawn?.getTime() ?: 0L}|${code ?: &apos;&apos;}&quot;
            emrMap[k] = [drawn:drawn, ordered:ord, result:res, code:code, value:value]
            emrCnt++
        }
    } finally { closeQ(rsAll); closeQ(psAll) }

    if (emrCnt != EXPECT_TOTAL) fails &lt;&lt; &quot;EMR total count mismatch (expected=${EXPECT_TOTAL}, actual=${emrCnt})&quot;

    // =====================================================
    // 6) EMR dump: 최신 drawn_dt 1세트(11row)
    // =====================================================
    PreparedStatement psDump = null
    ResultSet rsDump = null
    try {
        psDump = eConn.prepareStatement(&quot;&quot;&quot;
            SELECT created_dt, updated_dt, patient_id, encounter_id, drawn_dt, ordered_dt, result_dt, code, value
            FROM ${EMR_LAB_TABLE}
            WHERE patient_id = ?
              AND encounter_id = ?
              AND drawn_dt = ?
              AND code IN (${emrCodes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
              AND deleted_yn = 0
              AND invalid = 0
            ORDER BY ${orderCaseForEmrCode()}
        &quot;&quot;&quot;)
        int i=1
        psDump.setString(i++, pid)
        psDump.setString(i++, eid)
        psDump.setTimestamp(i++, emrLatestDrawn)
        emrCodes.each { c -&gt; psDump.setString(i++, c) }

        rsDump = psDump.executeQuery()
        emrDumpStr = dumpPretty(&quot;${EMR_LAB_TABLE}&quot;, rsDump, 50)
        if (!emrDumpStr?.trim()) emrDumpStr = &quot;${EMR_LAB_TABLE}\n(0 rows)\n&quot;
    } finally { closeQ(rsDump); closeQ(psDump) }

    // =====================================================
    // 7) connect VC + set key
    // =====================================================
    vConn = DriverManager.getConnection(vcUrl, vcUser, vcPw)
    if (vConn == null) throw new RuntimeException(&quot;[LAB] VC connection is null&quot;)
    setVcKey(vConn, &quot;LAB&quot;)

    // VC 시간(=EMR-9h)
    def minus9h = { Timestamp ts -&gt; new Timestamp(ts.getTime() - 9L*60L*60L*1000L) }
    def plus9h  = { Timestamp ts -&gt; new Timestamp(ts.getTime() + 9L*60L*60L*1000L) }

    def eqTsNullable = { Timestamp vcTs, Timestamp emrTs, Closure&lt;Timestamp&gt; toEmrTs -&gt;
      if (vcTs == null &amp;&amp; emrTs == null) return true
      if (vcTs == null || emrTs == null) return false
      def adj = (toEmrTs != null) ? toEmrTs(vcTs) : vcTs
      return (adj != null &amp;&amp; emrTs != null &amp;&amp; adj.getTime() == emrTs.getTime())
    }

    List&lt;Timestamp&gt; vcObsSet = emrDrawnSet.collect { minus9h(it) }
    Timestamp vcLatestObs = vcObsSet[0]

    def inVcObs = vcObsSet.collect { &quot;?&quot; }.join(&quot;,&quot;)

    // =====================================================
    // 8) VC counts (3테이블: 66 기대)
    // =====================================================
    def countVcObs = { String tableName -&gt;
        PreparedStatement ps=null; ResultSet rs=null
        try {
            ps = vConn.prepareStatement(&quot;&quot;&quot;
                SELECT COUNT(*) AS cnt
                FROM ${tableName}
                WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),   @secretkey, @iv) AS CHAR) = ?
                  AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR) = ?
                  AND observed_dt IN (${inVcObs})
                  AND type IN (${vcTypes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
            &quot;&quot;&quot;)
            int i=1
            ps.setString(i++, pid)
            ps.setString(i++, eid)
            vcObsSet.each { ts -&gt; ps.setTimestamp(i++, ts) }
            vcTypes.each { t -&gt; ps.setString(i++, t) }
            rs = ps.executeQuery(); rs.next()
            rs.getInt(&quot;cnt&quot;)
        } finally { closeQ(rs); closeQ(ps) }
    }

    def countVcEvent = {
        PreparedStatement ps=null; ResultSet rs=null
        try {
            ps = vConn.prepareStatement(&quot;&quot;&quot;
                SELECT COUNT(*) AS cnt
                FROM ${VC_TBL_VC_EVENT}
                WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),   @secretkey, @iv) AS CHAR) = ?
                  AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR) = ?
                  AND observed_dt IN (${inVcObs})
                  AND category = &apos;Observation&apos;
                  AND subcategory IN (${vcTypes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
            &quot;&quot;&quot;)
            int i=1
            ps.setString(i++, pid)
            ps.setString(i++, eid)
            vcObsSet.each { ts -&gt; ps.setTimestamp(i++, ts) }
            vcTypes.each { t -&gt; ps.setString(i++, t) }
            rs = ps.executeQuery(); rs.next()
            rs.getInt(&quot;cnt&quot;)
        } finally { closeQ(rs); closeQ(ps) }
    }

    int vcObsCnt   = countVcObs(VC_TBL_VC_OBS)
    int emrObsCnt  = countVcObs(VC_TBL_EMR_OBS)
    int vcEventCnt = countVcEvent()

    if (vcObsCnt  != EXPECT_TOTAL) fails &lt;&lt; &quot;VC vc_observation rows != ${EXPECT_TOTAL} (got=${vcObsCnt})&quot;
	if (emrObsCnt != EXPECT_TOTAL) fails &lt;&lt; &quot;VC emr_observation rows != ${EXPECT_TOTAL} (got=${emrObsCnt})&quot;
	if (vcEventCnt!= EXPECT_TOTAL) fails &lt;&lt; &quot;VC vc_event rows != ${EXPECT_TOTAL} (got=${vcEventCnt})&quot;

    // =====================================================
    // 9) VC 전체 row 매칭 (drawn/ordered/result + code + value)
    //     ✅ Notes 폭발 방지: VC row count 부족/0이면 상세 비교 스킵
    // =====================================================
    boolean canDetailCompare =
        (fails.find { it.toString().startsWith(&quot;VC &quot;) } == null) &amp;&amp;
        (emrCnt == EXPECT_TOTAL) &amp;&amp;
        (vcObsCnt == EXPECT_TOTAL) &amp;&amp; (emrObsCnt == EXPECT_TOTAL) &amp;&amp; (vcEventCnt == EXPECT_TOTAL)

    if (canDetailCompare) {

        def fetchVcObsAll = { String tableName -&gt;
            PreparedStatement ps=null; ResultSet rs=null
            List&lt;Map&gt; rows=[]
            try {
                ps = vConn.prepareStatement(&quot;&quot;&quot;
                    SELECT
                      observed_dt, ordered_dt, result_dt, type, value, raw_value,
                      CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),   @secretkey, @iv) AS CHAR) AS patient_id,
                      CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR) AS encounter_id
                    FROM ${tableName}
                    WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),   @secretkey, @iv) AS CHAR) = ?
                      AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR) = ?
                      AND observed_dt IN (${inVcObs})
                      AND type IN (${vcTypes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
                &quot;&quot;&quot;)
                int i=1
                ps.setString(i++, pid); ps.setString(i++, eid)
                vcObsSet.each { ts -&gt; ps.setTimestamp(i++, ts) }
                vcTypes.each { t -&gt; ps.setString(i++, t) }

                rs = ps.executeQuery()
                while (rs.next()) {
                    rows &lt;&lt; [
                        observed: rs.getTimestamp(&quot;observed_dt&quot;),
                        ordered : rs.getTimestamp(&quot;ordered_dt&quot;),
                        result  : rs.getTimestamp(&quot;result_dt&quot;),
                        type    : rs.getString(&quot;type&quot;),
                        value   : rs.getObject(&quot;value&quot;),
                        raw     : rs.getObject(&quot;raw_value&quot;)
                    ]
                }
            } finally { closeQ(rs); closeQ(ps) }
            rows
        }

        def vcAll1 = fetchVcObsAll(VC_TBL_VC_OBS)
        def vcAll2 = fetchVcObsAll(VC_TBL_EMR_OBS)

        def checkVcRows = { List&lt;Map&gt; vcRows, String tag -&gt;
            vcRows.each { r -&gt;
                Timestamp emrDrawn  = r.observed ? plus9h(r.observed) : null
                String emrCode = (r.type ?: &quot;&quot;).toString()

                // VC type &apos;HCT&apos; 는 EMR &apos;HEMATOCRIT&apos; 로 lookup
                String emrLookupCode = (emrCode == &quot;HCT&quot;) ? &quot;HEMATOCRIT&quot; : emrCode

                def k = &quot;${emrDrawn?.getTime() ?: 0L}|${emrLookupCode}&quot;
                def emr = emrMap[k]
                if (emr == null) {
                    fails &lt;&lt; &quot;${tag} row not found in EMR (drawn=${emrDrawn}, code=${emrLookupCode})&quot;
                    return
                }

                // EMR↔VC 정합성
                if (!eqTsNullable(r.ordered as Timestamp, emr.ordered as Timestamp, plus9h))
                   fails &lt;&lt; &quot;${tag} ordered_dt mismatch code=${emrLookupCode} (emr=${emr.ordered}, vc=${r.ordered})&quot;
                if (!eqTsNullable(r.result as Timestamp, emr.result as Timestamp, plus9h))
                   fails &lt;&lt; &quot;${tag} result_dt mismatch code=${emrLookupCode} (emr=${emr.result}, vc=${r.result})&quot;

                // value compare
                if (!numEq(r.value, emr.value))
                    fails &lt;&lt; &quot;${tag} value mismatch code=${emrLookupCode} (EMR=${emr.value}, VC=${r.value})&quot;
            }
        }

        checkVcRows(vcAll1, &quot;vc_observation&quot;)
        checkVcRows(vcAll2, &quot;emr_observation&quot;)

        // vc_event (observed_dt + subcategory + value)
        PreparedStatement psEv=null; ResultSet rsEv=null
        try {
            psEv = vConn.prepareStatement(&quot;&quot;&quot;
                SELECT observed_dt, subcategory, value, raw_value
                FROM ${VC_TBL_VC_EVENT}
                WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),   @secretkey, @iv) AS CHAR) = ?
                  AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR) = ?
                  AND observed_dt IN (${inVcObs})
                  AND category = &apos;Observation&apos;
                  AND subcategory IN (${vcTypes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
            &quot;&quot;&quot;)
            int i=1
            psEv.setString(i++, pid); psEv.setString(i++, eid)
            vcObsSet.each { ts -&gt; psEv.setTimestamp(i++, ts) }
            vcTypes.each { t -&gt; psEv.setString(i++, t) }

            rsEv = psEv.executeQuery()
            while (rsEv.next()) {
                Timestamp emrDrawn = rsEv.getTimestamp(&quot;observed_dt&quot;) ? plus9h(rsEv.getTimestamp(&quot;observed_dt&quot;)) : null
                String sub = rsEv.getString(&quot;subcategory&quot;)
                String emrLookupCode = (sub == &quot;HCT&quot;) ? &quot;HEMATOCRIT&quot; : sub

                def k = &quot;${emrDrawn?.getTime() ?: 0L}|${emrLookupCode}&quot;
                def emr = emrMap[k]
                if (emr == null) {
                    fails &lt;&lt; &quot;vc_event row not found in EMR (drawn=${emrDrawn}, code=${emrLookupCode})&quot;
                    continue
                }
                if (!numEq(rsEv.getObject(&quot;value&quot;), emr.value))
                    fails &lt;&lt; &quot;vc_event value mismatch code=${emrLookupCode} (EMR=${emr.value}, VC=${rsEv.getObject(&apos;value&apos;)})&quot;
            }
        } finally { closeQ(rsEv); closeQ(psEv) }

    } // end canDetailCompare

    // =====================================================
    // 10) VC dump: 최신 set(11row)만
    // =====================================================
    def dumpVcObsLatest = { String tableName, boolean includeEmrCreated -&gt;
        PreparedStatement ps=null; ResultSet rs=null
        try {
            ps = vConn.prepareStatement(&quot;&quot;&quot;
                SELECT
                  created_dt, updated_dt,
                  CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),   @secretkey, @iv) AS CHAR) AS patient_id,
                  CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR) AS encounter_id,
                  observed_dt, ordered_dt, result_dt,
                  type, value, raw_value
                  ${includeEmrCreated ? &quot;, emr_created_dt&quot; : &quot;&quot;}
                FROM ${tableName}
                WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),   @secretkey, @iv) AS CHAR) = ?
                  AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR) = ?
                  AND observed_dt = ?
                  AND type IN (${vcTypes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
                ORDER BY ${orderCaseForVcTypeCol(&quot;type&quot;)}
            &quot;&quot;&quot;)
            int i=1
            ps.setString(i++, pid); ps.setString(i++, eid)
            ps.setTimestamp(i++, vcLatestObs)
            vcTypes.each { t -&gt; ps.setString(i++, t) }

            rs = ps.executeQuery()
            def s = dumpPretty(&quot;${tableName}&quot;, rs, 80)
            s?.trim() ? s : &quot;${tableName}\n(0 rows)\n&quot;
        } finally { closeQ(rs); closeQ(ps) }
    }

    def dumpVcEventLatest = {
        PreparedStatement ps=null; ResultSet rs=null
        try {
            ps = vConn.prepareStatement(&quot;&quot;&quot;
                SELECT
                  created_dt, updated_dt,
                  CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),   @secretkey, @iv) AS CHAR) AS patient_id,
                  CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR) AS encounter_id,
                  observed_dt, category, subcategory, value, raw_value
                FROM ${VC_TBL_VC_EVENT}
                WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),   @secretkey, @iv) AS CHAR) = ?
                  AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR) = ?
                  AND observed_dt = ?
                  AND category = &apos;Observation&apos;
                  AND subcategory IN (${vcTypes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
                ORDER BY ${orderCaseForVcTypeCol(&quot;subcategory&quot;)}
            &quot;&quot;&quot;)
            int i=1
            ps.setString(i++, pid); ps.setString(i++, eid)
            ps.setTimestamp(i++, vcLatestObs)
            vcTypes.each { t -&gt; ps.setString(i++, t) }

            rs = ps.executeQuery()
            def s = dumpPretty(&quot;${VC_TBL_VC_EVENT}&quot;, rs, 80)
            s?.trim() ? s : &quot;${VC_TBL_VC_EVENT}\n(0 rows)\n&quot;
        } finally { closeQ(rs); closeQ(ps) }
    }

    def dumpVc1 = dumpVcObsLatest(VC_TBL_VC_OBS, true)
    def dumpVc2 = dumpVcObsLatest(VC_TBL_EMR_OBS, false)
    def dumpVc3 = dumpVcEventLatest()

    vcDumpStr = dumpVc1.trim() + &quot;\n\n&quot; + dumpVc2.trim() + &quot;\n\n&quot; + dumpVc3.trim() + &quot;\n&quot;

    // =====================================================
    // 11) verdict
    // =====================================================
    result = fails.isEmpty() ? &quot;PASS&quot; : &quot;FAIL&quot;
    notes  = fails.isEmpty() ? &quot;&quot; : fails.join(&quot; | &quot;)

    log.info(&quot;[LAB] setCount=${SET_COUNT}, expectedTotal=${EXPECT_TOTAL}, EMR=${emrCnt}, VC(vc_obs)=${vcObsCnt}, VC(emr_obs)=${emrObsCnt}, VC(event)=${vcEventCnt}, result=${result}&quot;)

} catch (Throwable t) {
    log.error(&quot;[LAB] Exception&quot;, t)
    result = &quot;FAIL&quot;
    notes  = &quot;exception: &quot; + t.getClass().getSimpleName() + &quot; - &quot; + (t.getMessage() ?: &quot;&quot;)
} finally {
    closeQ(eConn); closeQ(vConn)
    U.finish(prev, ctx, props, vars, orderKey, scenarioId, result, notes, emrDumpStr, vcDumpStr)
}

return</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Scenario 8" enabled="true">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
