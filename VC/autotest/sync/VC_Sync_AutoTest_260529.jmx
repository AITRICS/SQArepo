        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="ICU_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection
import java.sql.DriverManager
import java.sql.PreparedStatement

String url = &quot;${JDBC_URL}&quot;
String user = &quot;${JDBC_USER}&quot;
String password = &quot;${JDBC_PW}&quot;

String query =
  &quot;INSERT INTO ROOT.ICUS (PATIENT_ID, ENCOUNTER_ID, START_DT, END_DT, DELETED_YN) &quot; +
  &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), NULL, ?)&quot;

Connection conn = null
PreparedStatement stmt = null

try {
    conn = DriverManager.getConnection(url, user, password)
    stmt = conn.prepareStatement(query)

    int repeatCount = Integer.parseInt((vars.get(&quot;PatientCount&quot;) ?: &quot;1&quot;).toString().trim())

    int totalRows = 0

    for (int i = 0; i &lt; repeatCount; i++) {
        String PatientID = vars.get(&quot;PatientID&quot; + i)
        String EncounterID = vars.get(&quot;EncounterID&quot; + i)
        String icuIn = vars.get(&quot;icuIn&quot; + i)

        stmt.setString(1, PatientID)
        stmt.setString(2, EncounterID)
        stmt.setString(3, icuIn)
        stmt.setInt(4, 0)

        int rowsInsert = stmt.executeUpdate()
        totalRows += rowsInsert

        stmt.clearParameters()
    }

    log.info(&quot;[ICU] affectedRows=&quot; + totalRows)

} finally {
    try { if (stmt != null) stmt.close() } catch (ignored) {}
    try { if (conn != null) conn.close() } catch (ignored) {}
}
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Observation Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount} // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate to set timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {

    // ---------------------------------------
    // Patient / Encounter ID (DO NOT overwrite)
    //  - Reuse existing PatientID{i}, EncounterID{i} if present
    // ---------------------------------------
    String PatientID = (vars.get(&quot;PatientID&quot; + i) ?: &quot;&quot;).toString().trim()
    String EncounterID = (vars.get(&quot;EncounterID&quot; + i) ?: &quot;&quot;).toString().trim()

    if (!PatientID || !EncounterID) {
        // Create a Date object
        Date PatientSet = new Date(timestampDefault)
        Date EncounterSet = new Date(timestampDefault)

        // Create a SimpleDateFormat object and set it to timezone
        SimpleDateFormat sdf_patient = new SimpleDateFormat(i + &quot;yyMMddHHmmss&quot; + ${User_Thread})
        sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
        PatientID = sdf_patient.format(PatientSet)

        SimpleDateFormat sdf_encounter = new SimpleDateFormat(i + &quot;yyyyMMddHHmmss&quot; + ${User_Thread})
        sdf_encounter.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
        EncounterID = sdf_encounter.format(EncounterSet) + &quot;|&quot; + PatientID

        // Store only when generated (no overwrite)
        vars.put(&quot;PatientID&quot; + i, PatientID)
        vars.put(&quot;EncounterID&quot; + i, EncounterID)
    }

    // -----------------------------
    // Set ICU In Date
    // -----------------------------
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault)
    calendar.add(Calendar.MINUTE, - ((observationCount - 1) * ${Ob_Interval_Min}))

    // Align icuInSetTimestamp to next 10-minute mark
    int minuteIn = calendar.get(Calendar.MINUTE)
    int modIn = minuteIn % 10
    if (modIn != 0) {
        calendar.add(Calendar.MINUTE, 10 - modIn)
    } else {
        calendar.add(Calendar.MINUTE, 10)
    }
    calendar.set(Calendar.SECOND, 0)
    calendar.set(Calendar.MILLISECOND, 0)
    long icuInSetTimestamp = calendar.getTimeInMillis()
    Date icuInSet = new Date(icuInSetTimestamp)

    // -----------------------------
    // (Optional) Set ICU Out Date (kept for 6-2/6-3)
    // -----------------------------
    calendar.setTimeInMillis(timestampDefault)
    calendar.add(Calendar.HOUR, -1)

    // Align icuOutSetTimestamp to next 10-minute mark
    int minuteOut = calendar.get(Calendar.MINUTE)
    int modOut = minuteOut % 10
    if (modOut != 0) {
        calendar.add(Calendar.MINUTE, 10 - modOut)
        calendar.set(Calendar.SECOND, 0)
        calendar.set(Calendar.MILLISECOND, 0)
    }

    long icuOutSetTimestamp = calendar.getTimeInMillis()
    Date icuOutSet = new Date(icuOutSetTimestamp)

    // Create a SimpleDateFormat object and set it to timezone
    SimpleDateFormat sdf_icuIn = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    sdf_icuIn.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    String icuIn = sdf_icuIn.format(icuInSet)

    SimpleDateFormat sdf_icuOut = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    sdf_icuOut.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    String icuOut = sdf_icuOut.format(icuOutSet)

    // Store in variables (ICU times only)
    vars.put(&quot;icuIn&quot; + i, icuIn)
    vars.put(&quot;icuOut&quot; + i, icuOut)
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Wait_for_Sync" enabled="true">
          <intProp name="ActionProcessor.action">1</intProp>
          <intProp name="ActionProcessor.target">0</intProp>
          <stringProp name="ActionProcessor.duration">120000</stringProp>
        </TestAction>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Verify_ICU_In" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*

/**
 * Verify_ICU_IN_AndWriteCsv (Scenario 8)
 *
 * Expect (SYNC_OK)
 *  - EMR: ROOT.ICUS (pid,eid, DELETED_YN=0) count == 1
 *  - VC : vc_icu  (pid,eid, deleted=0) total count == 1  AND status=&apos;IN&apos;
 *  - VC : vc_event(pid,eid, deleted=0, category=&apos;ICU&apos;) total count == 1  AND subcategory=&apos;IN&apos;
 *  - 시간 정합:
 *      VC.observed_dt + 9h == EMR.start_dt
 *      VC.emr_created_dt + 9h == EMR.created_dt
 *
 * Dump
 *  - EMR ROOT.ICUS: pid+eid 전체
 *  - VC  vc_icu:   pid+eid 전체(복호화 포함)
 *  - VC  vc_event: pid+eid + category=&apos;ICU&apos; 전체(복호화 포함)
 */

// -----------------------------
// 0) CommonUtils
// -----------------------------
def U = props.get(&quot;CommonUtils&quot;)
if (!(U instanceof Map)) throw new RuntimeException(&quot;[ICU] CommonUtils not found in props.&quot;)
def closeQ     = U.closeQuietly
def setVcKey   = U.setVcKey
def dumpPretty = U.dumpPretty

// -----------------------------
// 1) vars / config
// -----------------------------
def scenarioId = (vars.get(&quot;scenario_id&quot;) ?: &quot;8&quot;).toString().trim()
def orderKey   = (vars.get(&quot;order_key&quot;) ?: &quot;610&quot;).toString().trim()
def expectMode = (vars.get(&quot;expect_mode&quot;) ?: &quot;SYNC_OK&quot;).toString().trim()

def emrUrl  = (vars.get(&quot;JDBC_URL&quot;) ?: &quot;&quot;).toString().trim()
def emrUser = (vars.get(&quot;JDBC_USER&quot;) ?: &quot;&quot;).toString().trim()
def emrPw   = (vars.get(&quot;JDBC_PW&quot;) ?: &quot;&quot;).toString()

def vcUrl   = (vars.get(&quot;JDBC_URL_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcUser  = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw    = (vars.get(&quot;JDBC_PW_VC&quot;) ?: &quot;&quot;).toString()

def pid = (vars.get(&quot;patient_id&quot;) ?: vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString().trim()
def eid = (vars.get(&quot;encounter_id&quot;) ?: vars.get(&quot;EncounterID0&quot;) ?: &quot;&quot;).toString().trim()

def EMR_ICU_TABLE = (vars.get(&quot;EMR_ICU_TABLE&quot;) ?: &quot;ROOT.ICUS&quot;).toString().trim()
def VC_TBL_VC_ICU = (vars.get(&quot;VC_TBL_VC_ICU&quot;) ?: &quot;vitalcare.vc_icu&quot;).toString().trim()
def VC_TBL_VC_EVT = (vars.get(&quot;VC_TBL_VC_EVENT&quot;) ?: &quot;vitalcare.vc_event&quot;).toString().trim()

def must = { String name, String v -&gt;
  if (v == null || v.trim().isEmpty()) throw new RuntimeException(&quot;[ICU] ${name} is empty&quot;)
  v.trim()
}
must(&quot;patient_id&quot;, pid); must(&quot;encounter_id&quot;, eid)
must(&quot;JDBC_URL&quot;, emrUrl); must(&quot;JDBC_USER&quot;, emrUser)
must(&quot;JDBC_URL_VC&quot;, vcUrl); must(&quot;JDBC_USER_VC&quot;, vcUser)

final long OFFSET_MS = 9L * 60L * 60L * 1000L
def plus9h = { Timestamp ts -&gt; (ts == null) ? null : new Timestamp(ts.getTime() + OFFSET_MS) }

// -----------------------------
// 2) holders
// -----------------------------
def fails = []
String result = &quot;FAIL&quot;
String notes  = &quot;&quot;
String emrDumpStr = &quot;&quot;
String vcDumpStr  = &quot;&quot;

Connection eConn=null
Connection vConn=null

try {
  // =====================================================
  // EMR: dump + count(=1) + latest row(created/start)
  // =====================================================
  eConn = DriverManager.getConnection(emrUrl, emrUser, emrPw)

  // dump (pid+eid 전체)
  PreparedStatement psEd=null; ResultSet rsEd=null
  try {
    psEd = eConn.prepareStatement(&quot;&quot;&quot;
      SELECT CREATED_DT, UPDATED_DT, PATIENT_ID, ENCOUNTER_ID, START_DT, END_DT
      FROM ${EMR_ICU_TABLE}
      WHERE PATIENT_ID=? AND ENCOUNTER_ID=? AND DELETED_YN=0
      ORDER BY CREATED_DT DESC
    &quot;&quot;&quot;)
    psEd.setString(1, pid); psEd.setString(2, eid)
    rsEd = psEd.executeQuery()
    emrDumpStr = dumpPretty(&quot;${EMR_ICU_TABLE}&quot;, rsEd, 200)
    if (!emrDumpStr?.trim()) emrDumpStr = &quot;${EMR_ICU_TABLE}\n(0 rows)\n&quot;
  } finally { closeQ(rsEd); closeQ(psEd) }

  // count
  int emrCnt = 0
  PreparedStatement psEc=null; ResultSet rsEc=null
  try {
    psEc = eConn.prepareStatement(&quot;&quot;&quot;
      SELECT COUNT(*) AS cnt
      FROM ${EMR_ICU_TABLE}
      WHERE PATIENT_ID=? AND ENCOUNTER_ID=? AND DELETED_YN=0
    &quot;&quot;&quot;)
    psEc.setString(1, pid); psEc.setString(2, eid)
    rsEc = psEc.executeQuery()
    rsEc.next()
    emrCnt = rsEc.getInt(&quot;cnt&quot;)
  } finally { closeQ(rsEc); closeQ(psEc) }

  // latest row for time compare (deterministic)
  Timestamp emrCreated=null
  Timestamp emrStart=null
  PreparedStatement psE1=null; ResultSet rsE1=null
  try {
    psE1 = eConn.prepareStatement(&quot;&quot;&quot;
      SELECT CREATED_DT, START_DT
      FROM ${EMR_ICU_TABLE}
      WHERE PATIENT_ID=? AND ENCOUNTER_ID=? AND DELETED_YN=0
      ORDER BY CREATED_DT DESC
      FETCH FIRST 1 ROWS ONLY
    &quot;&quot;&quot;)
    psE1.setString(1, pid); psE1.setString(2, eid)
    rsE1 = psE1.executeQuery()
    if (rsE1.next()) {
      emrCreated = rsE1.getTimestamp(1)
      emrStart   = rsE1.getTimestamp(2)
    }
  } finally { closeQ(rsE1); closeQ(psE1) }

  if (!&quot;SYNC_OK&quot;.equalsIgnoreCase(expectMode)) fails &lt;&lt; &quot;expect_mode=${expectMode} (expected SYNC_OK)&quot;
  if (emrCnt != 1) fails &lt;&lt; &quot;EMR ICUS count=${emrCnt} (expected 1)&quot;
  if (emrCreated == null) fails &lt;&lt; &quot;EMR CREATED_DT is null&quot;
  if (emrStart == null)   fails &lt;&lt; &quot;EMR START_DT is null&quot;

  // =====================================================
  // VC: dump + (IN 1건) + (event ICU/IN 1건) + time compare
  // =====================================================
  vConn = DriverManager.getConnection(vcUrl, vcUser, vcPw)
  setVcKey(vConn, &quot;ICU&quot;)

  def vcPidExpr = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),@secretkey,@iv) AS CHAR)&quot;
  def vcEidExpr = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id),@secretkey,@iv) AS CHAR)&quot;
  def vcCond    = &quot;${vcPidExpr}=? AND ${vcEidExpr}=?&quot;

  // dump vc_icu (pid+eid 전체)
  PreparedStatement psVd1=null; ResultSet rsVd1=null
  try {
    psVd1 = vConn.prepareStatement(&quot;&quot;&quot;
      SELECT
        created_dt, updated_dt,
        ${vcPidExpr} AS patient_id,
        ${vcEidExpr} AS encounter_id,
        observed_dt, status, emr_created_dt, deleted
      FROM ${VC_TBL_VC_ICU}
      WHERE ${vcCond}
      ORDER BY observed_dt DESC
    &quot;&quot;&quot;)
    psVd1.setString(1, pid); psVd1.setString(2, eid)
    rsVd1 = psVd1.executeQuery()
    def dump1 = dumpPretty(&quot;${VC_TBL_VC_ICU}&quot;, rsVd1, 200)
    vcDumpStr = (dump1?.trim() ? dump1.trim() : &quot;${VC_TBL_VC_ICU}\n(0 rows)\n&quot;)
  } finally { closeQ(rsVd1); closeQ(psVd1) }

  // dump vc_event (pid+eid + category=ICU 전체)
  PreparedStatement psVd2=null; ResultSet rsVd2=null
  try {
    psVd2 = vConn.prepareStatement(&quot;&quot;&quot;
      SELECT
        created_dt, updated_dt,
        ${vcPidExpr} AS patient_id,
        ${vcEidExpr} AS encounter_id,
        observed_dt, category, subcategory, deleted
      FROM ${VC_TBL_VC_EVT}
      WHERE ${vcCond} AND category=&apos;ICU&apos;
      ORDER BY observed_dt DESC
    &quot;&quot;&quot;)
    psVd2.setString(1, pid); psVd2.setString(2, eid)
    rsVd2 = psVd2.executeQuery()
    def dump2 = dumpPretty(&quot;${VC_TBL_VC_EVT}&quot;, rsVd2, 200)
    vcDumpStr = vcDumpStr.trim() + &quot;\n\n&quot; + (dump2?.trim() ? dump2.trim() : &quot;${VC_TBL_VC_EVT}\n(0 rows)\n&quot;) + &quot;\n&quot;
  } finally { closeQ(rsVd2); closeQ(psVd2) }

  // vc_icu IN count
  int vcIcuInCnt = 0
  PreparedStatement psIc=null; ResultSet rsIc=null
  try {
    psIc = vConn.prepareStatement(&quot;&quot;&quot;
      SELECT COUNT(*) AS cnt
      FROM ${VC_TBL_VC_ICU}
      WHERE ${vcCond} AND deleted=0 AND UPPER(status)=&apos;IN&apos;
    &quot;&quot;&quot;)
    psIc.setString(1, pid); psIc.setString(2, eid)
    rsIc = psIc.executeQuery()
    rsIc.next()
    vcIcuInCnt = rsIc.getInt(&quot;cnt&quot;)
  } finally { closeQ(rsIc); closeQ(psIc) }

  // vc_icu total count (deleted=0)
  int vcIcuTotalCnt = 0
  PreparedStatement psTic=null; ResultSet rsTic=null
  try {
    psTic = vConn.prepareStatement(&quot;&quot;&quot;
      SELECT COUNT(*) AS cnt
      FROM ${VC_TBL_VC_ICU}
      WHERE ${vcCond} AND deleted=0
    &quot;&quot;&quot;)
    psTic.setString(1, pid); psTic.setString(2, eid)
    rsTic = psTic.executeQuery()
    rsTic.next()
    vcIcuTotalCnt = rsTic.getInt(&quot;cnt&quot;)
  } finally { closeQ(rsTic); closeQ(psTic) }

  // vc_icu IN row (deterministic)
  Timestamp vcIcuObs=null
  Timestamp vcEmrCreated=null
  PreparedStatement psI1=null; ResultSet rsI1=null
  try {
    psI1 = vConn.prepareStatement(&quot;&quot;&quot;
      SELECT observed_dt, emr_created_dt
      FROM ${VC_TBL_VC_ICU}
      WHERE ${vcCond} AND deleted=0 AND UPPER(status)=&apos;IN&apos;
      ORDER BY observed_dt DESC
      LIMIT 1
    &quot;&quot;&quot;)
    psI1.setString(1, pid); psI1.setString(2, eid)
    rsI1 = psI1.executeQuery()
    if (rsI1.next()) {
      vcIcuObs     = rsI1.getTimestamp(1)
      vcEmrCreated = rsI1.getTimestamp(2)
    }
  } finally { closeQ(rsI1); closeQ(psI1) }

  // vc_event ICU/IN count
  int vcEvtInCnt = 0
  PreparedStatement psEv=null; ResultSet rsEv=null
  try {
    psEv = vConn.prepareStatement(&quot;&quot;&quot;
      SELECT COUNT(*) AS cnt
      FROM ${VC_TBL_VC_EVT}
      WHERE ${vcCond} AND category=&apos;ICU&apos; AND deleted=0 AND UPPER(subcategory)=&apos;IN&apos;
    &quot;&quot;&quot;)
    psEv.setString(1, pid); psEv.setString(2, eid)
    rsEv = psEv.executeQuery()
    rsEv.next()
    vcEvtInCnt = rsEv.getInt(&quot;cnt&quot;)
  } finally { closeQ(rsEv); closeQ(psEv) }

  // vc_event ICU total count (deleted=0)
  int vcEvtTotalCnt = 0
  PreparedStatement psTev=null; ResultSet rsTev=null
  try {
    psTev = vConn.prepareStatement(&quot;&quot;&quot;
      SELECT COUNT(*) AS cnt
      FROM ${VC_TBL_VC_EVT}
      WHERE ${vcCond} AND category=&apos;ICU&apos; AND deleted=0
    &quot;&quot;&quot;)
    psTev.setString(1, pid); psTev.setString(2, eid)
    rsTev = psTev.executeQuery()
    rsTev.next()
    vcEvtTotalCnt = rsTev.getInt(&quot;cnt&quot;)
  } finally { closeQ(rsTev); closeQ(psTev) }

  // vc_event ICU/IN row (deterministic)
  Timestamp vcEvtObs=null
  PreparedStatement psE1v=null; ResultSet rsE1v=null
  try {
    psE1v = vConn.prepareStatement(&quot;&quot;&quot;
      SELECT observed_dt
      FROM ${VC_TBL_VC_EVT}
      WHERE ${vcCond} AND category=&apos;ICU&apos; AND deleted=0 AND UPPER(subcategory)=&apos;IN&apos;
      ORDER BY observed_dt DESC
      LIMIT 1
    &quot;&quot;&quot;)
    psE1v.setString(1, pid); psE1v.setString(2, eid)
    rsE1v = psE1v.executeQuery()
    if (rsE1v.next()) vcEvtObs = rsE1v.getTimestamp(1)
  } finally { closeQ(rsE1v); closeQ(psE1v) }

  log.info(&quot;[ICU] Verify_ICU_In: icuIn=${vcIcuInCnt}, icuTotal=${vcIcuTotalCnt}, evtIn=${vcEvtInCnt}, evtTotal=${vcEvtTotalCnt}&quot;)

  if (vcIcuTotalCnt != 1)    fails &lt;&lt; &quot;VC vc_icu total count=${vcIcuTotalCnt} (expected 1, IN only)&quot;
  else if (vcIcuInCnt != 1)  fails &lt;&lt; &quot;VC vc_icu(IN) count=${vcIcuInCnt} (expected 1)&quot;
  if (vcEvtTotalCnt != 1)    fails &lt;&lt; &quot;VC vc_event(ICU) total count=${vcEvtTotalCnt} (expected 1, IN only)&quot;
  else if (vcEvtInCnt != 1)  fails &lt;&lt; &quot;VC vc_event(ICU,IN) count=${vcEvtInCnt} (expected 1)&quot;

  // time compare (ms exact)
  if (emrStart != null &amp;&amp; vcIcuObs != null) {
    def v = plus9h(vcIcuObs)
    if (v.getTime() != emrStart.getTime())
      fails &lt;&lt; &quot;start_dt mismatch: EMR(${emrStart}) vs VC_ICU+9h(${v})&quot;
  }
  if (emrStart != null &amp;&amp; vcEvtObs != null) {
    def v = plus9h(vcEvtObs)
    if (v.getTime() != emrStart.getTime())
      fails &lt;&lt; &quot;start_dt mismatch: EMR(${emrStart}) vs VC_EVT+9h(${v})&quot;
  }
  if (emrCreated != null &amp;&amp; vcEmrCreated != null) {
    def v = plus9h(vcEmrCreated)
    if (v.getTime() != emrCreated.getTime())
      fails &lt;&lt; &quot;created_dt mismatch: EMR(${emrCreated}) vs VC.emr_created_dt+9h(${v})&quot;
  }

  result = fails.isEmpty() ? &quot;PASS&quot; : &quot;FAIL&quot;
  notes  = fails.isEmpty() ? &quot;&quot; : fails.join(&quot; | &quot;)

} catch (Throwable t) {
  log.error(&quot;[ICU] Exception&quot;, t)
  result = &quot;FAIL&quot;
  notes  = &quot;exception: &quot; + t.getClass().getSimpleName() + &quot; - &quot; + (t.getMessage() ?: &quot;&quot;)
} finally {
  closeQ(eConn); closeQ(vConn)
  U.finish(prev, ctx, props, vars, orderKey, scenarioId, result, notes, emrDumpStr, vcDumpStr)
}

return
</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Scenario 9" enabled="true">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <OnceOnlyController guiclass="OnceOnlyControllerGui" testclass="OnceOnlyController" testname="Once Only Controller" enabled="true"/>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Setname Sampler" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">vars.put(&quot;currentControllerName&quot;, &quot;Scenario 6&quot;)

vars.put(&quot;scenario_id&quot;, &quot;Icu 퇴실&quot;)
vars.put(&quot;expect_mode&quot;, &quot;SYNC_OK&quot;)
vars.put(&quot;order_key&quot;, &quot;620&quot;)
vars.put(&quot;verify_target&quot;, &quot;ICU&quot;)

vars.put(&quot;PatientCount&quot;, &quot;1&quot;)


String tgName = ctx.getThreadGroup().getName()
String tgNum = &quot;0&quot;
try { tgNum = tgName.split(&quot; &quot;)[1] } catch (ignored) { tgNum = &quot;0&quot; }
vars.put(&quot;tgNum&quot;, tgNum)

log.info(&quot;[INIT] parent=${vars.get(&apos;currentControllerName&apos;)}, scenario_id=${vars.get(&apos;scenario_id&apos;)}, label=${vars.get(&apos;scenario_label&apos;)}, expect_mode=${vars.get(&apos;expect_mode&apos;)}, order_key=${vars.get(&apos;order_key&apos;)}, verify_target=${vars.get(&apos;verify_target&apos;)}, PatientCount=${vars.get(&apos;PatientCount&apos;)}, tgNum=${vars.get(&apos;tgNum&apos;)}&quot;)

</stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Mark StartTime" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.text.SimpleDateFormat
import java.util.TimeZone
import java.util.Date

def tz = (vars.get(&quot;TimeZone&quot;) ?: &quot;Asia/Seoul&quot;).toString()
def sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss,SSS&quot;)
sdf.setTimeZone(TimeZone.getTimeZone(tz))

long startMs = System.currentTimeMillis()
vars.putObject(&quot;caseStartMillis&quot;, startMs)

def startTs = sdf.format(new Date(startMs))
vars.put(&quot;case_start_ts&quot;, startTs)

// CSV/HTML이 기존 키를 쓰면 호환용으로 같이 세팅
vars.put(&quot;verify_startTime&quot;, startTs)

log.info(&quot;[CASE_START] scenario_id=${vars.get(&apos;scenario_id&apos;)} start_ts=${startTs} TZ=${tz}&quot;)
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Patient_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;

def pidLog = (vars.get(&quot;patient_id&quot;) ?: vars.get(&quot;PatientID&quot;) ?: vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString()
log.info(&quot;[PAT INSERT DBG] scenario_id=&quot; + (vars.get(&quot;scenario_id&quot;) ?: &quot;&quot;)
        + &quot; thread=&quot; + ctx.getThreadNum()
        + &quot; pid=&quot; + pidLog)


// Scenario(Thread) start time: set once
if (!vars.get(&quot;startTimeThread&quot;)) {
    vars.put(&quot;startTimeThread&quot;, String.valueOf(System.currentTimeMillis()))
}

	// JDBC connection information
	String url = &quot;${JDBC_URL}&quot;;
	String user = &quot;${JDBC_USER}&quot;;
	String password = &quot;${JDBC_PW}&quot;;

	// Define the query
	String query = &quot;INSERT INTO ROOT.PATIENTS (PATIENT_ID, NAME, BIRTHDATE, SEX) &quot; +
	                &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?)&quot;;

	// JDBC connection
	Connection conn = DriverManager.getConnection(url, user, password);

	// Prepare the statement
	PreparedStatement stmt = conn.prepareStatement(query);

	// Repeat the process for multiple sets of parameters
	int repeatCount = ${PatientCount}; // Number of repetitions set
		for (int i = 0; i &lt; repeatCount; i++) {
		    // Set String parameters for the query
		    String PatientID = vars.get(&quot;PatientID&quot; + i);
		    String Name = vars.get(&quot;Name&quot; + i);
		    String BirthDate = vars.get(&quot;BirthDate&quot; + i);
		    
		    // Set parameters for the query
		    stmt.setString(1, PatientID);
		    stmt.setString(2, &quot;QA&quot;+Name);
		    stmt.setString(3, BirthDate);
		    // Set gender based on whether i is odd or even
		    if (${User_Thread} % 2 == 0) {
		        stmt.setString(4, &quot;female&quot;);
		    } else {
		        stmt.setString(4, &quot;male&quot;);
		    }
		    
		    // Execute the query
		    int rowsInsert = stmt.executeUpdate();
		    
		    // Log
		    log.info(&quot;Inserted patientID: &quot; + PatientID);

		    vars.put(&quot;patient_id&quot;, PatientID)
			//log.info(&quot;[ID_MAP] patient_id=&quot; + vars.get(&quot;patient_id&quot;))

		    
		    // Clear parameters for reusing the statement
		    stmt.clearParameters();

		}
// Close the connection
conn.close();
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Patient Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount} // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
    
    // Create a Date object
    Date PatientSet = new Date(timestampDefault)
    Date EncounterSet = new Date(timestampDefault)
    Date NameSet = new Date(timestampDefault)

    // Set Date
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault) // Set the default timestamp    
    calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}))

    // --- Generate random birthdate for age between 19 and 150 ---
    int minAge = 19
    int maxAge = 110
    int randomAge = minAge + (int)(Math.random() * (maxAge - minAge + 1))
    
    // Copy current timestamp for age validation
    Calendar nowCal = Calendar.getInstance()
    nowCal.setTimeInMillis(timestampDefault)
    
    // Subtract random age in years
    calendar.add(Calendar.YEAR, -randomAge)
    
    // Randomize month and day
    int randomMonth = (int)(Math.random() * 12)  // 0-11
    calendar.set(Calendar.MONTH, randomMonth)
    int maxDay = calendar.getActualMaximum(Calendar.DAY_OF_MONTH)
    int randomDay = 1 + (int)(Math.random() * maxDay)
    calendar.set(Calendar.DAY_OF_MONTH, randomDay)
    
    // Ensure age is at least 19 (if birthday is in the future, subtract one more year)
    if (calendar.after(nowCal)) {
        calendar.add(Calendar.YEAR, -1)
    }
    
    // Final birthdate object
    long BirthDatetimeStamp = calendar.getTimeInMillis()
    Date BirthSet = new Date(BirthDatetimeStamp)
    
    String threadGroupName = ctx.getThreadGroup().getName()
    String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1]

    // Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i + &quot;yyMMddHHmmss&quot; + ${User_Thread} + threadGroupNumber)
    sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string
    String PatientID = sdf_patient.format(PatientSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_name = new SimpleDateFormat(i+&quot;ddHHmmss&quot;+${User_Thread})
    sdf_name.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String Name = sdf_name.format(NameSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_birthdate = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;)
    sdf_birthdate.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String BirthDate = sdf_birthdate.format(BirthSet)

    // Store in variables
    vars.put(&quot;PatientID&quot; + i, PatientID)
    vars.put(&quot;Name&quot; + i, Name)
    vars.put(&quot;BirthDate&quot; + i, BirthDate)
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Encounter_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
