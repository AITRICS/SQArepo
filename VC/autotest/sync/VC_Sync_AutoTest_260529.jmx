        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Verify_5Patients">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*
import java.time.LocalDate
def U = props.get(&quot;CommonUtils&quot;)
def closeQ = U.closeQuietly; def setVcKey = U.setVcKey; def dumpPretty = U.dumpPretty

String orderKey   = &quot;930&quot;
String scenarioId = &quot;퇴원 스케줄 sync - 상태 유지 · pin 삭제&quot;

def vcUrl   = (vars.get(&quot;JDBC_URL_VC&quot;)  ?: &quot;&quot;).toString().trim()
def vcUser  = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw    = (vars.get(&quot;JDBC_PW_VC&quot;)   ?: &quot;&quot;).toString()
def emrUrl  = (vars.get(&quot;JDBC_URL&quot;)     ?: &quot;&quot;).toString()
def emrUser = (vars.get(&quot;JDBC_USER&quot;)    ?: &quot;&quot;).toString()
def emrPw   = (vars.get(&quot;JDBC_PW&quot;)      ?: &quot;&quot;).toString()
def pids    = (0..4).collect { (vars.get(&quot;PatientID${it}&quot;) ?: &quot;&quot;).toString().trim() }
def encEids = (0..4).collect { (vars.get(&quot;encEid${it}&quot;) ?: &quot;&quot;).toString().trim() }
def VC_TBL_ENC  = (vars.get(&quot;VC_TBL_EMR_ENCOUNTER&quot;) ?: &quot;vitalcare.emr_encounter&quot;).toString().trim()
def VC_TBL_AP   = (vars.get(&quot;VC_TBL_ACCOUNTS_PIN&quot;)  ?: &quot;vitalcare.accounts_pin&quot;).toString().trim()
def EMR_TBL_ENC = (vars.get(&quot;EMR_ENCOUNTER_TABLE&quot;)  ?: &quot;ROOT.ENCOUNTERS&quot;).toString().trim()

def allFails  = []
def emrDumpSb = new StringBuilder()
def vcDumpSb  = new StringBuilder()
vcDumpSb.append(vars.get(&quot;vcDump_before211&quot;) ?: &quot;&quot;)

def encDecExpr    = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),@secretkey,@iv) AS CHAR)&quot;
def encEidDecExpr = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id),@secretkey,@iv) AS CHAR)&quot;
def vcPidCond     = &quot;${encDecExpr}=?&quot;

def discStr = vars.get(&quot;discDate_211&quot;) ?: &quot;&quot;
String expectedPrefix = discStr.length() &gt;= 10
    ? LocalDate.parse(discStr.substring(0, 10)).minusDays(1).toString() + &quot; 15:00&quot;
    : &quot;&quot;

Connection eConn = null; Connection vConn = null
try {
    eConn = DriverManager.getConnection(emrUrl, emrUser, emrPw)
    PreparedStatement psEmr = null; ResultSet rsEmr = null
    try {
        def emrIn = pids.collect { &quot;?&quot; }.join(&quot;,&quot;)
        psEmr = eConn.prepareStatement(
            &quot;SELECT CREATED_DT, UPDATED_DT, PATIENT_ID, ENCOUNTER_ID, ADMISSION_DATE, DISCHARGE_DATE FROM ${EMR_TBL_ENC} WHERE PATIENT_ID IN (${emrIn}) ORDER BY PATIENT_ID&quot;)
        pids.eachWithIndex { pid, i -&gt; psEmr.setString(i + 1, pid) }
        rsEmr = psEmr.executeQuery()
        emrDumpSb.append(dumpPretty(EMR_TBL_ENC, rsEmr, 10) ?: &quot;(no rows)&quot;).append(&quot;\n&quot;)
    } finally { closeQ(rsEmr); closeQ(psEmr) }
    closeQ(eConn); eConn = null

    vConn = DriverManager.getConnection(vcUrl, vcUser, vcPw)
    setVcKey(vConn, &quot;TAG&quot;)
    def inClause   = pids.collect { &quot;?&quot; }.join(&quot;,&quot;)
    def apInClause = encEids.collect { &quot;?&quot; }.join(&quot;,&quot;)

    vcDumpSb.append(&quot;퇴원 처리 후\n&quot;)

    PreparedStatement psEnc = null; ResultSet rsEnc = null
    try {
        psEnc = vConn.prepareStatement(&quot;&quot;&quot;
            SELECT created_dt, updated_dt,
                   ${encDecExpr} AS patient_id,
                   CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id),@secretkey,@iv) AS CHAR) AS encounter_id,
                   status, admission_dt, discharge_dt
            FROM ${VC_TBL_ENC}
            WHERE ${encDecExpr} IN (${inClause})
            ORDER BY ${encDecExpr}&quot;&quot;&quot;)
        pids.eachWithIndex { pid, i -&gt; psEnc.setString(i + 1, pid) }
        rsEnc = psEnc.executeQuery()
        vcDumpSb.append(dumpPretty(VC_TBL_ENC, rsEnc, 10) ?: &quot;(no rows)&quot;).append(&quot;\n&quot;)
    } finally { closeQ(rsEnc); closeQ(psEnc) }

    PreparedStatement psAp = null; ResultSet rsAp = null
    try {
        psAp = vConn.prepareStatement(&quot;&quot;&quot;
            SELECT created_dt, updated_dt, username,
                   ${encEidDecExpr} AS encounter_id
            FROM ${VC_TBL_AP}
            WHERE encrypted_encounter_id IN (${apInClause})&quot;&quot;&quot;)
        encEids.eachWithIndex { eid, i -&gt; psAp.setString(i + 1, eid) }
        rsAp = psAp.executeQuery()
        vcDumpSb.append(dumpPretty(VC_TBL_AP, rsAp, 10) ?: &quot;(no rows)&quot;).append(&quot;\n&quot;)
    } finally { closeQ(rsAp); closeQ(psAp) }

    def failNotFound = []
    def failNullDt   = []
    def failMismatch = []
    def failStatus   = []
    def failPin      = []

    (0..4).each { i -&gt;
        def pid       = pids[i]
        def encEid    = encEids[i]
        def beforeSts = vars.get(&quot;before211_status${i}&quot;) ?: &quot;&quot;

        PreparedStatement psChk = null; ResultSet rsChk = null
        try {
            psChk = vConn.prepareStatement(
                &quot;SELECT discharge_dt, status FROM ${VC_TBL_ENC} WHERE ${vcPidCond} LIMIT 1&quot;)
            psChk.setString(1, pid)
            rsChk = psChk.executeQuery()
            if (!rsChk.next()) {
                failNotFound &lt;&lt; &quot;pid${i}&quot;
            } else {
                def discVal = rsChk.getObject(&quot;discharge_dt&quot;)
                if (discVal == null) {
                    failNullDt &lt;&lt; &quot;pid${i}&quot;
                } else {
                    String actualStr = discVal.toString().trim().replace(&quot;T&quot;, &quot; &quot;)
                    if (!actualStr.startsWith(expectedPrefix))
                        failMismatch &lt;&lt; &quot;pid${i}: discharge_dt 불일치 (expected=${expectedPrefix}, actual=${actualStr})&quot;
                }
                def afterSts = rsChk.getString(&quot;status&quot;)
                if (afterSts != beforeSts)
                    failStatus &lt;&lt; &quot;pid${i}: status 변경됨 (before=${beforeSts}, after=${afterSts})&quot;
            }
        } finally { closeQ(rsChk); closeQ(psChk) }

        PreparedStatement psCnt = null; ResultSet rsCnt = null
        try {
            psCnt = vConn.prepareStatement(
                &quot;SELECT COUNT(*) FROM ${VC_TBL_AP} WHERE encrypted_encounter_id=?&quot;)
            psCnt.setString(1, encEid)
            rsCnt = psCnt.executeQuery()
            if (rsCnt.next() &amp;&amp; rsCnt.getInt(1) &gt; 0)
                failPin &lt;&lt; &quot;pid${i}&quot;
        } finally { closeQ(rsCnt); closeQ(psCnt) }
    }

    if (!failNotFound.isEmpty())
        allFails &lt;&lt; (failNotFound.size() == 5 ? &quot;VC row not found (all cases)&quot; : &quot;VC row not found: ${failNotFound.join(&apos;, &apos;)}&quot;)
    if (!failNullDt.isEmpty())
        allFails &lt;&lt; (failNullDt.size() == 5 ? &quot;discharge_dt NULL (미처리) (all cases)&quot; : &quot;discharge_dt NULL (미처리): ${failNullDt.join(&apos;, &apos;)}&quot;)
    if (failMismatch.size() == 5)
        allFails &lt;&lt; &quot;discharge_dt 불일치 (expected=${expectedPrefix}) (all cases)&quot;
    else
        allFails.addAll(failMismatch)
    allFails.addAll(failStatus)
    if (!failPin.isEmpty())
        allFails &lt;&lt; (failPin.size() == 5 ? &quot;accounts_pin 미삭제 (all cases)&quot; : &quot;accounts_pin 미삭제: ${failPin.join(&apos;, &apos;)}&quot;)

} catch (Throwable t) {
    log.error(&quot;[Verify_211] Exception&quot;, t)
    allFails &lt;&lt; &quot;exception: &quot; + t.getClass().getSimpleName() + &quot; - &quot; + (t.getMessage() ?: &quot;&quot;)
} finally {
    closeQ(eConn); closeQ(vConn)
    String result = allFails.isEmpty() ? &quot;PASS&quot; : &quot;FAIL&quot;
    String notes  = allFails.isEmpty() ? &quot;&quot; : allFails.join(&quot; | &quot;)
    U.finish(prev, ctx, props, vars, orderKey, scenarioId, result, notes, emrDumpSb.toString(), vcDumpSb.toString())
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Scenario 19 (Alt_Icu)" enabled="true">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <OnceOnlyController guiclass="OnceOnlyControllerGui" testclass="OnceOnlyController" testname="Once Only Controller" enabled="true"/>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Setname Sampler" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">vars.put(&quot;currentControllerName&quot;, &quot;Scenario 10&quot;)

vars.put(&quot;scenario_id&quot;, &quot;Icu 전동 - 입실/퇴실&quot;)
vars.put(&quot;expect_mode&quot;, &quot;SYNC_OK&quot;)
vars.put(&quot;order_key&quot;, &quot;1000&quot;)
vars.put(&quot;verify_target&quot;, &quot;ALT_ICU&quot;)

vars.put(&quot;PatientCount&quot;, &quot;1&quot;)


String tgName = ctx.getThreadGroup().getName()
String tgNum = &quot;0&quot;
try { tgNum = tgName.split(&quot; &quot;)[1] } catch (ignored) { tgNum = &quot;0&quot; }
vars.put(&quot;tgNum&quot;, tgNum)

log.info(&quot;[INIT] parent=${vars.get(&apos;currentControllerName&apos;)}, scenario_id=${vars.get(&apos;scenario_id&apos;)}, label=${vars.get(&apos;scenario_label&apos;)}, expect_mode=${vars.get(&apos;expect_mode&apos;)}, order_key=${vars.get(&apos;order_key&apos;)}, verify_target=${vars.get(&apos;verify_target&apos;)}, PatientCount=${vars.get(&apos;PatientCount&apos;)}, tgNum=${vars.get(&apos;tgNum&apos;)}&quot;)

</stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Mark StartTime" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.text.SimpleDateFormat
import java.util.TimeZone
import java.util.Date

def tz = (vars.get(&quot;TimeZone&quot;) ?: &quot;Asia/Seoul&quot;).toString()
def sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss,SSS&quot;)
sdf.setTimeZone(TimeZone.getTimeZone(tz))

long startMs = System.currentTimeMillis()
vars.putObject(&quot;caseStartMillis&quot;, startMs)

def startTs = sdf.format(new Date(startMs))
vars.put(&quot;case_start_ts&quot;, startTs)

// CSV/HTML이 기존 키를 쓰면 호환용으로 같이 세팅
vars.put(&quot;verify_startTime&quot;, startTs)

log.info(&quot;[CASE_START] scenario_id=${vars.get(&apos;scenario_id&apos;)} start_ts=${startTs} TZ=${tz}&quot;)
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Setup_Type (demo_icu_b)" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import com.jcraft.jsch.*
import java.sql.DriverManager

def host        = vars.get(&quot;SSH_HOST&quot;)
def port        = Integer.parseInt(vars.get(&quot;SSH_PORT&quot;) ?: &quot;22&quot;)
def sshUser     = vars.get(&quot;SSH_USER&quot;)
def sshPw       = vars.get(&quot;SSH_PW&quot;)
def composeDir  = vars.get(&quot;SSH_COMPOSE_DIR&quot;)
def filePath    = &quot;${composeDir}/envs/vc-sync-v220.env&quot;

def execCmd = { Session sess, String cmd -&gt;
    ChannelExec ch = (ChannelExec) sess.openChannel(&quot;exec&quot;)
    ch.setCommand(cmd)
    def is = ch.getInputStream()
    ch.connect()
    def sb = new StringBuilder()
    def buf = new byte[1024]; int len
    while ((len = is.read(buf)) != -1) sb.append(new String(buf, 0, len))
    while (!ch.isClosed()) Thread.sleep(100)
    ch.disconnect()
    sb.toString().trim()
}

Session session = null
try {
    def jsch = new JSch()
    session = jsch.getSession(sshUser, host, port)
    session.setPassword(sshPw)
    session.setConfig(&quot;StrictHostKeyChecking&quot;, &quot;no&quot;)
    session.connect(10000)
    
    def activeIcuB = execCmd(session, &quot;grep &apos;^VCSYNC_EMR_HOSPITAL=demo_icu_b&apos; ${filePath}&quot;)
    if (!activeIcuB) {
    		execCmd(session, &quot;sed -i &apos;s/^VCSYNC_EMR_HOSPITAL=demo/#VCSYNC_EMR_HOSPITAL=demo/&apos; ${filePath}&quot;)
    		execCmd(session, &quot;sed -i &apos;s/^#VCSYNC_EMR_HOSPITAL=demo_icu_b/VCSYNC_EMR_HOSPITAL=demo_icu_b/&apos; ${filePath}&quot;)
        execCmd(session, &quot;cd ${composeDir} &amp;&amp; docker compose up -d sync&quot;)
        vars.put(&quot;envChanged&quot;, &quot;true&quot;)
        log.info(&quot;[Setup_ICU_Transfer] demo -&gt; demo_icu_b 전환 후 재시작&quot;)
    } else {
        vars.put(&quot;envChanged&quot;, &quot;false&quot;)
        log.info(&quot;[Setup_ICU_Transfer] 변경 불필요 (이미 demo_icu_b)&quot;)
    }

} catch (Throwable t) {
    log.error(&quot;[Setup_ICU_Transfer] SSH Exception&quot;, t)
    vars.put(&quot;envChanged&quot;, &quot;false&quot;)
    throw t
} finally {
    session?.disconnect()
}

// DELETE emr_location (VC MySQL)
def vcUrl  = (vars.get(&quot;JDBC_URL_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcUser = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw   = (vars.get(&quot;JDBC_PW_VC&quot;) ?: &quot;&quot;).toString()
java.sql.Connection vConn = null
try {
    vConn = DriverManager.getConnection(vcUrl, vcUser, vcPw)
    def del = vConn.prepareStatement(&quot;DELETE FROM vitalcare.emr_location WHERE site != &apos;demo_icu_b&apos;&quot;)
    int rows = del.executeUpdate()
    del.close()
    log.info(&quot;[Setup_ICU_Transfer] DELETE emr_location: ${rows} rows&quot;)
} catch (Throwable t) {
    log.warn(&quot;[Setup_ICU_Transfer] emr_location DELETE failed: &quot; + t.getMessage())
} finally {
    try { vConn?.close() } catch (ignored) {}
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Patient_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;

def pidLog = (vars.get(&quot;patient_id&quot;) ?: vars.get(&quot;PatientID&quot;) ?: vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString()
log.info(&quot;[PAT INSERT DBG] scenario_id=&quot; + (vars.get(&quot;scenario_id&quot;) ?: &quot;&quot;)
        + &quot; thread=&quot; + ctx.getThreadNum()
        + &quot; pid=&quot; + pidLog)


// Scenario(Thread) start time: set once
if (!vars.get(&quot;startTimeThread&quot;)) {
    vars.put(&quot;startTimeThread&quot;, String.valueOf(System.currentTimeMillis()))
}

	// JDBC connection information
	String url = &quot;${JDBC_URL}&quot;;
	String user = &quot;${JDBC_USER}&quot;;
	String password = &quot;${JDBC_PW}&quot;;

	// Define the query
	String query = &quot;INSERT INTO ROOT.PATIENTS (PATIENT_ID, NAME, BIRTHDATE, SEX) &quot; +
	                &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?)&quot;;

	// JDBC connection
	Connection conn = DriverManager.getConnection(url, user, password);

	// Prepare the statement
	PreparedStatement stmt = conn.prepareStatement(query);

	// Repeat the process for multiple sets of parameters
	int repeatCount = ${PatientCount}; // Number of repetitions set
		for (int i = 0; i &lt; repeatCount; i++) {
		    // Set String parameters for the query
		    String PatientID = vars.get(&quot;PatientID&quot; + i);
		    String Name = vars.get(&quot;Name&quot; + i);
		    String BirthDate = vars.get(&quot;BirthDate&quot; + i);
		    
		    // Set parameters for the query
		    stmt.setString(1, PatientID);
		    stmt.setString(2, &quot;QA&quot;+Name);
		    stmt.setString(3, BirthDate);
		    // Set gender based on whether i is odd or even
		    if (${User_Thread} % 2 == 0) {
		        stmt.setString(4, &quot;female&quot;);
		    } else {
		        stmt.setString(4, &quot;male&quot;);
		    }
		    
		    // Execute the query
		    int rowsInsert = stmt.executeUpdate();
		    
		    // Log
		    log.info(&quot;Inserted patientID: &quot; + PatientID);

		    vars.put(&quot;patient_id&quot;, PatientID)
			//log.info(&quot;[ID_MAP] patient_id=&quot; + vars.get(&quot;patient_id&quot;))

		    
		    // Clear parameters for reusing the statement
		    stmt.clearParameters();

		}
// Close the connection
conn.close();
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Patient Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount} // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
    
    // Create a Date object
    Date PatientSet = new Date(timestampDefault)
    Date EncounterSet = new Date(timestampDefault)
    Date NameSet = new Date(timestampDefault)

    // Set Date
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault) // Set the default timestamp    
    calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}))

    // --- Generate random birthdate for age between 19 and 150 ---
    int minAge = 19
    int maxAge = 110
    int randomAge = minAge + (int)(Math.random() * (maxAge - minAge + 1))
    
    // Copy current timestamp for age validation
    Calendar nowCal = Calendar.getInstance()
    nowCal.setTimeInMillis(timestampDefault)
    
    // Subtract random age in years
    calendar.add(Calendar.YEAR, -randomAge)
    
    // Randomize month and day
    int randomMonth = (int)(Math.random() * 12)  // 0-11
    calendar.set(Calendar.MONTH, randomMonth)
    int maxDay = calendar.getActualMaximum(Calendar.DAY_OF_MONTH)
    int randomDay = 1 + (int)(Math.random() * maxDay)
    calendar.set(Calendar.DAY_OF_MONTH, randomDay)
    
    // Ensure age is at least 19 (if birthday is in the future, subtract one more year)
    if (calendar.after(nowCal)) {
        calendar.add(Calendar.YEAR, -1)
    }
    
    // Final birthdate object
    long BirthDatetimeStamp = calendar.getTimeInMillis()
    Date BirthSet = new Date(BirthDatetimeStamp)
    
    String threadGroupName = ctx.getThreadGroup().getName()
    String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1]

    // Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i + &quot;yyMMddHHmmss&quot; + ${User_Thread} + threadGroupNumber)
    sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string
    String PatientID = sdf_patient.format(PatientSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_name = new SimpleDateFormat(i+&quot;ddHHmmss&quot;+${User_Thread})
    sdf_name.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String Name = sdf_name.format(NameSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_birthdate = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;)
    sdf_birthdate.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String BirthDate = sdf_birthdate.format(BirthSet)

    // Store in variables
    vars.put(&quot;PatientID&quot; + i, PatientID)
    vars.put(&quot;Name&quot; + i, Name)
    vars.put(&quot;BirthDate&quot; + i, BirthDate)
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Encounter_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;

	// JDBC connection information
	String url = &quot;${JDBC_URL}&quot;;
	String user = &quot;${JDBC_USER}&quot;;
	String password = &quot;${JDBC_PW}&quot;;

	// Define the query
	String query = &quot;INSERT INTO ROOT.ENCOUNTERS (ENCOUNTER_ID, PATIENT_ID, ADMISSION_DATE, DISCHARGE_DATE) &quot; +
	                &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;))&quot;;

    Connection conn = DriverManager.getConnection(url, user, password);
    PreparedStatement stmt = conn.prepareStatement(query);

	// Repeat the process for multiple sets of parameters
	int repeatCount = ${PatientCount}; // Number of repetitions set
		for (int i = 0; i &lt; repeatCount; i++) {
		    // Set parameters for the query
		    String EncounterID=vars.get(&quot;EncounterID&quot; + i);
		    String PatientID=vars.get(&quot;PatientID&quot; + i);
		    String AdmissionDate=vars.get(&quot;AdmissionDate&quot; + i);
		    String DisChargeDate=vars.get(&quot;DischargeDate&quot; + i);
		    stmt.setString(1, EncounterID);
		    stmt.setString(2, PatientID);
		    stmt.setString(3, AdmissionDate);
	         if (i == 9) {
		        stmt.setString(4, DisChargeDate);
		    } else {
		        stmt.setNull(4, java.sql.Types.DATE); // Set NULL value
		    }
		    
		    // Execute the query
		    int rowsInsert = stmt.executeUpdate();
		    
		    // Log the number of inserted rows
		    log.info(&quot;Inserted EncounterID: &quot; + EncounterID);

		    vars.put(&quot;encounter_id&quot;, EncounterID)  
			//log.info(&quot;[ID_MAP] encounter_id=&quot; + vars.get(&quot;encounter_id&quot;))

		    
		    // Clear parameters for reusing the statement
		    stmt.clearParameters();
		}
// Close the connection
conn.close();

 
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Encounter Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount} // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
    
    // Create a Date object
    Date PatientSet = new Date(timestampDefault)
    Date EncounterSet = new Date(timestampDefault)

    // Set Date
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault) // Set the default timestamp    
    calendar.add(Calendar.HOUR, -1)

    long DischargeDateTimestamp = calendar.getTimeInMillis()
    Date DischargeSet = new Date(DischargeDateTimestamp)

    calendar.setTimeInMillis(timestampDefault) // Reset timestamp    
    calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}))
    calendar.add(Calendar.MONTH, -(i+1))
    long AdmissionDatetimeStamp = calendar.getTimeInMillis()
    Date AdmissionSet = new Date(AdmissionDatetimeStamp)
    
    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_patient = new SimpleDateFormat(i+&quot;yyMMddHHmmss&quot;+${User_Thread})
    sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    
    // Format the date to string
    String PatientID = vars.get(&quot;PatientID&quot; + i)

    String threadGroupName = ctx.getThreadGroup().getName()
    String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1]

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_encounter = new SimpleDateFormat(i + &quot;yyyyMMddHHmmss&quot; + ${User_Thread} + threadGroupNumber)
    sdf_encounter.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String EncounterID = sdf_encounter.format(EncounterSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_admission = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    sdf_admission.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String AdmissionDate = sdf_admission.format(AdmissionSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_discharge = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    sdf_discharge.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String DischargeDate = sdf_discharge.format(DischargeSet)
    
    // Store in variables
    vars.put(&quot;EncounterID&quot; + i, EncounterID + &quot;|&quot; + PatientID)
    vars.put(&quot;AdmissionDate&quot; + i, AdmissionDate)
    vars.put(&quot;DischargeDate&quot; + i, DischargeDate)
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Location_Info_JSR223 Sampler">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection
import java.sql.DriverManager
import java.sql.PreparedStatement
import java.sql.Types

String url      = &quot;${JDBC_URL}&quot;
String user     = &quot;${JDBC_USER}&quot;
String password = &quot;${JDBC_PW}&quot;

String query =
    &quot;INSERT INTO ROOT.LOCATIONS (PATIENT_ID, ENCOUNTER_ID, START_DT, END_DT, WARD, ROOM, BED, &quot; +
    &quot;practitioner_id, practitioner_name, department_code, department_name) &quot; +
    &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?, ?, ?, ?, ?, ?, ?)&quot;

Connection conn = null
PreparedStatement stmt = null

try {
    conn = DriverManager.getConnection(url, user, password)
    stmt = conn.prepareStatement(query)

    int repeatCount = ${PatientCount}

    for (int i = 0; i &lt; repeatCount; i++) {
        String PatientID    = vars.get(&quot;PatientID&quot; + i)
        String EncounterID  = vars.get(&quot;EncounterID&quot; + i)
        String LocationStart = vars.get(&quot;gw_start_dt&quot;)
        String LocationEnd   = vars.get(&quot;icu_in_dt&quot;)

        stmt.setString(1, PatientID)
        stmt.setString(2, EncounterID)
        stmt.setString(3, LocationStart)
        stmt.setNull(4, Types.VARCHAR)
        stmt.setString(5, &quot;QA_GW&quot;)
        stmt.setString(6, ${User_Thread} + &quot;QA_ROOM&quot; + i)
        stmt.setString(7, ${User_Thread} + &quot;QA_BED&quot; + i)
        stmt.setString(8, ${User_Thread} + &quot;QAP&quot; + i)
        stmt.setString(9, ${User_Thread} + &quot;테스트&quot; + i)
        stmt.setString(10, ${User_Thread} + &quot;QAD&quot; + i)
        stmt.setString(11, ${User_Thread} + &quot;Quality Assurance&quot; + i)

        int rowsInsert = stmt.executeUpdate()
        log.info(&quot;[LOC] affectedRows=&quot; + rowsInsert)

        stmt.clearParameters()
    }

} catch (Exception e) {
    log.error(&quot;[LOC] insert failed&quot;, e)
    throw e
} finally {
    try { if (stmt != null) stmt.close() } catch (ignored) {}
    try { if (conn != null) conn.close() } catch (ignored) {}
}
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Location Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.TimeZone
import java.util.Calendar

def sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
sdf.setTimeZone(TimeZone.getTimeZone((vars.get(&quot;TimeZone&quot;) ?: &quot;Asia/Seoul&quot;).toString()))

Calendar cal = Calendar.getInstance()
cal.setTimeInMillis(${timestamp_default})
cal.add(Calendar.MINUTE, -(${ObservationCount} * ${Ob_Interval_Min}))
cal.add(Calendar.MONTH, -1)

vars.put(&quot;gw_start_dt&quot;, sdf.format(cal.getTime()))
cal.add(Calendar.DAY_OF_MONTH, 1)
vars.put(&quot;icu_in_dt&quot;, sdf.format(cal.getTime()))
cal.add(Calendar.DAY_OF_MONTH, 1)
vars.put(&quot;icu_out_dt&quot;, sdf.format(cal.getTime()))

log.info(&quot;[ALT_ICU] gw_start=${vars.get(&apos;gw_start_dt&apos;)}, icu_in=${vars.get(&apos;icu_in_dt&apos;)}, icu_out=${vars.get(&apos;icu_out_dt&apos;)}&quot;)
</stringProp>
          </JSR223PreProcessor>
