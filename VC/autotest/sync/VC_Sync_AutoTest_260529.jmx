      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Scenario 20 (Alt_Icu_InOut)">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
