        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Verify_manual_DNR_MultiEid" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*

def U = props.get(&quot;CommonUtils&quot;)
if (!(U instanceof Map)) throw new RuntimeException(&quot;[S15] CommonUtils not found in props.&quot;)
def closeQ     = U.closeQuietly
def setVcKey   = U.setVcKey
def dumpPretty = U.dumpPretty

def scenarioId = (vars.get(&quot;scenario_id&quot;) ?: &quot;15&quot;).toString().trim()
def orderKey   = (vars.get(&quot;order_key&quot;)   ?: &quot;830&quot;).toString().trim()
def emrUrl  = (vars.get(&quot;JDBC_URL&quot;)     ?: &quot;&quot;).toString().trim()
def emrUser = (vars.get(&quot;JDBC_USER&quot;)    ?: &quot;&quot;).toString().trim()
def emrPw   = (vars.get(&quot;JDBC_PW&quot;)      ?: &quot;&quot;).toString()
def vcUrl   = (vars.get(&quot;JDBC_URL_VC&quot;)  ?: &quot;&quot;).toString().trim()
def vcUser  = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw    = (vars.get(&quot;JDBC_PW_VC&quot;)  ?: &quot;&quot;).toString()
def pid0 = (vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString().trim()
def pid1 = (vars.get(&quot;PatientID1&quot;) ?: &quot;&quot;).toString().trim()
def EMR_TBL_PAT = (vars.get(&quot;EMR_PATIENT_TABLE&quot;)  ?: &quot;ROOT.PATIENTS&quot;).toString().trim()
def VC_TBL_PAT  = (vars.get(&quot;VC_TBL_EMR_PATIENT&quot;) ?: &quot;vitalcare.emr_patient&quot;).toString().trim()

def vcPidCond = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id),@secretkey,@iv) AS CHAR)=?&quot;

def allFails = []
String emrDumpStr = &quot;&quot;
String vcDumpStr  = &quot;&quot;

Connection eConn = null
Connection vConn = null
try {
    // EMR dump
eConn = DriverManager.getConnection(emrUrl, emrUser, emrPw)

PreparedStatement psEd = null; ResultSet rsEd = null
PreparedStatement psEe = null; ResultSet rsEe = null
try {
    psEd = eConn.prepareStatement(&quot;&quot;&quot;
        SELECT CREATED_DT, UPDATED_DT, PATIENT_ID, DNR
        FROM ${EMR_TBL_PAT}
        WHERE PATIENT_ID IN (?, ?)
        ORDER BY PATIENT_ID
    &quot;&quot;&quot;)
    psEd.setString(1, pid0); psEd.setString(2, pid1)
    rsEd = psEd.executeQuery()
    def dPat = dumpPretty(&quot;${EMR_TBL_PAT}&quot;, rsEd, 10)

    def EMR_TBL_ENC = (vars.get(&quot;EMR_ENCOUNTER_TABLE&quot;) ?: &quot;ROOT.ENCOUNTERS&quot;).toString().trim()
    psEe = eConn.prepareStatement(&quot;&quot;&quot;
        SELECT CREATED_DT, UPDATED_DT, PATIENT_ID, ENCOUNTER_ID, ADMISSION_DATE
        FROM ${EMR_TBL_ENC}
        WHERE PATIENT_ID IN (?, ?)
        ORDER BY PATIENT_ID, ADMISSION_DATE
    &quot;&quot;&quot;)
    psEe.setString(1, pid0); psEe.setString(2, pid1)
    rsEe = psEe.executeQuery()
    def dEnc = dumpPretty(&quot;${EMR_TBL_ENC}&quot;, rsEe, 10)

    emrDumpStr = (dPat?.trim() ?: &quot;${EMR_TBL_PAT}\n(0 rows)&quot;) + &quot;\n\n&quot; +
                 (dEnc?.trim() ?: &quot;${EMR_TBL_ENC}\n(0 rows)&quot;)
} finally {
    closeQ(rsEd); closeQ(psEd)
    closeQ(rsEe); closeQ(psEe)
}

    // VC
    vConn = DriverManager.getConnection(vcUrl, vcUser, vcPw)
    setVcKey(vConn, &quot;S15_VERIFY&quot;)

    // VC after dump (두 환자 한 번에)
    PreparedStatement psVd = null; ResultSet rsVd = null
    try {
        psVd = vConn.prepareStatement(&quot;&quot;&quot;
            SELECT created_dt, updated_dt,
                   CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id), @secretkey,@iv) AS CHAR) AS patient_id,
                   emr_dnr, manual_dnr
            FROM ${VC_TBL_PAT}
            WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id), @secretkey,@iv) AS CHAR) IN (?, ?)
            ORDER BY patient_id
        &quot;&quot;&quot;)
        psVd.setString(1, pid0); psVd.setString(2, pid1)
        rsVd = psVd.executeQuery()
        def d = dumpPretty(&quot;${VC_TBL_PAT} (after)&quot;, rsVd, 10)
        def afterDump  = d?.trim() ?: &quot;${VC_TBL_PAT} (after)\n(0 rows)&quot;
        def beforeDump = vars.get(&quot;manual_dnr_before_dump&quot;) ?: &quot;(no before dump)&quot;
        vcDumpStr = beforeDump + &quot;\n\n&quot; + afterDump
    } finally { closeQ(rsVd); closeQ(psVd) }

    // 검증
    def cases = [
    [pid: pid0, label: &quot;PID1&quot;],
    [pid: pid1, label: &quot;PID2&quot;]
    ]
    cases.each { c -&gt;
        def caseFails = []
        PreparedStatement psVf = null; ResultSet rsVf = null
        try {
            psVf = vConn.prepareStatement(
                &quot;SELECT manual_dnr FROM ${VC_TBL_PAT} WHERE ${vcPidCond} LIMIT 1&quot;
            )
            psVf.setString(1, c.pid); rsVf = psVf.executeQuery()
            if (!rsVf.next()) {
                caseFails &lt;&lt; &quot;VC row not found&quot;
            } else {
                def manualDnr = rsVf.getObject(&quot;manual_dnr&quot;)
                if (manualDnr != null) caseFails &lt;&lt; &quot;manual_dnr not reset (got=${manualDnr})&quot;
            }
        } finally { closeQ(rsVf); closeQ(psVf) }
        if (caseFails) allFails &lt;&lt; &quot;${c.label}: &quot; + caseFails.join(&quot;, &quot;)
    }
} finally {
    closeQ(eConn); closeQ(vConn)
}

def result = allFails ? &quot;FAIL&quot; : &quot;PASS&quot;
def notes  = allFails ? allFails.join(&quot; | &quot;) : &quot;&quot;
U.finish(prev, ctx, props, vars, orderKey, scenarioId, result, notes, emrDumpStr, vcDumpStr)
</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Scenario 16" enabled="true">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <OnceOnlyController guiclass="OnceOnlyControllerGui" testclass="OnceOnlyController" testname="Once Only Controller" enabled="true"/>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Setname Sampler" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">vars.put(&quot;currentControllerName&quot;, &quot;Scenario 8&quot;)

vars.put(&quot;scenario_id&quot;, &quot;수동 DNR - 퇴원 EID 추가&quot;)
vars.put(&quot;expect_mode&quot;, &quot;SYNC_OK&quot;)
vars.put(&quot;order_key&quot;, &quot;840&quot;)
vars.put(&quot;verify_target&quot;, &quot;DNR_MANUAL_DISCH&quot;)
vars.put(&quot;dnr_env&quot;, &quot;ON&quot;)

vars.put(&quot;PatientCount&quot;, &quot;1&quot;)


String tgName = ctx.getThreadGroup().getName()
String tgNum = &quot;0&quot;
try { tgNum = tgName.split(&quot; &quot;)[1] } catch (ignored) { tgNum = &quot;0&quot; }
vars.put(&quot;tgNum&quot;, tgNum)

log.info(&quot;[INIT] parent=${vars.get(&apos;currentControllerName&apos;)}, scenario_id=${vars.get(&apos;scenario_id&apos;)}, label=${vars.get(&apos;scenario_label&apos;)}, expect_mode=${vars.get(&apos;expect_mode&apos;)}, order_key=${vars.get(&apos;order_key&apos;)}, verify_target=${vars.get(&apos;verify_target&apos;)}, PatientCount=${vars.get(&apos;PatientCount&apos;)}, tgNum=${vars.get(&apos;tgNum&apos;)}&quot;)
</stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Setup_DNR_Env" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import com.jcraft.jsch.*

def host        = vars.get(&quot;SSH_HOST&quot;)
def port        = Integer.parseInt(vars.get(&quot;SSH_PORT&quot;) ?: &quot;22&quot;)
def sshUser     = vars.get(&quot;SSH_USER&quot;)
def sshPw       = vars.get(&quot;SSH_PW&quot;)
def composeDir  = vars.get(&quot;SSH_COMPOSE_DIR&quot;)
def filePath    = &quot;${composeDir}/envs/vc-sync-v220.env&quot;
def targetValue = (vars.get(&quot;dnr_env&quot;) == &quot;ON&quot;) ? &quot;true&quot; : &quot;false&quot;

def execCmd = { Session sess, String cmd -&gt;
    ChannelExec ch = (ChannelExec) sess.openChannel(&quot;exec&quot;)
    ch.setCommand(cmd)
    def is = ch.getInputStream()
    ch.connect()
    def sb = new StringBuilder()
    def buf = new byte[1024]; int len
    while ((len = is.read(buf)) != -1) sb.append(new String(buf, 0, len))
    while (!ch.isClosed()) Thread.sleep(100)
    ch.disconnect()
    sb.toString().trim()
}

Session session = null
try {
    def jsch = new JSch()
    session = jsch.getSession(sshUser, host, port)
    session.setPassword(sshPw)
    session.setConfig(&quot;StrictHostKeyChecking&quot;, &quot;no&quot;)
    session.connect(10000)

    def current      = execCmd(session, &quot;grep &apos;VCSYNC_SYNC_DNR&apos; ${filePath}&quot;)
    def currentValue = current.split(&quot;=&quot;)[1]?.trim()
    log.info(&quot;[Setup_DNR_Env] current=${currentValue}, target=${targetValue}&quot;)

    if (currentValue != targetValue) {
        execCmd(session, &quot;sed -i &apos;s/VCSYNC_SYNC_DNR=${currentValue}/VCSYNC_SYNC_DNR=${targetValue}/&apos; ${filePath}&quot;)
        execCmd(session, &quot;cd ${composeDir} &amp;&amp; docker compose up -d sync&quot;)
        vars.put(&quot;envChanged&quot;, &quot;true&quot;)
        log.info(&quot;[Setup_DNR_Env] ${currentValue} → ${targetValue} 변경 후 재시작&quot;)
    } else {
        vars.put(&quot;envChanged&quot;, &quot;false&quot;)
        log.info(&quot;[Setup_DNR_Env] 변경 불필요 (이미 ${targetValue})&quot;)
    }

} catch (Throwable t) {
    log.error(&quot;[Setup_DNR_Env] Exception&quot;, t)
    vars.put(&quot;envChanged&quot;, &quot;false&quot;)
    throw t
} finally {
    session?.disconnect()
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <IfController guiclass="IfControllerPanel" testclass="IfController" testname="If Controller" enabled="true">
          <stringProp name="IfController.condition">${envChanged}</stringProp>
          <boolProp name="IfController.evaluateAll">false</boolProp>
          <boolProp name="IfController.useExpression">true</boolProp>
        </IfController>
