        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Setup_Alt_Icu_InOut">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*
import java.text.SimpleDateFormat
import java.util.TimeZone
import java.util.Calendar

def U      = props.get(&quot;CommonUtils&quot;)
def closeQ = U.closeQuietly

String pidVal = vars.get(&quot;PatientID0&quot;)
String eidVal = vars.get(&quot;EncounterID0&quot;)

def sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
sdf.setTimeZone(TimeZone.getTimeZone(&quot;Asia/Seoul&quot;))

def cal = Calendar.getInstance()
cal.setTimeZone(TimeZone.getTimeZone(&quot;Asia/Seoul&quot;))

String icuOut = sdf.format(cal.getTime())
vars.put(&quot;icu_out_dt&quot;, icuOut)

cal.add(Calendar.DAY_OF_MONTH, -1)
String icuIn = sdf.format(cal.getTime())
vars.put(&quot;icu_in_dt&quot;, icuIn)

log.info(&quot;[ALT_ICU InOut] icu_in=${icuIn}, icu_out=${icuOut}&quot;)

Connection emrConn = null
PreparedStatement ps = null
ResultSet rs = null
try {
    emrConn = DriverManager.getConnection(&quot;${JDBC_URL}&quot;, &quot;${JDBC_USER}&quot;, &quot;${JDBC_PW}&quot;)

    // 0. 기존 QA_GW row에서 room/bed/practitioner/dept 읽기
    String room = null, bed = null, practId = null, practName = null, deptCode = null, deptName = null
    ps = emrConn.prepareStatement(
        &quot;SELECT ROOM, BED, PRACTITIONER_ID, PRACTITIONER_NAME, DEPARTMENT_CODE, DEPARTMENT_NAME &quot; +
        &quot;FROM ROOT.LOCATIONS WHERE PATIENT_ID=? AND ENCOUNTER_ID=? AND WARD=&apos;QA_GW&apos; AND END_DT IS NULL&quot;)
    ps.setString(1, pidVal); ps.setString(2, eidVal)
    rs = ps.executeQuery()
    if (rs.next()) {
        room = rs.getString(&quot;ROOM&quot;); bed = rs.getString(&quot;BED&quot;)
        practId = rs.getString(&quot;PRACTITIONER_ID&quot;); practName = rs.getString(&quot;PRACTITIONER_NAME&quot;)
        deptCode = rs.getString(&quot;DEPARTMENT_CODE&quot;); deptName = rs.getString(&quot;DEPARTMENT_NAME&quot;)
    }
    closeQ(rs); closeQ(ps)

    // 1. QA_GW END_DT = icu_in_dt 로 UPDATE
    ps = emrConn.prepareStatement(
        &quot;UPDATE ROOT.LOCATIONS SET END_DT=TO_DATE(?,&apos;YYYY-MM-DD HH24:MI:SS&apos;) &quot; +
        &quot;WHERE PATIENT_ID=? AND ENCOUNTER_ID=? AND WARD=&apos;QA_GW&apos; AND END_DT IS NULL&quot;)
    ps.setString(1, icuIn); ps.setString(2, pidVal); ps.setString(3, eidVal)
    int upd = ps.executeUpdate()
    closeQ(ps)
    log.info(&quot;[ALT_ICU InOut] UPDATE GW END_DT rows=${upd}, END_DT=${icuIn}&quot;)

    // 2. QA_ICU row INSERT (START=icu_in, END=icu_out)
    ps = emrConn.prepareStatement(
        &quot;INSERT INTO ROOT.LOCATIONS &quot; +
        &quot;(PATIENT_ID,ENCOUNTER_ID,START_DT,END_DT,WARD,ROOM,BED,PRACTITIONER_ID,PRACTITIONER_NAME,DEPARTMENT_CODE,DEPARTMENT_NAME) &quot; +
        &quot;VALUES (?,?,TO_DATE(?,&apos;YYYY-MM-DD HH24:MI:SS&apos;),TO_DATE(?,&apos;YYYY-MM-DD HH24:MI:SS&apos;),?,?,?,?,?,?,?)&quot;)
    ps.setString(1, pidVal);    ps.setString(2, eidVal)
    ps.setString(3, icuIn);     ps.setString(4, icuOut)
    ps.setString(5, &quot;QA_ICU&quot;);  ps.setString(6, room)
    ps.setString(7, bed);       ps.setString(8, practId)
    ps.setString(9, practName); ps.setString(10, deptCode)
    ps.setString(11, deptName)
    int insIcu = ps.executeUpdate()
    closeQ(ps)
    log.info(&quot;[ALT_ICU InOut] INSERT ICU rows=${insIcu}, START=${icuIn}, END=${icuOut}&quot;)

    Thread.sleep(1000)

    // 3. 복귀 QA_GW row INSERT (START=icu_out, END=NULL)
    ps = emrConn.prepareStatement(
        &quot;INSERT INTO ROOT.LOCATIONS &quot; +
        &quot;(PATIENT_ID,ENCOUNTER_ID,START_DT,END_DT,WARD,ROOM,BED,PRACTITIONER_ID,PRACTITIONER_NAME,DEPARTMENT_CODE,DEPARTMENT_NAME) &quot; +
        &quot;VALUES (?,?,TO_DATE(?,&apos;YYYY-MM-DD HH24:MI:SS&apos;),NULL,?,?,?,?,?,?,?)&quot;)
    ps.setString(1, pidVal);    ps.setString(2, eidVal)
    ps.setString(3, icuOut);    ps.setString(4, &quot;QA_GW&quot;)
    ps.setString(5, room);      ps.setString(6, bed)
    ps.setString(7, practId);   ps.setString(8, practName)
    ps.setString(9, deptCode);  ps.setString(10, deptName)
    int insGw = ps.executeUpdate()
    closeQ(ps)
    log.info(&quot;[ALT_ICU InOut] INSERT return GW rows=${insGw}, START=${icuOut}&quot;)

} finally {
    closeQ(rs); closeQ(ps); closeQ(emrConn)
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Wait_for_Sync">
          <intProp name="ActionProcessor.action">1</intProp>
          <intProp name="ActionProcessor.target">0</intProp>
          <stringProp name="ActionProcessor.duration">180000</stringProp>
        </TestAction>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Verify_Alt_Icu_InOut">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*
import java.text.SimpleDateFormat
import java.util.TimeZone

def U          = props.get(&quot;CommonUtils&quot;)
def closeQ     = U.closeQuietly
def setVcKey   = U.setVcKey
def dumpPretty = U.dumpPretty
def finishFn   = U.finish

String orderKey   = &quot;1200&quot;
String scenarioId = &quot;Icu 전동 - 입/퇴실&quot;

def pid = (vars.get(&quot;patient_id&quot;) ?: vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString().trim()
def eid = (vars.get(&quot;encounter_id&quot;) ?: vars.get(&quot;EncounterID0&quot;) ?: &quot;&quot;).toString().trim()

def VC_TBL_ICU = (vars.get(&quot;VC_TBL_VC_ICU&quot;)   ?: &quot;vitalcare.vc_icu&quot;).toString().trim()
def VC_TBL_EVT = (vars.get(&quot;VC_TBL_VC_EVENT&quot;) ?: &quot;vitalcare.vc_event&quot;).toString().trim()

def vcPidExpr = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),@secretkey,@iv) AS CHAR)&quot;
def vcEidExpr = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id),@secretkey,@iv) AS CHAR)&quot;
def vcCond    = &quot;${vcPidExpr}=? AND ${vcEidExpr}=?&quot;

def sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
sdf.setTimeZone(TimeZone.getTimeZone(&quot;Asia/Seoul&quot;))
Timestamp icuInDt  = vars.get(&quot;icu_in_dt&quot;)  ? new Timestamp(sdf.parse(vars.get(&quot;icu_in_dt&quot;)).getTime())  : null
Timestamp icuOutDt = vars.get(&quot;icu_out_dt&quot;) ? new Timestamp(sdf.parse(vars.get(&quot;icu_out_dt&quot;)).getTime()) : null

final long OFFSET_MS = 9L * 60L * 60L * 1000L
def plus9h     = { Timestamp ts -&gt; (ts == null) ? null : new Timestamp(ts.getTime() + OFFSET_MS) }
def truncToMin = { Timestamp ts -&gt; (ts == null) ? null : new Timestamp(ts.getTime().intdiv(60000L) * 60000L) }

def fails      = []
String result  = &quot;FAIL&quot;
String notes   = &quot;&quot;
String emrDump = &quot;&quot;
String vcDump  = &quot;&quot;

Connection eConn = null
Connection vConn = null
PreparedStatement ps = null
ResultSet rs = null

try {
    eConn = DriverManager.getConnection(&quot;${JDBC_URL}&quot;, &quot;${JDBC_USER}&quot;, &quot;${JDBC_PW}&quot;)

    ps = eConn.prepareStatement(
        &quot;SELECT * FROM DEMO_TYPE_B_2.AITRICS_ICU_VIEW WHERE PATIENT_ID=? AND ENCOUNTER_ID=? ORDER BY CREATED_DT DESC&quot;)
    ps.setString(1, pid); ps.setString(2, eid)
    rs = ps.executeQuery()
    def viewDump = dumpPretty(&quot;DEMO_TYPE_B_2.AITRICS_ICU_VIEW&quot;, rs, 10)
    closeQ(rs); closeQ(ps)

    ps = eConn.prepareStatement(
        &quot;SELECT CREATED_DT, UPDATED_DT, PATIENT_ID, ENCOUNTER_ID, START_DT, END_DT, WARD, ID &quot; +
        &quot;FROM ROOT.LOCATIONS WHERE PATIENT_ID=? AND ENCOUNTER_ID=? ORDER BY CREATED_DT DESC&quot;)
    ps.setString(1, pid); ps.setString(2, eid)
    rs = ps.executeQuery()
    def locDump = dumpPretty(&quot;ROOT.LOCATIONS&quot;, rs, 10)
    closeQ(rs); closeQ(ps)

    emrDump = &quot;${locDump}\n${viewDump}&quot;

    vConn = DriverManager.getConnection(
        vars.get(&quot;JDBC_URL_VC&quot;), vars.get(&quot;JDBC_USER_VC&quot;), vars.get(&quot;JDBC_PW_VC&quot;))
    setVcKey(vConn, &quot;ICU&quot;)

    ps = vConn.prepareStatement(
        &quot;SELECT COUNT(*) FROM ${VC_TBL_ICU} WHERE ${vcCond} AND deleted=0 AND UPPER(status)=&apos;IN&apos;&quot; as String)
    ps.setString(1, pid); ps.setString(2, eid); rs = ps.executeQuery(); rs.next()
    int icuInCnt = rs.getInt(1); closeQ(rs); closeQ(ps)

    ps = vConn.prepareStatement(
        &quot;SELECT COUNT(*) FROM ${VC_TBL_ICU} WHERE ${vcCond} AND deleted=0 AND UPPER(status)=&apos;OUT&apos;&quot; as String)
    ps.setString(1, pid); ps.setString(2, eid); rs = ps.executeQuery(); rs.next()
    int icuOutCnt = rs.getInt(1); closeQ(rs); closeQ(ps)

    ps = vConn.prepareStatement(
        &quot;SELECT COUNT(*) FROM ${VC_TBL_EVT} WHERE ${vcCond} AND category=&apos;ICU&apos; AND UPPER(subcategory)=&apos;IN&apos; AND deleted=0&quot; as String)
    ps.setString(1, pid); ps.setString(2, eid); rs = ps.executeQuery(); rs.next()
    int evtInCnt = rs.getInt(1); closeQ(rs); closeQ(ps)

    ps = vConn.prepareStatement(
        &quot;SELECT COUNT(*) FROM ${VC_TBL_EVT} WHERE ${vcCond} AND category=&apos;ICU&apos; AND UPPER(subcategory)=&apos;OUT&apos; AND deleted=0&quot; as String)
    ps.setString(1, pid); ps.setString(2, eid); rs = ps.executeQuery(); rs.next()
    int evtOutCnt = rs.getInt(1); closeQ(rs); closeQ(ps)

    Timestamp vcIcuInObs = null
    ps = vConn.prepareStatement(
        &quot;SELECT observed_dt FROM ${VC_TBL_ICU} WHERE ${vcCond} AND deleted=0 AND UPPER(status)=&apos;IN&apos; ORDER BY observed_dt DESC LIMIT 1&quot; as String)
    ps.setString(1, pid); ps.setString(2, eid); rs = ps.executeQuery()
    if (rs.next()) vcIcuInObs = rs.getTimestamp(1); closeQ(rs); closeQ(ps)

    Timestamp vcIcuOutObs = null
    ps = vConn.prepareStatement(
        &quot;SELECT observed_dt FROM ${VC_TBL_ICU} WHERE ${vcCond} AND deleted=0 AND UPPER(status)=&apos;OUT&apos; ORDER BY observed_dt DESC LIMIT 1&quot; as String)
    ps.setString(1, pid); ps.setString(2, eid); rs = ps.executeQuery()
    if (rs.next()) vcIcuOutObs = rs.getTimestamp(1); closeQ(rs); closeQ(ps)

    Timestamp vcEvtInObs = null
    ps = vConn.prepareStatement(
        &quot;SELECT observed_dt FROM ${VC_TBL_EVT} WHERE ${vcCond} AND category=&apos;ICU&apos; AND UPPER(subcategory)=&apos;IN&apos; AND deleted=0 ORDER BY observed_dt DESC LIMIT 1&quot; as String)
    ps.setString(1, pid); ps.setString(2, eid); rs = ps.executeQuery()
    if (rs.next()) vcEvtInObs = rs.getTimestamp(1); closeQ(rs); closeQ(ps)

    Timestamp vcEvtOutObs = null
    ps = vConn.prepareStatement(
        &quot;SELECT observed_dt FROM ${VC_TBL_EVT} WHERE ${vcCond} AND category=&apos;ICU&apos; AND UPPER(subcategory)=&apos;OUT&apos; AND deleted=0 ORDER BY observed_dt DESC LIMIT 1&quot; as String)
    ps.setString(1, pid); ps.setString(2, eid); rs = ps.executeQuery()
    if (rs.next()) vcEvtOutObs = rs.getTimestamp(1); closeQ(rs); closeQ(ps)

    log.info(&quot;[ALT_ICU] Verify_InOut: icuIn=${icuInCnt}, icuOut=${icuOutCnt}, evtIn=${evtInCnt}, evtOut=${evtOutCnt}&quot;)
    if (icuInCnt  != 1) fails &lt;&lt; &quot;VC vc_icu(IN) count=${icuInCnt} (expected 1)&quot;
    if (icuOutCnt != 1) fails &lt;&lt; &quot;VC vc_icu(OUT) count=${icuOutCnt} (expected 1)&quot;
    if (evtInCnt  != 1) fails &lt;&lt; &quot;VC vc_event(ICU,IN) count=${evtInCnt} (expected 1)&quot;
    if (evtOutCnt != 1) fails &lt;&lt; &quot;VC vc_event(ICU,OUT) count=${evtOutCnt} (expected 1)&quot;

    if (icuInDt != null &amp;&amp; vcIcuInObs != null) {
        def v = plus9h(vcIcuInObs)
        if (truncToMin(v).getTime() != truncToMin(icuInDt).getTime())
            fails &lt;&lt; &quot;vc_icu(IN) observed_dt mismatch: expected=${icuInDt} VC+9h=${v}&quot;
    }
    if (icuInDt != null &amp;&amp; vcEvtInObs != null) {
        def v = plus9h(vcEvtInObs)
        if (truncToMin(v).getTime() != truncToMin(icuInDt).getTime())
            fails &lt;&lt; &quot;vc_event(ICU,IN) observed_dt mismatch: expected=${icuInDt} VC+9h=${v}&quot;
    }
    if (icuOutDt != null &amp;&amp; vcIcuOutObs != null) {
        def v = plus9h(vcIcuOutObs)
        if (truncToMin(v).getTime() != truncToMin(icuOutDt).getTime())
            fails &lt;&lt; &quot;vc_icu(OUT) observed_dt mismatch: expected=${icuOutDt} VC+9h=${v}&quot;
    }
    if (icuOutDt != null &amp;&amp; vcEvtOutObs != null) {
        def v = plus9h(vcEvtOutObs)
        if (truncToMin(v).getTime() != truncToMin(icuOutDt).getTime())
            fails &lt;&lt; &quot;vc_event(ICU,OUT) observed_dt mismatch: expected=${icuOutDt} VC+9h=${v}&quot;
    }

    ps = vConn.prepareStatement(&quot;&quot;&quot;
        SELECT version, created_dt, updated_dt,
               ${vcPidExpr} AS patient_id,
               ${vcEidExpr} AS encounter_id,
               observed_dt, status, emr_created_dt
        FROM ${VC_TBL_ICU} WHERE ${vcCond} AND deleted=0 ORDER BY observed_dt DESC&quot;&quot;&quot;)
    ps.setString(1, pid); ps.setString(2, eid)
    rs = ps.executeQuery()
    def icuDump = dumpPretty(VC_TBL_ICU, rs, 10)
    closeQ(rs); closeQ(ps)

    ps = vConn.prepareStatement(&quot;&quot;&quot;
        SELECT version, created_dt, updated_dt,
               ${vcPidExpr} AS patient_id,
               ${vcEidExpr} AS encounter_id,
               observed_dt, category, subcategory
        FROM ${VC_TBL_EVT} WHERE ${vcCond} AND category=&apos;ICU&apos; AND deleted=0 ORDER BY observed_dt DESC&quot;&quot;&quot;)
    ps.setString(1, pid); ps.setString(2, eid)
    rs = ps.executeQuery()
    def evtDump = dumpPretty(VC_TBL_EVT, rs, 10)
    closeQ(rs); closeQ(ps)

    vcDump = &quot;${icuDump}\n${evtDump}&quot;

    result = fails.isEmpty() ? &quot;PASS&quot; : &quot;FAIL&quot;
    notes  = fails.join(&quot; | &quot;)

} catch (Throwable t) {
    result = &quot;FAIL&quot;
    notes  = &quot;exception: ${t.getClass().getSimpleName()} - ${t.getMessage()}&quot;
    log.error(&quot;[ALT_ICU] Verify_ICU_InOut failed&quot;, t)
} finally {
    closeQ(rs); closeQ(ps)
    closeQ(eConn); closeQ(vConn)
    finishFn(prev, ctx, props, vars, orderKey, scenarioId, result, notes, emrDump, vcDump)
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Cleanup_Icu_Type">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import com.jcraft.jsch.*
import java.sql.DriverManager

def host        = vars.get(&quot;SSH_HOST&quot;)
def port        = Integer.parseInt(vars.get(&quot;SSH_PORT&quot;) ?: &quot;22&quot;)
def sshUser     = vars.get(&quot;SSH_USER&quot;)
def sshPw       = vars.get(&quot;SSH_PW&quot;)
def composeDir  = vars.get(&quot;SSH_COMPOSE_DIR&quot;)
def filePath    = &quot;${composeDir}/envs/vc-sync-v220.env&quot;

def execCmd = { Session sess, String cmd -&gt;
    ChannelExec ch = (ChannelExec) sess.openChannel(&quot;exec&quot;)
    ch.setCommand(cmd)
    def is = ch.getInputStream()
    ch.connect()
    def sb = new StringBuilder()
    def buf = new byte[1024]; int len
    while ((len = is.read(buf)) != -1) sb.append(new String(buf, 0, len))
    while (!ch.isClosed()) Thread.sleep(100)
    ch.disconnect()
    sb.toString().trim()
}

Session session = null
try {
    def jsch = new JSch()
    session = jsch.getSession(sshUser, host, port)
    session.setPassword(sshPw)
    session.setConfig(&quot;StrictHostKeyChecking&quot;, &quot;no&quot;)
    session.connect(10000)

    def activeIcuB = execCmd(session, &quot;grep &apos;^VCSYNC_EMR_HOSPITAL=demo_icu_b&apos; ${filePath}&quot;)
    if (activeIcuB) {
    execCmd(session, &quot;sed -i &apos;s/^VCSYNC_EMR_HOSPITAL=demo_icu_b/#VCSYNC_EMR_HOSPITAL=demo_icu_b/&apos; ${filePath}&quot;)
    def sedDemo = &apos;s/^#VCSYNC_EMR_HOSPITAL=demo$/VCSYNC_EMR_HOSPITAL=demo/&apos;
    execCmd(session, &quot;sed -i &apos;${sedDemo}&apos; ${filePath}&quot;)
    execCmd(session, &quot;cd ${composeDir} &amp;&amp; docker compose up -d sync&quot;)
    log.info(&quot;[Cleanup_ICU_Transfer] demo_icu_b -&gt; demo 복원 후 재시작&quot;)
}
 else {
        log.info(&quot;[Cleanup_ICU_Transfer] 복원 불필요 (이미 demo)&quot;)
    }

} catch (Throwable t) {
    log.error(&quot;[Cleanup_ICU_Transfer] SSH Exception&quot;, t)
    throw t
} finally {
    session?.disconnect()
}

def vcUrl  = (vars.get(&quot;JDBC_URL_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcUser = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw   = (vars.get(&quot;JDBC_PW_VC&quot;) ?: &quot;&quot;).toString()
java.sql.Connection vConn = null
try {
    vConn = DriverManager.getConnection(vcUrl, vcUser, vcPw)
    def del = vConn.prepareStatement(&quot;DELETE FROM vitalcare.emr_location&quot;)
    int rows = del.executeUpdate()
    del.close()
    log.info(&quot;[Cleanup_ICU_Transfer] DELETE emr_location: ${rows} rows&quot;)
} catch (Throwable t) {
    log.warn(&quot;[Cleanup_ICU_Transfer] emr_location DELETE failed: &quot; + t.getMessage())
} finally {
    try { vConn?.close() } catch (ignored) {}
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
      <PostThreadGroup guiclass="PostThreadGroupGui" testclass="PostThreadGroup" testname="tearDown Thread Group">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </PostThreadGroup>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(Result)_JSR223 Sampler">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.util.TimeZone
import java.text.SimpleDateFormat
import java.util.Date
import groovy.json.JsonOutput

// -----------------------------
// Helpers
// -----------------------------
def parseCsvText = { String text -&gt;
    def records = []
    def row = []
    def sb = new StringBuilder()
    boolean inQuotes = false

    for (int i = 0; i &lt; text.length(); i++) {
        char c = text.charAt(i)

        if (inQuotes) {
            if (c == &apos;&quot;&apos;) {
                if (i + 1 &lt; text.length() &amp;&amp; text.charAt(i + 1) == &apos;&quot;&apos;) {
                    sb.append(&apos;&quot;&apos;); i++
                } else {
                    inQuotes = false
                }
            } else {
                sb.append(c)
            }
        } else {
            if (c == &apos;&quot;&apos;) inQuotes = true
            else if (c == &apos;,&apos;) { row &lt;&lt; sb.toString(); sb.setLength(0) }
            else if (c == &apos;\n&apos;) {
                row &lt;&lt; sb.toString(); sb.setLength(0)
                if (!(row.size() == 1 &amp;&amp; row[0].trim().isEmpty())) records &lt;&lt; row
                row = []
            } else if (c != &apos;\r&apos;) sb.append(c)
        }
    }

    row &lt;&lt; sb.toString()
    if (!(row.size() == 1 &amp;&amp; row[0].trim().isEmpty())) {
        if (records.isEmpty() || row.any { it != &quot;&quot; }) records &lt;&lt; row
    }
    return records
}

def htmlEscape = { Object v -&gt;
    def s = (v == null) ? &quot;&quot; : v.toString()
    s = s.replace(&quot;&amp;&quot;, &quot;&amp;amp;&quot;)
         .replace(&quot;&lt;&quot;, &quot;&amp;lt;&quot;)
         .replace(&quot;&gt;&quot;, &quot;&amp;gt;&quot;)
         .replace(&quot;\&quot;&quot;, &quot;&amp;quot;&quot;)
         .replace(&quot;&apos;&quot;, &quot;&amp;#39;&quot;)
    return s
}

def safeStr = { Object v -&gt; (v == null) ? &quot;&quot; : v.toString().trim() }

def idxOf = { List header, String name -&gt;
    if (header == null) return -1
    return header.indexOf(name)
}

def parseIntSafe = { String s, int defVal -&gt;
    try { return Integer.parseInt((s ?: &quot;&quot;).trim()) } catch (ignored) { return defVal }
}

// time parser
def tz = TimeZone.getTimeZone(&quot;Asia/Seoul&quot;)
def sdfMs  = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss,SSS&quot;); sdfMs.setTimeZone(tz)
def sdfSec = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);     sdfSec.setTimeZone(tz)

def parseTimeMs = { String s -&gt;
    if (!s) return null
    def t = s.trim()
    try { return sdfMs.parse(t).getTime() } catch (ignored) {}
    try { return sdfSec.parse(t).getTime() } catch (ignored) {}
    return null
}

// &quot;Scenario 1-3-2&quot; -&gt; &quot;Scenario 1&quot;
def groupKeyOfScenario = { String scenarioText -&gt;
    def sc = safeStr(scenarioText)
    if (!sc) return &quot;Scenario&quot;
    def m = (sc =~ /Scenario\s+(\d+)/)
    if (m.find()) return &quot;Scenario &quot; + m.group(1)
    return sc
}

def normResult = { Object v -&gt;
    def s = safeStr(v).toUpperCase()
    if (s.startsWith(&quot;PASS&quot;)) return &quot;PASS&quot;
    if (s.startsWith(&quot;FAIL&quot;)) return &quot;FAIL&quot;
    if (s.startsWith(&quot;SKIP&quot;)) return &quot;SKIP&quot;
    if (s.startsWith(&quot;ERROR&quot;)) return &quot;ERROR&quot;
    return s
}


def dumpViewHtml = { String raw -&gt;
    def s = htmlEscape(raw ?: &quot;&quot;)
    // wrap hints after common delimiters
    s = s.replace(&quot;|&quot;, &quot;|&lt;wbr&gt;&quot;)
         .replace(&quot;,&quot;, &quot;,&lt;wbr&gt;&quot;)
         .replace(&quot;;&quot;, &quot;;&lt;wbr&gt;&quot;)
    return s
}

def b64Utf8 = { String raw -&gt;
    return ((raw ?: &quot;&quot;).getBytes(&quot;UTF-8&quot;)).encodeBase64().toString()
}



// -----------------------------
// Runner
// -----------------------------
def csvPathStr  = (props.get(&quot;lastCsvFile&quot;)  ?: &quot;&quot;).toString()
def htmlPathStr = (props.get(&quot;lastHtmlFile&quot;) ?: &quot;&quot;).toString()

if (!csvPathStr) { log.warn(&quot;[HTML] lastCsvFile is empty.&quot;); return }
def csvFile = new File(csvPathStr)
if (!csvFile.exists()) { log.warn(&quot;[HTML] CSV not found: &quot; + csvFile.absolutePath); return }

def htmlFile = htmlPathStr ? new File(htmlPathStr) : new File(csvFile.parentFile, csvFile.name.replace(&quot;.csv&quot;, &quot;.html&quot;))

// -----------------------------
// Load &amp; parse
// -----------------------------
def csvText = csvFile.getText(&quot;UTF-8&quot;).replace(&quot;\r\n&quot;, &quot;\n&quot;).replace(&quot;\r&quot;, &quot;\n&quot;)
def records = parseCsvText(csvText)
if (!records || records.isEmpty()) { log.warn(&quot;[HTML] CSV empty&quot;); return }

def header = records[0]
def rows = (records.size() &gt; 1) ? records.subList(1, records.size()) : []
if (!rows) { log.warn(&quot;[HTML] CSV has header only&quot;); return }

// -----------------------------
// Column index
// -----------------------------
int idxOrder    = idxOf(header, &quot;order_key&quot;)
int idxGroupCol = idxOf(header, &quot;Group&quot;)
int idxParent   = idxOf(header, &quot;Scenario(Parent)&quot;)
int idxScenario = idxOf(header, &quot;Scenario&quot;)
int idxStart    = idxOf(header, &quot;StartTime&quot;)
int idxEnd      = idxOf(header, &quot;EndTime&quot;)
int idxResult   = idxOf(header, &quot;Test Result&quot;)
int idxSource   = idxOf(header, &quot;Source (EMR)&quot;)
int idxDest     = idxOf(header, &quot;Destination (VC)&quot;)
int idxNotes    = idxOf(header, &quot;Notes&quot;)

// -----------------------------
// Sort by order_key
// -----------------------------
if (idxOrder &gt;= 0) {
    rows.sort { a, b -&gt;
        def oa = (a.size() &gt; idxOrder) ? safeStr(a[idxOrder]) : &quot;&quot;
        def ob = (b.size() &gt; idxOrder) ? safeStr(b[idxOrder]) : &quot;&quot;
        parseIntSafe(oa, 999) &lt;=&gt; parseIntSafe(ob, 999)
    }
}

// -----------------------------
// Summary + Grouping
// -----------------------------
long minStartMs = Long.MAX_VALUE
long maxEndMs = 0L
int totalCount = 0
int passCount = 0
int failCount = 0

def groupStats = new LinkedHashMap&lt;String, Map&gt;()
def groupRows  = new LinkedHashMap&lt;String, List&gt;()

def ensureGroup = { String g -&gt;
    if (!groupStats.containsKey(g)) {
        groupStats[g] = [name:g, totalTest:0, passCount:0, failCount:0, minStartMs:Long.MAX_VALUE, maxEndMs:0L]
        groupRows[g] = []
    }
}

rows.each { r -&gt;
    totalCount++
    def res = normResult((idxResult &gt;= 0 &amp;&amp; r.size() &gt; idxResult) ? r[idxResult] : &quot;&quot;)
    if (res == &quot;PASS&quot;) passCount++
    else if (res == &quot;FAIL&quot;) failCount++

    def sStr = (idxStart &gt;= 0 &amp;&amp; r.size() &gt; idxStart) ? safeStr(r[idxStart]) : &quot;&quot;
    def eStr = (idxEnd   &gt;= 0 &amp;&amp; r.size() &gt; idxEnd)   ? safeStr(r[idxEnd])   : &quot;&quot;
    def sMs = parseTimeMs(sStr)
    def eMs = parseTimeMs(eStr)
    if (sMs != null &amp;&amp; sMs &lt; minStartMs) minStartMs = sMs
    if (eMs != null &amp;&amp; eMs &gt; maxEndMs) maxEndMs = eMs

    def parentText = (idxParent &gt;= 0 &amp;&amp; r.size() &gt; idxParent) ? safeStr(r[idxParent]) : &quot;&quot;
    def g = parentText ? parentText : &quot;Scenario&quot;

    ensureGroup(g)
    groupRows[g] &lt;&lt; r

    def gs = groupStats[g]
    gs.totalTest++
    if (res == &quot;PASS&quot;) gs.passCount++
    else if (res == &quot;FAIL&quot;) gs.failCount++

    if (sMs != null &amp;&amp; sMs &lt; gs.minStartMs) gs.minStartMs = sMs
    if (eMs != null &amp;&amp; eMs &gt; gs.maxEndMs) gs.maxEndMs = eMs
}

def summaryStart = (minStartMs == Long.MAX_VALUE) ? &quot;&quot; : sdfSec.format(new Date(minStartMs))
def summaryEnd   = (maxEndMs == 0L) ? &quot;&quot; : sdfSec.format(new Date(maxEndMs))
def durationSec  = (minStartMs == Long.MAX_VALUE || maxEndMs == 0L || maxEndMs &lt; minStartMs) ? &quot;&quot; : String.valueOf((maxEndMs - minStartMs)/1000L)

groupStats.values().each { gs -&gt;
    long gStart = (gs.minStartMs == Long.MAX_VALUE) ? 0L : (gs.minStartMs as long)
    long gEnd   = (gs.maxEndMs as long)
    gs.startTime = (gStart == 0L) ? &quot;&quot; : sdfSec.format(new Date(gStart))
    gs.endTime   = (gEnd == 0L) ? &quot;&quot; : sdfSec.format(new Date(gEnd))
    gs.duration  = (gStart == 0L || gEnd == 0L || gEnd &lt; gStart) ? &quot;&quot; : String.valueOf((gEnd - gStart)/1000L)
}

// -----------------------------
// Output columns (skip order/group/parent)
// -----------------------------
def skipIdx = new HashSet&lt;Integer&gt;()
if (idxOrder &gt;= 0) skipIdx.add(idxOrder)
if (idxGroupCol &gt;= 0) skipIdx.add(idxGroupCol)
if (idxParent &gt;= 0) skipIdx.add(idxParent)

def outHeader = []
for (int i=0; i&lt;header.size(); i++) {
    if (!skipIdx.contains(i)) outHeader &lt;&lt; header[i]
}

def colStyleFor = { String colName -&gt;
    def n = (colName ?: &quot;&quot;).toLowerCase()
    if (n == &quot;scenario&quot;) return &quot;width:150px;&quot;
    if (n.contains(&quot;starttime&quot;)) return &quot;width:160px;&quot;
    if (n.contains(&quot;endtime&quot;)) return &quot;width:160px;&quot;
    if (n.contains(&quot;test result&quot;)) return &quot;width:110px;&quot;
    if (n.contains(&quot;notes&quot;)) return &quot;width:200px;&quot;
    if (n.contains(&quot;source&quot;)) return &quot;width:460px;&quot;
    if (n.contains(&quot;destination&quot;)) return &quot;width:460px;&quot;

    return &quot;&quot;
}


// -----------------------------
// Tabs (planned + data)
// -----------------------------
def tabLabelMap = new LinkedHashMap&lt;String, String&gt;()
tabLabelMap[&quot;Scenario 1&quot;] = &quot;Scenario 1 (기본정보)&quot;
tabLabelMap[&quot;Scenario 2&quot;] = &quot;Scenario 2 (입원정보)&quot;
tabLabelMap[&quot;Scenario 3&quot;] = &quot;Scenario 3 (주치의/진료과/위치)&quot;
tabLabelMap[&quot;Scenario 4&quot;] = &quot;Scenario 4 (Vital)&quot;
tabLabelMap[&quot;Scenario 5&quot;] = &quot;Scenario 5 (Lab)&quot;
tabLabelMap[&quot;Scenario 6&quot;] = &quot;Scenario 6 (Icu)&quot;
tabLabelMap[&quot;Scenario 7&quot;] = &quot;Scenario 7 (Vital 형제 데이터)&quot;
tabLabelMap[&quot;Scenario 8&quot;] = &quot;Scenario 8 (DNR)&quot;
tabLabelMap[&quot;Scenario 9&quot;] = &quot;Scenario 9 (퇴원 처리)&quot;
tabLabelMap[&quot;Scenario 10&quot;] = &quot;Scenario 10 (Icu 전동)&quot;


def tabDescMap = new LinkedHashMap&lt;String, String&gt;()
tabDescMap[&quot;Scenario 1&quot;] = &quot;환자 기본 정보 추가, 변경에 대한 연동 시나리오 케이스&quot;
tabDescMap[&quot;Scenario 2&quot;] = &quot;환자 입원 정보 추가에 대한 연동 시나리오 케이스&quot;
tabDescMap[&quot;Scenario 3&quot;] = &quot;신규 주치의/진료과/위치 정보 추가에 대한 연동 시나리오 케이스&quot;
tabDescMap[&quot;Scenario 4&quot;] = &quot;Vital 데이터 추가에 대한 연동 시나리오 케이스&quot;
tabDescMap[&quot;Scenario 5&quot;] = &quot;Lab 데이터 추가에 대한 연동 시나리오 케이스&quot;
tabDescMap[&quot;Scenario 6&quot;] = &quot;Icu 입/퇴실 정보 추가에 대한 연동 시나리오 케이스&quot;
tabDescMap[&quot;Scenario 7&quot;] = &quot;Vital 형제 코드 존재 시 VC 연동 코드 변환 검증 케이스&quot;
tabDescMap[&quot;Scenario 8&quot;] = &quot;DNR 연동/수동 설정 관련 시나리오 케이스&quot;
tabDescMap[&quot;Scenario 9&quot;] = &quot;퇴원 처리 설정 시각에 퇴원 처리 여부 시나리오 케이스&quot;
tabDescMap[&quot;Scenario 10&quot;] = &quot;(demo_icu_b) Icu 전동 입/퇴실 정보 추가에 대한 연동 시나리오 케이스&quot;


def plannedGroups = [&quot;Scenario 1&quot;,&quot;Scenario 2&quot;,&quot;Scenario 3&quot;,&quot;Scenario 4&quot;,&quot;Scenario 5&quot;,&quot;Scenario 6&quot;,&quot;Scenario 7&quot;,&quot;Scenario 8&quot;,&quot;Scenario 9&quot;]
def dataGroups = groupStats.keySet().toList()

def finalGroups = []
plannedGroups.each { if (!finalGroups.contains(it)) finalGroups &lt;&lt; it }
dataGroups.each { if (!finalGroups.contains(it)) finalGroups &lt;&lt; it }

// Charts data
def groupNames = groupStats.values().collect { it.name }
def groupTotal = groupStats.values().collect { it.totalTest }


// -----------------------------
// Build HTML
// -----------------------------
def sb = new StringBuilder()
sb.append(&quot;&lt;!DOCTYPE html&gt;\n&lt;html&gt;\n&lt;head&gt;\n&quot;)
sb.append(&quot;&lt;meta charset=\&quot;UTF-8\&quot; /&gt;\n&quot;)
sb.append(&quot;&lt;script src=\&quot;https://cdn.jsdelivr.net/npm/chart.js\&quot;&gt;&lt;/script&gt;\n&quot;)

sb.append(&quot;&lt;style&gt;\n&quot;)
sb.append(&quot;*{box-sizing:border-box;}\n&quot;)

sb.append(&quot;body{margin:0;color:#1f2330;background:#faf9fe;font-family:system-ui,-apple-system,\&quot;Segoe UI\&quot;,Roboto,\&quot;Noto Sans KR\&quot;,Arial,sans-serif;font-size:15px;}\n&quot;)
sb.append(&quot;.wrap{width:100%;max-width:none;margin:0 auto;padding:22px 34px;box-sizing:border-box;}\n&quot;)

sb.append(&quot;.title{font-weight:700;font-size:24px;letter-spacing:-0.2px;margin:12px 0 12px 0;}\n&quot;)
sb.append(&quot;.testResultsTitle{font-weight:700;font-size:24px;margin:12px 0 16px 0;}\n&quot;)
sb.append(&quot;.testSummaryTitle{font-weight:700;font-size:16px;margin:12px 0 16px 0;}\n&quot;)
sb.append(&quot;.sectionTitle{font-weight:700;font-size:15px;letter-spacing:-0.1px;margin:18px 0 10px 0;}\n&quot;)
sb.append(&quot;.subTitle{font-weight:700;font-size:14px;margin:0 0 10px 0;color:#2a2f3a;}\n&quot;)
sb.append(&quot;.panelDesc{margin:0 0 18px 0;font-size:14px;font-weight:700;font-style:italic;color:#374151;}\n&quot;)

sb.append(&quot;.card{overflow-x:auto;...}\n&quot;)
sb.append(&quot;.card table{width:calc(100% - 8px);}\n&quot;)
sb.append(&quot;.card{width:100%;background:#fff;border-radius:10px;padding:26px 26px 22px 26px;margin-bottom:16px;border:1px solid #e8e8f2;box-shadow:0 2px 10px rgba(31,35,48,0.04);box-sizing:border-box;}\n&quot;)
sb.append(&quot;table{width:100%;border-collapse:collapse;table-layout:fixed;font-size:14px;font-family:inherit;}\n&quot;)
sb.append(&quot;th,td{padding:12px 14px;border:1px solid #ddd;vertical-align:top;text-align:left;font-family:inherit;}\n&quot;)
sb.append(&quot;th{background:#f4f4f4;font-weight:700;color:#1f2330;}\n&quot;)
sb.append(&quot;td{font-weight:400;color:#1f2330;}\n&quot;)
sb.append(&quot;pre{white-space:pre-wrap;word-break:normal;overflow-wrap:normal;margin:0;max-width:100%;max-height:300px;overflow:auto;font-family:inherit;}\n&quot;)

sb.append(&quot;.dumpWrap{position:relative;}\n&quot;)
sb.append(&quot;.dumpPre{padding-right:56px;}\n&quot;)
sb.append(&quot;.copyBtn{position:absolute;top:3px;right:20px;width:28px;height:28px;border-radius:9px;border:1px solid rgba(31,35,48,0.15);background:rgba(255,255,255,0.92);cursor:pointer;display:flex;align-items:center;justify-content:center;opacity:0.18;transition:opacity .15s ease, transform .15s ease, background .15s ease, border-color .15s ease;}\n&quot;)
sb.append(&quot;.dumpWrap:hover .copyBtn{opacity:1;transform:translateY(-1px);}\n&quot;)
sb.append(&quot;.copyBtn:active{transform:translateY(0px) scale(0.98);}\n&quot;)
sb.append(&quot;.copyBtn svg{width:15px;height:15px;fill:#1f2330;}\n&quot;)
sb.append(&quot;.copyBtn.copied{opacity:1;background:rgba(238,245,255,0.95);border-color:rgba(27,90,166,0.35);}\n&quot;)
sb.append(&quot;.copyBtn.copied svg{fill:#1b5aa6;}\n&quot;)
sb.append(&quot;.copyBtn.copied .ico-copy{display:none;}\n&quot;)
sb.append(&quot;.copyBtn.copied .ico-check{display:block !important;}\n&quot;)

sb.append(&quot;.badge{display:inline-block;padding:3px 10px;border-radius:999px;font-weight:700;font-size:13px;}\n&quot;)
sb.append(&quot;.scenarioLabel{font-weight:500;padding-left:5px;border-left:3px solid #6a63e6;}\n&quot;)
sb.append(&quot;.pass{background:#eef5ff;color:#1b5aa6;}\n&quot;)
sb.append(&quot;.fail{background:#fff0f1;color:#a61b28;}\n&quot;)

sb.append(&quot;.tabs{display:flex;gap:10px;flex-wrap:wrap;margin:10px 0 16px 0;padding-bottom:6px;}\n&quot;)
sb.append(&quot;.tabBtn{border:1px solid #dedaf7;background:#fbfaff;color:#1f2330;border-radius:6px;padding:10px 14px;font-weight:700;font-size:14px;cursor:pointer;white-space:nowrap;}\n&quot;)
sb.append(&quot;.tabBtn:hover{background:#f5f3ff;}\n&quot;)
sb.append(&quot;.tabBtn.active{background:#6a63e6;border-color:#6a63e6;color:#fff;}\n&quot;)
sb.append(&quot;.tabPanel{display:none;}\n&quot;)
sb.append(&quot;.tabPanel.active{display:block;}\n&quot;)

sb.append(&quot;.chart-container{margin-top:14px;margin-bottom:22px;width:100% !important;height:420px;}\n&quot;)

sb.append(&quot;table,thead,tbody,tr,th,td,pre{font-family:\&quot;Segoe UI\&quot;,Roboto,Arial,sans-serif !important;}\n&quot;)
sb.append(&quot;td,pre{font-size:14px !important;font-weight:400 !important;color:#1f2330 !important;}\n&quot;)

sb.append(&quot;&lt;/style&gt;\n&quot;)
sb.append(&quot;&lt;/head&gt;\n&quot;)
sb.append(&quot;&lt;body&gt;\n&quot;)
sb.append(&quot;&lt;div class=\&quot;wrap\&quot;&gt;\n&quot;)

def reportTitle = &quot;VC Sync AutoTest Report&quot;
sb.append(&quot;&lt;div class=\&quot;title\&quot;&gt;&quot;).append(htmlEscape(reportTitle)).append(&quot;&lt;/div&gt;\n&quot;)

// -----------------------------
// TOP TABS
// -----------------------------
def topTabs = []
topTabs &lt;&lt; &quot;Test Results&quot;
finalGroups.each { topTabs &lt;&lt; it }

def tabLabelOf = { String key -&gt;
    if (key == &quot;Test Results&quot;) return &quot;Test Results&quot;
    return tabLabelMap.containsKey(key) ? tabLabelMap[key] : key
}

def tabShortLabelOf = { String key -&gt;
    def full = tabLabelOf(key)
    def m = (full =~ /^(Scenario\s+\d+)/)
    if (m.find()) return m.group(1)
    return full
}

sb.append(&quot;&lt;div class=\&quot;tabs\&quot; id=\&quot;topTabs\&quot;&gt;\n&quot;)
topTabs.eachWithIndex { key, i -&gt;
    def active = (i == 0) ? &quot; active&quot; : &quot;&quot;
    sb.append(&quot;&lt;button class=\&quot;tabBtn&quot;).append(active)
      .append(&quot;\&quot; data-tab=\&quot;panel_&quot;).append(i).append(&quot;\&quot;&gt;&quot;)
      .append(htmlEscape(tabLabelOf(key)))
      .append(&quot;&lt;/button&gt;\n&quot;)
}
sb.append(&quot;&lt;/div&gt;\n&quot;)

// -----------------------------
// PANELS
// -----------------------------
topTabs.eachWithIndex { key, i -&gt;
    def active = (i == 0) ? &quot; active&quot; : &quot;&quot;
    sb.append(&quot;&lt;div class=\&quot;tabPanel&quot;).append(active).append(&quot;\&quot; id=\&quot;panel_&quot;).append(i).append(&quot;\&quot;&gt;\n&quot;)

    if (key == &quot;Test Results&quot;) {

        sb.append(&quot;&lt;div class=\&quot;card\&quot;&gt;\n&quot;)
        sb.append(&quot;&lt;div class=\&quot;testResultsTitle\&quot;&gt;Test Summary&lt;/div&gt;\n&quot;)

        sb.append(&quot;&lt;div class=\&quot;sectionTitle\&quot;&gt;Total Summary Statistics&lt;/div&gt;\n&quot;)
        sb.append(&quot;&lt;table&gt;\n&lt;tbody&gt;\n&quot;)
        def addSumRow = { String k, String v -&gt;
            sb.append(&quot;&lt;tr&gt;&quot;)
              .append(&quot;&lt;th style=\&quot;width:220px;\&quot;&gt;&quot;).append(htmlEscape(k)).append(&quot;&lt;/th&gt;&quot;)
              .append(&quot;&lt;td&gt;&quot;).append(htmlEscape(v)).append(&quot;&lt;/td&gt;&quot;)
              .append(&quot;&lt;/tr&gt;\n&quot;)
        }
        addSumRow(&quot;Total TestCases&quot;, String.valueOf(totalCount))
        addSumRow(&quot;PASS (Count)&quot;, String.valueOf(passCount))
        addSumRow(&quot;FAIL (Count)&quot;, String.valueOf(failCount))
        addSumRow(&quot;Start Time&quot;, summaryStart)
        addSumRow(&quot;End Time&quot;, summaryEnd)
        addSumRow(&quot;Duration (sec)&quot;, durationSec)
        sb.append(&quot;&lt;/tbody&gt;\n&lt;/table&gt;\n&quot;)

        sb.append(&quot;&lt;div class=\&quot;sectionTitle\&quot;&gt;Group Summary Statistics&lt;/div&gt;\n&quot;)
        sb.append(&quot;&lt;table&gt;\n&lt;thead&gt;&lt;tr&gt;&quot;)
        sb.append(&quot;&lt;th&gt;Scenario Group&lt;/th&gt;&lt;th&gt;TestCases&lt;/th&gt;&lt;th&gt;PASS Count&lt;/th&gt;&lt;th&gt;FAIL Count&lt;/th&gt;&lt;th&gt;StartTime&lt;/th&gt;&lt;th&gt;EndTime&lt;/th&gt;&lt;th&gt;Duration (sec)&lt;/th&gt;&quot;)
        sb.append(&quot;&lt;/tr&gt;&lt;/thead&gt;\n&lt;tbody&gt;\n&quot;)
        groupStats.values().each { gs -&gt;
            sb.append(&quot;&lt;tr&gt;&quot;)
            sb.append(&quot;&lt;td&gt;&quot;).append(htmlEscape(tabShortLabelOf(gs.name))).append(&quot;&lt;/td&gt;&quot;)
            sb.append(&quot;&lt;td&gt;&quot;).append(String.valueOf(gs.totalTest)).append(&quot;&lt;/td&gt;&quot;)
            sb.append(&quot;&lt;td&gt;&quot;).append(String.valueOf(gs.passCount)).append(&quot;&lt;/td&gt;&quot;)
            sb.append(&quot;&lt;td&gt;&quot;).append(String.valueOf(gs.failCount)).append(&quot;&lt;/td&gt;&quot;)
            sb.append(&quot;&lt;td&gt;&quot;).append(htmlEscape(gs.startTime)).append(&quot;&lt;/td&gt;&quot;)
            sb.append(&quot;&lt;td&gt;&quot;).append(htmlEscape(gs.endTime)).append(&quot;&lt;/td&gt;&quot;)
            sb.append(&quot;&lt;td&gt;&quot;).append(htmlEscape(gs.duration)).append(&quot;&lt;/td&gt;&quot;)
            sb.append(&quot;&lt;/tr&gt;\n&quot;)
        }
        sb.append(&quot;&lt;/tbody&gt;&lt;/table&gt;\n&quot;)

        def chartGroupNames = groupStats.values().collect { tabLabelOf(it.name) }
        def chartGroupTotal = groupStats.values().collect { it.totalTest }

        sb.append(&quot;&lt;div class=\&quot;sectionTitle\&quot;&gt;Visualizations&lt;/div&gt;\n&quot;)
        sb.append(&quot;&lt;div class=\&quot;subTitle\&quot;&gt;TestCases per Scenario Group&lt;/div&gt;\n&quot;)
        sb.append(&quot;&lt;div class=\&quot;chart-container\&quot;&gt;&lt;canvas id=\&quot;bar-chart\&quot;&gt;&lt;/canvas&gt;&lt;/div&gt;\n&quot;)
        sb.append(&quot;&lt;div class=\&quot;subTitle\&quot; style=\&quot;margin-top:16px;\&quot;&gt;PASS vs FAIL&lt;/div&gt;\n&quot;)
        sb.append(&quot;&lt;div class=\&quot;chart-container\&quot;&gt;&lt;canvas id=\&quot;pie-chart\&quot;&gt;&lt;/canvas&gt;&lt;/div&gt;\n&quot;)

        sb.append(&quot;&lt;/div&gt;\n&quot;)

        sb.append(&quot;&lt;script&gt;\n&quot;)
        sb.append(&quot;(function(){\n&quot;)
        sb.append(&quot;  function renderCharts(){\n&quot;)
        sb.append(&quot;    if (window.__chartsInited) return;\n&quot;)
        sb.append(&quot;    var bar = document.getElementById(&apos;bar-chart&apos;);\n&quot;)
        sb.append(&quot;    var pie = document.getElementById(&apos;pie-chart&apos;);\n&quot;)
        sb.append(&quot;    if (!bar || !pie) return;\n&quot;)
        sb.append(&quot;    window.__chartsInited = true;\n&quot;)
        sb.append(&quot;    try {\n&quot;)
        sb.append(&quot;      new Chart(bar.getContext(&apos;2d&apos;), {\n&quot;)
        sb.append(&quot;        type:&apos;bar&apos;,\n&quot;)
        sb.append(&quot;        data:{ labels:&quot;).append(JsonOutput.toJson(chartGroupNames)).append(&quot;, datasets:[{ label:&apos;Count&apos;, data:&quot;)
          .append(JsonOutput.toJson(chartGroupTotal)).append(&quot;, backgroundColor:&apos;#4A90E2&apos;, borderColor:&apos;#4A90E2&apos;, borderWidth:1 }] },\n&quot;)
        sb.append(&quot;        options:{ responsive:true, maintainAspectRatio:false, scales:{ x:{ title:{display:true,text:&apos;Scenario Group&apos;} }, y:{ title:{display:true,text:&apos;TestCase Count&apos;} } } }\n&quot;)
        sb.append(&quot;      });\n&quot;)
        sb.append(&quot;      new Chart(pie.getContext(&apos;2d&apos;), {\n&quot;)
        sb.append(&quot;        type:&apos;pie&apos;,\n&quot;)
        sb.append(&quot;        data:{ labels:[&apos;PASS&apos;,&apos;FAIL&apos;], datasets:[{ data:[&quot;).append(passCount).append(&quot;,&quot;).append(failCount)
          .append(&quot;], backgroundColor:[&apos;#4A90E2&apos;,&apos;#D0021B&apos;] }] },\n&quot;)
        sb.append(&quot;        options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{ position:&apos;bottom&apos; } } }\n&quot;)
        sb.append(&quot;      });\n&quot;)
        sb.append(&quot;    } catch(e) { console &amp;&amp; console.error &amp;&amp; console.error(e); }\n&quot;)
        sb.append(&quot;  }\n&quot;)
        sb.append(&quot;  window.__renderCharts = function(){ setTimeout(renderCharts, 120); };\n&quot;)
        sb.append(&quot;  window.addEventListener(&apos;load&apos;, function(){ window.__renderCharts(); });\n&quot;)
        sb.append(&quot;})();\n&quot;)
        sb.append(&quot;&lt;/script&gt;\n&quot;)
    }

    else {
        def g = key
        def gRows = groupRows[g] ?: []

        sb.append(&quot;&lt;div class=\&quot;card\&quot;&gt;\n&quot;)
        sb.append(&quot;&lt;div class=\&quot;testSummaryTitle\&quot;&gt;&quot;).append(htmlEscape(tabLabelOf(g))).append(&quot;&lt;/div&gt;\n&quot;)

        def desc = tabDescMap[g] ?: &quot;&quot;
        if (desc) {
            sb.append(&quot;&lt;div class=\&quot;panelDesc\&quot;&gt;&quot;).append(htmlEscape(desc)).append(&quot;&lt;/div&gt;\n&quot;)
        }

        if (gRows.isEmpty()) {
            sb.append(&quot;&lt;div style=\&quot;color:#6b7280;\&quot;&gt;No data yet.&lt;/div&gt;\n&quot;)
        } else {
            sb.append(&quot;&lt;table&gt;\n&quot;)

            sb.append(&quot;&lt;colgroup&gt;\n&quot;)
            outHeader.each { h -&gt; sb.append(&quot;&lt;col style=\&quot;&quot;).append(colStyleFor(h)).append(&quot;\&quot; /&gt;\n&quot;) }
            sb.append(&quot;&lt;/colgroup&gt;\n&quot;)

            sb.append(&quot;&lt;thead&gt;&lt;tr&gt;\n&quot;)
            outHeader.each { h -&gt; sb.append(&quot;&lt;th&gt;&quot;).append(htmlEscape(h)).append(&quot;&lt;/th&gt;\n&quot;) }
            sb.append(&quot;&lt;/tr&gt;&lt;/thead&gt;\n&lt;tbody&gt;\n&quot;)

            gRows.each { r -&gt;
                sb.append(&quot;&lt;tr&gt;\n&quot;)
                for (int colIdx=0; colIdx&lt;header.size(); colIdx++) {
                    if (skipIdx.contains(colIdx)) continue
                    def cell = (colIdx &lt; r.size()) ? r[colIdx] : &quot;&quot;

                    if (colIdx == idxResult) {
                        def v = normResult(cell)
                        if (v.equalsIgnoreCase(&quot;PASS&quot;)) sb.append(&quot;&lt;td&gt;&lt;span class=\&quot;badge pass\&quot;&gt;PASS&lt;/span&gt;&lt;/td&gt;\n&quot;)
                        else if (v.equalsIgnoreCase(&quot;FAIL&quot;)) sb.append(&quot;&lt;td&gt;&lt;span class=\&quot;badge fail\&quot;&gt;FAIL&lt;/span&gt;&lt;/td&gt;\n&quot;)
                        else sb.append(&quot;&lt;td&gt;&quot;).append(htmlEscape(cell)).append(&quot;&lt;/td&gt;\n&quot;)
                        continue
                    }

                    if (colIdx == idxSource || colIdx == idxDest) {
                        def raw = (cell == null) ? &quot;&quot; : cell.toString()
                        def rawB64 = b64Utf8(raw)
                        
                        sb.append(&quot;&lt;td&gt;&lt;div class=\&quot;dumpWrap\&quot;&gt;&quot;)
                        sb.append(&quot;&lt;button class=\&quot;copyBtn\&quot; type=\&quot;button\&quot; aria-label=\&quot;copy\&quot; data-rawb64=\&quot;&quot;).append(rawB64).append(&quot;\&quot;&gt;&quot;)
                        
                        sb.append(&quot;&lt;svg class=\&quot;ico-copy\&quot; viewBox=\&quot;0 0 24 24\&quot; aria-hidden=\&quot;true\&quot;&gt;&quot;)
                        sb.append(&quot;&lt;path d=\&quot;M16 1H6a2 2 0 0 0-2 2v10h2V3h10V1zm3 4H10a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2zm0 16H10V7h9v14z\&quot;/&gt;&quot;)
                        sb.append(&quot;&lt;/svg&gt;&quot;)
                        
                        sb.append(&quot;&lt;svg class=\&quot;ico-check\&quot; viewBox=\&quot;0 0 24 24\&quot; aria-hidden=\&quot;true\&quot; style=\&quot;display:none;\&quot;&gt;&quot;)
                        sb.append(&quot;&lt;path d=\&quot;M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z\&quot;/&gt;&quot;)
                        sb.append(&quot;&lt;/svg&gt;&quot;)
                        
                        sb.append(&quot;&lt;/button&gt;&quot;)
                        sb.append(&quot;&lt;pre class=\&quot;dumpPre\&quot;&gt;&quot;).append(dumpViewHtml(raw)).append(&quot;&lt;/pre&gt;&quot;)
                        sb.append(&quot;&lt;/div&gt;&lt;/td&gt;\n&quot;)
                        continue
                        }


                    if (colIdx == idxScenario) {
                        sb.append(&quot;&lt;td&gt;&lt;span class=\&quot;scenarioLabel\&quot;&gt;&quot;).append(htmlEscape(cell)).append(&quot;&lt;/span&gt;&lt;/td&gt;\n&quot;)
                        continue
                    }


                    if (colIdx == idxNotes) {
				    def raw = (cell == null) ? &quot;&quot; : cell.toString()
				    def rawB64 = b64Utf8(raw)
				    sb.append(&quot;&lt;td&gt;&lt;div class=\&quot;dumpWrap\&quot;&gt;&quot;)
				    sb.append(&quot;&lt;button class=\&quot;copyBtn\&quot; type=\&quot;button\&quot; aria-label=\&quot;copy\&quot; data-rawb64=\&quot;&quot;).append(rawB64).append(&quot;\&quot;&gt;&quot;)
				    sb.append(&quot;&lt;svg class=\&quot;ico-copy\&quot; viewBox=\&quot;0 0 24 24\&quot; aria-hidden=\&quot;true\&quot;&gt;&lt;path d=\&quot;M16 1H6a2 2 0 0 0-2 2v10h2V3h10V1zm3 4H10a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2zm0 16H10V7h9v14z\&quot;/&gt;&lt;/svg&gt;&quot;)
				    sb.append(&quot;&lt;svg class=\&quot;ico-check\&quot; viewBox=\&quot;0 0 24 24\&quot; aria-hidden=\&quot;true\&quot; style=\&quot;display:none;\&quot;&gt;&lt;path d=\&quot;M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z\&quot;/&gt;&lt;/svg&gt;&quot;)
				    sb.append(&quot;&lt;/button&gt;&quot;)
				    sb.append(&quot;&lt;pre class=\&quot;dumpPre\&quot;&gt;&quot;).append(htmlEscape(cell)).append(&quot;&lt;/pre&gt;&quot;)
				    sb.append(&quot;&lt;/div&gt;&lt;/td&gt;\n&quot;)
				    continue
				}

                    sb.append(&quot;&lt;td&gt;&quot;).append(htmlEscape(cell)).append(&quot;&lt;/td&gt;\n&quot;)
                }
                sb.append(&quot;&lt;/tr&gt;\n&quot;)
            }

            sb.append(&quot;&lt;/tbody&gt;\n&lt;/table&gt;\n&quot;)
        }

        sb.append(&quot;&lt;/div&gt;\n&quot;)
    }

    sb.append(&quot;&lt;/div&gt;\n&quot;)
}

// -----------------------------
// COPY SCRIPT
// -----------------------------
sb.append(&quot;&lt;script&gt;\n&quot;)
sb.append(&quot;(function(){\n&quot;)
sb.append(&quot;  function toast(msg){\n&quot;)
sb.append(&quot;    var t = document.createElement(&apos;div&apos;);\n&quot;)
sb.append(&quot;    t.textContent = msg || &apos;&apos;;\n&quot;)
sb.append(&quot;    t.style.cssText = &apos;position:fixed;right:16px;bottom:16px;z-index:99999;&apos;\n&quot;)
sb.append(&quot;      + &apos;background:rgba(31,35,48,0.92);color:#fff;padding:10px 12px;border-radius:10px;font-size:12px;&apos;\n&quot;)
sb.append(&quot;      + &apos;box-shadow:0 8px 24px rgba(0,0,0,0.18);transition:opacity .25s ease;&apos;;\n&quot;)
sb.append(&quot;    document.body.appendChild(t);\n&quot;)
sb.append(&quot;    setTimeout(function(){ t.style.opacity=&apos;0&apos;; }, 700);\n&quot;)
sb.append(&quot;    setTimeout(function(){ if(t &amp;&amp; t.parentNode) t.parentNode.removeChild(t); }, 950);\n&quot;)
sb.append(&quot;  }\n&quot;)
sb.append(&quot;\n&quot;)
sb.append(&quot;  async function copyText(text){\n&quot;)
sb.append(&quot;    if (text == null) text = &apos;&apos;;\n&quot;)
sb.append(&quot;    try {\n&quot;)
sb.append(&quot;      if (navigator.clipboard &amp;&amp; navigator.clipboard.writeText) {\n&quot;)
sb.append(&quot;        await navigator.clipboard.writeText(text);\n&quot;)
sb.append(&quot;        return true;\n&quot;)
sb.append(&quot;      }\n&quot;)
sb.append(&quot;    } catch(e) {}\n&quot;)
sb.append(&quot;    try {\n&quot;)
sb.append(&quot;      var ta = document.createElement(&apos;textarea&apos;);\n&quot;)
sb.append(&quot;      ta.value = text;\n&quot;)
sb.append(&quot;      ta.setAttribute(&apos;readonly&apos;,&apos;&apos;);\n&quot;)
sb.append(&quot;      ta.style.position=&apos;fixed&apos;; ta.style.left=&apos;-9999px&apos;; ta.style.top=&apos;0&apos;;\n&quot;)
sb.append(&quot;      document.body.appendChild(ta);\n&quot;)
sb.append(&quot;      ta.select();\n&quot;)
sb.append(&quot;      var ok = document.execCommand(&apos;copy&apos;);\n&quot;)
sb.append(&quot;      document.body.removeChild(ta);\n&quot;)
sb.append(&quot;      return ok;\n&quot;)
sb.append(&quot;    } catch(e2) { return false; }\n&quot;)
sb.append(&quot;  }\n&quot;)
sb.append(&quot;\n&quot;)
sb.append(&quot;  document.addEventListener(&apos;click&apos;, async function(e){\n&quot;)
sb.append(&quot;    var btn = e.target.closest &amp;&amp; e.target.closest(&apos;.copyBtn&apos;);\n&quot;)
sb.append(&quot;    if (!btn) return;\n&quot;)
sb.append(&quot;    var wrap = btn.closest(&apos;.dumpWrap&apos;);\n&quot;)
sb.append(&quot;    if (!wrap) return;\n&quot;)
sb.append(&quot;    var pre = wrap.querySelector(&apos;pre&apos;);\n&quot;)
sb.append(&quot;    if (!pre) return;\n&quot;)
sb.append(&quot;\n&quot;)
sb.append(&quot;    var b64 = btn.getAttribute(&apos;data-rawb64&apos;) || &apos;&apos;;\n&quot;)
sb.append(&quot;    var text = &apos;&apos;;\n&quot;)
sb.append(&quot;    try {\n&quot;)
sb.append(&quot;      if (b64) {\n&quot;)
sb.append(&quot;        text = decodeURIComponent(escape(atob(b64)));\n&quot;)
sb.append(&quot;      } else {\n&quot;)
sb.append(&quot;        text = pre.innerText || pre.textContent || &apos;&apos;;\n&quot;)
sb.append(&quot;      }\n&quot;)
sb.append(&quot;    } catch(e) {\n&quot;)
sb.append(&quot;      text = pre.innerText || pre.textContent || &apos;&apos;;\n&quot;)
sb.append(&quot;    }\n&quot;)
sb.append(&quot;\n&quot;)
sb.append(&quot;    var ok = await copyText(text);\n&quot;)
sb.append(&quot;    if (ok) {\n&quot;)
sb.append(&quot;      btn.classList.add(&apos;copied&apos;);\n&quot;)
sb.append(&quot;      toast(&apos;Copied&apos;);\n&quot;)
sb.append(&quot;      setTimeout(function(){ btn.classList.remove(&apos;copied&apos;); }, 900);\n&quot;)
sb.append(&quot;    } else {\n&quot;)
sb.append(&quot;      toast(&apos;Copy failed&apos;);\n&quot;)
sb.append(&quot;    }\n&quot;)
sb.append(&quot;  });\n&quot;)
sb.append(&quot;})();\n&quot;)
sb.append(&quot;&lt;/script&gt;\n&quot;)


// -----------------------------
// TAB SCRIPT
// -----------------------------
sb.append(&quot;&lt;script&gt;\n&quot;)
sb.append(&quot;(function(){\n&quot;)
sb.append(&quot;  var btns = document.querySelectorAll(&apos;#topTabs .tabBtn&apos;);\n&quot;)
sb.append(&quot;  var panels = document.querySelectorAll(&apos;.tabPanel&apos;);\n&quot;)
sb.append(&quot;  btns.forEach(function(btn){\n&quot;)
sb.append(&quot;    btn.addEventListener(&apos;click&apos;, function(){\n&quot;)
sb.append(&quot;      btns.forEach(function(b){ b.classList.remove(&apos;active&apos;); });\n&quot;)
sb.append(&quot;      panels.forEach(function(p){ p.classList.remove(&apos;active&apos;); });\n&quot;)
sb.append(&quot;      btn.classList.add(&apos;active&apos;);\n&quot;)
sb.append(&quot;      var id = btn.getAttribute(&apos;data-tab&apos;);\n&quot;)
sb.append(&quot;      var panel = document.getElementById(id);\n&quot;)
sb.append(&quot;      if(panel) panel.classList.add(&apos;active&apos;);\n&quot;)
sb.append(&quot;      if (id === &apos;panel_0&apos; &amp;&amp; window.__renderCharts) { setTimeout(window.__renderCharts, 80); }\n&quot;)
sb.append(&quot;    });\n&quot;)
sb.append(&quot;  });\n&quot;)
sb.append(&quot;})();\n&quot;)
sb.append(&quot;&lt;/script&gt;\n&quot;)

sb.append(&quot;&lt;/div&gt;\n&lt;/body&gt;\n&lt;/html&gt;\n&quot;)

htmlFile.setText(sb.toString(), &quot;UTF-8&quot;)
log.info(&quot;[HTML] generated: &quot; + htmlFile.absolutePath)
</stringProp>
        </JSR223Sampler>
