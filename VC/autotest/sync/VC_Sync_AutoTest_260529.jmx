        </TestAction>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="set_manual_DNR" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*
def U = props.get(&quot;CommonUtils&quot;)
def closeQ = U.closeQuietly; def setVcKey = U.setVcKey; def dumpPretty = U.dumpPretty
def vcUrl  = (vars.get(&quot;JDBC_URL_VC&quot;)  ?: &quot;&quot;).toString().trim()
def vcUser = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw   = (vars.get(&quot;JDBC_PW_VC&quot;)   ?: &quot;&quot;).toString()
def pid0   = (vars.get(&quot;PatientID0&quot;)   ?: &quot;&quot;).toString().trim()
def VC_TBL_PAT      = (vars.get(&quot;VC_TBL_EMR_PATIENT&quot;) ?: &quot;vitalcare.emr_patient&quot;).toString().trim()
def VC_TBL_DNR_HIST = (vars.get(&quot;VC_TBL_DNR_HISTORY&quot;) ?: &quot;vitalcare.emr_dnr_history&quot;).toString().trim()
def vcPidCond   = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id),@secretkey,@iv) AS CHAR)=?&quot;
def histPidCond = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),@secretkey,@iv) AS CHAR)=?&quot;

Connection vConn = null
try {
    vConn = DriverManager.getConnection(vcUrl, vcUser, vcPw)
    setVcKey(vConn, &quot;S16_SETUP&quot;)

    // manual_dnr=TRUE 설정
    def ps = vConn.prepareStatement(&quot;UPDATE ${VC_TBL_PAT} SET manual_dnr=? WHERE ${vcPidCond}&quot;)
    ps.setString(1, &quot;TRUE&quot;); ps.setString(2, pid0); ps.executeUpdate(); closeQ(ps)

    // before dump
    PreparedStatement psDump = null; ResultSet rsDump = null
    try {
        psDump = vConn.prepareStatement(&quot;&quot;&quot;
            SELECT created_dt, updated_dt,
                   CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id),@secretkey,@iv) AS CHAR) AS patient_id,
                   emr_dnr, manual_dnr
            FROM ${VC_TBL_PAT} WHERE ${vcPidCond}&quot;&quot;&quot;)
        psDump.setString(1, pid0); rsDump = psDump.executeQuery()
        def d = dumpPretty(&quot;${VC_TBL_PAT} (before)&quot;, rsDump, 10)
        vars.put(&quot;manual_dnr_before_dump&quot;, d?.trim() ?: &quot;${VC_TBL_PAT} (before)\n(0 rows)&quot;)
    } finally { closeQ(rsDump); closeQ(psDump) }

    // emr_dnr 현재값 기록
    PreparedStatement psEmrDnr = null; ResultSet rsEmrDnr = null
    try {
        psEmrDnr = vConn.prepareStatement(
            &quot;SELECT emr_dnr FROM ${VC_TBL_PAT} WHERE ${vcPidCond} LIMIT 1&quot;)
        psEmrDnr.setString(1, pid0); rsEmrDnr = psEmrDnr.executeQuery()
        def emrDnrVal = rsEmrDnr.next() ? (rsEmrDnr.getObject(1)?.toString() ?: &quot;null&quot;) : &quot;not_found&quot;
        vars.put(&quot;emr_dnr_before&quot;, emrDnrVal)
    } finally { closeQ(rsEmrDnr); closeQ(psEmrDnr) }

    // dnr_history count 기록
    PreparedStatement psHCnt = null; ResultSet rsHCnt = null
    try {
        psHCnt = vConn.prepareStatement(&quot;SELECT COUNT(*) FROM ${VC_TBL_DNR_HIST} WHERE ${histPidCond}&quot;)
        psHCnt.setString(1, pid0); rsHCnt = psHCnt.executeQuery()
        def cnt = rsHCnt.next() ? rsHCnt.getInt(1) : 0
        vars.put(&quot;hist_count_before&quot;, &quot;${cnt}&quot;)
    } finally { closeQ(rsHCnt); closeQ(psHCnt) }

} finally { closeQ(vConn) }
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="add_encounter_discharge" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*
import java.sql.Types
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter

String url  = vars.get(&quot;JDBC_URL&quot;)
String user = vars.get(&quot;JDBC_USER&quot;)
String pw   = vars.get(&quot;JDBC_PW&quot;)
String EMR_TBL_ENC = (vars.get(&quot;EMR_ENCOUNTER_TABLE&quot;) ?: &quot;ROOT.ENCOUNTERS&quot;).toString().trim()
String userThread  = (vars.get(&quot;User_Thread&quot;) ?: &quot;1&quot;).toString()

def fmt    = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd HH:mm:ss&quot;)
String pid0   = vars.get(&quot;PatientID0&quot;)
String eid0   = vars.get(&quot;EncounterID0&quot;)
String admStr = vars.get(&quot;AdmissionDate0&quot;)

LocalDateTime admDt    = LocalDateTime.parse(admStr, fmt)
LocalDateTime newAdmDt = admDt.plusDays(1)
String newEid     = eid0 + &quot;|2&quot;
String newAdmStr  = newAdmDt.format(fmt)
String newDiscStr = newAdmDt.withHour(23).withMinute(59).withSecond(0).format(fmt)

Connection conn = null
try {
    conn = DriverManager.getConnection(url, user, pw)

    PreparedStatement psEnc = null
    try {
        psEnc = conn.prepareStatement(
            &quot;INSERT INTO ${EMR_TBL_ENC} (ENCOUNTER_ID, PATIENT_ID, ADMISSION_DATE, DISCHARGE_DATE) &quot; +
            &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;))&quot;
        )
        psEnc.setString(1, newEid); psEnc.setString(2, pid0)
        psEnc.setString(3, newAdmStr); psEnc.setString(4, newDiscStr)
        psEnc.executeUpdate()
        log.info(&quot;[ADD_DISC_ENC] pid=${pid0} eid=${newEid} adm=${newAdmStr} disc=${newDiscStr}&quot;)
    } finally { try { psEnc?.close() } catch (ignored) {} }

    PreparedStatement psLoc = null
    try {
        psLoc = conn.prepareStatement(
            &quot;INSERT INTO ROOT.LOCATIONS (PATIENT_ID, ENCOUNTER_ID, START_DT, END_DT, WARD, ROOM, BED, &quot; +
            &quot;practitioner_id, practitioner_name, department_code, department_name) &quot; +
            &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?, ?, ?, ?, ?, ?, ?)&quot;
        )
        String ward = (userThread.toInteger() % 2 == 0) ? &quot;QA_ICU&quot; : &quot;QA_GW&quot;
        psLoc.setString(1, pid0); psLoc.setString(2, newEid)
        psLoc.setString(3, newAdmStr); psLoc.setNull(4, Types.VARCHAR)
        psLoc.setString(5, ward)
        psLoc.setString(6, userThread + &quot;QA_ROOM0&quot;); psLoc.setString(7, userThread + &quot;QA_BED0&quot;)
        psLoc.setString(8, userThread + &quot;QAP0&quot;);     psLoc.setString(9, userThread + &quot;테스트0&quot;)
        psLoc.setString(10, userThread + &quot;QAD0&quot;);    psLoc.setString(11, userThread + &quot;Quality Assurance0&quot;)
        psLoc.executeUpdate()
        log.info(&quot;[ADD_DISC_LOC] pid=${pid0} eid=${newEid}&quot;)
    } finally { try { psLoc?.close() } catch (ignored) {} }

    vars.put(&quot;EncounterID0_2&quot;, newEid)
} finally {
    try { conn?.close() } catch (ignored) {}
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Wait_for_Sync" enabled="true">
          <intProp name="ActionProcessor.action">1</intProp>
          <intProp name="ActionProcessor.target">0</intProp>
          <stringProp name="ActionProcessor.duration">180000</stringProp>
        </TestAction>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Verify_manual_DNR_DischEid">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*

def U = props.get(&quot;CommonUtils&quot;)
if (!(U instanceof Map)) throw new RuntimeException(&quot;[DNR_DISC] CommonUtils not found in props.&quot;)
def closeQ     = U.closeQuietly
def setVcKey   = U.setVcKey
def dumpPretty = U.dumpPretty
def finishFn   = U.finish

def scenarioId = (vars.get(&quot;scenario_id&quot;) ?: &quot;16&quot;).toString().trim()
def orderKey   = (vars.get(&quot;order_key&quot;)   ?: &quot;840&quot;).toString().trim()
def emrUrl  = (vars.get(&quot;JDBC_URL&quot;)     ?: &quot;&quot;).toString().trim()
def emrUser = (vars.get(&quot;JDBC_USER&quot;)    ?: &quot;&quot;).toString().trim()
def emrPw   = (vars.get(&quot;JDBC_PW&quot;)      ?: &quot;&quot;).toString()
def vcUrl   = (vars.get(&quot;JDBC_URL_VC&quot;)  ?: &quot;&quot;).toString().trim()
def vcUser  = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw    = (vars.get(&quot;JDBC_PW_VC&quot;)   ?: &quot;&quot;).toString()

def pid0            = (vars.get(&quot;PatientID0&quot;)       ?: &quot;&quot;).toString().trim()
def EMR_TBL_PAT     = (vars.get(&quot;EMR_PATIENT_TABLE&quot;)   ?: &quot;ROOT.PATIENTS&quot;).toString().trim()
def EMR_TBL_ENC     = (vars.get(&quot;EMR_ENCOUNTER_TABLE&quot;) ?: &quot;ROOT.ENCOUNTERS&quot;).toString().trim()
def VC_TBL_PAT      = (vars.get(&quot;VC_TBL_EMR_PATIENT&quot;)  ?: &quot;vitalcare.emr_patient&quot;).toString().trim()
def VC_TBL_DNR_HIST = (vars.get(&quot;VC_TBL_DNR_HISTORY&quot;)  ?: &quot;vitalcare.emr_dnr_history&quot;).toString().trim()
def histCountBefore = (vars.get(&quot;hist_count_before&quot;) ?: &quot;0&quot;).toInteger()

if (!pid0?.trim()) throw new RuntimeException(&quot;[DNR_DISC] PatientID0 is empty&quot;)
if (!emrUrl || !emrUser) throw new RuntimeException(&quot;[DNR_DISC] EMR JDBC vars empty&quot;)
if (!vcUrl  || !vcUser)  throw new RuntimeException(&quot;[DNR_DISC] VC JDBC vars empty&quot;)

def allFails  = []
String emrDumpStr = &quot;&quot;
String vcDumpStr  = &quot;&quot;

Connection eConn = null
Connection vConn = null

try {
    // ===== EMR dump =====
    eConn = DriverManager.getConnection(emrUrl, emrUser, emrPw)
    PreparedStatement psPat = null; ResultSet rsPat = null
    PreparedStatement psEnc = null; ResultSet rsEnc = null
    try {
        psPat = eConn.prepareStatement(
            &quot;SELECT CREATED_DT, UPDATED_DT, PATIENT_ID, DNR FROM ${EMR_TBL_PAT} WHERE PATIENT_ID=?&quot;)
        psPat.setString(1, pid0); rsPat = psPat.executeQuery()
        def patDump = dumpPretty(&quot;${EMR_TBL_PAT}&quot;, rsPat, 10)
        if (!patDump?.trim()) patDump = &quot;${EMR_TBL_PAT}\n(0 rows)\n&quot;

        psEnc = eConn.prepareStatement(&quot;&quot;&quot;
            SELECT CREATED_DT, UPDATED_DT, ENCOUNTER_ID, PATIENT_ID, ADMISSION_DATE, DISCHARGE_DATE
            FROM ${EMR_TBL_ENC} WHERE PATIENT_ID=? ORDER BY CREATED_DT&quot;&quot;&quot;)
        psEnc.setString(1, pid0); rsEnc = psEnc.executeQuery()
        def encDump = dumpPretty(&quot;${EMR_TBL_ENC}&quot;, rsEnc, 20)
        if (!encDump?.trim()) encDump = &quot;${EMR_TBL_ENC}\n(0 rows)\n&quot;

        emrDumpStr = (patDump.trim() + &quot;\n\n&quot; + encDump.trim()).trim() + &quot;\n&quot;
    } finally { closeQ(rsPat); closeQ(psPat); closeQ(rsEnc); closeQ(psEnc) }

    // ===== VC 연결 =====
    vConn = DriverManager.getConnection(vcUrl, vcUser, vcPw)
    setVcKey(vConn, &quot;DNR_DISC&quot;)

    def vcPidCond   = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id),@secretkey,@iv) AS CHAR)=?&quot;
    def histPidCond = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),@secretkey,@iv) AS CHAR)=?&quot;

    // ===== VC dump: before(Setup에서 저장) + after =====
    def beforeDump = (vars.get(&quot;manual_dnr_before_dump&quot;) ?: &quot;&quot;).toString()

    PreparedStatement psAfter = null; ResultSet rsAfter = null
    String afterDump = &quot;&quot;
    try {
        psAfter = vConn.prepareStatement(&quot;&quot;&quot;
            SELECT created_dt, updated_dt,
                   CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id),@secretkey,@iv) AS CHAR) AS patient_id,
                   emr_dnr, manual_dnr
            FROM ${VC_TBL_PAT} WHERE ${vcPidCond}&quot;&quot;&quot;)
        psAfter.setString(1, pid0); rsAfter = psAfter.executeQuery()
        def d = dumpPretty(&quot;${VC_TBL_PAT} (after)&quot;, rsAfter, 10)
        afterDump = d?.trim() ?: &quot;${VC_TBL_PAT} (after)\n(0 rows)&quot;
    } finally { closeQ(rsAfter); closeQ(psAfter) }

    // ===== VC dump: dnr_history =====
    PreparedStatement psHist = null; ResultSet rsHist = null
    String histDump = &quot;&quot;
    try {
        psHist = vConn.prepareStatement(&quot;&quot;&quot;
            SELECT created_dt, updated_dt,
                   CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),@secretkey,@iv) AS CHAR) AS patient_id,
                   CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id),@secretkey,@iv) AS CHAR) AS encounter_id,
                   reason, is_dnr
            FROM ${VC_TBL_DNR_HIST} WHERE ${histPidCond}
            ORDER BY created_dt ASC LIMIT 10&quot;&quot;&quot;)
        psHist.setString(1, pid0); rsHist = psHist.executeQuery()
        def d = dumpPretty(&quot;${VC_TBL_DNR_HIST}&quot;, rsHist, 10)
        histDump = d?.trim() ?: &quot;${VC_TBL_DNR_HIST}\n(0 rows)&quot;
    } finally { closeQ(rsHist); closeQ(psHist) }

    vcDumpStr = (beforeDump.trim() + &quot;\n\n&quot; + afterDump.trim() + &quot;\n\n&quot; + histDump.trim()).trim() + &quot;\n&quot;

    // ===== 검증 =====
    // ① manual_dnr 가 NULL이 아닌지 (변동 없어야 함)
    int vcCnt = 0
    PreparedStatement psCnt = null; ResultSet rsCnt = null
    try {
        psCnt = vConn.prepareStatement(&quot;SELECT COUNT(*) FROM ${VC_TBL_PAT} WHERE ${vcPidCond}&quot;)
        psCnt.setString(1, pid0); rsCnt = psCnt.executeQuery()
        if (rsCnt.next()) vcCnt = rsCnt.getInt(1)
    } finally { closeQ(rsCnt); closeQ(psCnt) }

    if (vcCnt == 0) {
        allFails &lt;&lt; &quot;VC row not found&quot;
    } else {
        PreparedStatement psVf = null; ResultSet rsVf = null
        try {
            psVf = vConn.prepareStatement(
                &quot;SELECT manual_dnr FROM ${VC_TBL_PAT} WHERE ${vcPidCond} LIMIT 1&quot;)
            psVf.setString(1, pid0); rsVf = psVf.executeQuery()
            if (rsVf.next()) {
                def raw = rsVf.getObject(1)
                if (raw == null) allFails &lt;&lt; &quot;manual_dnr reset to NULL&quot;
            }
        } finally { closeQ(rsVf); closeQ(psVf) }
    }

    // ② emr_dnr 변동 없는지 확인
    def emrDnrBefore = (vars.get(&quot;emr_dnr_before&quot;) ?: &quot;&quot;).toString()
    PreparedStatement psEmrDnr = null; ResultSet rsEmrDnr = null
    try {
        psEmrDnr = vConn.prepareStatement(
            &quot;SELECT emr_dnr FROM ${VC_TBL_PAT} WHERE ${vcPidCond} LIMIT 1&quot;)
        psEmrDnr.setString(1, pid0); rsEmrDnr = psEmrDnr.executeQuery()
        if (rsEmrDnr.next()) {
            def emrDnrAfter = rsEmrDnr.getObject(1)?.toString() ?: &quot;null&quot;
            if (emrDnrAfter != emrDnrBefore) {
                allFails &lt;&lt; &quot;emr_dnr changed&quot;
            }
        }
    } finally { closeQ(rsEmrDnr); closeQ(psEmrDnr) }


    // ③ dnr_history count 동일한지
    int histCntAfter = 0
    PreparedStatement psHCnt = null; ResultSet rsHCnt = null
    try {
        psHCnt = vConn.prepareStatement(
            &quot;SELECT COUNT(*) FROM ${VC_TBL_DNR_HIST} WHERE ${histPidCond}&quot;)
        psHCnt.setString(1, pid0); rsHCnt = psHCnt.executeQuery()
        if (rsHCnt.next()) histCntAfter = rsHCnt.getInt(1)
    } finally { closeQ(rsHCnt); closeQ(psHCnt) }

    if (histCntAfter != histCountBefore) {
        allFails &lt;&lt; &quot;history count changed (before=${histCountBefore}, after=${histCntAfter})&quot;
    }

} catch (Throwable t) {
    log.error(&quot;[DNR_DISC] Exception&quot;, t)
    allFails &lt;&lt; &quot;exception: &quot; + t.getClass().getSimpleName() + &quot; - &quot; + (t.getMessage() ?: &quot;&quot;)
} finally {
    closeQ(eConn); closeQ(vConn)
    String result = allFails.isEmpty() ? &quot;PASS&quot; : &quot;FAIL&quot;
    String notes  = allFails.isEmpty() ? &quot;&quot; : allFails.join(&quot; | &quot;)
    finishFn(prev, ctx, props, vars, orderKey, scenarioId, result, notes, emrDumpStr, vcDumpStr)
}

return
</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Scenario 17" enabled="true">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <OnceOnlyController guiclass="OnceOnlyControllerGui" testclass="OnceOnlyController" testname="Once Only Controller" enabled="true"/>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Setname Sampler" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">vars.put(&quot;currentControllerName&quot;, &quot;Scenario 9&quot;)

vars.put(&quot;scenario_id&quot;, &quot;퇴원 처리&quot;)
vars.put(&quot;expect_mode&quot;, &quot;SYNC_OK&quot;)
vars.put(&quot;order_key&quot;, &quot;900&quot;)
vars.put(&quot;verify_target&quot;, &quot;DISCHARGE&quot;)

vars.put(&quot;PatientCount&quot;, &quot;2&quot;)


String tgName = ctx.getThreadGroup().getName()
String tgNum = &quot;0&quot;
try { tgNum = tgName.split(&quot; &quot;)[1] } catch (ignored) { tgNum = &quot;0&quot; }
vars.put(&quot;tgNum&quot;, tgNum)

log.info(&quot;[INIT] parent=${vars.get(&apos;currentControllerName&apos;)}, scenario_id=${vars.get(&apos;scenario_id&apos;)}, label=${vars.get(&apos;scenario_label&apos;)}, expect_mode=${vars.get(&apos;expect_mode&apos;)}, order_key=${vars.get(&apos;order_key&apos;)}, verify_target=${vars.get(&apos;verify_target&apos;)}, PatientCount=${vars.get(&apos;PatientCount&apos;)}, tgNum=${vars.get(&apos;tgNum&apos;)}&quot;)
</stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Mark StartTime" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.text.SimpleDateFormat
import java.util.TimeZone
import java.util.Date

def tz = (vars.get(&quot;TimeZone&quot;) ?: &quot;Asia/Seoul&quot;).toString()
def sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss,SSS&quot;)
sdf.setTimeZone(TimeZone.getTimeZone(tz))

long startMs = System.currentTimeMillis()
vars.putObject(&quot;caseStartMillis&quot;, startMs)

def startTs = sdf.format(new Date(startMs))
vars.put(&quot;case_start_ts&quot;, startTs)

// CSV/HTML이 기존 키를 쓰면 호환용으로 같이 세팅
vars.put(&quot;verify_startTime&quot;, startTs)

log.info(&quot;[CASE_START] scenario_id=${vars.get(&apos;scenario_id&apos;)} start_ts=${startTs} TZ=${tz}&quot;)
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Patient_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;

def pidLog = (vars.get(&quot;patient_id&quot;) ?: vars.get(&quot;PatientID&quot;) ?: vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString()
log.info(&quot;[PAT INSERT DBG] scenario_id=&quot; + (vars.get(&quot;scenario_id&quot;) ?: &quot;&quot;)
        + &quot; thread=&quot; + ctx.getThreadNum()
        + &quot; pid=&quot; + pidLog)


// Scenario(Thread) start time: set once
if (!vars.get(&quot;startTimeThread&quot;)) {
    vars.put(&quot;startTimeThread&quot;, String.valueOf(System.currentTimeMillis()))
}

	// JDBC connection information
	String url = &quot;${JDBC_URL}&quot;;
	String user = &quot;${JDBC_USER}&quot;;
	String password = &quot;${JDBC_PW}&quot;;

	// Define the query
	String query = &quot;INSERT INTO ROOT.PATIENTS (PATIENT_ID, NAME, BIRTHDATE, SEX, DNR) &quot; +
	                &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?, ?)&quot;;

	// JDBC connection
	Connection conn = DriverManager.getConnection(url, user, password);

	// Prepare the statement
	PreparedStatement stmt = conn.prepareStatement(query);

	// Repeat the process for multiple sets of parameters
	int repeatCount = ${PatientCount}; // Number of repetitions set
		for (int i = 0; i &lt; repeatCount; i++) {
		    // Set String parameters for the query
		    String PatientID = vars.get(&quot;PatientID&quot; + i);
		    String Name = vars.get(&quot;Name&quot; + i);
		    String BirthDate = vars.get(&quot;BirthDate&quot; + i);
		    
		    // Set parameters for the query
		    stmt.setString(1, PatientID);
		    stmt.setString(2, &quot;QA&quot;+Name);
		    stmt.setString(3, BirthDate);
		    // Set gender based on whether i is odd or even
		    if (${User_Thread} % 2 == 0) {
		        stmt.setString(4, &quot;female&quot;);
		    } else {
		        stmt.setString(4, &quot;male&quot;);
		    }
		    stmt.setInt(5, i == 0 ? 0 : 1);  // PID1: DNR=0, PID2: DNR=1
		    
		    // Execute the query
		    int rowsInsert = stmt.executeUpdate();
		    
		    // Log
		    log.info(&quot;Inserted patientID: &quot; + PatientID);

		    vars.put(&quot;patient_id&quot;, PatientID)
			//log.info(&quot;[ID_MAP] patient_id=&quot; + vars.get(&quot;patient_id&quot;))

		    
		    // Clear parameters for reusing the statement
		    stmt.clearParameters();

		}
// Close the connection
conn.close();
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Patient Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount} // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
    
    // Create a Date object
    Date PatientSet = new Date(timestampDefault)
    Date EncounterSet = new Date(timestampDefault)
    Date NameSet = new Date(timestampDefault)

    // Set Date
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault) // Set the default timestamp    
    calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}))

    // --- Generate random birthdate for age between 19 and 150 ---
    int minAge = 19
    int maxAge = 110
    int randomAge = minAge + (int)(Math.random() * (maxAge - minAge + 1))
    
    // Copy current timestamp for age validation
    Calendar nowCal = Calendar.getInstance()
    nowCal.setTimeInMillis(timestampDefault)
    
    // Subtract random age in years
    calendar.add(Calendar.YEAR, -randomAge)
    
    // Randomize month and day
    int randomMonth = (int)(Math.random() * 12)  // 0-11
    calendar.set(Calendar.MONTH, randomMonth)
    int maxDay = calendar.getActualMaximum(Calendar.DAY_OF_MONTH)
    int randomDay = 1 + (int)(Math.random() * maxDay)
    calendar.set(Calendar.DAY_OF_MONTH, randomDay)
    
    // Ensure age is at least 19 (if birthday is in the future, subtract one more year)
    if (calendar.after(nowCal)) {
        calendar.add(Calendar.YEAR, -1)
    }
    
    // Final birthdate object
    long BirthDatetimeStamp = calendar.getTimeInMillis()
    Date BirthSet = new Date(BirthDatetimeStamp)
    
    String threadGroupName = ctx.getThreadGroup().getName()
    String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1]

    // Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i + &quot;yyMMddHHmmss&quot; + ${User_Thread} + threadGroupNumber)
    sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string
    String PatientID = sdf_patient.format(PatientSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_name = new SimpleDateFormat(i+&quot;ddHHmmss&quot;+${User_Thread})
    sdf_name.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String Name = sdf_name.format(NameSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_birthdate = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;)
    sdf_birthdate.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String BirthDate = sdf_birthdate.format(BirthSet)

    // Store in variables
    vars.put(&quot;PatientID&quot; + i, PatientID)
    vars.put(&quot;Name&quot; + i, Name)
    vars.put(&quot;BirthDate&quot; + i, BirthDate)
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Encounter_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;

	// JDBC connection information
	String url = &quot;${JDBC_URL}&quot;;
	String user = &quot;${JDBC_USER}&quot;;
	String password = &quot;${JDBC_PW}&quot;;

	// Define the query
	String query = &quot;INSERT INTO ROOT.ENCOUNTERS (ENCOUNTER_ID, PATIENT_ID, ADMISSION_DATE, DISCHARGE_DATE) &quot; +
	                &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;))&quot;;

    Connection conn = DriverManager.getConnection(url, user, password);
    PreparedStatement stmt = conn.prepareStatement(query);

	// Repeat the process for multiple sets of parameters
	int repeatCount = ${PatientCount}; // Number of repetitions set
		for (int i = 0; i &lt; repeatCount; i++) {
		    // Set parameters for the query
		    String EncounterID=vars.get(&quot;EncounterID&quot; + i);
		    String PatientID=vars.get(&quot;PatientID&quot; + i);
		    String AdmissionDate=vars.get(&quot;AdmissionDate&quot; + i);
		    String DisChargeDate=vars.get(&quot;DischargeDate&quot; + i);
		    stmt.setString(1, EncounterID);
		    stmt.setString(2, PatientID);
		    stmt.setString(3, AdmissionDate);
	         if (i == 9) {
		        stmt.setString(4, DisChargeDate);
		    } else {
		        stmt.setNull(4, java.sql.Types.DATE); // Set NULL value
		    }
		    
		    // Execute the query
		    int rowsInsert = stmt.executeUpdate();
		    
		    // Log the number of inserted rows
		    log.info(&quot;Inserted EncounterID: &quot; + EncounterID);

		    vars.put(&quot;encounter_id&quot;, EncounterID)  
			//log.info(&quot;[ID_MAP] encounter_id=&quot; + vars.get(&quot;encounter_id&quot;))

		    
		    // Clear parameters for reusing the statement
		    stmt.clearParameters();
		}
// Close the connection
conn.close();

 
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Encounter Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount} // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
    
    // Create a Date object
    Date PatientSet = new Date(timestampDefault)
    Date EncounterSet = new Date(timestampDefault)

    // Set Date
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault) // Set the default timestamp    
    calendar.add(Calendar.HOUR, -1)

    long DischargeDateTimestamp = calendar.getTimeInMillis()
    Date DischargeSet = new Date(DischargeDateTimestamp)

    calendar.setTimeInMillis(timestampDefault) // Reset timestamp    
    calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}))
    calendar.add(Calendar.MONTH, -(i+1))
    long AdmissionDatetimeStamp = calendar.getTimeInMillis()
    Date AdmissionSet = new Date(AdmissionDatetimeStamp)
    
    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_patient = new SimpleDateFormat(i+&quot;yyMMddHHmmss&quot;+${User_Thread})
    sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    
    // Format the date to string
    String PatientID = vars.get(&quot;PatientID&quot; + i)

    String threadGroupName = ctx.getThreadGroup().getName()
    String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1]

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_encounter = new SimpleDateFormat(i + &quot;yyyyMMddHHmmss&quot; + ${User_Thread} + threadGroupNumber)
    sdf_encounter.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String EncounterID = sdf_encounter.format(EncounterSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_admission = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    sdf_admission.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String AdmissionDate = sdf_admission.format(AdmissionSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_discharge = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    sdf_discharge.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String DischargeDate = sdf_discharge.format(DischargeSet)
    
    // Store in variables
    vars.put(&quot;EncounterID&quot; + i, EncounterID + &quot;|&quot; + PatientID)
    vars.put(&quot;AdmissionDate&quot; + i, AdmissionDate)
    vars.put(&quot;DischargeDate&quot; + i, DischargeDate)
}
</stringProp>
          </JSR223PreProcessor>
