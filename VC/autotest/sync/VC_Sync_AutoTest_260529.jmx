        </TestAction>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="update_dnr_onoff" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*

String url  = vars.get(&quot;JDBC_URL&quot;)
String user = vars.get(&quot;JDBC_USER&quot;)
String pw   = vars.get(&quot;JDBC_PW&quot;)
String pid0 = vars.get(&quot;PatientID0&quot;)
String pid1 = vars.get(&quot;PatientID1&quot;)

Connection conn = null
try {
    conn = DriverManager.getConnection(url, user, pw)
    PreparedStatement ps = conn.prepareStatement(
        &quot;UPDATE ROOT.PATIENTS SET DNR=? WHERE PATIENT_ID=?&quot;
    )
    // PID1: 0→1
    ps.setInt(1, 1); ps.setString(2, pid0); ps.executeUpdate(); ps.clearParameters()
    // PID2: 1→0
    ps.setInt(1, 0); ps.setString(2, pid1); ps.executeUpdate()
    log.info(&quot;[DNR UPDATE] pid0=${pid0} DNR→1, pid1=${pid1} DNR→0&quot;)
} finally {
    try { conn?.close() } catch (ignored) {}
}

log.info(&quot;[DNR UPDATE] dnrUpdateMillis=&quot; + vars.get(&quot;dnrUpdateMillis&quot;))</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Wait_for_Sync" enabled="true">
          <intProp name="ActionProcessor.action">1</intProp>
          <intProp name="ActionProcessor.target">0</intProp>
          <stringProp name="ActionProcessor.duration">180000</stringProp>
        </TestAction>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Verify_DNR_On" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*

// 0) CommonUtils
def U = props.get(&quot;CommonUtils&quot;)
if (!(U instanceof Map)) throw new RuntimeException(&quot;[DNR] CommonUtils not found in props.&quot;)
def closeQ     = U.closeQuietly
def setVcKey   = U.setVcKey
def dumpPretty = U.dumpPretty
def finishFn   = U.finish

// 1) vars
def scenarioId = (vars.get(&quot;scenario_id&quot;) ?: &quot;13&quot;).toString().trim()
def orderKey   = (vars.get(&quot;order_key&quot;)   ?: &quot;810&quot;).toString().trim()
def emrUrl  = (vars.get(&quot;JDBC_URL&quot;)     ?: &quot;&quot;).toString().trim()
def emrUser = (vars.get(&quot;JDBC_USER&quot;)    ?: &quot;&quot;).toString().trim()
def emrPw   = (vars.get(&quot;JDBC_PW&quot;)      ?: &quot;&quot;).toString()
def vcUrl   = (vars.get(&quot;JDBC_URL_VC&quot;)  ?: &quot;&quot;).toString().trim()
def vcUser  = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw    = (vars.get(&quot;JDBC_PW_VC&quot;)   ?: &quot;&quot;).toString()

def pid0 = (vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString().trim()
def eid0 = (vars.get(&quot;EncounterID0&quot;) ?: &quot;&quot;).toString().trim()
def pid1 = (vars.get(&quot;PatientID1&quot;) ?: &quot;&quot;).toString().trim()
def eid1 = (vars.get(&quot;EncounterID1&quot;) ?: &quot;&quot;).toString().trim()

def EMR_TBL_PAT     = (vars.get(&quot;EMR_PATIENT_TABLE&quot;)  ?: &quot;ROOT.PATIENTS&quot;).toString().trim()
def VC_TBL_PAT      = (vars.get(&quot;VC_TBL_EMR_PATIENT&quot;) ?: &quot;vitalcare.emr_patient&quot;).toString().trim()
def VC_TBL_DNR_HIST = (vars.get(&quot;VC_TBL_DNR_HISTORY&quot;) ?: &quot;vitalcare.emr_dnr_history&quot;).toString().trim()

[pid0, pid1].eachWithIndex { v, i -&gt;                                             
    if (!v?.trim()) throw new RuntimeException(&quot;[DNR] PatientID${i} is empty&quot;)
}
if (!emrUrl || !emrUser) throw new RuntimeException(&quot;[DNR] EMR JDBC vars empty&quot;)
if (!vcUrl  || !vcUser)  throw new RuntimeException(&quot;[DNR] VC JDBC vars empty&quot;)

def normDnr = { Object v -&gt;
    if (v == null) return &quot;0&quot;
    def s = v.toString().trim().toLowerCase()
    if (!s || s == &quot;null&quot;) return &quot;0&quot;
    if (s in [&quot;none&quot;,&quot;na&quot;,&quot;n/a&quot;,&quot;no&quot;,&quot;n&quot;,&quot;off&quot;,&quot;false&quot;,&quot;f&quot;]) return &quot;0&quot;
    if (s in [&quot;yes&quot;,&quot;y&quot;,&quot;on&quot;,&quot;true&quot;,&quot;t&quot;]) return &quot;1&quot;
    if (s.isInteger()) return (s == &quot;0&quot;) ? &quot;0&quot; : &quot;1&quot;
    def m = (s =~ /(\d+)/)
    if (m.find()) return (m.group(1) == &quot;0&quot;) ? &quot;0&quot; : &quot;1&quot;
    s
}

// 케이스 정의
// PID1(i=0): 초기 DNR=0 → 업데이트 DNR=1 → emr_dnr=TRUE, history=[FALSE, TRUE]
// PID2(i=1): 초기 DNR=1 → 업데이트 DNR=0 → emr_dnr=FALSE, history=[TRUE, FALSE]
def cases = [
    [pid: pid0, expEmrDnr: &quot;1&quot;, expHist: [false, true],  label: &quot;PID1(0→1)&quot;],
    [pid: pid1, expEmrDnr: &quot;0&quot;, expHist: [true,  false], label: &quot;PID2(1→0)&quot;]
]

def allFails = []
String emrDumpStr = &quot;&quot;
String vcDumpStr  = &quot;&quot;

Connection eConn = null
Connection vConn = null

try {
    // ===== EMR dump (두 환자) =====
    eConn = DriverManager.getConnection(emrUrl, emrUser, emrPw)

    PreparedStatement psEd = null; ResultSet rsEd = null
    try {
        psEd = eConn.prepareStatement(&quot;&quot;&quot;
            SELECT CREATED_DT, UPDATED_DT, PATIENT_ID, DNR
            FROM ${EMR_TBL_PAT}
            WHERE PATIENT_ID IN (?, ?)
            ORDER BY PATIENT_ID
        &quot;&quot;&quot;)
        psEd.setString(1, pid0); psEd.setString(2, pid1)
        rsEd = psEd.executeQuery()
        emrDumpStr = dumpPretty(&quot;${EMR_TBL_PAT}&quot;, rsEd, 50)
        if (!emrDumpStr?.trim()) emrDumpStr = &quot;${EMR_TBL_PAT}\n(0 rows)\n&quot;
    } finally { closeQ(rsEd); closeQ(psEd) }

    // ===== VC 연결 =====
    vConn = DriverManager.getConnection(vcUrl, vcUser, vcPw)
    setVcKey(vConn, &quot;DNR&quot;)

    def vcPidCond   = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id),@secretkey,@iv) AS CHAR)=?&quot;
    def histPidCond = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),@secretkey,@iv) AS CHAR)=?&quot;

    // ===== VC dump: emr_patient (두 환자 순차) =====
    def patDumps = []
    [pid0, pid1].each { p -&gt;
        PreparedStatement ps = null; ResultSet rs = null
        try {
            ps = vConn.prepareStatement(&quot;&quot;&quot;
                SELECT created_dt, updated_dt,
           CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id), @secretkey,@iv) AS CHAR) AS patient_id,
           emr_dnr, manual_dnr
                FROM ${VC_TBL_PAT}
                WHERE ${vcPidCond}
                LIMIT 10
            &quot;&quot;&quot;)
            ps.setString(1, p); rs = ps.executeQuery()
            def d = dumpPretty(&quot;${VC_TBL_PAT}&quot;, rs, 10)
            patDumps &lt;&lt; (d?.trim() ?: &quot;${VC_TBL_PAT}\n(0 rows)\n&quot;)
        } finally { closeQ(rs); closeQ(ps) }
    }

    // ===== VC dump: emr_dnr_history (두 환자 순차) =====
    def histDumps = []
    [pid0, pid1].each { p -&gt;
        PreparedStatement ps = null; ResultSet rs = null
        try {
            ps = vConn.prepareStatement(&quot;&quot;&quot;
    SELECT created_dt, updated_dt,
           CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id), @secretkey, @iv) AS CHAR) AS patient_id,
           reason, is_dnr
    FROM ${VC_TBL_DNR_HIST}
    WHERE ${histPidCond}
    ORDER BY created_dt ASC
    LIMIT 10
&quot;&quot;&quot;)
            ps.setString(1, p); rs = ps.executeQuery()
            def d = dumpPretty(&quot;${VC_TBL_DNR_HIST}&quot;, rs, 10)
            histDumps &lt;&lt; (d?.trim() ?: &quot;${VC_TBL_DNR_HIST}\n(0 rows)\n&quot;)
        } finally { closeQ(rs); closeQ(ps) }
    }

    vcDumpStr = (
    &quot;[PID1]\n&quot; + patDumps[0].trim() + &quot;\n\n&quot; + histDumps[0].trim() + &quot;\n\n&quot; +
    &quot;[PID2]\n&quot; + patDumps[1].trim() + &quot;\n\n&quot; + histDumps[1].trim()
).trim() + &quot;\n&quot;

    // ===== 검증 =====
    cases.each { c -&gt;
        def caseFails = []

        // ① emr_patient.emr_dnr 확인
        int vcCnt = 0
        PreparedStatement psCnt = null; ResultSet rsCnt = null
        try {
            psCnt = vConn.prepareStatement(&quot;SELECT COUNT(*) FROM ${VC_TBL_PAT} WHERE ${vcPidCond}&quot;)
            psCnt.setString(1, c.pid); rsCnt = psCnt.executeQuery()
            if (rsCnt.next()) vcCnt = rsCnt.getInt(1)
        } finally { closeQ(rsCnt); closeQ(psCnt) }

        if (vcCnt == 0) {
            caseFails &lt;&lt; &quot;VC row not found&quot;
        } else {
            if (vcCnt &gt; 1) caseFails &lt;&lt; &quot;VC row duplicated (count=${vcCnt})&quot;
            String vcEmrDnr = &quot;0&quot;
            PreparedStatement psVf = null; ResultSet rsVf = null
            try {
                psVf = vConn.prepareStatement(&quot;SELECT emr_dnr FROM ${VC_TBL_PAT} WHERE ${vcPidCond} LIMIT 1&quot;)
                psVf.setString(1, c.pid); rsVf = psVf.executeQuery()
                if (rsVf.next()) vcEmrDnr = normDnr(rsVf.getObject(1))
            } finally { closeQ(rsVf); closeQ(psVf) }
            if (vcEmrDnr != c.expEmrDnr)
                caseFails &lt;&lt; &quot;emr_dnr mismatch&quot;
        }


        // ② emr_dnr_history 확인
        def histRows = []
        PreparedStatement psH = null; ResultSet rsH = null
        try {
            psH = vConn.prepareStatement(&quot;&quot;&quot;
                SELECT created_dt, updated_dt, is_dnr
                FROM ${VC_TBL_DNR_HIST}
                WHERE ${histPidCond}
                ORDER BY created_dt ASC
                LIMIT 10
            &quot;&quot;&quot;)
            psH.setString(1, c.pid); rsH = psH.executeQuery()
            while (rsH.next()) {
                histRows &lt;&lt; [cd: rsH.getTimestamp(1), ud: rsH.getTimestamp(2), dn: rsH.getObject(3)]
            }
        } finally { closeQ(rsH); closeQ(psH) }

        if (histRows.size() != 2) {
    caseFails &lt;&lt; &quot;history count=${histRows.size()} (expected 2)&quot;
} else {
    [0, 1].each { idx -&gt;
        def actual   = normDnr(histRows[idx].dn)
        def expected = c.expHist[idx] ? &quot;1&quot; : &quot;0&quot;
        if (actual != expected)
            caseFails &lt;&lt; &quot;history[${idx}].is_dnr mismatch&quot;

        if (histRows[idx].cd?.getTime() != histRows[idx].ud?.getTime())
            caseFails &lt;&lt; &quot;history[${idx}].created_dt != updated_dt&quot;
    }

    if (histRows[1].cd.getTime() &lt;= histRows[0].cd.getTime())
        caseFails &lt;&lt; &quot;history[1].created_dt not after history[0].created_dt&quot;
}
        if (caseFails) allFails &lt;&lt; &quot;${c.label}: &quot; + caseFails.join(&quot;, &quot;)
    }

} catch (Throwable t) {
    log.error(&quot;[DNR] Exception&quot;, t)
    allFails &lt;&lt; &quot;exception: &quot; + t.getClass().getSimpleName() + &quot; - &quot; + (t.getMessage() ?: &quot;&quot;)
} finally {
    closeQ(eConn); closeQ(vConn)
    String result = allFails.isEmpty() ? &quot;PASS&quot; : &quot;FAIL&quot;
    String notes  = allFails.isEmpty() ? &quot;&quot; : allFails.join(&quot; | &quot;)
    finishFn(prev, ctx, props, vars, orderKey, scenarioId, result, notes, emrDumpStr, vcDumpStr)
}

return</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Scenario 14" enabled="true">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <OnceOnlyController guiclass="OnceOnlyControllerGui" testclass="OnceOnlyController" testname="Once Only Controller" enabled="true"/>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Setname Sampler" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">vars.put(&quot;currentControllerName&quot;, &quot;Scenario 8&quot;)

vars.put(&quot;scenario_id&quot;, &quot;DNR 연동 O - 재원 EID 추가&quot;)
vars.put(&quot;expect_mode&quot;, &quot;SYNC_OK&quot;)
vars.put(&quot;order_key&quot;, &quot;820&quot;)
vars.put(&quot;verify_target&quot;, &quot;DNR_EID&quot;)
vars.put(&quot;dnr_env&quot;, &quot;ON&quot;)

vars.put(&quot;PatientCount&quot;, &quot;2&quot;)


String tgName = ctx.getThreadGroup().getName()
String tgNum = &quot;0&quot;
try { tgNum = tgName.split(&quot; &quot;)[1] } catch (ignored) { tgNum = &quot;0&quot; }
vars.put(&quot;tgNum&quot;, tgNum)

log.info(&quot;[INIT] parent=${vars.get(&apos;currentControllerName&apos;)}, scenario_id=${vars.get(&apos;scenario_id&apos;)}, label=${vars.get(&apos;scenario_label&apos;)}, expect_mode=${vars.get(&apos;expect_mode&apos;)}, order_key=${vars.get(&apos;order_key&apos;)}, verify_target=${vars.get(&apos;verify_target&apos;)}, PatientCount=${vars.get(&apos;PatientCount&apos;)}, tgNum=${vars.get(&apos;tgNum&apos;)}&quot;)
</stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Setup_DNR_Env" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import com.jcraft.jsch.*

def host        = vars.get(&quot;SSH_HOST&quot;)
def port        = Integer.parseInt(vars.get(&quot;SSH_PORT&quot;) ?: &quot;22&quot;)
def sshUser     = vars.get(&quot;SSH_USER&quot;)
def sshPw       = vars.get(&quot;SSH_PW&quot;)
def composeDir  = vars.get(&quot;SSH_COMPOSE_DIR&quot;)
def filePath    = &quot;${composeDir}/envs/vc-sync-v220.env&quot;
def targetValue = (vars.get(&quot;dnr_env&quot;) == &quot;ON&quot;) ? &quot;true&quot; : &quot;false&quot;

def execCmd = { Session sess, String cmd -&gt;
    ChannelExec ch = (ChannelExec) sess.openChannel(&quot;exec&quot;)
    ch.setCommand(cmd)
    def is = ch.getInputStream()
    ch.connect()
    def sb = new StringBuilder()
    def buf = new byte[1024]; int len
    while ((len = is.read(buf)) != -1) sb.append(new String(buf, 0, len))
    while (!ch.isClosed()) Thread.sleep(100)
    ch.disconnect()
    sb.toString().trim()
}

Session session = null
try {
    def jsch = new JSch()
    session = jsch.getSession(sshUser, host, port)
    session.setPassword(sshPw)
    session.setConfig(&quot;StrictHostKeyChecking&quot;, &quot;no&quot;)
    session.connect(10000)

    def current      = execCmd(session, &quot;grep &apos;VCSYNC_SYNC_DNR&apos; ${filePath}&quot;)
    def currentValue = current.split(&quot;=&quot;)[1]?.trim()
    log.info(&quot;[Setup_DNR_Env] current=${currentValue}, target=${targetValue}&quot;)

    if (currentValue != targetValue) {
        execCmd(session, &quot;sed -i &apos;s/VCSYNC_SYNC_DNR=${currentValue}/VCSYNC_SYNC_DNR=${targetValue}/&apos; ${filePath}&quot;)
        execCmd(session, &quot;cd ${composeDir} &amp;&amp; docker compose up -d sync&quot;)
        vars.put(&quot;envChanged&quot;, &quot;true&quot;)
        log.info(&quot;[Setup_DNR_Env] ${currentValue} → ${targetValue} 변경 후 재시작&quot;)
    } else {
        vars.put(&quot;envChanged&quot;, &quot;false&quot;)
        log.info(&quot;[Setup_DNR_Env] 변경 불필요 (이미 ${targetValue})&quot;)
    }

} catch (Throwable t) {
    log.error(&quot;[Setup_DNR_Env] Exception&quot;, t)
    vars.put(&quot;envChanged&quot;, &quot;false&quot;)
    throw t
} finally {
    session?.disconnect()
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <IfController guiclass="IfControllerPanel" testclass="IfController" testname="If Controller" enabled="true">
          <stringProp name="IfController.condition">${envChanged}</stringProp>
