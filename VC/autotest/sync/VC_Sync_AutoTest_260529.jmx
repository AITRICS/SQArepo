        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Verify_Vital_Sibling" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*
import java.math.BigDecimal

// 0) CommonUtils
def U = props.get(&quot;CommonUtils&quot;)
if (!(U instanceof Map)) throw new RuntimeException(&quot;[SIBLING] CommonUtils not found in props.&quot;)
def closeQ     = U.closeQuietly
def setVcKey   = U.setVcKey
def dumpPretty = U.dumpPretty
def finishFn   = U.finish

// 1) vars / config
def scenarioId = (vars.get(&quot;scenario_id&quot;) ?: &quot;11&quot;).toString().trim()

def emrUrl  = (vars.get(&quot;JDBC_URL&quot;)      ?: &quot;&quot;).toString().trim()
def emrUser = (vars.get(&quot;JDBC_USER&quot;)     ?: &quot;&quot;).toString().trim()
def emrPw   = (vars.get(&quot;JDBC_PW&quot;)       ?: &quot;&quot;).toString()
def vcUrl   = (vars.get(&quot;JDBC_URL_VC&quot;)   ?: &quot;&quot;).toString().trim()
def vcUser  = (vars.get(&quot;JDBC_USER_VC&quot;)  ?: &quot;&quot;).toString().trim()
def vcPw    = (vars.get(&quot;JDBC_PW_VC&quot;)    ?: &quot;&quot;).toString()
def pid     = (vars.get(&quot;patient_id&quot;)    ?: &quot;&quot;).toString().trim()
def eid     = (vars.get(&quot;encounter_id&quot;)  ?: &quot;&quot;).toString().trim()

def must = { String k, String v -&gt; if (!v?.trim()) throw new RuntimeException(&quot;[SIBLING] ${k} empty&quot;); v.trim() }
must(&quot;JDBC_URL&quot;, emrUrl); must(&quot;JDBC_USER&quot;, emrUser)
must(&quot;JDBC_URL_VC&quot;, vcUrl); must(&quot;JDBC_USER_VC&quot;, vcUser)
must(&quot;patient_id&quot;, pid); must(&quot;encounter_id&quot;, eid)

def EMR_VITAL_TABLE = (vars.get(&quot;EMR_VITAL_TABLE&quot;) ?: &quot;ROOT.VITALS&quot;).toString().trim()
def VC_TBL_EMR_OBS  = (vars.get(&quot;VC_TBL_EMR_OBS&quot;)  ?: &quot;vitalcare.emr_observation&quot;).toString().trim()
def VC_TBL_VC_OBS   = (vars.get(&quot;VC_TBL_VC_OBS&quot;)   ?: &quot;vitalcare.vc_observation&quot;).toString().trim()
def VC_TBL_VC_EVENT = (vars.get(&quot;VC_TBL_VC_EVENT&quot;) ?: &quot;vitalcare.vc_event&quot;).toString().trim()

final long OFFSET_9H_MS = 9L * 60L * 60L * 1000L

// 2) mapType
def mapType = { String c -&gt;
    if (!c) return &quot;&quot;
    switch (c.trim()) {
        case &quot;HR&quot;:       return &quot;PR&quot;
        case &quot;PULSE&quot;:    return &quot;PR&quot;
        case &quot;ISBP&quot;:     return &quot;SBP&quot;
        case &quot;IDBP&quot;:     return &quot;DBP&quot;
        case &quot;GCS_LOC&quot;:  return &quot;GCS&quot;
        case &quot;GCS_AVPU&quot;: return &quot;GCS&quot;
        case &quot;GCS_EVM&quot;:  return &quot;GCS&quot;
        default:         return c.trim()
    }
}

// 3) value compare helpers
def asBd = { Object v -&gt;
    if (v == null) return null
    if (v instanceof Number) return BigDecimal.valueOf(((Number)v).doubleValue())
    def s = v.toString().trim()
    if (!s) return null
    try { return new BigDecimal(s) } catch (ignored) {
        def m = (s =~ /-?\d+(\.\d+)?/)
        return m.find() ? new BigDecimal(m.group(0)) : null
    }
}

def eqValue = { String emrCode, Object emrVal, Object vcVal -&gt;
    BigDecimal e = asBd(emrVal)
    BigDecimal v = asBd(vcVal)
    if (e != null &amp;&amp; v != null) return e.stripTrailingZeros().compareTo(v.stripTrailingZeros()) == 0
    def es = (emrVal == null ? &quot;&quot; : emrVal.toString().trim())
    def vs = (vcVal  == null ? &quot;&quot; : vcVal.toString().trim())
    return es == vs
}

// 4) cases
def cases = [
    [label:&quot;HR→PR&quot;,          emrCodes:[&quot;HR&quot;],                               vcTypes:[&quot;PR&quot;],                                     emrExp:1, vcExp:1],
    [label:&quot;PULSE→PR&quot;,       emrCodes:[&quot;PULSE&quot;],                            vcTypes:[&quot;PR&quot;],                                     emrExp:1, vcExp:1],
    [label:&quot;ISBP→SBP&quot;,       emrCodes:[&quot;ISBP&quot;],                             vcTypes:[&quot;SBP&quot;],                                    emrExp:1, vcExp:1],
    [label:&quot;SBP→SBP&quot;,        emrCodes:[&quot;SBP&quot;],                              vcTypes:[&quot;SBP&quot;],                                    emrExp:1, vcExp:1],
    [label:&quot;IDBP→DBP&quot;,       emrCodes:[&quot;IDBP&quot;],                             vcTypes:[&quot;DBP&quot;],                                    emrExp:1, vcExp:1],
    [label:&quot;DBP→DBP&quot;,        emrCodes:[&quot;DBP&quot;],                              vcTypes:[&quot;DBP&quot;],                                    emrExp:1, vcExp:1],
    [label:&quot;GCS_LOC→GCS&quot;,    emrCodes:[&quot;GCS_LOC&quot;],                          vcTypes:[&quot;GCS&quot;],                                    emrExp:1, vcExp:1],
    [label:&quot;GCS_AVPU→GCS&quot;,   emrCodes:[&quot;GCS_AVPU&quot;],                         vcTypes:[&quot;GCS&quot;],                                    emrExp:1, vcExp:1],
    [label:&quot;GCS→GCS&quot;,        emrCodes:[&quot;GCS&quot;],                              vcTypes:[&quot;GCS&quot;],                                    emrExp:1, vcExp:1],
    [label:&quot;GCS_EVM→GCS&quot;,    emrCodes:[&quot;GCS_EYE&quot;,&quot;GCS_VERBAL&quot;,&quot;GCS_MOTOR&quot;], vcTypes:[&quot;GCS_EYE&quot;,&quot;GCS_VERBAL&quot;,&quot;GCS_MOTOR&quot;,&quot;GCS&quot;], emrExp:3, vcExp:4]
]

// dump용 전체 코드/타입 (설계 순서 기준)
def allEmrCodes = [&quot;HR&quot;,&quot;PULSE&quot;,&quot;ISBP&quot;,&quot;SBP&quot;,&quot;IDBP&quot;,&quot;DBP&quot;,&quot;GCS_LOC&quot;,&quot;GCS_AVPU&quot;,&quot;GCS&quot;,&quot;GCS_EYE&quot;,&quot;GCS_VERBAL&quot;,&quot;GCS_MOTOR&quot;]
def allVcTypes  = [&quot;PR&quot;,&quot;SBP&quot;,&quot;DBP&quot;,&quot;GCS&quot;,&quot;GCS_EYE&quot;,&quot;GCS_VERBAL&quot;,&quot;GCS_MOTOR&quot;]

def vcPidExpr = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),   @secretkey, @iv) AS CHAR)&quot;
def vcEidExpr = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR)&quot;

def allFails      = []
String allEmrDump = &quot;&quot;
String allVcDump  = &quot;&quot;

Connection eConn = null
Connection vConn = null

try {
    eConn = DriverManager.getConnection(emrUrl, emrUser, emrPw)
    vConn = DriverManager.getConnection(vcUrl, vcUser, vcPw)
    setVcKey(vConn, &quot;VITAL&quot;)

    // =====================================================
    // 검증 루프 (dump 없음)
    // =====================================================
    for (int j = 0; j &lt; 10; j++) {
        def c               = cases[j]
        String caseLabel    = c.label
        List&lt;String&gt; cEmrCodes = c.emrCodes
        List&lt;String&gt; cVcTypes  = c.vcTypes
        int emrExp = c.emrExp
        int vcExp  = c.vcExp

        String observedDtStr = vars.get(&quot;ObservedDt&quot; + j)

        def caseFails     = []
        def mismatchLines = []

        try {
            // A) EMR 조회
            def emrMap = [:]
            Timestamp vcObsTs = null

            PreparedStatement psEmr = null; ResultSet rsEmr = null
            try {
                psEmr = eConn.prepareStatement(&quot;&quot;&quot;
                    SELECT OBSERVED_DT, CODE, VALUE
                    FROM ${EMR_VITAL_TABLE}
                    WHERE PATIENT_ID=? AND ENCOUNTER_ID=?
                      AND OBSERVED_DT=TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;)
                      AND CODE IN (${cEmrCodes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
                      AND DELETED_YN=0 AND INVALID=0
                &quot;&quot;&quot;)
                int i = 1
                psEmr.setString(i++, pid); psEmr.setString(i++, eid); psEmr.setString(i++, observedDtStr)
                cEmrCodes.each { code -&gt; psEmr.setString(i++, code) }
                rsEmr = psEmr.executeQuery()
                while (rsEmr.next()) {
                    Timestamp emrObs  = rsEmr.getTimestamp(1)
                    String    emrCode = (rsEmr.getString(2) ?: &quot;&quot;).toString().trim()
                    Object    emrVal  = rsEmr.getObject(3)
                    String    vcType  = mapType(emrCode)
                    Timestamp vcObs   = new Timestamp(emrObs.getTime() - OFFSET_9H_MS)
                    String    key     = vcObs.getTime() + &quot;|&quot; + vcType
                    emrMap[key] = [code: emrCode, val: emrVal, emrObs: emrObs, vcObs: vcObs]
                    if (vcObsTs == null) vcObsTs = vcObs
                }
            } finally { closeQ(rsEmr); closeQ(psEmr) }

            if (emrMap.size() != emrExp)
                caseFails &lt;&lt; &quot;EMR rows != ${emrExp} (got=${emrMap.size()})&quot;

            // B) VC 조회
            if (vcObsTs == null) {
                def sdf = new java.text.SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
                sdf.setTimeZone(java.util.TimeZone.getTimeZone(&quot;UTC&quot;))
                vcObsTs = new Timestamp(sdf.parse(observedDtStr).getTime() - OFFSET_9H_MS)
            }
            final Timestamp vcObsTsFinal = vcObsTs

            def loadVcMap = { String tableName, String typeCol, String valueCol, String extraWhere -&gt;
                def m = [:]
                PreparedStatement ps = null; ResultSet rs = null
                try {
                    ps = vConn.prepareStatement(&quot;&quot;&quot;
                        SELECT observed_dt, ${typeCol} AS t, ${valueCol} AS v
                        FROM ${tableName}
                        WHERE ${vcPidExpr}=? AND ${vcEidExpr}=?
                          AND observed_dt=?
                          AND ${typeCol} IN (${cVcTypes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
                          ${extraWhere ?: &quot;&quot;}
                    &quot;&quot;&quot;)
                    int p = 1
                    ps.setString(p++, pid); ps.setString(p++, eid)
                    ps.setTimestamp(p++, vcObsTsFinal)
                    cVcTypes.each { t -&gt; ps.setString(p++, t) }
                    rs = ps.executeQuery()
                    while (rs.next()) {
                        Timestamp obs = rs.getTimestamp(1)
                        String    t   = (rs.getString(2) ?: &quot;&quot;).toString().trim()
                        Object    v   = rs.getObject(3)
                        m[obs.getTime() + &quot;|&quot; + t] = v
                    }
                    return m
                } finally { closeQ(rs); closeQ(ps) }
            }

            def vcObsMap  = loadVcMap(VC_TBL_VC_OBS,   &quot;type&quot;,        &quot;value&quot;, &quot;&quot;)
            def emrObsMap = loadVcMap(VC_TBL_EMR_OBS,  &quot;type&quot;,        &quot;value&quot;, &quot;&quot;)
            def evtMap    = loadVcMap(VC_TBL_VC_EVENT,  &quot;subcategory&quot;, &quot;value&quot;, &quot;AND category=&apos;Observation&apos;&quot;)

            if (vcObsMap.size() == 0 &amp;&amp; emrObsMap.size() == 0 &amp;&amp; evtMap.size() == 0) {
                caseFails &lt;&lt; &quot;VC row not found&quot;
            } else {
                if (vcObsMap.size()  != vcExp) caseFails &lt;&lt; &quot;VC vc_observation rows != ${vcExp} (got=${vcObsMap.size()})&quot;
                if (emrObsMap.size() != vcExp) caseFails &lt;&lt; &quot;VC emr_observation rows != ${vcExp} (got=${emrObsMap.size()})&quot;
                if (evtMap.size()    != vcExp) caseFails &lt;&lt; &quot;VC vc_event rows != ${vcExp} (got=${evtMap.size()})&quot;
            }

            boolean canDetailCompare =
                emrMap.size() == emrExp &amp;&amp;
                vcObsMap.size() == vcExp &amp;&amp; emrObsMap.size() == vcExp &amp;&amp; evtMap.size() == vcExp

            if (canDetailCompare) {
                def addMismatch = { String where, String code, String type, Object ev, Object av -&gt;
                    if (mismatchLines.size() &lt; 10)
                        mismatchLines &lt;&lt; &quot;${where} ${code} mismatch (emr=${ev}, vc=${av})&quot;
                }

                emrMap.each { key, rec -&gt;
                    String code   = rec.code
                    String vcType = mapType(code)
                    Object emrVal = rec.val
                    Object v1 = vcObsMap[key]; Object v2 = emrObsMap[key]; Object v3 = evtMap[key]
                    if (v1 == null || v2 == null || v3 == null) {
                        if (mismatchLines.size() &lt; 10) mismatchLines &lt;&lt; &quot;missing row (${code}) [type=${vcType}]&quot;
                        return
                    }
                    if (!eqValue(code, emrVal, v1)) addMismatch(&quot;vc_observation&quot;,  code, vcType, emrVal, v1)
                    if (!eqValue(code, emrVal, v2)) addMismatch(&quot;emr_observation&quot;, code, vcType, emrVal, v2)
                    if (!eqValue(code, emrVal, v3)) addMismatch(&quot;vc_event&quot;,        code, vcType, emrVal, v3)
                }

                if (j == 9) {
                    long tsMs    = vcObsTsFinal.getTime()
                    def eyeVal   = asBd(vcObsMap[&quot;${tsMs}|GCS_EYE&quot;])
                    def verbVal  = asBd(vcObsMap[&quot;${tsMs}|GCS_VERBAL&quot;])
                    def motorVal = asBd(vcObsMap[&quot;${tsMs}|GCS_MOTOR&quot;])
                    def gcsVal   = asBd(vcObsMap[&quot;${tsMs}|GCS&quot;])
                    if (eyeVal != null &amp;&amp; verbVal != null &amp;&amp; motorVal != null &amp;&amp; gcsVal != null) {
                        def expected = eyeVal.add(verbVal).add(motorVal)
                        if (expected.stripTrailingZeros().compareTo(gcsVal.stripTrailingZeros()) != 0)
                            addMismatch(&quot;vc_observation(GCS_EVM sum)&quot;, &quot;GCS_EVM&quot;, &quot;GCS&quot;, expected, gcsVal)
                    } else {
                        if (mismatchLines.size() &lt; 10)
                            mismatchLines &lt;&lt; &quot;GCS_EVM sum check: null value (EYE=${eyeVal} VERBAL=${verbVal} MOTOR=${motorVal} GCS=${gcsVal})&quot;
                    }
                }
            }

            if (!mismatchLines.isEmpty())
                caseFails &lt;&lt; mismatchLines.join(&quot;, &quot;)

        } catch (Throwable t) {
            log.error(&quot;[SIBLING] case=${caseLabel} exception&quot;, t)
            caseFails &lt;&lt; &quot;exception: &quot; + t.getClass().getSimpleName() + &quot; - &quot; + (t.getMessage() ?: &quot;&quot;)
        }

        caseFails.each { msg -&gt; allFails &lt;&lt; &quot;[${caseLabel}] ${msg}&quot; }
    }

    // =====================================================
    // 통합 dump (루프 후 1회)
    // =====================================================
    PreparedStatement psBigEmr = null; ResultSet rsBigEmr = null
    try {
        psBigEmr = eConn.prepareStatement(&quot;&quot;&quot;
            SELECT CREATED_DT, UPDATED_DT, PATIENT_ID, ENCOUNTER_ID, OBSERVED_DT, CODE, VALUE
            FROM ${EMR_VITAL_TABLE}
            WHERE PATIENT_ID=? AND ENCOUNTER_ID=?
              AND CODE IN (${allEmrCodes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
              AND DELETED_YN=0 AND INVALID=0
            ORDER BY OBSERVED_DT DESC
        &quot;&quot;&quot;)
        int i = 1
        psBigEmr.setString(i++, pid); psBigEmr.setString(i++, eid)
        allEmrCodes.each { c -&gt; psBigEmr.setString(i++, c) }
        rsBigEmr = psBigEmr.executeQuery()
        allEmrDump = dumpPretty(EMR_VITAL_TABLE, rsBigEmr, 100)
        if (!allEmrDump?.trim()) allEmrDump = &quot;${EMR_VITAL_TABLE}\n(0 rows)\n&quot;
    } finally { closeQ(rsBigEmr); closeQ(psBigEmr) }

    def dumpVcBig = { String tableName, String typeCol, String selectCols, String extraWhere -&gt;
    PreparedStatement ps = null; ResultSet rs = null
    try {
        ps = vConn.prepareStatement(&quot;&quot;&quot;
            SELECT ${selectCols}
            FROM ${tableName}
            WHERE ${vcPidExpr}=? AND ${vcEidExpr}=?
              ${extraWhere ?: &quot;&quot;}
            ORDER BY observed_dt DESC
        &quot;&quot;&quot;)
        int p = 1
        ps.setString(p++, pid); ps.setString(p++, eid)
            rs = ps.executeQuery()
            def s = dumpPretty(tableName, rs, 100)
            return s?.trim() ? s : &quot;${tableName}\n(0 rows)\n&quot;
        } finally { closeQ(rs); closeQ(ps) }
    }

    def vcObsDump  = dumpVcBig(VC_TBL_VC_OBS,
        &quot;type&quot;,
        &quot;created_dt, updated_dt, ${vcPidExpr} AS patient_id, ${vcEidExpr} AS encounter_id, observed_dt, type, value, raw_value&quot;,
        &quot;&quot;)
    def emrObsDump = dumpVcBig(VC_TBL_EMR_OBS,
        &quot;type&quot;,
        &quot;created_dt, updated_dt, ${vcPidExpr} AS patient_id, ${vcEidExpr} AS encounter_id, observed_dt, type, value, raw_value&quot;,
        &quot;&quot;)
    def eventDump  = dumpVcBig(VC_TBL_VC_EVENT,
        &quot;subcategory&quot;,
        &quot;created_dt, updated_dt, ${vcPidExpr} AS patient_id, ${vcEidExpr} AS encounter_id, observed_dt, category, subcategory, value, raw_value&quot;,
        &quot;AND category=&apos;Observation&apos;&quot;)

    allVcDump = (vcObsDump.trim() + &quot;\n\n&quot; + emrObsDump.trim() + &quot;\n\n&quot; + eventDump.trim()).trim() + &quot;\n&quot;

} catch (Throwable outer) {
    allFails &lt;&lt; &quot;DB connection error: &quot; + outer.getClass().getSimpleName() + &quot; - &quot; + (outer.getMessage() ?: &quot;&quot;)
} finally {
    closeQ(eConn); closeQ(vConn)
}

def notFoundFails = allFails.findAll { it.endsWith(&quot;VC row not found&quot;) }
def otherFails    = allFails.findAll { !it.endsWith(&quot;VC row not found&quot;) }

def parts = []
if (notFoundFails) {
    if (notFoundFails.size() == 10) {
        parts &lt;&lt; &quot;VC row not found (all cases)&quot;
    } else {
        def labels = notFoundFails.collect { it.replaceAll(/^\[(.+)\] VC row not found$/, &apos;$1&apos;) }
        parts &lt;&lt; &quot;VC row not found: ${labels.join(&quot;, &quot;)}&quot;
    }
}
parts.addAll(otherFails)

String finalResult = allFails.isEmpty() ? &quot;PASS&quot; : &quot;FAIL&quot;
String finalNotes  = parts.isEmpty() ? &quot;&quot; : parts.join(&quot; | &quot;)

finishFn(prev, ctx, props, vars, &quot;700&quot;, scenarioId, finalResult, finalNotes, allEmrDump.trim(), allVcDump.trim())

return
</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Scenario 12" enabled="true">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
