        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="set_manual_DNR" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*

def U = props.get(&quot;CommonUtils&quot;)
if (!(U instanceof Map)) throw new RuntimeException(&quot;[S15] CommonUtils not found in props.&quot;)
def closeQ     = U.closeQuietly
def setVcKey   = U.setVcKey
def dumpPretty = U.dumpPretty

def vcUrl  = (vars.get(&quot;JDBC_URL_VC&quot;)  ?: &quot;&quot;).toString().trim()
def vcUser = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw   = (vars.get(&quot;JDBC_PW_VC&quot;)  ?: &quot;&quot;).toString()
def pid0   = (vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString().trim()
def pid1   = (vars.get(&quot;PatientID1&quot;) ?: &quot;&quot;).toString().trim()
def VC_TBL_PAT = (vars.get(&quot;VC_TBL_EMR_PATIENT&quot;) ?: &quot;vitalcare.emr_patient&quot;).toString().trim()

def vcPidCond = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id),@secretkey,@iv) AS CHAR)=?&quot;

Connection vConn = null
try {
    vConn = DriverManager.getConnection(vcUrl, vcUser, vcPw)
    setVcKey(vConn, &quot;S15_SETUP&quot;)

    def ps = vConn.prepareStatement(
        &quot;UPDATE ${VC_TBL_PAT} SET manual_dnr = ? WHERE ${vcPidCond}&quot;
    )
    ps.setString(1, &quot;TRUE&quot;);  ps.setString(2, pid0); ps.executeUpdate(); ps.clearParameters()
    ps.setString(1, &quot;FALSE&quot;); ps.setString(2, pid1); ps.executeUpdate()
    closeQ(ps)

    // before dump (두 환자 한 번에)
    PreparedStatement psDump = null; ResultSet rsDump = null
    try {
        psDump = vConn.prepareStatement(&quot;&quot;&quot;
            SELECT created_dt, updated_dt,
                   CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id), @secretkey,@iv) AS CHAR) AS patient_id,
                   emr_dnr, manual_dnr
            FROM ${VC_TBL_PAT}
            WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id), @secretkey,@iv) AS CHAR) IN (?, ?)
            ORDER BY patient_id
        &quot;&quot;&quot;)
        psDump.setString(1, pid0); psDump.setString(2, pid1)
        rsDump = psDump.executeQuery()
        def d = dumpPretty(&quot;${VC_TBL_PAT} (before)&quot;, rsDump, 10)
        vars.put(&quot;manual_dnr_before_dump&quot;, d?.trim() ?: &quot;${VC_TBL_PAT} (before)\n(0 rows)&quot;)
    } finally { closeQ(rsDump); closeQ(psDump) }

    log.info(&quot;[SETUP_MANUAL_DNR] pid0=${pid0} manual_dnr=TRUE, pid1=${pid1} manual_dnr=FALSE&quot;)
} finally {
    closeQ(vConn)
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="add_encounter" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter

String url  = vars.get(&quot;JDBC_URL&quot;)
String user = vars.get(&quot;JDBC_USER&quot;)
String pw   = vars.get(&quot;JDBC_PW&quot;)
String EMR_TBL_ENC = (vars.get(&quot;EMR_ENCOUNTER_TABLE&quot;) ?: &quot;ROOT.ENCOUNTERS&quot;).toString().trim()
String EMR_TBL_LOC = (vars.get(&quot;EMR_LOCATION_TABLE&quot;)  ?: &quot;ROOT.LOCATIONS&quot;).toString().trim()

def fmt = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd HH:mm:ss&quot;)

Connection conn = null
PreparedStatement stmtEnc = null
PreparedStatement stmtLoc = null
try {
    conn = DriverManager.getConnection(url, user, pw)

    stmtEnc = conn.prepareStatement(
        &quot;INSERT INTO ${EMR_TBL_ENC} (ENCOUNTER_ID, PATIENT_ID, ADMISSION_DATE) &quot; +
        &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;))&quot;
    )
    stmtLoc = conn.prepareStatement(
        &quot;INSERT INTO ${EMR_TBL_LOC} &quot; +
        &quot;(PATIENT_ID, ENCOUNTER_ID, START_DT, END_DT, WARD, ROOM, BED, &quot; +
        &quot; PRACTITIONER_ID, PRACTITIONER_NAME, DEPARTMENT_CODE, DEPARTMENT_NAME) &quot; +
        &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), NULL, ?, ?, ?, ?, ?, ?, ?)&quot;
    )

    (0..1).each { i -&gt;
        String eid    = vars.get(&quot;EncounterID${i}&quot;)
        String pid    = vars.get(&quot;PatientID${i}&quot;)
        String admStr = vars.get(&quot;AdmissionDate${i}&quot;)

        String newAdmStr = LocalDateTime.parse(admStr, fmt).plusDays(1).format(fmt)
        String newEid    = eid + &quot;|2&quot;

        // ENCOUNTERS INSERT
        stmtEnc.setString(1, newEid)
        stmtEnc.setString(2, pid)
        stmtEnc.setString(3, newAdmStr)
        stmtEnc.executeUpdate()
        stmtEnc.clearParameters()

        // LOCATIONS INSERT
        stmtLoc.setString(1, pid)
        stmtLoc.setString(2, newEid)
        stmtLoc.setString(3, newAdmStr)
        stmtLoc.setString(4, &quot;QA_TEST&quot;)
        stmtLoc.setString(5, &quot;TEST_ROOM&quot;)
        stmtLoc.setString(6, &quot;TEST_BED&quot;)
        stmtLoc.setString(7, &quot;TEST_PRACCODE&quot;)
        stmtLoc.setString(8, &quot;TEST_PRACNAME&quot;)
        stmtLoc.setString(9, &quot;TEST_DEPRTCODE&quot;)
        stmtLoc.setString(10, &quot;TEST_DEPARTNAME&quot;)
        stmtLoc.executeUpdate()
        stmtLoc.clearParameters()

        vars.put(&quot;EncounterID${i}_2&quot;, newEid)
        log.info(&quot;[ADD_ENC] pid=${pid} new_eid=${newEid} adm=${newAdmStr}&quot;)
    }
} finally {
    try { stmtEnc?.close() } catch (ignored) {}
    try { stmtLoc?.close() } catch (ignored) {}
    try { conn?.close() } catch (ignored) {}
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Wait_for_Sync" enabled="true">
          <intProp name="ActionProcessor.action">1</intProp>
          <intProp name="ActionProcessor.target">0</intProp>
          <stringProp name="ActionProcessor.duration">180000</stringProp>
