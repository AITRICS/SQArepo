        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Vital_Data_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection
import java.sql.DriverManager
import java.sql.PreparedStatement
import java.util.Random

String url      = &quot;${JDBC_URL}&quot;
String user     = &quot;${JDBC_USER}&quot;
String password = &quot;${JDBC_PW}&quot;

String query = &quot;INSERT INTO ROOT.VITALS (PATIENT_ID, ENCOUNTER_ID, OBSERVED_DT, CODE, VALUE, DELETED_YN, INVALID) &quot; +
               &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?, ?, ?, ?)&quot;

String PatientID   = vars.get(&quot;PatientID0&quot;)
String EncounterID = vars.get(&quot;EncounterID0&quot;)

// j 인덱스와 ObservedDt 인덱스 일치
// j=1  : PULSE  (EMR 코드명. VC에서 PR로 매핑됨)
// j=9  : GCS_EYE + GCS_VERBAL + GCS_MOTOR 3건 (같은 observed_dt, bridge에서 GCS_EVM으로 합산)
def codes = [&quot;HR&quot;, &quot;PULSE&quot;, &quot;ISBP&quot;, &quot;SBP&quot;, &quot;IDBP&quot;, &quot;DBP&quot;, &quot;GCS_LOC&quot;, &quot;GCS_AVPU&quot;, &quot;GCS&quot;, &quot;GCS_EVM&quot;]

Connection conn = DriverManager.getConnection(url, user, password)
PreparedStatement stmt = conn.prepareStatement(query)
Random random = new Random()

for (int j = 0; j &lt; 10; j++) {
    String observedDt = vars.get(&quot;ObservedDt&quot; + j)

    if (j == 9) {
        // GCS_EVM: EMR에 3개 컴포넌트를 동일 observed_dt로 삽입
        insertObservation(conn, stmt, PatientID, EncounterID, observedDt, &quot;GCS_EYE&quot;,    String.valueOf(random.nextInt(4) + 1), j)
        insertObservation(conn, stmt, PatientID, EncounterID, observedDt, &quot;GCS_VERBAL&quot;, String.valueOf(random.nextInt(5) + 1), j)
        insertObservation(conn, stmt, PatientID, EncounterID, observedDt, &quot;GCS_MOTOR&quot;,  String.valueOf(random.nextInt(6) + 1), j)
    } else {
        String value = String.valueOf(random.nextInt(300) + 1)
        insertObservation(conn, stmt, PatientID, EncounterID, observedDt, codes[j], value, j)
    }
}

conn.close()

// 기존과 완전히 동일
public void insertObservation(Connection conn, PreparedStatement stmt, String patientID,
                              String encounterID, String observerdDt, String code, String value, int j) {
    stmt.setString(1, patientID)
    stmt.setString(2, encounterID)
    stmt.setString(3, observerdDt)
    stmt.setString(4, code)
    stmt.setDouble(5, Double.parseDouble(value))
    stmt.setInt(6, 0)
    stmt.setInt(7, 0)

    int rowsInsert = stmt.executeUpdate()
    stmt.clearParameters()
}</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Observation Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// 기준 시각 (초/밀리초 제거)
Calendar base = Calendar.getInstance(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
base.set(Calendar.SECOND, 0)
base.set(Calendar.MILLISECOND, 0)
long baseMs = base.getTimeInMillis()

SimpleDateFormat sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
sdf.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

// j=0~9, 1분 간격
for (int j = 0; j &lt; 10; j++) {
    Calendar cal = Calendar.getInstance(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    cal.setTimeInMillis(baseMs)
    cal.add(Calendar.MINUTE, -j)
    vars.put(&quot;ObservedDt&quot; + j, sdf.format(cal.getTime()))
}

log.info(&quot;[OBS_VARS S7] ObservedDt0=&quot; + vars.get(&quot;ObservedDt0&quot;) + &quot; ~ ObservedDt9=&quot; + vars.get(&quot;ObservedDt9&quot;))</stringProp>
          </JSR223PreProcessor>
