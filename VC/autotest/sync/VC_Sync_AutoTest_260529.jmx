        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Setup_Alt_Icu_In">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*

def U          = props.get(&quot;CommonUtils&quot;)
def closeQ     = U.closeQuietly
def dumpPretty = U.dumpPretty

String pidVal = vars.get(&quot;PatientID0&quot;)
String eidVal = vars.get(&quot;EncounterID0&quot;)
String icuIn  = vars.get(&quot;icu_in_dt&quot;)

Connection emrConn = null
PreparedStatement ps = null
ResultSet rs = null

try {    
    // ── ROOT.LOCATIONS UPDATE ─────────────────────────────────────
    emrConn = DriverManager.getConnection(&quot;${JDBC_URL}&quot;, &quot;${JDBC_USER}&quot;, &quot;${JDBC_PW}&quot;)
    ps = emrConn.prepareStatement(
        &quot;UPDATE ROOT.LOCATIONS SET WARD=&apos;QA_ICU&apos;, START_DT=TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;) &quot; +
        &quot;WHERE PATIENT_ID=? AND ENCOUNTER_ID=?&quot;)
    ps.setString(1, icuIn); ps.setString(2, pidVal); ps.setString(3, eidVal)
    int rows = ps.executeUpdate()
    closeQ(ps)
    log.info(&quot;[ALT_ICU] ICU_In updated rows=${rows}, START_DT=${icuIn}&quot;)

} finally {
    closeQ(rs); closeQ(ps)
    closeQ(emrConn);
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Wait_for_Sync">
          <intProp name="ActionProcessor.action">1</intProp>
