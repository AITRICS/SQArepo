        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Setup_Discharge" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import com.jcraft.jsch.*
import java.sql.*
import java.time.*
import java.time.format.DateTimeFormatter

def U      = props.get(&quot;CommonUtils&quot;)
def closeQ = U.closeQuietly

// ===== 1. Calculate scheduled sync time =====
def tz = ZoneId.of(&quot;Asia/Seoul&quot;)
def now = LocalDateTime.now(tz)
int bufferMin = 6; int syncIntervalMin = 3

int nowTotalMin = now.getHour() * 60 + now.getMinute()
int targetMin = (int)(Math.ceil((nowTotalMin + bufferMin) / (double)syncIntervalMin)) * syncIntervalMin
targetMin = targetMin % (24 * 60)
int hh = targetMin / 60; int mm = targetMin % 60
String scheduledHHMM = String.format(&quot;%02d%02d&quot;, hh, mm)


long scheduledMs = now.toLocalDate().atTime(hh, mm, 0).atZone(tz).toInstant().toEpochMilli()
if (scheduledMs &lt;= System.currentTimeMillis()) scheduledMs += 24L * 60 * 60 * 1000

vars.put(&quot;scheduledTimeMs&quot;,   &quot;${scheduledMs}&quot;)
vars.put(&quot;scheduledTimeHHMM&quot;, scheduledHHMM)
log.info(&quot;[S9_SETUP] scheduled=${scheduledHHMM}, scheduledMs=${scheduledMs}&quot;)

// ===== 2. SSH: update VCSYNC_DAILY_SCHEDULED_TIME_HHMM =====
def host       = vars.get(&quot;SSH_HOST&quot;)
def port       = Integer.parseInt(vars.get(&quot;SSH_PORT&quot;) ?: &quot;22&quot;)
def sshUser    = vars.get(&quot;SSH_USER&quot;)
def sshPw      = vars.get(&quot;SSH_PW&quot;)
def composeDir = vars.get(&quot;SSH_COMPOSE_DIR&quot;)
def filePath   = &quot;${composeDir}/envs/vc-sync-v220.env&quot;

def execCmd = { Session sess, String cmd -&gt;
    ChannelExec ch = (ChannelExec) sess.openChannel(&quot;exec&quot;)
    ch.setCommand(cmd)
    def is = ch.getInputStream()
    ch.connect()
    def sb = new StringBuilder(); def buf = new byte[1024]; int len
    while ((len = is.read(buf)) != -1) sb.append(new String(buf, 0, len))
    while (!ch.isClosed()) Thread.sleep(100)
    ch.disconnect()
    sb.toString().trim()
}

Session session = null
try {
    def jsch = new JSch()
    session = jsch.getSession(sshUser, host, port)
    session.setPassword(sshPw)
    session.setConfig(&quot;StrictHostKeyChecking&quot;, &quot;no&quot;)
    session.connect(10000)

    def line = execCmd(session, &quot;grep &apos;VCSYNC_DAILY_SCHEDULED_TIME_HHMM&apos; ${filePath}&quot;)
    def origValue = line.split(&quot;=&quot;)[1]?.trim() ?: &quot;&quot;
    vars.put(&quot;origScheduledHHMM&quot;, origValue)
    log.info(&quot;[S9_SETUP] origScheduled=${origValue} → ${scheduledHHMM}&quot;)

    execCmd(session, &quot;sed -i &apos;s/VCSYNC_DAILY_SCHEDULED_TIME_HHMM=${origValue}/VCSYNC_DAILY_SCHEDULED_TIME_HHMM=${scheduledHHMM}/&apos; ${filePath}&quot;)
    execCmd(session, &quot;cd ${composeDir} &amp;&amp; docker compose up -d sync&quot;)
    log.info(&quot;[S9_SETUP] env updated &amp; sync restarted&quot;)
} finally { session?.disconnect() }

// ===== 3. EMR: UPDATE DISCHARGE_DATE =====
String emrUrl  = (vars.get(&quot;JDBC_URL&quot;)  ?: &quot;&quot;).toString()
String emrUser = (vars.get(&quot;JDBC_USER&quot;) ?: &quot;&quot;).toString()
String emrPw   = (vars.get(&quot;JDBC_PW&quot;)   ?: &quot;&quot;).toString()
String EMR_TBL_ENC = (vars.get(&quot;EMR_ENCOUNTER_TABLE&quot;) ?: &quot;ROOT.ENCOUNTERS&quot;).toString().trim()
String pid0 = (vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString().trim()
String pid1 = (vars.get(&quot;PatientID1&quot;) ?: &quot;&quot;).toString().trim()

def today = now.toLocalDate()
String yesterdayStr = today.minusDays(1).format(DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;)) + &quot; 10:00:00&quot;
String todayStr     = today.format(DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;))              + &quot; 10:00:00&quot;
vars.put(&quot;discDate0&quot;, yesterdayStr)
vars.put(&quot;discDate1&quot;, todayStr)
log.info(&quot;[S9_SETUP] pid0=${pid0} disc=${yesterdayStr}, pid1=${pid1} disc=${todayStr}&quot;)

Connection conn = null
try {
    conn = DriverManager.getConnection(emrUrl, emrUser, emrPw)
    PreparedStatement ps = null
    try {
        ps = conn.prepareStatement(
            &quot;UPDATE ${EMR_TBL_ENC} SET DISCHARGE_DATE = TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;) WHERE PATIENT_ID = ?&quot;)
        ps.setString(1, yesterdayStr); ps.setString(2, pid0); ps.executeUpdate(); ps.clearParameters()
        ps.setString(1, todayStr);     ps.setString(2, pid1); ps.executeUpdate()
        log.info(&quot;[S9_SETUP] DISCHARGE_DATE updated for both patients&quot;)
    } finally { try { ps?.close() } catch (ignored) {} }
} finally { try { conn?.close() } catch (ignored) {} }
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Wait_for_Sync" enabled="true">
          <intProp name="ActionProcessor.action">1</intProp>
