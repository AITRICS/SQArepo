          <intProp name="ActionProcessor.target">0</intProp>
          <stringProp name="ActionProcessor.duration">240000</stringProp>
        </TestAction>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Verify_After (Discharge O)">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*
def U = props.get(&quot;CommonUtils&quot;)
def closeQ = U.closeQuietly; def setVcKey = U.setVcKey; def dumpPretty = U.dumpPretty

String orderKey   = &quot;920&quot;
String scenarioId = &quot;퇴원 스케줄 sync - 퇴원 처리&quot;

def vcUrl  = (vars.get(&quot;JDBC_URL_VC&quot;)  ?: &quot;&quot;).toString().trim()
def vcUser = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw   = (vars.get(&quot;JDBC_PW_VC&quot;)   ?: &quot;&quot;).toString()
def emrUrl  = (vars.get(&quot;JDBC_URL&quot;)  ?: &quot;&quot;).toString()
def emrUser = (vars.get(&quot;JDBC_USER&quot;) ?: &quot;&quot;).toString()
def emrPw   = (vars.get(&quot;JDBC_PW&quot;)   ?: &quot;&quot;).toString()
def pid0 = (vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString().trim()
def pid1 = (vars.get(&quot;PatientID1&quot;) ?: &quot;&quot;).toString().trim()
def VC_TBL_ENC  = (vars.get(&quot;VC_TBL_EMR_ENCOUNTER&quot;) ?: &quot;vitalcare.emr_encounter&quot;).toString().trim()
def EMR_TBL_ENC = (vars.get(&quot;EMR_ENCOUNTER_TABLE&quot;)  ?: &quot;ROOT.ENCOUNTERS&quot;).toString().trim()
def vcPidCond   = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),@secretkey,@iv) AS CHAR)=?&quot;

// pid0 기대값: EMR discDate0(어제) -1일 15:00
def emrDiscStr = vars.get(&quot;discDate0&quot;) ?: &quot;&quot;
String expectedDisc = &quot;&quot;
if (emrDiscStr.length() &gt;= 10) {
    def emrDate = java.time.LocalDate.parse(emrDiscStr.substring(0, 10))
    expectedDisc = emrDate.minusDays(1).toString() + &quot; 15:00:00&quot;
}

def allFails  = []
def emrDumpSb = new StringBuilder()
def vcDumpSb  = new StringBuilder()

Connection eConn = null; Connection vConn = null
try {
    eConn = DriverManager.getConnection(emrUrl, emrUser, emrPw)
    PreparedStatement psEd = null; ResultSet rsEd = null
    try {
        psEd = eConn.prepareStatement(
            &quot;SELECT created_dt, updated_dt,PATIENT_ID, ENCOUNTER_ID, ADMISSION_DATE, DISCHARGE_DATE FROM ${EMR_TBL_ENC} WHERE PATIENT_ID IN (?,?) ORDER BY PATIENT_ID&quot;)
        psEd.setString(1, pid0); psEd.setString(2, pid1)
        rsEd = psEd.executeQuery()
        emrDumpSb.append(dumpPretty(EMR_TBL_ENC, rsEd, 10) ?: &quot;${EMR_TBL_ENC}\n(0 rows)&quot;)
    } finally { closeQ(rsEd); closeQ(psEd) }
    closeQ(eConn); eConn = null

    vConn = DriverManager.getConnection(vcUrl, vcUser, vcPw)
    setVcKey(vConn, &quot;S9_AFTER&quot;)

    def patientChecks = [
        [pid: pid0, label: &quot;pid0 (어제 퇴원)&quot;, expectNull: false],
        [pid: pid1, label: &quot;pid1 (오늘 퇴원)&quot;, expectNull: true ]
    ]
    patientChecks.each { chk -&gt;
        def pid = chk.pid; def label = chk.label; def expectNull = chk.expectNull

        PreparedStatement psDump = null; ResultSet rsDump = null
        try {
            psDump = vConn.prepareStatement(&quot;&quot;&quot;
                SELECT created_dt, updated_dt,
                       CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),@secretkey,@iv) AS CHAR) AS patient_id,
                       CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id),@secretkey,@iv) AS CHAR) AS encounter_id,
                       admission_dt, discharge_dt
                FROM ${VC_TBL_ENC} WHERE ${vcPidCond}&quot;&quot;&quot;)
            psDump.setString(1, pid); rsDump = psDump.executeQuery()
            def dump = dumpPretty(VC_TBL_ENC, rsDump, 10) ?: &quot;${VC_TBL_ENC}\n(0 rows)&quot;
            vcDumpSb.append(&quot;${label}\n&quot;).append(dump).append(&quot;\n&quot;)
        } finally { closeQ(rsDump); closeQ(psDump) }

        PreparedStatement psChk = null; ResultSet rsChk = null
        try {
            psChk = vConn.prepareStatement(
                &quot;SELECT discharge_dt FROM ${VC_TBL_ENC} WHERE ${vcPidCond} LIMIT 1&quot;)
            psChk.setString(1, pid); rsChk = psChk.executeQuery()
            if (!rsChk.next()) {
                allFails &lt;&lt; &quot;${label}: VC row not found&quot;
            } else {
                def discVal = rsChk.getObject(&quot;discharge_dt&quot;)
                if (expectNull) {
                    if (discVal != null) allFails &lt;&lt; &quot;${label}: discharge_dt 예상치 않게 설정됨 (${discVal})&quot;
                } else {
                    if (discVal == null) {
                        allFails &lt;&lt; &quot;${label}: discharge_dt가 NULL (퇴원 처리 안 됨)&quot;
                    } else {
                        String actualStr = discVal.toString().trim().replace(&quot;T&quot;, &quot; &quot;)
                        String expectedPrefix = expectedDisc.substring(0, Math.min(16, expectedDisc.length()))
                        if (!actualStr.startsWith(expectedPrefix)) {
                            allFails &lt;&lt; &quot;${label}: discharge_dt 불일치 (expected=${expectedPrefix}, actual=${actualStr})&quot;
                        }
                    }
                }
            }
        } finally { closeQ(rsChk); closeQ(psChk) }
    }
} catch (Throwable t) {
    log.error(&quot;[S9_AFTER] Exception&quot;, t)
    allFails &lt;&lt; &quot;exception: &quot; + t.getClass().getSimpleName() + &quot; - &quot; + (t.getMessage() ?: &quot;&quot;)
} finally {
    closeQ(eConn); closeQ(vConn)
    String result = allFails.isEmpty() ? &quot;PASS&quot; : &quot;FAIL&quot;
    String notes  = allFails.isEmpty() ? &quot;&quot; : allFails.join(&quot; | &quot;)
    U.finish(prev, ctx, props, vars, orderKey, scenarioId, result, notes, emrDumpSb.toString(), vcDumpSb.toString())
}
</stringProp>
        </JSR223Sampler>
