              <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Set Vars (1-3)" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone

/**
 * Set Vars (1-3)
 * - 1-3 실행 전 변수 초기화(이전 실행 잔재 제거)
 * - 1-3 케이스 시작시각(ms) 기록 (FAIL/REPORT 기준)
 * - update/verify loop 카운터 및 slot별 expect/beforeDump/time 초기화
 */

vars.remove(&quot;rep_fail_score&quot;)
vars.remove(&quot;rep_fail_slot&quot;)
vars.remove(&quot;rep_fail_pid&quot;)
vars.remove(&quot;rep_fail_notes&quot;)

def tz = TimeZone.getTimeZone(vars.get(&quot;TZ&quot;) ?: &quot;Asia/Seoul&quot;)
def sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss,SSS&quot;)
sdf.setTimeZone(tz)

// [1-3] case start ms (If Controller 내 __groovy 파서 이슈 회피용: 여기서만 기록)
long now = System.currentTimeMillis()
vars.putObject(&quot;case_1_3_start_ms&quot;, now as Long)
log.info(&quot;[CASE_1_3_START@SETVARS] ms=&quot; + now)

// 이전 실행 잔재 제거: slot start time (1-1 fail 후 재사용 방지)
for (int i = 0; i &lt; 4; i++) {
  vars.remove(&quot;slot_start_ts_&quot; + i)
  vars.remove(&quot;slot_start_ms_&quot; + i)
}

// ---- 1-3 init ----
vars.remove(&quot;csv_scenario&quot;)
vars.remove(&quot;csv_notes&quot;) // 1-3은 verify_notes 사용

vars.put(&quot;chg_slot&quot;, &quot;-1&quot;) // update loop slot counter
vars.put(&quot;ver_slot&quot;, &quot;-1&quot;) // verify loop slot counter
vars.put(&quot;scenario_id&quot;, &quot;1-3&quot;)
vars.put(&quot;expect_mode&quot;, vars.get(&quot;expect_mode&quot;) ?: &quot;SYNC_OK&quot;)

// slot별 expect/flags/덤프/시간 초기화 (stale 재사용 방지)
for (int i = 0; i &lt; 4; i++) {
  vars.remove(&quot;change_field_&quot; + i)
  vars.remove(&quot;expect_name_&quot; + i)
  vars.remove(&quot;expect_sex_&quot; + i)
  vars.remove(&quot;expect_birth_&quot; + i)
  vars.remove(&quot;expect_dnr_&quot; + i)

  // before dump keys
  vars.remove(&quot;vc_before_dump_&quot; + i)
  vars.remove(&quot;vc_before_body_&quot; + i)

  // 이전 성공 케이스 시간 잔재 제거(핵심)
  vars.put(&quot;slot_start_ts_&quot; + i, &quot;&quot;)
  vars.putObject(&quot;slot_start_ms_&quot; + i, null)
}

vars.put(&quot;verify_notes&quot;, &quot;&quot;)
vars.put(&quot;verify_result&quot;, &quot;&quot;)

def prereqOk = &quot;true&quot;.equalsIgnoreCase((vars.get(&quot;prereq_1_1_all_pass&quot;) ?: &quot;false&quot;).toString())
vars.put(&quot;prereq_ok&quot;, prereqOk ? &quot;true&quot; : &quot;false&quot;)

log.info(&quot;[1-3 INIT] ready. p_pid_0=&quot; + (vars.get(&quot;p_pid_0&quot;) ?: &quot;&quot;))
log.info(&quot;[1-3 INIT] prereq_ok=&quot; + vars.get(&quot;prereq_ok&quot;))
log.info(&quot;[1-3 INIT] slot_start_ts_* cleared (0..3)&quot;)

vars.put(&quot;order_key&quot;, &quot;130&quot;)
</stringProp>
