          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="SnapshotIds" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">// SnapshotIds: 생성된 PatientID/EncounterID를 슬롯(p_pid_N/p_eid_N)으로 저장
def count = ((vars.get(&quot;PatientCount&quot;) ?: &quot;4&quot;) as int)

for (int i = 0; i &lt; count; i++) {
    def pid = (vars.get(&quot;PatientID${i}&quot;) ?: &quot;&quot;).toString()
    def eid = (vars.get(&quot;EncounterID${i}&quot;) ?: &quot;&quot;).toString()

    if (!pid) throw new RuntimeException(&quot;[SnapshotIds] PatientID${i} is empty&quot;)
    if (!eid) throw new RuntimeException(&quot;[SnapshotIds] EncounterID${i} is empty&quot;)

    vars.put(&quot;p_pid_${i}&quot;, pid)
    vars.put(&quot;p_eid_${i}&quot;, eid)

    log.info(&quot;[1-1 SETUP] snapshot slot=${i} pid=${pid} eid=${eid}&quot;)
}
</stringProp>
          </JSR223Sampler>
          <hashTree/>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="SnapshotBaseline_4Patients" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.sql.*

/**
 * SnapshotBaseline_4Patients (EMR)
 * - 슬롯(p_pid_0..N-1) 기준 baseline 조회 후 base_*_N 저장
 */

def url  = (vars.get(&quot;JDBC_URL&quot;) ?: &quot;&quot;).toString().trim()
def user = (vars.get(&quot;JDBC_USER&quot;) ?: &quot;&quot;).toString().trim()
def pw   = (vars.get(&quot;JDBC_PW&quot;) ?: &quot;&quot;).toString().trim()
if (!url || !user) throw new RuntimeException(&quot;[SnapshotBaseline] JDBC_URL/JDBC_USER is empty&quot;)

def count = ((vars.get(&quot;PatientCount&quot;) ?: &quot;4&quot;) as int)

def closeQuietly = { AutoCloseable c -&gt;
    try { if (c != null) c.close() } catch (ignored) {}
}

Connection conn = null
PreparedStatement ps = null
ResultSet rs = null

try {
    conn = DriverManager.getConnection(url, user, pw)
    conn.setAutoCommit(true)

    ps = conn.prepareStatement(&quot;&quot;&quot;
        SELECT NAME, SEX, BIRTHDATE, DNR
        FROM ROOT.PATIENTS
        WHERE PATIENT_ID=?
    &quot;&quot;&quot;)

    for (int i = 0; i &lt; count; i++) {
        def pid = (vars.get(&quot;p_pid_${i}&quot;) ?: &quot;&quot;).toString().trim()
        if (!pid) throw new RuntimeException(&quot;[SnapshotBaseline] p_pid_${i} is empty&quot;)

        ps.setString(1, pid)
        rs = ps.executeQuery()
        if (!rs.next()) throw new RuntimeException(&quot;[SnapshotBaseline] EMR patient not found. pid=&quot; + pid)

        def name  = (rs.getString(&quot;NAME&quot;) ?: &quot;&quot;).toString()
        def sex   = (rs.getString(&quot;SEX&quot;) ?: &quot;&quot;).toString()
        def birth = (rs.getString(&quot;BIRTHDATE&quot;) ?: &quot;&quot;).toString()
        def dnr   = (rs.getString(&quot;DNR&quot;) ?: &quot;&quot;).toString()

        vars.put(&quot;base_name_${i}&quot;,  name)
        vars.put(&quot;base_sex_${i}&quot;,   sex)
        vars.put(&quot;base_birth_${i}&quot;, birth)
        vars.put(&quot;base_dnr_${i}&quot;,   dnr)

        log.info(&quot;[1-1 BASE] slot=${i} pid=${pid} | name=${name}, sex=${sex}, birth=${birth}, dnr=${dnr}&quot;)

        closeQuietly(rs)
        rs = null
    }
} finally {
    closeQuietly(rs)
    closeQuietly(ps)
    closeQuietly(conn)
}
</stringProp>
          </JSR223Sampler>
