        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Verify_Encounter">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*
import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

/**
 * Verify_Encounter_AndWriteCsv (Scenario 4)
 * Expect:
 *  - VC emr_encounter row exists for (pid,eid) (SYNC_OK)
 *  - admission_dt rule: EMR admission_date -&gt; VC admission_dt = prev day 15:00:00 (TZ 기준)
 * Dump:
 *  - EMR ROOT.ENCOUNTERS
 *  - VC  vitalcare.emr_encounter
 * Finish:
 *  - finish() 1회 (CSV/HTML 기존 구조 유지)
 */

// -----------------------------
// 0) CommonUtils
// -----------------------------
def U = props.get(&quot;CommonUtils&quot;)
if (!(U instanceof Map)) throw new RuntimeException(&quot;[S4] CommonUtils not found in props.&quot;)

def closeQ     = U.closeQuietly
def setVcKey   = U.setVcKey
def dumpPretty = U.dumpPretty
def finishFn   = U.finish
def normTs     = U.normTs

// -----------------------------
// 1) vars
// -----------------------------
def scenarioId = (vars.get(&quot;scenario_id&quot;) ?: &quot;4&quot;).toString().trim()
def orderKey      = (vars.get(&quot;order_key&quot;) ?: &quot;200&quot;).toString().trim()
def expectMode    = (vars.get(&quot;expect_mode&quot;) ?: &quot;SYNC_OK&quot;).toString().trim()

def emrUrl  = (vars.get(&quot;JDBC_URL&quot;) ?: &quot;&quot;).toString().trim()
def emrUser = (vars.get(&quot;JDBC_USER&quot;) ?: &quot;&quot;).toString().trim()
def emrPw   = (vars.get(&quot;JDBC_PW&quot;) ?: &quot;&quot;).toString()

def vcUrl   = (vars.get(&quot;JDBC_URL_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcUser  = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw    = (vars.get(&quot;JDBC_PW_VC&quot;) ?: &quot;&quot;).toString()

def pid = (vars.get(&quot;patient_id&quot;) ?: vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString().trim()
def eid = (vars.get(&quot;encounter_id&quot;) ?: vars.get(&quot;EncounterID0&quot;) ?: &quot;&quot;).toString().trim()

def EMR_TBL_ENC = (vars.get(&quot;EMR_ENCOUNTER_TABLE&quot;) ?: &quot;ROOT.ENCOUNTERS&quot;).toString().trim()
def VC_TBL_ENC  = (vars.get(&quot;VC_TBL_EMR_ENCOUNTER&quot;) ?: &quot;vitalcare.emr_encounter&quot;).toString().trim()

def TZ = (vars.get(&quot;TimeZone&quot;) ?: (U.TZ ?: &quot;Asia/Seoul&quot;)).toString().trim()

if (!pid) throw new RuntimeException(&quot;[S4] patient_id is empty&quot;)
if (!eid) throw new RuntimeException(&quot;[S4] encounter_id is empty&quot;)
if (!emrUrl || !emrUser) throw new RuntimeException(&quot;[S4] EMR JDBC vars empty&quot;)
if (!vcUrl  || !vcUser)  throw new RuntimeException(&quot;[S4] VC JDBC vars empty&quot;)

// -----------------------------
// 2) admission_dt rule helper
// -----------------------------
def toPrevDay15 = { Object v -&gt;
    if (v == null) return &quot;&quot;
    def s = v.toString().trim()
    if (!s) return &quot;&quot;

    // 여러 포맷 섞여도 &quot;Date&quot;로 파싱 시도
    Date dt = null
    def fmts = [
            &quot;yyyy-MM-dd HH:mm:ss.SSS&quot;,
            &quot;yyyy-MM-dd HH:mm:ss&quot;,
            &quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss.SSS&quot;,
            &quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;,
            &quot;yyyy-MM-dd&quot;
    ]

    for (String f : fmts) {
        try {
            def sdf = new SimpleDateFormat(f)
            sdf.setTimeZone(TimeZone.getTimeZone(TZ))
            dt = sdf.parse(s)
            break
        } catch (ignored) {}
    }
    if (dt == null) return &quot;&quot;

    def cal = Calendar.getInstance(TimeZone.getTimeZone(TZ))
    cal.setTime(dt)
    cal.add(Calendar.DATE, -1)
    cal.set(Calendar.HOUR_OF_DAY, 15)
    cal.set(Calendar.MINUTE, 0)
    cal.set(Calendar.SECOND, 0)
    cal.set(Calendar.MILLISECOND, 0)

    // finish 비교는 normTs로 통일하므로 여기서는 표준 형태로만 반환
    def out = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    out.setTimeZone(TimeZone.getTimeZone(TZ))
    return out.format(cal.getTime())
}

// -----------------------------
// 3) holders
// -----------------------------
def fails = []
String result = &quot;FAIL&quot;
String notes  = &quot;&quot;
String emrDumpStr = &quot;&quot;
String vcDumpStr  = &quot;&quot;

Connection eConn=null
Connection vConn=null

try {
    // -----------------------------
    // 4) EMR dump + field read
    // -----------------------------
    eConn = DriverManager.getConnection(emrUrl, emrUser, emrPw)

    String emrAdmRaw = &quot;&quot;
    boolean emrFound = false

    PreparedStatement psEd=null; ResultSet rsEd=null
    try {
        psEd = eConn.prepareStatement(&quot;&quot;&quot;
            SELECT
              CREATED_DT, UPDATED_DT,
              PATIENT_ID, ENCOUNTER_ID,
              ADMISSION_DATE, DISCHARGE_DATE
            FROM ${EMR_TBL_ENC}
            WHERE PATIENT_ID=? AND ENCOUNTER_ID=?
        &quot;&quot;&quot;)
        psEd.setString(1, pid)
        psEd.setString(2, eid)
        rsEd = psEd.executeQuery()
        emrDumpStr = dumpPretty(&quot;${EMR_TBL_ENC}&quot;, rsEd, 50)
        if (!emrDumpStr?.trim()) emrDumpStr = &quot;${EMR_TBL_ENC}\n(0 rows)\n&quot;
    } finally { closeQ(rsEd); closeQ(psEd) }

    PreparedStatement psEf=null; ResultSet rsEf=null
    try {
        psEf = eConn.prepareStatement(&quot;&quot;&quot;
            SELECT ADMISSION_DATE
            FROM ${EMR_TBL_ENC}
            WHERE PATIENT_ID=? AND ENCOUNTER_ID=?
        &quot;&quot;&quot;)
        psEf.setString(1, pid)
        psEf.setString(2, eid)
        rsEf = psEf.executeQuery()
        if (rsEf.next()) {
            emrFound = true
            emrAdmRaw = (rsEf.getObject(1) ?: &quot;&quot;).toString()
        }
    } finally { closeQ(rsEf); closeQ(psEf) }

    if (!emrFound) fails &lt;&lt; &quot;EMR row not found&quot;

    // -----------------------------
    // 5) VC dump + field read
    // -----------------------------
    vConn = DriverManager.getConnection(vcUrl, vcUser, vcPw)
    setVcKey(vConn, &quot;S4_ENCOUNTER&quot;)

    def vcPidCond = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id), @secretkey, @iv) AS CHAR)=?&quot;
    def vcEidCond = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id),     @secretkey, @iv) AS CHAR)=?&quot;

    PreparedStatement psVd=null; ResultSet rsVd=null
    try {
        // ✅ created_dt/updated_dt 맨 앞 유지(네 요구사항)
        psVd = vConn.prepareStatement(&quot;&quot;&quot;
            SELECT
              created_dt, updated_dt,
              CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id), @secretkey, @iv) AS CHAR) AS patient_id,
              CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id),     @secretkey, @iv) AS CHAR) AS encounter_id,
              admission_dt, discharge_dt
            FROM ${VC_TBL_ENC}
            WHERE ${vcPidCond} AND ${vcEidCond}
            LIMIT 50
        &quot;&quot;&quot;)
        psVd.setString(1, pid)
        psVd.setString(2, eid)
        rsVd = psVd.executeQuery()
        vcDumpStr = dumpPretty(&quot;${VC_TBL_ENC}&quot;, rsVd, 50)
        if (!vcDumpStr?.trim()) vcDumpStr = &quot;${VC_TBL_ENC}\n(0 rows)\n&quot;
    } finally { closeQ(rsVd); closeQ(psVd) }

    boolean vcFound = false
    String vcPid = &quot;&quot;
    String vcEid = &quot;&quot;
    String vcAdm = &quot;&quot;

    PreparedStatement psVf=null; ResultSet rsVf=null
    try {
        psVf = vConn.prepareStatement(&quot;&quot;&quot;
            SELECT
              CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id), @secretkey, @iv) AS CHAR) AS patient_id,
              CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id),     @secretkey, @iv) AS CHAR) AS encounter_id,
              admission_dt
            FROM ${VC_TBL_ENC}
            WHERE ${vcPidCond} AND ${vcEidCond}
            LIMIT 1
        &quot;&quot;&quot;)
        psVf.setString(1, pid)
        psVf.setString(2, eid)
        rsVf = psVf.executeQuery()
        if (rsVf.next()) {
            vcFound = true
            vcPid = (rsVf.getString(1) ?: &quot;&quot;).toString().trim()
            vcEid = (rsVf.getString(2) ?: &quot;&quot;).toString().trim()
            vcAdm = normTs(rsVf.getObject(3))  // ✅ T 제거/초 보정 포함
        }
    } finally { closeQ(rsVf); closeQ(psVf) }

    // -----------------------------
    // 6) verdict
    // -----------------------------
    if (!&quot;SYNC_OK&quot;.equalsIgnoreCase(expectMode)) fails &lt;&lt; &quot;expect_mode=${expectMode} (expected SYNC_OK)&quot;
    if (!vcFound) fails &lt;&lt; &quot;VC row not found&quot;

    if (&quot;SYNC_OK&quot;.equalsIgnoreCase(expectMode) &amp;&amp; vcFound &amp;&amp; emrFound) {
        def expectedAdm = normTs(toPrevDay15(emrAdmRaw))
        def actualAdm   = normTs(vcAdm)

        if ((pid ?: &quot;&quot;) != (vcPid ?: &quot;&quot;)) fails &lt;&lt; &quot;field mismatch: patient_id&quot;
        if ((eid ?: &quot;&quot;) != (vcEid ?: &quot;&quot;)) fails &lt;&lt; &quot;field mismatch: encounter_id&quot;
        if ((expectedAdm ?: &quot;&quot;) != (actualAdm ?: &quot;&quot;)) {
            fails &lt;&lt; &quot;field mismatch: admission_dt (expected=${expectedAdm}, vc=${actualAdm})&quot;
        }
    }

    result = fails.isEmpty() ? &quot;PASS&quot; : &quot;FAIL&quot;
    notes  = fails.isEmpty() ? &quot;&quot; : fails.join(&quot; | &quot;)

} catch (Throwable t) {
    log.error(&quot;[S4] Exception&quot;, t)
    result = &quot;FAIL&quot;
    notes  = &quot;exception: &quot; + t.getClass().getSimpleName() + &quot; - &quot; + (t.getMessage() ?: &quot;&quot;)
} finally {
    closeQ(eConn); closeQ(vConn)
    finishFn(prev, ctx, props, vars, orderKey, scenarioId, result, notes, (emrDumpStr ?: &quot;&quot;), (vcDumpStr ?: &quot;&quot;))
}

return
</stringProp>
        </JSR223Sampler>
