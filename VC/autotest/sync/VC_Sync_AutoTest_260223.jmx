          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Prereq_Init" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">/**
 * Prereq_Init
 * - prereq 집계 변수 초기화
 * - slot(0..3)별 결과/노트/덤프 저장용 키 정리
 * - 대표 FAIL 선택(rep_fail_*) 상태 초기화
 * - 1-3 게이트용 prereq_1_1_all_pass 초기화
 */

vars.put(&quot;pr_slot&quot;, &quot;-1&quot;)        // Loop에서 +1 =&gt; 0..3
vars.put(&quot;pr_fail_count&quot;, &quot;0&quot;)   // FAIL 개수
vars.put(&quot;pr_all_ok&quot;, &quot;true&quot;)    // FAIL 발생 시 false

// slot별 저장 키 정리
for (int i = 0; i &lt; 4; i++) {
    vars.remove(&quot;pr_result_${i}&quot;)
    vars.remove(&quot;pr_notes_${i}&quot;)
    vars.remove(&quot;pr_scenario_${i}&quot;)
    vars.remove(&quot;pr_dump_emr_${i}&quot;)
    vars.remove(&quot;pr_dump_vc_${i}&quot;)
}

// 대표 FAIL 선택 상태 초기화 (이전 실행 흔적 방지)
vars.remove(&quot;rep_fail_score&quot;)
vars.remove(&quot;rep_fail_slot&quot;)
vars.remove(&quot;rep_fail_pid&quot;)
vars.remove(&quot;rep_fail_notes&quot;)

// 1-3 게이트용 플래그(초기값)
vars.put(&quot;prereq_1_1_all_pass&quot;, &quot;false&quot;)

log.info(&quot;[PREREQ] init done (slots=0..3)&quot;)
</stringProp>
          </JSR223Sampler>
          <hashTree/>
          <LoopController guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller" enabled="true">
            <stringProp name="LoopController.loops">4</stringProp>
          </LoopController>
          <hashTree>
            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Prereq_BindSlot" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">/**
 * Prereq_BindSlot
 * - pr_slot 포인터 증가(0..3)
 * - 해당 slot의 pid/eid를 patient_id/encounter_id에 바인딩 (Common 대상 전환)
 * - prereq 수행 중 scenario_id/verify_scenario를 임시 값으로 세팅(키 충돌 방지)
 */

int slot = ((vars.get(&quot;pr_slot&quot;) ?: &quot;-1&quot;) as int) + 1
vars.put(&quot;pr_slot&quot;, String.valueOf(slot))

// Common/덤프 로직에서 참조하는 slot 키(기존 유지)
vars.put(&quot;slot&quot;, String.valueOf(slot))
vars.put(&quot;cur_slot&quot;, String.valueOf(slot))

def pid = (vars.get(&quot;p_pid_${slot}&quot;) ?: &quot;&quot;).toString()
def eid = (vars.get(&quot;p_eid_${slot}&quot;) ?: &quot;&quot;).toString()
if (!pid) throw new RuntimeException(&quot;[Prereq_BindSlot] p_pid_${slot} is empty&quot;)
if (!eid) throw new RuntimeException(&quot;[Prereq_BindSlot] p_eid_${slot} is empty&quot;)

vars.put(&quot;patient_id&quot;, pid)
vars.put(&quot;encounter_id&quot;, eid)

// prereq가 Common 내부의 “1-1 본 케이스 키”와 충돌하지 않게 임시 scenario_id 사용
vars.put(&quot;scenario_id&quot;, &quot;1-1-prereq-${slot}&quot;)
vars.put(&quot;verify_scenario&quot;, &quot;Prereq 1-1 slot${slot}&quot;)

vars.put(&quot;pr_scenario_${slot}&quot;, vars.get(&quot;verify_scenario&quot;))

log.info(&quot;[PREREQ] bind slot=${slot} pid=${pid} eid=${eid}&quot;)
</stringProp>
            </JSR223Sampler>
            <hashTree/>
