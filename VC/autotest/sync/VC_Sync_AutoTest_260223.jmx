            <hashTree/>
            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Prereq_CaptureResult" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import java.lang.*

// =====================================================
// Prereq_CaptureResult / JSR223 Sampler (CLEAN)
// 목적:
// 1) slot별 결과 저장(pr_result_i / pr_notes_i)
// 2) slot별 dump 저장(pr_dump_emr_i / pr_dump_vc_i)
// 3) FAIL 대표 슬롯 선정(rep_fail_slot/score/pid/notes)
// =====================================================

// -----------------------------------------------------
// 0) slot 결정 (slot 우선, 없으면 pr_slot, 그래도 없으면 0)
// -----------------------------------------------------
int slotVar = -1
try { slotVar = (vars.get(&quot;slot&quot;) ?: &quot;-1&quot;) as int } catch (ignored) {}
int slotPr  = -1
try { slotPr  = (vars.get(&quot;pr_slot&quot;) ?: &quot;-1&quot;) as int } catch (ignored) {}

int slot = (slotVar &gt;= 0) ? slotVar : ((slotPr &gt;= 0) ? slotPr : 0)

// -----------------------------------------------------
// 1) 결과/노트 저장
// -----------------------------------------------------
def r = (vars.get(&quot;verify_result&quot;) ?: &quot;&quot;).toString().trim()
def n = (vars.get(&quot;verify_notes&quot;)  ?: &quot;&quot;).toString().trim()

vars.put(&quot;pr_result_&quot; + slot, r)
vars.put(&quot;pr_notes_&quot;  + slot, n)

// -----------------------------------------------------
// 2) dump 저장
// -----------------------------------------------------
def emrDump = (vars.get(&quot;verify_emrDump&quot;) ?: &quot;&quot;).toString()
def vcDump  = (vars.get(&quot;verify_vcDump&quot;)  ?: &quot;&quot;).toString()

vars.put(&quot;pr_dump_emr_&quot; + slot, emrDump)
vars.put(&quot;pr_dump_vc_&quot;  + slot, vcDump)

log.info(&quot;[PREREQ_DUMP_SAVE] slot=&quot; + slot + &quot; emrLen=&quot; + emrDump.length() + &quot; vcLen=&quot; + vcDump.length())

// -----------------------------------------------------
// 3) 집계
// -----------------------------------------------------
boolean ok = &quot;PASS&quot;.equalsIgnoreCase(r)
if (!ok) {
  vars.put(&quot;pr_all_ok&quot;, &quot;false&quot;)
  int fc = (vars.get(&quot;pr_fail_count&quot;) ?: &quot;0&quot;) as int
  vars.put(&quot;pr_fail_count&quot;, String.valueOf(fc + 1))
}

// -----------------------------------------------------
// 4) FAIL 대표 슬롯 선정 (NOT_FOUND &gt; EXCEPTION &gt; MISMATCH &gt; ETC)
// -----------------------------------------------------
def res = (r ?: &quot;&quot;).toUpperCase()
def notesLower = (n ?: &quot;&quot;).toLowerCase()

if (res &amp;&amp; res != &quot;PASS&quot;) {
  int score = 9
  if (notesLower.contains(&quot;row not found&quot;) || notesLower.contains(&quot;not found&quot;)) score = 1
  else if (notesLower.contains(&quot;exception&quot;) || notesLower.contains(&quot;error&quot;) || notesLower.contains(&quot;script&quot;)) score = 2
  else if (notesLower.contains(&quot;mismatch&quot;) || notesLower.contains(&quot;field mismatch&quot;)) score = 3

  int curScore = (vars.get(&quot;rep_fail_score&quot;) ?: &quot;999&quot;) as int
  int curSlot  = (vars.get(&quot;rep_fail_slot&quot;)  ?: &quot;999&quot;) as int

  if (score &lt; curScore || (score == curScore &amp;&amp; slot &lt; curSlot)) {
    vars.put(&quot;rep_fail_score&quot;, String.valueOf(score))
    vars.put(&quot;rep_fail_slot&quot;,  String.valueOf(slot))
    vars.put(&quot;rep_fail_pid&quot;,   (vars.get(&quot;patient_id&quot;) ?: &quot;&quot;).toString())
    vars.put(&quot;rep_fail_notes&quot;, n)

    log.info(&quot;[REP_FAIL_PICK] picked slot=&quot; + slot + &quot; score=&quot; + score
        + &quot; pid=&quot; + vars.get(&quot;rep_fail_pid&quot;)
        + &quot; notes=&quot; + n)
  }
}
</stringProp>
            </JSR223Sampler>
            <hashTree/>
          </hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Prereq_Finalize" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">/**
 * Prereq_Finalize
 * - prereq_1_1_all_pass 확정
 * - rep_slot 결정(PASS면 0, FAIL이면 rep_fail_slot)
 * - Scenario 1-1 요약행(csv_*) 확정 + 대표 dump 반영
 * - 이후 단계 영향 방지 위해 scenario_id/verify_scenario 복원
 */

int failCount = (vars.get(&quot;pr_fail_count&quot;) ?: &quot;0&quot;) as int
boolean allOk = (failCount == 0)

vars.put(&quot;pr_all_ok&quot;, allOk ? &quot;true&quot; : &quot;false&quot;)
vars.put(&quot;prereq_1_1_all_pass&quot;, allOk ? &quot;true&quot; : &quot;false&quot;)

// 대표 slot
int repSlot = allOk ? 0 : ((vars.get(&quot;rep_fail_slot&quot;) ?: &quot;0&quot;) as int)
if (repSlot &lt; 0 || repSlot &gt; 3) repSlot = 0
vars.put(&quot;rep_slot&quot;, String.valueOf(repSlot))

def repPid = (vars.get(&quot;p_pid_${repSlot}&quot;) ?: vars.get(&quot;p_pid_0&quot;) ?: &quot;&quot;).toString()
def repEid = (vars.get(&quot;p_eid_${repSlot}&quot;) ?: vars.get(&quot;p_eid_0&quot;) ?: &quot;&quot;).toString()

// 대표 FAIL notes
String oneFailMsg = &quot;&quot;
if (!allOk) {
    oneFailMsg = (vars.get(&quot;rep_fail_notes&quot;) ?: &quot;&quot;).toString().trim()
    if (!oneFailMsg) {
        for (int i = 0; i &lt; 4; i++) {
            def rr = (vars.get(&quot;pr_result_${i}&quot;) ?: &quot;&quot;).toString()
            def nn = (vars.get(&quot;pr_notes_${i}&quot;) ?: &quot;&quot;).toString().trim()
            if (!&quot;PASS&quot;.equalsIgnoreCase(rr)) { oneFailMsg = nn ?: &quot;Prereq FAIL&quot;; break }
        }
    }
    if (!oneFailMsg) oneFailMsg = &quot;Prereq FAIL&quot;
}

// CSV 요약행(Scenario 1-1)
vars.put(&quot;csv_scenario&quot;, &quot;Scenario 1-1&quot;)
vars.put(&quot;csv_result&quot;,   allOk ? &quot;PASS&quot; : &quot;FAIL&quot;)
vars.put(&quot;csv_notes&quot;,    allOk ? &quot;&quot; : oneFailMsg)

// 시간(이미 Mark StartTime에서 설정한 값 사용)
vars.put(&quot;csv_start_ts&quot;, (vars.get(&quot;case_start_ts&quot;) ?: &quot;&quot;).toString())
vars.put(&quot;csv_end_ts&quot;,   (vars.get(&quot;case_end_ts&quot;)   ?: &quot;&quot;).toString())

// 대표 dump 반영
def emrDump = (vars.get(&quot;pr_dump_emr_${repSlot}&quot;) ?: &quot;&quot;).toString()
def vcDump  = (vars.get(&quot;pr_dump_vc_${repSlot}&quot;)  ?: &quot;&quot;).toString()
vars.put(&quot;csv_emrDump&quot;, emrDump)
vars.put(&quot;csv_vcDump&quot;,  vcDump)

// 리포트 바인딩(대표 pid/eid로 고정)
vars.put(&quot;html_report_patient_id&quot;, repPid)
if (repPid) vars.put(&quot;patient_id&quot;, repPid)
if (repEid) vars.put(&quot;encounter_id&quot;, repEid)

// 1-3 SKIP 안내용
vars.put(&quot;prereq_fail_notes&quot;, allOk ? &quot;&quot; : &quot;Prereq FAIL&quot;)

// 복원/정리(다음 단계 영향 방지)
vars.put(&quot;scenario_id&quot;, &quot;1-1&quot;)
vars.put(&quot;verify_scenario&quot;, &quot;Scenario 1-1&quot;)
vars.remove(&quot;verify_notes&quot;)

log.info(&quot;[PREREQ] finalize allOk=${allOk}, failCount=${failCount}, repSlot=${repSlot}, repPid=${repPid}&quot;)
</stringProp>
          </JSR223Sampler>
