              <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Set Vars (1-2)" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">/**
 * Set Vars (1-2)
 * - scenario_id/expect_mode/order_key/PatientCount 초기화
 * - 1-2 전용 patient_id 생성 (prefix=4)
 * - insert가 참조하는 PatientID0에 동일 pid 세팅
 */

import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone

vars.put(&quot;scenario_id&quot;, &quot;1-2&quot;)
vars.put(&quot;expect_mode&quot;, &quot;SYNC_NOT_EXPECTED&quot;)
vars.put(&quot;order_key&quot;, &quot;120&quot;)
vars.put(&quot;PatientCount&quot;, &quot;1&quot;)

def tz = TimeZone.getTimeZone((vars.get(&quot;TimeZone&quot;) ?: &quot;Asia/Seoul&quot;).toString())
def sdf = new SimpleDateFormat(&quot;yyMMddHHmmss&quot;)
sdf.setTimeZone(tz)

def base = sdf.format(new Date())
def suffix = (System.currentTimeMillis() % 100).toString().padLeft(2, &apos;0&apos;)
def pid = &quot;4&quot; + base + suffix

vars.put(&quot;patient_id&quot;, pid)   // 공통/로그/검증용
vars.put(&quot;PatientID0&quot;, pid)   // insert가 참조하는 키

log.info(&quot;[1-2 INIT] patient_id=&quot; + pid + &quot;, PatientCount=1&quot;)


// ---- TG 번호 추출  ----
String threadGroupName = ctx.getThreadGroup().getName()
String threadGroupNumber = &quot;0&quot;
try {
    threadGroupNumber = threadGroupName.split(&quot; &quot;)[1] 
} catch (ignored) {
    threadGroupNumber = &quot;0&quot;
}

vars.put(&quot;tgNum&quot;, threadGroupNumber)
</stringProp>
              </JSR223Sampler>
              <hashTree/>
              <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Mark StartTime" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">/**
 * Mark StartTime (1-2)
 * - 케이스 시작 시각 기록 (millis + ts)
 * - 호환용으로 verify_startTime도 함께 세팅
 */

import java.text.SimpleDateFormat
import java.util.TimeZone
import java.util.Date

def tz = (vars.get(&quot;TimeZone&quot;) ?: &quot;Asia/Seoul&quot;).toString()
def sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss,SSS&quot;)
sdf.setTimeZone(TimeZone.getTimeZone(tz))

long startMs = System.currentTimeMillis()
vars.putObject(&quot;caseStartMillis&quot;, startMs as Long)

def startTs = sdf.format(new Date(startMs))
vars.put(&quot;case_start_ts&quot;, startTs)

// CSV/HTML 호환용
vars.put(&quot;verify_startTime&quot;, startTs)

log.info(&quot;[CASE_START] scenario_id=&quot; + (vars.get(&quot;scenario_id&quot;) ?: &quot;&quot;)
  + &quot; start_ts=&quot; + startTs
  + &quot; TZ=&quot; + tz)
</stringProp>
              </JSR223Sampler>
              <hashTree/>
              <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Patient_Info_JSR223 Sampler" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;

def pidLog = (vars.get(&quot;patient_id&quot;) ?: vars.get(&quot;PatientID&quot;) ?: vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString()
log.info(&quot;[PAT INSERT DBG] scenario_id=&quot; + (vars.get(&quot;scenario_id&quot;) ?: &quot;&quot;)
        + &quot; thread=&quot; + ctx.getThreadNum()
        + &quot; pid=&quot; + pidLog)


log.info(&quot;[PAT TOP] scenario_id=&quot; + vars.get(&quot;scenario_id&quot;)
  + &quot;, BEFORE LOOP PatientID0=&quot; + vars.get(&quot;PatientID0&quot;)
  + &quot;, PatientID=&quot; + vars.get(&quot;PatientID&quot;));


// Scenario(Thread) start time: set once
if (!vars.get(&quot;startTimeThread&quot;)) {
    vars.put(&quot;startTimeThread&quot;, String.valueOf(System.currentTimeMillis()))
}

	// JDBC connection information
	String url = &quot;${JDBC_URL}&quot;;
	String user = &quot;${JDBC_USER}&quot;;
	String password = &quot;${JDBC_PW}&quot;;

	// Define the query
	String query = &quot;INSERT INTO ROOT.PATIENTS (PATIENT_ID, NAME, BIRTHDATE, SEX) &quot; +
	                &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?)&quot;;

	// JDBC connection
	Connection conn = DriverManager.getConnection(url, user, password);

	// Prepare the statement
	PreparedStatement stmt = conn.prepareStatement(query);

	// Repeat the process for multiple sets of parameters
	int repeatCount = ${PatientCount}; // Number of repetitions set
		for (int i = 0; i &lt; repeatCount; i++) {
		    // Set String parameters for the query

String scenario = (vars.get(&quot;scenario_id&quot;) ?: &quot;&quot;).toString().trim()

String PatientID
if (scenario == &quot;1-2&quot;) {
    PatientID = (vars.get(&quot;patient_id&quot;) ?: &quot;&quot;).toString().trim()
    if (!PatientID) throw new RuntimeException(&quot;1-2 patient_id is empty. Check SetVars(1-2).&quot;)
} else {
    PatientID = (vars.get(&quot;PatientID&quot; + i) ?: &quot;&quot;).toString()
}

log.info(&quot;[PAT LOOP] scenario_id=&quot; + scenario + &quot; i=&quot; + i + &quot; PatientID=&quot; + PatientID)


		    String Name = vars.get(&quot;Name&quot; + i);
		    String BirthDate = vars.get(&quot;BirthDate&quot; + i);

		    
		    // Set parameters for the query
		    stmt.setString(1, PatientID);
		    stmt.setString(2, &quot;QA&quot;+Name);
		    stmt.setString(3, BirthDate);
		    // Set gender based on whether i is odd or even
		    if (${User_Thread} % 2 == 0) {
		        stmt.setString(4, &quot;female&quot;);
		    } else {
		        stmt.setString(4, &quot;male&quot;);
		    }
		    
		    // Execute the query
		    int rowsInsert = stmt.executeUpdate();
		    
		    // Log
		    log.info(&quot;Inserted patientID: &quot; + PatientID);
		    
		    // Clear parameters for reusing the statement
		    stmt.clearParameters();
		}
// Close the connection
conn.close();
</stringProp>
              </JSR223Sampler>
              <hashTree>
                <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Patient Variables" enabled="true">
                  <stringProp name="scriptLanguage">groovy</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

def scenario = (vars.get(&quot;scenario_id&quot;) ?: &quot;&quot;).toString().trim()

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount}
int observationCount = ${ObservationCount}

// Iterate to set variables
for (int i = 0; i &lt; repeatCount; i++) {

    // Create Date objects
    Date PatientSet = new Date(timestampDefault)
    Date EncounterSet = new Date(timestampDefault)
    Date NameSet = new Date(timestampDefault)

    // Calendar for birthdate
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault)
    calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}))

    // --- Generate random birthdate for age between 19 and 110 ---
    int minAge = 19
    int maxAge = 110
    int randomAge = minAge + (int)(Math.random() * (maxAge - minAge + 1))

    Calendar nowCal = Calendar.getInstance()
    nowCal.setTimeInMillis(timestampDefault)

    calendar.add(Calendar.YEAR, -randomAge)

    int randomMonth = (int)(Math.random() * 12)  // 0-11
    calendar.set(Calendar.MONTH, randomMonth)
    int maxDay = calendar.getActualMaximum(Calendar.DAY_OF_MONTH)
    int randomDay = 1 + (int)(Math.random() * maxDay)
    calendar.set(Calendar.DAY_OF_MONTH, randomDay)

    if (calendar.after(nowCal)) {
        calendar.add(Calendar.YEAR, -1)
    }

    long BirthDatetimeStamp = calendar.getTimeInMillis()
    Date BirthSet = new Date(BirthDatetimeStamp)

    // --------------------------
    // PatientID 생성(기존) or 1-2 고정(핵심)
    // --------------------------
    String PatientID
    if (scenario == &quot;1-2&quot; &amp;&amp; i == 0) {
        // 1-2는 SetVars에서 만든 고유 pid를 0번에 고정
        PatientID = (vars.get(&quot;PatientID0&quot;) ?: vars.get(&quot;patient_id&quot;) ?: &quot;&quot;).toString().trim()
        if (!PatientID) {
            throw new RuntimeException(&quot;1-2 PatientID0/patient_id is empty. Check 1-2 SetVars.&quot;)
        }
        vars.put(&quot;PatientID0&quot;, PatientID)
        log.info(&quot;[SET PAT VARS@1-2] fixed PatientID0=&quot; + PatientID)
    } else {
        // 기존 방식 그대로
        SimpleDateFormat sdf_patient = new SimpleDateFormat(i + &quot;yyMMddHHmmss&quot; + ${User_Thread})
        sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
        PatientID = sdf_patient.format(PatientSet)
    }

    // Name 생성 (기존 유지)
    SimpleDateFormat sdf_name = new SimpleDateFormat(i + &quot;ddHHmmss&quot; + ${User_Thread})
    sdf_name.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    String Name = sdf_name.format(NameSet)

    // BirthDate 생성 (기존 유지)
    SimpleDateFormat sdf_birthdate = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;)
    sdf_birthdate.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    String BirthDate = sdf_birthdate.format(BirthSet)

    // Store in variables (기존 유지)
    vars.put(&quot;PatientID&quot; + i, PatientID)
    vars.put(&quot;Name&quot; + i, Name)
    vars.put(&quot;BirthDate&quot; + i, BirthDate)
}
</stringProp>
                </JSR223PreProcessor>
                <hashTree/>
              </hashTree>
              <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Encounter_Info_JSR223 Sampler" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;

	// JDBC connection information
	String url = &quot;${JDBC_URL}&quot;;
	String user = &quot;${JDBC_USER}&quot;;
	String password = &quot;${JDBC_PW}&quot;;

	// Define the query
	String query = &quot;INSERT INTO ROOT.ENCOUNTERS (ENCOUNTER_ID, PATIENT_ID, ADMISSION_DATE, DISCHARGE_DATE) &quot; +
	                &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;))&quot;;

    Connection conn = DriverManager.getConnection(url, user, password);
    PreparedStatement stmt = conn.prepareStatement(query);

	// Repeat the process for multiple sets of parameters
	int repeatCount = ${PatientCount}; // Number of repetitions set
		for (int i = 0; i &lt; repeatCount; i++) {
		    // Set parameters for the query
		    String EncounterID=vars.get(&quot;EncounterID&quot; + i);
		    String PatientID=vars.get(&quot;PatientID&quot; + i);
		    String AdmissionDate=vars.get(&quot;AdmissionDate&quot; + i);
		    String DisChargeDate=vars.get(&quot;DischargeDate&quot; + i);
		    stmt.setString(1, EncounterID);
		    stmt.setString(2, PatientID);
		    stmt.setString(3, AdmissionDate);
	         if (i == 9) {
		        stmt.setString(4, DisChargeDate);
		    } else {
		        stmt.setNull(4, java.sql.Types.DATE); // Set NULL value
		    }
		    
		    // Execute the query
		    int rowsInsert = stmt.executeUpdate();
		    
		    // Log the number of inserted rows
		    log.info(&quot;Inserted EncounterID: &quot; + EncounterID);
		    
		    // Clear parameters for reusing the statement
		    stmt.clearParameters();
		}
// Close the connection
conn.close();

 
</stringProp>
              </JSR223Sampler>
              <hashTree>
                <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Encounter Variables" enabled="true">
                  <stringProp name="scriptLanguage">groovy</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount} // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
    
    // Create a Date object
    Date PatientSet = new Date(timestampDefault)
    Date EncounterSet = new Date(timestampDefault)

    // Set Date
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault) // Set the default timestamp    
    calendar.add(Calendar.HOUR, -1)

    long DischargeDateTimestamp = calendar.getTimeInMillis()
    Date DischargeSet = new Date(DischargeDateTimestamp)

    calendar.setTimeInMillis(timestampDefault) // Reset timestamp    
    calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}))
    calendar.add(Calendar.MONTH, -(i+1))
    long AdmissionDatetimeStamp = calendar.getTimeInMillis()
    Date AdmissionSet = new Date(AdmissionDatetimeStamp)
    
    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_patient = new SimpleDateFormat(i+&quot;yyMMddHHmmss&quot;+${User_Thread})
    sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    
    // Format the date to string
    String PatientID = vars.get(&quot;PatientID&quot; + i)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_encounter = new SimpleDateFormat(i+&quot;yyyyMMddHHmmss&quot;+${User_Thread})
    sdf_encounter.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String EncounterID = sdf_encounter.format(EncounterSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_admission = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    sdf_admission.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String AdmissionDate = sdf_admission.format(AdmissionSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_discharge = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    sdf_discharge.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String DischargeDate = sdf_discharge.format(DischargeSet)
    
    // Store in variables
    vars.put(&quot;EncounterID&quot; + i, EncounterID + &quot;|&quot; + PatientID)
    vars.put(&quot;AdmissionDate&quot; + i, AdmissionDate)
    vars.put(&quot;DischargeDate&quot; + i, DischargeDate)
}
</stringProp>
                </JSR223PreProcessor>
                <hashTree/>
              </hashTree>
              <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Location_Info_JSR223 Sampler" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">import java.sql.Connection
import java.sql.DriverManager
import java.sql.PreparedStatement
import java.sql.Types

String url = &quot;${JDBC_URL}&quot;
String user = &quot;${JDBC_USER}&quot;
String password = &quot;${JDBC_PW}&quot;

String query =
    &quot;INSERT INTO ROOT.LOCATIONS (PATIENT_ID, ENCOUNTER_ID, START_DT, END_DT, WARD, ROOM, BED, &quot; +
    &quot;practitioner_id, practitioner_name, department_code, department_name) &quot; +
    &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?, ?, ?, ?, ?, ?, ?)&quot;

Connection conn = null
PreparedStatement stmt = null

try {

    conn = DriverManager.getConnection(url, user, password)
    stmt = conn.prepareStatement(query)

    int repeatCount = ${PatientCount}

    for (int i = 0; i &lt; repeatCount; i++) {
        String PatientID = vars.get(&quot;PatientID&quot; + i)
        String EncounterID = vars.get(&quot;EncounterID&quot; + i)
        String LocationStart = vars.get(&quot;LocationStart&quot; + i)
        String LocationEnd = vars.get(&quot;LocationEnd&quot; + i)

        stmt.setString(1, PatientID)
        stmt.setString(2, EncounterID)
        stmt.setString(3, LocationStart)

        // 원본 로직 유지: END_DT는 NULL로 넣고 싶으면 NULL
        stmt.setNull(4, Types.VARCHAR)

        if (${User_Thread} % 2 == 0) {
            stmt.setString(5, &quot;QA_ICU&quot;)
        } else {
            stmt.setString(5, &quot;QA_GW&quot;)
        }

        stmt.setString(6, ${User_Thread} + &quot;QA_ROOM&quot; + i)
        stmt.setString(7, ${User_Thread} + &quot;QA_BED&quot; + i)
        stmt.setString(8, ${User_Thread} + &quot;QAP&quot; + i)
        stmt.setString(9, ${User_Thread} + &quot;테스트&quot; + i)
        stmt.setString(10, ${User_Thread} + &quot;QAD&quot; + i)
        stmt.setString(11, ${User_Thread} + &quot;Quality Assurance&quot; + i)

        int rowsInsert = stmt.executeUpdate()
        log.info(&quot;[LOC] affectedRows=&quot; + rowsInsert)

        stmt.clearParameters()
    }

} catch (Exception e) {
    // 여기서 ORA-00001 / ORA-xxxx 같은 핵심이 반드시 로그로 찍힘
    log.error(&quot;[LOC] insert failed&quot;, e)
    throw e
} finally {
    try { if (stmt != null) stmt.close() } catch (ignored) {}
    try { if (conn != null) conn.close() } catch (ignored) {}
}
</stringProp>
              </JSR223Sampler>
              <hashTree>
                <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Location Variables" enabled="true">
                  <stringProp name="scriptLanguage">groovy</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.TimeZone;
import java.util.Calendar;

// Default timestamp
long timestampDefault = ${timestamp_default};
//long timestampDefault = props.get(&quot;timestamp_default&quot;) as long;

// Repeat count
int repeatCount = ${PatientCount}; // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
	// Create a Date object
	Date PatientSet = new Date(timestampDefault);
	Date EncounterSet = new Date(timestampDefault);
	Date LocationEndSet= new Date(timestampDefault);
	// Set Date
	Calendar calendar = Calendar.getInstance();
	calendar.setTimeInMillis(timestampDefault); // Set the default timestamp		
	calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}));
	calendar.add(Calendar.MONTH, -(i+1));

	long LocationStartSetTimestamp = calendar.getTimeInMillis();
	Date LocationStartSet= new Date(LocationStartSetTimestamp);

	String threadGroupName = ctx.getThreadGroup().getName();
	String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1];

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i+&quot;yyMMddHHmmss&quot;+${User_Thread}+threadGroupNumber);
	sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

	// Format the date to string
	String PatientID = sdf_patient.format(PatientSet);

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_encounter = new SimpleDateFormat(i+&quot;yyyyMMddHHmmss&quot;+${User_Thread}+threadGroupNumber);
	sdf_encounter.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

	// Format the date to string
	String EncounterID = sdf_encounter.format(EncounterSet);

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_LocationStartSet = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	sdf_LocationStartSet.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

	// Format the date to string
	String LocationStart = sdf_LocationStartSet.format(LocationStartSet);

	// Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_LocationEndSet = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);
	sdf_LocationEndSet.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;));

	// Format the date to string
	String LocationEnd = sdf_LocationEndSet.format(LocationEndSet);

// Store ONLY location time variables (do NOT override Patient/Encounter IDs)
vars.put(&quot;LocationStart&quot; + i, LocationStart)
vars.put(&quot;LocationEnd&quot; + i, LocationEnd)

}
</stringProp>
                </JSR223PreProcessor>
                <hashTree/>
              </hashTree>
              <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Delete Encounter" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">/**
 * Delete Encounter (1-2)
 * - ROOT.ENCOUNTERS에서 해당 PATIENT_ID의 encounter 삭제
 * - 1-2는 &quot;입원정보 없음&quot; 상태를 만들기 위한 강제 단계
 * - (호환/방어) verify_patient_id가 있으면 PatientID0를 그 값으로 덮어씀
 */

import java.sql.*

def oracleUrl  = (vars.get(&quot;JDBC_URL&quot;)  ?: &quot;&quot;).toString().trim()
def oracleUser = (vars.get(&quot;JDBC_USER&quot;) ?: &quot;&quot;).toString().trim()
def oraclePw   = (vars.get(&quot;JDBC_PW&quot;)   ?: &quot;&quot;).toString()

if (!oracleUrl || !oracleUser) {
  throw new RuntimeException(&quot;[Delete_Encounter] JDBC_URL/JDBC_USER empty&quot;)
}

// 1-2에서는 케이스 고정 PID로 삭제하도록 강제(호환/방어)
if (&quot;1-2&quot;.equals(vars.get(&quot;scenario_id&quot;)) &amp;&amp; (vars.get(&quot;verify_patient_id&quot;) ?: &quot;&quot;).toString().trim()) {
  vars.put(&quot;PatientID0&quot;, (vars.get(&quot;verify_patient_id&quot;) ?: &quot;&quot;).toString().trim())
}

def patientId = (vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString().trim()
if (!patientId) throw new RuntimeException(&quot;[Delete_Encounter] PatientID0 is empty&quot;)

Connection conn = null
PreparedStatement ps = null

try {
  conn = DriverManager.getConnection(oracleUrl, oracleUser, oraclePw)

  ps = conn.prepareStatement(&quot;&quot;&quot;
    DELETE FROM ROOT.ENCOUNTERS
    WHERE PATIENT_ID = ?
  &quot;&quot;&quot;)
  ps.setString(1, patientId)

  int deleted = ps.executeUpdate()
  log.info(&quot;[1-2 DELETE] ENCOUNTERS deletedRows=&quot; + deleted + &quot; (PATIENT_ID=&quot; + patientId + &quot;)&quot;)

} finally {
  try { if (ps != null) ps.close() } catch (ignored) {}
  try { if (conn != null) conn.close() } catch (ignored) {}
}
</stringProp>
              </JSR223Sampler>
              <hashTree/>
              <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Capture_Sync" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">import java.sql.*

/**
 * Capture_Sync (1-2)
 * - Delete encounter 직후 시점의 VC MAX(updated_dt)=T0 저장
 * - VC timestamp가 -9h로 읽히는 환경 보정(+9h) 적용
 * - Output: vars.putObject(&quot;hb_t0_kst_epoch&quot;, Long)
 */

def vcUrl  = (vars.get(&quot;JDBC_URL_VC&quot;)  ?: &quot;&quot;).toString().trim()
def vcUser = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw   = (vars.get(&quot;JDBC_PW_VC&quot;)   ?: &quot;&quot;).toString()

def VC_TABLE = &quot;vitalcare.emr_patient&quot;
def TS_COL   = &quot;updated_dt&quot;

// VC가 -9h로 읽히는 환경 보정(+9h)
long offsetMs = 9L * 60L * 60L * 1000L

if (!vcUrl || !vcUser) throw new RuntimeException(&quot;[Capture_Sync] JDBC_URL_VC/JDBC_USER_VC is empty&quot;)

Connection conn = null
PreparedStatement ps = null
ResultSet rs = null

long t0 = -1L

try {
  conn = DriverManager.getConnection(vcUrl, vcUser, vcPw)

  ps = conn.prepareStatement(&quot;SELECT MAX(&quot; + TS_COL + &quot;) AS mx FROM &quot; + VC_TABLE)
  rs = ps.executeQuery()
  rs.next()

  def mx = rs.getTimestamp(&quot;mx&quot;)
  if (mx != null) t0 = mx.getTime() + offsetMs

} finally {
  try { if (rs != null) rs.close() } catch (ignored) {}
  try { if (ps != null) ps.close() } catch (ignored) {}
  try { if (conn != null) conn.close() } catch (ignored) {}
}

vars.putObject(&quot;hb_t0_kst_epoch&quot;, t0 as Long)
log.info(&quot;[HB_T0] t0_kst_epoch=&quot; + t0)
</stringProp>
              </JSR223Sampler>
              <hashTree/>
              <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Wait_for_Sync" enabled="true">
                <intProp name="ActionProcessor.action">1</intProp>
                <intProp name="ActionProcessor.target">0</intProp>
                <stringProp name="ActionProcessor.duration">40000</stringProp>
              </TestAction>
              <hashTree/>
              <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Capture_Sync_Change" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">import java.sql.*
import java.text.SimpleDateFormat
import java.util.TimeZone
import java.util.Date

/**
 * Capture_Sync_Change (1-2)
 * - Wait 이후 VC MAX(updated_dt)=T1 조회
 * - T1 &gt; T0 이면 &quot;이번 구간에 sync가 실행됨&quot;으로 판정
 * - Output:
 *   vars.sync_ok = &quot;true&quot;/&quot;false&quot;
 *   vars.sync_heartbeat_kst = &quot;yyyy-MM-dd HH:mm:ss&quot; (T1 기준)
 */

def vcUrl  = (vars.get(&quot;JDBC_URL_VC&quot;)  ?: &quot;&quot;).toString().trim()
def vcUser = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw   = (vars.get(&quot;JDBC_PW_VC&quot;)   ?: &quot;&quot;).toString()

def VC_TABLE = &quot;vitalcare.emr_patient&quot;
def TS_COL   = &quot;updated_dt&quot;

// VC가 -9h로 읽히는 환경 보정(+9h)
long offsetMs = 9L * 60L * 60L * 1000L

long t0 = -1L
def t0Obj = vars.getObject(&quot;hb_t0_kst_epoch&quot;)
if (t0Obj != null) t0 = (t0Obj as long)

def sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
sdf.setTimeZone(TimeZone.getTimeZone(&quot;Asia/Seoul&quot;))

Connection conn = null
PreparedStatement ps = null
ResultSet rs = null

long t1 = -1L
String hbKst = &quot;&quot;
boolean ok = false

try {
  if (!vcUrl || !vcUser) throw new RuntimeException(&quot;[Capture_Sync_Change] JDBC_URL_VC/JDBC_USER_VC is empty&quot;)

  conn = DriverManager.getConnection(vcUrl, vcUser, vcPw)

  ps = conn.prepareStatement(&quot;SELECT MAX(&quot; + TS_COL + &quot;) AS mx FROM &quot; + VC_TABLE)
  rs = ps.executeQuery()
  rs.next()

  def mx = rs.getTimestamp(&quot;mx&quot;)
  if (mx != null) {
    t1 = mx.getTime() + offsetMs
    hbKst = sdf.format(new Date(t1))
  }

  ok = (t0 &gt;= 0L &amp;&amp; t1 &gt; t0)

} catch (Throwable t) {
  ok = false
  hbKst = &quot;&quot;
  log.warn(&quot;[HB_T1] check failed: &quot; + t.getClass().getSimpleName() + &quot; - &quot; + (t.getMessage() ?: &quot;&quot;))
} finally {
  try { if (rs != null) rs.close() } catch (ignored) {}
  try { if (ps != null) ps.close() } catch (ignored) {}
  try { if (conn != null) conn.close() } catch (ignored) {}
}

vars.put(&quot;sync_ok&quot;, ok ? &quot;true&quot; : &quot;false&quot;)
vars.put(&quot;sync_heartbeat_kst&quot;, hbKst)

log.info(&quot;[HB_T1] sync_ok=&quot; + ok + &quot; t0=&quot; + t0 + &quot; t1=&quot; + t1 + &quot; hbKST=&quot; + hbKst)
</stringProp>
              </JSR223Sampler>
              <hashTree/>
              <IfController guiclass="IfControllerPanel" testclass="IfController" testname="If Controller_SyncOK" enabled="true">
                <stringProp name="IfController.condition">${__groovy(&quot;true&quot;.equalsIgnoreCase((vars.get(&quot;sync_ok&quot;) ?: &quot;false&quot;).toString()))}</stringProp>
                <boolProp name="IfController.evaluateAll">false</boolProp>
                <boolProp name="IfController.useExpression">true</boolProp>
              </IfController>
              <hashTree>
                <ModuleController guiclass="ModuleControllerGui" testclass="ModuleController" testname="Module Controller" enabled="true">
                  <collectionProp name="ModuleController.node_path">
                    <stringProp name="764597751">Test Plan</stringProp>
                    <stringProp name="764597751">Test Plan</stringProp>
                    <stringProp name="230036048">Test Fragment_1</stringProp>
                  </collectionProp>
                </ModuleController>
                <hashTree/>
              </hashTree>
              <IfController guiclass="IfControllerPanel" testclass="IfController" testname="If Controller_SyncNotOK" enabled="true">
                <stringProp name="IfController.condition">${__groovy(!&quot;true&quot;.equalsIgnoreCase((vars.get(&quot;sync_ok&quot;) ?: &quot;false&quot;).toString()))}</stringProp>
                <boolProp name="IfController.evaluateAll">false</boolProp>
                <boolProp name="IfController.useExpression">true</boolProp>
              </IfController>
              <hashTree>
                <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Prereq_SyncNotExecuted" enabled="true">
                  <stringProp name="scriptLanguage">groovy</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">/**
 * Prereq_SyncNotExecuted
 * - 1-2에서 sync 미실행(sync_ok=false) 시 전제 실패로 FAIL 처리 (Common 미사용)
 * - EMR Source dump는 남김 (VC dump는 공란)
 * - verify_startTime: case_start_ts 우선, 없으면 now
 * - verify_endTime  : now
 */

import java.sql.*
import java.text.SimpleDateFormat
import java.util.TimeZone
import java.util.Date

def TZ = (vars.get(&quot;TimeZone&quot;) ?: &quot;Asia/Seoul&quot;).toString().trim()
def tzObj = TimeZone.getTimeZone(TZ)

def sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss,SSS&quot;)
sdf.setTimeZone(tzObj)

def nowMs = System.currentTimeMillis()
def nowTs = sdf.format(new Date(nowMs))

def scenarioId = (vars.get(&quot;scenario_id&quot;) ?: &quot;1-2&quot;).toString().trim()
def scenarioName = scenarioId ? (&quot;Scenario &quot; + scenarioId) : &quot;Scenario 1-2&quot;

def startTs = (vars.get(&quot;case_start_ts&quot;) ?: &quot;&quot;).toString().trim()
if (!startTs) startTs = nowTs

def patientId = (vars.get(&quot;patient_id&quot;) ?: &quot;&quot;).toString().trim()

vars.put(&quot;verify_scenario&quot;, scenarioName)
vars.put(&quot;verify_startTime&quot;, startTs)
vars.put(&quot;verify_endTime&quot;, nowTs)
vars.put(&quot;verify_result&quot;, &quot;FAIL&quot;)
vars.put(&quot;verify_notes&quot;, &quot;Not Synced&quot;)

vars.put(&quot;verify_vcDump&quot;, &quot;&quot;)
vars.put(&quot;verify_emrDump&quot;, &quot;ROOT.PATIENTS\n(not captured: init)\n&quot;)

log.warn(&quot;[SYNC_NOT_EXECUTED] scenario_id=&quot; + scenarioId + &quot; pid=&quot; + patientId)

// ---- EMR dump ----
def EMR_TABLE = &quot;ROOT.PATIENTS&quot;
int MAX_DUMP_ROWS = 5

def dumpResultSetAllColumnsPretty = { String tableName, ResultSet rs, int maxRows -&gt;
  def sb = new StringBuilder()
  sb.append(tableName).append(&quot;\n&quot;)

  if (rs == null) {
    sb.append(&quot;(rs is null)\n&quot;)
    return sb.toString()
  }

  ResultSetMetaData md = rs.getMetaData()
  int colCount = md.getColumnCount()

  def colNames = []
  for (int i = 1; i &lt;= colCount; i++) colNames &lt;&lt; md.getColumnLabel(i)

  def rows = []
  int count = 0
  while (rs.next()) {
    def row = []
    for (int i = 1; i &lt;= colCount; i++) {
      def obj = rs.getObject(i)
      row &lt;&lt; ((obj == null) ? &quot;&quot; : obj.toString())
    }
    rows &lt;&lt; row
    count++
    if (count &gt;= maxRows) break
  }

  def widths = new int[colCount]
  for (int i = 0; i &lt; colCount; i++) widths[i] = colNames[i].length()
  rows.each { r -&gt;
    for (int i = 0; i &lt; colCount; i++) widths[i] = Math.max(widths[i], (r[i] ?: &quot;&quot;).length())
  }

  sb.append((0..&lt;colCount).collect { i -&gt; colNames[i].padRight(widths[i]) }.join(&quot;|&quot;)).append(&quot;\n&quot;)
  sb.append((0..&lt;colCount).collect { i -&gt; &quot;-&quot; * widths[i] }.join(&quot;+&quot;)).append(&quot;\n&quot;)

  rows.each { r -&gt;
    sb.append((0..&lt;colCount).collect { i -&gt; (r[i] ?: &quot;&quot;).padRight(widths[i]) }.join(&quot;|&quot;)).append(&quot;\n&quot;)
  }

  if (rows.isEmpty()) sb.append(&quot;(0 rows)\n&quot;)
  else if (count &gt;= maxRows) sb.append(&quot;... (truncated, maxRows=&quot;).append(maxRows).append(&quot;)\n&quot;)

  return sb.toString()
}

Connection conn = null
PreparedStatement ps = null
ResultSet rs = null

try {
  if (!patientId) {
    vars.put(&quot;verify_emrDump&quot;, &quot;${EMR_TABLE}\n(not captured: patient_id empty)\n&quot;)
    return
  }

  def emrUrl  = ((vars.get(&quot;JDBC_URL&quot;)  ?: props.get(&quot;JDBC_URL&quot;))  ?: &quot;&quot;).toString().trim()
  def emrUser = ((vars.get(&quot;JDBC_USER&quot;) ?: props.get(&quot;JDBC_USER&quot;)) ?: &quot;&quot;).toString().trim()
  def emrPw   = ((vars.get(&quot;JDBC_PW&quot;)   ?: props.get(&quot;JDBC_PW&quot;))   ?: &quot;&quot;).toString()

  if (!emrUrl || !emrUser) {
    vars.put(&quot;verify_emrDump&quot;, &quot;${EMR_TABLE}\n(not captured: JDBC_URL/JDBC_USER empty)\n&quot;)
    return
  }

  conn = DriverManager.getConnection(emrUrl, emrUser, emrPw)
  ps = conn.prepareStatement(&quot;SELECT * FROM ${EMR_TABLE} WHERE PATIENT_ID = ?&quot;)
  ps.setString(1, patientId)
  rs = ps.executeQuery()

  def dump = dumpResultSetAllColumnsPretty(EMR_TABLE, rs, MAX_DUMP_ROWS)
  vars.put(&quot;verify_emrDump&quot;, dump ?: &quot;${EMR_TABLE}\n(0 rows)\n&quot;)

} catch (Throwable e) {
  def msg = (e.getMessage() ?: &quot;&quot;).toString()
  vars.put(&quot;verify_emrDump&quot;, &quot;${EMR_TABLE}\n(not captured: exception ${e.getClass().getSimpleName()} - ${msg})\n&quot;)
  log.error(&quot;[EMR_DUMP] exception&quot;, e)

} finally {
  try { if (rs != null) rs.close() } catch (ignored) {}
  try { if (ps != null) ps.close() } catch (ignored) {}
  try { if (conn != null) conn.close() } catch (ignored) {}
}

prev.setSuccessful(false)
prev.setResponseMessage(&quot;SYNC FAIL | Not Synced&quot;)
</stringProp>
                </JSR223Sampler>
