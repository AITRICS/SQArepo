        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Capture_VC_Before" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*

def U = props.get(&quot;CommonUtils&quot;)
if (!(U instanceof Map)) throw new RuntimeException(&quot;[CAP_VC_BEFORE] CommonUtils not found in props.&quot;)
def closeQ     = U.closeQuietly
def setVcKey   = U.setVcKey
def dumpPretty = U.dumpPretty

def vcUrl   = (vars.get(&quot;JDBC_URL_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcUser  = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw    = (vars.get(&quot;JDBC_PW_VC&quot;) ?: &quot;&quot;).toString()

def VC_TBL_PAT = (vars.get(&quot;VC_TBL_EMR_PATIENT&quot;) ?: &quot;vitalcare.emr_patient&quot;).toString().trim()

int pc = ((vars.get(&quot;PatientCount&quot;) ?: &quot;4&quot;).toString().trim() as int)
if (pc &lt;= 0) pc = 4
if (!vcUrl || !vcUser) throw new RuntimeException(&quot;[CAP_VC_BEFORE] VC JDBC vars empty&quot;)

def bodyOnly = { String dumpStr, String tableName -&gt;
  if (!dumpStr) return &quot;&quot;
  def s = dumpStr.toString().trim()
  if (!s) return &quot;&quot;
  def lines = s.split(&quot;\\r?\\n&quot;, -1)
  if (lines.length &gt;= 1 &amp;&amp; lines[0].trim() == tableName) {
    return lines.length &gt; 1 ? lines[1..-1].join(&quot;\n&quot;).trim() : &quot;&quot;
  }
  return s
}

Connection vConn=null
try {
  vConn = DriverManager.getConnection(vcUrl, vcUser, vcPw)
  setVcKey(vConn, &quot;PATIENT&quot;)

  for (int i=0; i&lt;pc; i++) {
    def pid = (vars.get(&quot;PatientID&quot;+i) ?: &quot;&quot;).toString().trim()
    if (!pid) throw new RuntimeException(&quot;[CAP_VC_BEFORE] PatientID&quot;+i+&quot; is empty&quot;)

    PreparedStatement ps=null; ResultSet rs=null
    String dumpStr=&quot;&quot;
    try {
      ps = vConn.prepareStatement(&quot;&quot;&quot;
        SELECT
          created_dt, updated_dt,
          CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id), @secretkey, @iv) AS CHAR) AS patient_id,
          CAST(AES_DECRYPT(FROM_BASE64(encrypted_name), @secretkey, @iv) AS CHAR) AS name,
          CAST(AES_DECRYPT(FROM_BASE64(encrypted_sex), @secretkey, @iv) AS CHAR) AS sex,
          CAST(AES_DECRYPT(FROM_BASE64(encrypted_birth_date), @secretkey, @iv) AS CHAR) AS birth_date,
          emr_dnr, manual_dnr
        FROM ${VC_TBL_PAT}
        WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id), @secretkey, @iv) AS CHAR) = ?
        ORDER BY updated_dt DESC
        LIMIT 1
      &quot;&quot;&quot;)
      ps.setString(1, pid)
      rs = ps.executeQuery()
      dumpStr = dumpPretty(&quot;${VC_TBL_PAT}&quot;, rs, 5)
    } finally { closeQ(rs); closeQ(ps) }

    def body = bodyOnly(dumpStr, VC_TBL_PAT)
    if (!body?.trim()) body = &quot;(0 rows)&quot;

    vars.put(&quot;vc_before_dump_&quot; + i, body)

    log.info(&quot;[CAP_VC_BEFORE] slot=${i} pid=${pid} stored=vc_before_dump_${i} len=&quot; + body.length())
  }

  log.info(&quot;[CAP_VC_BEFORE] captured slots=0..&quot; + (pc-1))

} finally {
  closeQ(vConn)
}
return
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Update_EMR" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">/**
 * Scenario 1-3 : Update_EMR (compact, maintenance-friendly)
 * - PatientCount=4 기준으로 slot0~3 각각 다른 필드 변경을 &quot;한 샘플러에서&quot; 순차 수행
 *   slot0 -&gt; name, slot1 -&gt; sex, slot2 -&gt; birthdate, slot3 -&gt; dnr
 * - slot_start_ms_&lt;slot&gt; / slot_start_ts_&lt;slot&gt; 저장 (변경 시작 시점)
 * - expect_*_&lt;slot&gt; 저장 (VC 검증용 기대값)  ※ 변경한 slot만 채움, 나머지는 clear
 *
 * Prereq:
 * - vars: PatientID0~PatientID3 (setname sampler에서 생성/저장)
 * - base_*_&lt;slot&gt; (가능하면 setname에서 함께 저장)
 *   base_name_&lt;slot&gt;, base_sex_&lt;slot&gt;, base_birth_&lt;slot&gt;, base_dnr_&lt;slot&gt;
 * - JDBC vars: JDBC_URL/JDBC_USER/JDBC_PW
 */
import java.sql.*
import java.text.SimpleDateFormat
import java.time.LocalDate
import java.util.Date
import java.util.TimeZone

def tz = TimeZone.getTimeZone(&quot;Asia/Seoul&quot;)
def sdfLog = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss,SSS&quot;)
sdfLog.setTimeZone(tz)
def sdfHHmm = new SimpleDateFormat(&quot;HHmm&quot;)
sdfHHmm.setTimeZone(tz)

def url  = (vars.get(&quot;JDBC_URL&quot;) ?: &quot;&quot;).toString().trim()
def user = (vars.get(&quot;JDBC_USER&quot;) ?: &quot;&quot;).toString().trim()
def pw   = (vars.get(&quot;JDBC_PW&quot;) ?: &quot;&quot;).toString()
if (!url || !user) throw new RuntimeException(&quot;[1-3 UPDATE] JDBC_URL/JDBC_USER empty&quot;)

def EMR_TBL_PAT = (vars.get(&quot;EMR_PATIENT_TABLE&quot;) ?: &quot;ROOT.PATIENTS&quot;).toString().trim()

int pc = ((vars.get(&quot;PatientCount&quot;) ?: &quot;4&quot;).toString().trim() as int)
if (pc &lt;= 0) pc = 4
if (pc &lt; 4) {
  log.warn(&quot;[1-3 UPDATE] PatientCount=${pc} (&lt;4). Will update slots 0..${pc-1} only.&quot;)
}

def normSexToMF = { Object v -&gt;
  if (v == null) return &quot;&quot;
  def s = v.toString().trim().toUpperCase()
  if (s == &quot;MALE&quot;) s = &quot;M&quot;
  if (s == &quot;FEMALE&quot;) s = &quot;F&quot;
  return s
}

def clearExpectForSlot = { int slot -&gt;
  vars.put(&quot;expect_name_&quot; + slot,  &quot;&quot;)
  vars.put(&quot;expect_sex_&quot; + slot,   &quot;&quot;)
  vars.put(&quot;expect_birth_&quot; + slot, &quot;&quot;)
  vars.put(&quot;expect_dnr_&quot; + slot,   &quot;&quot;)
}

Connection conn = null
PreparedStatement ps = null

try {
  conn = DriverManager.getConnection(url, user, pw)
  conn.setAutoCommit(false)

  for (int slot=0; slot&lt;pc &amp;&amp; slot&lt;4; slot++) {

    // 1) slot 시작시각 기록
    long now = System.currentTimeMillis()
    vars.putObject(&quot;slot_start_ms_&quot; + slot, now as Long)
    vars.put(&quot;slot_start_ts_&quot; + slot, sdfLog.format(new Date(now)))

    // 2) pid
    def pid = (vars.get(&quot;PatientID&quot;+slot) ?: &quot;&quot;).toString().trim()
    if (!pid) throw new RuntimeException(&quot;[1-3 UPDATE] PatientID${slot} empty&quot;)

    // 3) 대상 필드 결정
    String field
    if (slot == 0) field = &quot;name&quot;
    else if (slot == 1) field = &quot;sex&quot;
    else if (slot == 2) field = &quot;birthdate&quot;
    else field = &quot;dnr&quot;

    clearExpectForSlot(slot)

    // --- 변수 세팅 직후 1줄 로그(체크리스트) ---
    log.info(&quot;[1-3 SLOT_START@EMR] slot=${slot} pid=${pid} field=${field} ts=${vars.get(&apos;slot_start_ts_&apos; + slot)}&quot;)

    // 4) 필드별 UPDATE
    if (field == &quot;name&quot;) {
      def base = (vars.get(&quot;base_name_&quot; + slot) ?: vars.get(&quot;base_name&quot;) ?: &quot;&quot;).toString().trim()
      if (!base) {
        log.warn(&quot;[1-3 UPDATE] SKIP(name): base_name empty. slot=${slot} pid=${pid}&quot;)
        conn.rollback()
        prev.setSuccessful(true)
        continue
      }

      def hhmm = sdfHHmm.format(new Date())
      def newVal = base + &quot;_test&quot; + hhmm

      ps = conn.prepareStatement(&quot;UPDATE ${EMR_TBL_PAT} SET NAME=? WHERE PATIENT_ID=?&quot;)
      ps.setString(1, newVal)
      ps.setString(2, pid)

      int affected = ps.executeUpdate()
      conn.commit()

      vars.put(&quot;expect_name_&quot; + slot, newVal)
      log.info(&quot;[1-3 UPDATE] slot=${slot} pid=${pid} name: ${base} -&gt; ${newVal}, affected=${affected}&quot;)

    } else if (field == &quot;sex&quot;) {
      def baseSex = (vars.get(&quot;base_sex_&quot; + slot) ?: vars.get(&quot;base_sex&quot;) ?: &quot;&quot;).toString().trim()
      if (!baseSex) {
        log.warn(&quot;[1-3 UPDATE] SKIP(sex): base_sex empty. slot=${slot} pid=${pid}&quot;)
        conn.rollback()
        prev.setSuccessful(true)
        continue
      }

      def baseNorm = normSexToMF(baseSex)
      if (!baseNorm) throw new RuntimeException(&quot;[1-3 UPDATE] base_sex invalid: ${baseSex}&quot;)

      def newSexEmr = (baseNorm == &quot;M&quot;) ? &quot;female&quot; : &quot;male&quot;
      def expectVc  = (baseNorm == &quot;M&quot;) ? &quot;F&quot; : &quot;M&quot;

      ps = conn.prepareStatement(&quot;UPDATE ${EMR_TBL_PAT} SET SEX=? WHERE PATIENT_ID=?&quot;)
      ps.setString(1, newSexEmr)
      ps.setString(2, pid)

      int affected = ps.executeUpdate()
      conn.commit()

      vars.put(&quot;expect_sex_&quot; + slot, expectVc)
      log.info(&quot;[1-3 UPDATE] slot=${slot} pid=${pid} sex: ${baseSex} -&gt; ${newSexEmr} | expect(VC)=${expectVc}, affected=${affected}&quot;)

    } else if (field == &quot;birthdate&quot;) {
      def baseBirthRaw = (vars.get(&quot;base_birth_&quot; + slot) ?: vars.get(&quot;base_birth&quot;) ?: &quot;&quot;).toString().trim()
      if (!baseBirthRaw) {
        log.warn(&quot;[1-3 UPDATE] SKIP(birthdate): base_birth empty. slot=${slot} pid=${pid}&quot;)
        conn.rollback()
        prev.setSuccessful(true)
        continue
      }

      def baseBirth = baseBirthRaw.length() &gt;= 10 ? baseBirthRaw.substring(0, 10) : baseBirthRaw
      def newBirthStr = LocalDate.parse(baseBirth).minusYears(1).toString()

      ps = conn.prepareStatement(&quot;UPDATE ${EMR_TBL_PAT} SET BIRTHDATE=? WHERE PATIENT_ID=?&quot;)
      ps.setDate(1, java.sql.Date.valueOf(newBirthStr))
      ps.setString(2, pid)

      int affected = ps.executeUpdate()
      conn.commit()

      vars.put(&quot;expect_birth_&quot; + slot, newBirthStr)
      log.info(&quot;[1-3 UPDATE] slot=${slot} pid=${pid} birth: ${baseBirth} -&gt; ${newBirthStr}, affected=${affected}&quot;)

    } else { // dnr
      def baseDnr = (vars.get(&quot;base_dnr_&quot; + slot) ?: vars.get(&quot;base_dnr&quot;) ?: &quot;&quot;).toString().trim()
      if (!baseDnr) {
        log.warn(&quot;[1-3 UPDATE] SKIP(dnr): base_dnr empty. slot=${slot} pid=${pid}&quot;)
        conn.rollback()
        prev.setSuccessful(true)
        continue
      }

      def newVal
      if (baseDnr == &quot;0&quot;) newVal = &quot;1&quot;
      else if (baseDnr == &quot;1&quot;) newVal = &quot;0&quot;
      else throw new RuntimeException(&quot;[1-3 UPDATE] base_dnr not 0/1: ${baseDnr}&quot;)

      ps = conn.prepareStatement(&quot;UPDATE ${EMR_TBL_PAT} SET DNR=? WHERE PATIENT_ID=?&quot;)
      ps.setString(1, newVal)
      ps.setString(2, pid)

      int affected = ps.executeUpdate()
      conn.commit()

      vars.put(&quot;expect_dnr_&quot; + slot, newVal)
      log.info(&quot;[1-3 UPDATE] slot=${slot} pid=${pid} dnr: ${baseDnr} -&gt; ${newVal}, affected=${affected}&quot;)
    }

    try { if (ps != null) ps.close() } catch (ignored) {}
    ps = null
  }

} finally {
  try { if (ps != null) ps.close() } catch (ignored) {}
  try { if (conn != null) conn.close() } catch (ignored) {}
}
return
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Wait_for_Sync" enabled="true">
          <intProp name="ActionProcessor.action">1</intProp>
          <intProp name="ActionProcessor.target">0</intProp>
          <stringProp name="ActionProcessor.duration">180000</stringProp>
        </TestAction>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Verify_Patient_Change" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">/**
 * Verify (Scenario 1-3) - PATIENT_CHANGE (CLEAN)
 * 목표: EMR ↔ VC Sync 정합성 검증 (결과 중심: mismatch만 notes에 기록)
 *
 * - 4명 patient 변경 케이스:
 *   1) name update
 *   2) sex update
 *   3) birthdate update
 *   4) dnr update
 *
 * - finish() 1회
 */
 
import java.sql.*

def U = props.get(&quot;CommonUtils&quot;)
if (!(U instanceof Map)) throw new RuntimeException(&quot;[1-3 VERIFY] CommonUtils not found&quot;)

def closeQ     = U.closeQuietly
def setVcKey   = U.setVcKey
def dumpPretty = U.dumpPretty
def finishFn   = U.finish

def scenarioId = (vars.get(&quot;scenario_id&quot;) ?: &quot;3&quot;).toString().trim()
String orderKey = (vars.get(&quot;order_key&quot;) ?: &quot;130&quot;).toString().trim()

def emrUrl  = (vars.get(&quot;JDBC_URL&quot;) ?: &quot;&quot;).toString().trim()
def emrUser = (vars.get(&quot;JDBC_USER&quot;) ?: &quot;&quot;).toString().trim()
def emrPw   = (vars.get(&quot;JDBC_PW&quot;) ?: &quot;&quot;).toString()

def vcUrl   = (vars.get(&quot;JDBC_URL_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcUser  = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw    = (vars.get(&quot;JDBC_PW_VC&quot;) ?: &quot;&quot;).toString()

def EMR_TBL_PAT = (vars.get(&quot;EMR_PATIENT_TABLE&quot;) ?: &quot;ROOT.PATIENTS&quot;).toString().trim()
def VC_TBL_PAT  = (vars.get(&quot;VC_TBL_EMR_PATIENT&quot;) ?: &quot;vitalcare.emr_patient&quot;).toString().trim()

int pc = ((vars.get(&quot;PatientCount&quot;) ?: &quot;4&quot;).toString().trim() as int)
if (pc &lt;= 0) pc = 4

def TITLES = [&quot;1. Name Update&quot;, &quot;2. Sex Update&quot;, &quot;3. Birthdate Update&quot;, &quot;4. DNR Update&quot;]
def caseTitle = { int i -&gt; (i &gt;= 0 &amp;&amp; i &lt; TITLES.size()) ? TITLES[i] : &quot;case${i+1}&quot; }

def stripFirstTableLine = { String dumpStr, String tableName -&gt;
  if (!dumpStr) return &quot;&quot;
  def s = dumpStr.toString().trim()
  if (!s) return &quot;&quot;
  def lines = s.split(&quot;\\r?\\n&quot;, -1)
  if (lines.length &gt;= 1 &amp;&amp; lines[0].trim() == tableName) {
    return (lines.length &gt; 1 ? lines[1..-1].join(&quot;\n&quot;) : &quot;&quot;).trim()
  }
  return s
}

def normSex = { Object v -&gt;
  if (v == null) return &quot;&quot;
  def s = v.toString().trim().toUpperCase()
  if (s == &quot;MALE&quot;) s = &quot;M&quot;
  if (s == &quot;FEMALE&quot;) s = &quot;F&quot;
  return s
}
def normBirth = { Object v -&gt;
  if (v == null) return &quot;&quot;
  def s = v.toString().trim()
  if (s.contains(&quot; &quot;)) return s.split(&quot; &quot;)[0]
  if (s.contains(&quot;T&quot;)) return s.split(&quot;T&quot;)[0]
  return s
}

def normDnr = { Object v -&gt;
  if (v == null) return &quot;0&quot;
  def s = v.toString().trim().toLowerCase()
  if (!s || s == &quot;null&quot;) return &quot;0&quot;
  if (s in [&quot;none&quot;,&quot;na&quot;,&quot;n/a&quot;,&quot;no&quot;,&quot;n&quot;,&quot;off&quot;,&quot;false&quot;,&quot;f&quot;]) return &quot;0&quot;
  if (s in [&quot;yes&quot;,&quot;y&quot;,&quot;on&quot;,&quot;true&quot;,&quot;t&quot;]) return &quot;1&quot;
  if (s.isInteger()) return (s == &quot;0&quot;) ? &quot;0&quot; : &quot;1&quot;
  def m = (s =~ /(\d+)/)
  if (m.find()) return (m.group(1) == &quot;0&quot;) ? &quot;0&quot; : &quot;1&quot;
  return s
}

def dumpBody = { String tbl, ResultSet rs -&gt;
  def s = dumpPretty(tbl, rs, 5)
  s = stripFirstTableLine(s, tbl)
  return (s?.trim() ? s.trim() : &quot;(0 rows)&quot;)
}

Connection eConn = null
Connection vConn = null

String result = &quot;FAIL&quot;
String notes  = &quot;&quot;
String emrDump = &quot;&quot;
String vcDump  = &quot;&quot;

def fails = []
def emrSb = new StringBuilder()
def vcSb  = new StringBuilder()

try {
  if (!emrUrl || !emrUser) throw new RuntimeException(&quot;[1-3 VERIFY] EMR JDBC vars empty&quot;)
  if (!vcUrl  || !vcUser)  throw new RuntimeException(&quot;[1-3 VERIFY] VC JDBC vars empty&quot;)

  eConn = DriverManager.getConnection(emrUrl, emrUser, emrPw)
  vConn = DriverManager.getConnection(vcUrl,  vcUser,  vcPw)
  setVcKey(vConn, &quot;PATIENT&quot;)

  for (int i=0; i&lt;pc; i++) {
    def pid = (vars.get(&quot;PatientID&quot;+i) ?: &quot;&quot;).toString().trim()
    if (!pid) { fails &lt;&lt; &quot;case${i+1}: PatientID empty&quot;; continue }

    // VC before (body-only 전제, 방어 포함)
    def vcBeforeBody = (vars.get(&quot;vc_before_dump_&quot; + i) ?: &quot;&quot;).toString().trim()
    if (!vcBeforeBody) vcBeforeBody = &quot;(0 rows or not captured)&quot;
    vcBeforeBody = stripFirstTableLine(vcBeforeBody, VC_TBL_PAT)

    // -------------------------
    // EMR dump (after)
    // -------------------------
    PreparedStatement psEd=null; ResultSet rsEd=null
    String emrBody=&quot;&quot;
    try {
      psEd = eConn.prepareStatement(&quot;&quot;&quot;
        SELECT CREATED_DT, UPDATED_DT, PATIENT_ID, NAME, SEX, BIRTHDATE, DNR
        FROM ${EMR_TBL_PAT}
        WHERE PATIENT_ID=?
      &quot;&quot;&quot;)
      psEd.setString(1, pid)
      rsEd = psEd.executeQuery()
      emrBody = dumpBody(EMR_TBL_PAT, rsEd)
    } finally { closeQ(rsEd); closeQ(psEd) }

    emrSb.append(caseTitle(i)).append(&quot;\n&quot;)
         .append(EMR_TBL_PAT).append(&quot; (after)\n&quot;)
         .append(emrBody).append(&quot;\n\n&quot;)

    // -------------------------
    // VC dump (after)
    // -------------------------
    PreparedStatement psVd=null; ResultSet rsVd=null
    String vcAfterBody=&quot;&quot;
    try {
      psVd = vConn.prepareStatement(&quot;&quot;&quot;
        SELECT
          created_dt, updated_dt,
          CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id), @secretkey, @iv) AS CHAR) AS patient_id,
          CAST(AES_DECRYPT(FROM_BASE64(encrypted_name), @secretkey, @iv) AS CHAR) AS name,
          CAST(AES_DECRYPT(FROM_BASE64(encrypted_sex), @secretkey, @iv) AS CHAR) AS sex,
          CAST(AES_DECRYPT(FROM_BASE64(encrypted_birth_date), @secretkey, @iv) AS CHAR) AS birth_date,
          emr_dnr, manual_dnr
        FROM ${VC_TBL_PAT}
        WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id), @secretkey, @iv) AS CHAR) = ?
        LIMIT 1
      &quot;&quot;&quot;)
      psVd.setString(1, pid)
      rsVd = psVd.executeQuery()
      vcAfterBody = dumpBody(VC_TBL_PAT, rsVd)
    } finally { closeQ(rsVd); closeQ(psVd) }

    vcSb.append(caseTitle(i)).append(&quot;\n&quot;)
        .append(VC_TBL_PAT).append(&quot; (before)\n&quot;).append(vcBeforeBody).append(&quot;\n\n&quot;)
        .append(VC_TBL_PAT).append(&quot; (after)\n&quot;).append(vcAfterBody).append(&quot;\n\n&quot;)

    // -------------------------
    // EMR field read
    // -------------------------
    PreparedStatement psEf=null; ResultSet rsEf=null
    boolean emrFound=false
    String emrName=&quot;&quot;; String emrBirth=&quot;&quot;; String emrSex=&quot;&quot;; String emrDnr=&quot;&quot;
    Object emrDnrRaw=null
    try {
      psEf = eConn.prepareStatement(&quot;&quot;&quot;
        SELECT NAME, BIRTHDATE, SEX, DNR
        FROM ${EMR_TBL_PAT}
        WHERE PATIENT_ID=?
      &quot;&quot;&quot;)
      psEf.setString(1, pid)
      rsEf = psEf.executeQuery()
      if (rsEf.next()) {
        emrFound = true
        emrName   = (rsEf.getString(1) ?: &quot;&quot;)
        emrBirth  = normBirth(rsEf.getObject(2))
        emrSex    = normSex(rsEf.getObject(3))
        emrDnrRaw = rsEf.getObject(4)
        emrDnr    = normDnr(emrDnrRaw)
      }
    } finally { closeQ(rsEf); closeQ(psEf) }
    if (!emrFound) { fails &lt;&lt; &quot;case${i+1}: EMR not found&quot;; continue }

    // -------------------------
    // VC field read (emr_dnr only)
    // -------------------------
    PreparedStatement psVf=null; ResultSet rsVf=null
    boolean vcFound=false
    String vcName=&quot;&quot;; String vcBirth=&quot;&quot;; String vcSex=&quot;&quot;; String vcDnr=&quot;&quot;
    Object vcDnrRaw=null
    try {
      psVf = vConn.prepareStatement(&quot;&quot;&quot;
        SELECT
          CAST(AES_DECRYPT(FROM_BASE64(encrypted_name), @secretkey, @iv) AS CHAR) AS name,
          CAST(AES_DECRYPT(FROM_BASE64(encrypted_birth_date), @secretkey, @iv) AS CHAR) AS birth,
          CAST(AES_DECRYPT(FROM_BASE64(encrypted_sex), @secretkey, @iv) AS CHAR) AS sex,
          emr_dnr
        FROM ${VC_TBL_PAT}
        WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id), @secretkey, @iv) AS CHAR) = ?
        LIMIT 1
      &quot;&quot;&quot;)
      psVf.setString(1, pid)
      rsVf = psVf.executeQuery()
      if (rsVf.next()) {
        vcFound = true
        vcName   = (rsVf.getString(1) ?: &quot;&quot;)
        vcBirth  = normBirth(rsVf.getObject(2))
        vcSex    = normSex(rsVf.getObject(3))
        vcDnrRaw = rsVf.getObject(4)
        vcDnr    = normDnr(vcDnrRaw)
      }
    } finally { closeQ(rsVf); closeQ(psVf) }
    if (!vcFound) { fails &lt;&lt; &quot;case${i+1}: VC not found&quot;; continue }

    // -------------------------
    // expected (message hint only)
    // -------------------------
    def expName  = (vars.get(&quot;expect_name_&quot; + i)  ?: &quot;&quot;).toString()
    def expSex   = (vars.get(&quot;expect_sex_&quot; + i)   ?: &quot;&quot;).toString()
    def expBirth = (vars.get(&quot;expect_birth_&quot; + i) ?: &quot;&quot;).toString()
    def expDnr   = (vars.get(&quot;expect_dnr_&quot; + i)   ?: &quot;&quot;).toString()

    def expSexN   = expSex   ? normSex(expSex)     : &quot;&quot;
    def expBirthN = expBirth ? normBirth(expBirth) : &quot;&quot;
    def expDnrN   = expDnr   ? normDnr(expDnr)     : &quot;&quot;

    // -------------------------
    // mismatch only (EMR vs VC) + expected hint if present
    // -------------------------
    if (emrName != vcName) {
      def hint = expName ? &quot; expected=${expName}&quot; : &quot;&quot;
      fails &lt;&lt; &quot;case${i+1}: name mismatch (emr=${emrName}, vc=${vcName}${hint})&quot;
    }
    if (emrSex != vcSex) {
      def hint = expSexN ? &quot; expected=${expSexN}&quot; : &quot;&quot;
      fails &lt;&lt; &quot;case${i+1}: sex mismatch (emr=${emrSex}, vc=${vcSex}${hint})&quot;
    }
    if (emrBirth != vcBirth) {
      def hint = expBirthN ? &quot; expected=${expBirthN}&quot; : &quot;&quot;
      fails &lt;&lt; &quot;case${i+1}: birth mismatch (emr=${emrBirth}, vc=${vcBirth}${hint})&quot;
    }
    if (emrDnr != vcDnr) {
      def hint = expDnrN ? &quot; expected=${expDnrN}&quot; : &quot;&quot;
      fails &lt;&lt; &quot;case${i+1}: dnr mismatch (emrRaw=${emrDnrRaw}, vcRaw=${vcDnrRaw}, emr=${emrDnr}, vc=${vcDnr}${hint})&quot;
    }
  }

  emrDump = emrSb.toString().trim()
  vcDump  = vcSb.toString().trim()

  result = fails.isEmpty() ? &quot;PASS&quot; : &quot;FAIL&quot;
  notes  = fails.isEmpty() ? &quot;&quot; : fails.join(&quot; | &quot;)

} catch (Throwable t) {
  log.error(&quot;[1-3 VERIFY] Exception&quot;, t)
  result = &quot;FAIL&quot;
  notes  = &quot;exception: &quot; + t.getClass().getSimpleName() + &quot; - &quot; + (t.getMessage() ?: &quot;&quot;)
} finally {
  try { closeQ(eConn) } catch (ignored) {}
  try { closeQ(vConn) } catch (ignored) {}
  finishFn(prev, ctx, props, vars, orderKey, scenarioId, result, notes, (emrDump ?: &quot;&quot;), (vcDump ?: &quot;&quot;))
}
return
</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Scenario 4" enabled="true">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <OnceOnlyController guiclass="OnceOnlyControllerGui" testclass="OnceOnlyController" testname="Once Only Controller" enabled="true"/>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Setname Scenario" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">vars.put(&quot;currentControllerName&quot;, &quot;Scenario 2&quot;)

vars.put(&quot;scenario_id&quot;, &quot;4&quot;)
vars.put(&quot;expect_mode&quot;, &quot;SYNC_OK&quot;)
vars.put(&quot;order_key&quot;, &quot;200&quot;)
vars.put(&quot;verify_target&quot;, &quot;ENCOUNTER&quot;)

vars.put(&quot;PatientCount&quot;, &quot;1&quot;)


String tgName = ctx.getThreadGroup().getName()
String tgNum = &quot;0&quot;
try { tgNum = tgName.split(&quot; &quot;)[1] } catch (ignored) { tgNum = &quot;0&quot; }
vars.put(&quot;tgNum&quot;, tgNum)

log.info(&quot;[INIT] parent=${vars.get(&apos;currentControllerName&apos;)}, scenario_id=${vars.get(&apos;scenario_id&apos;)}, label=${vars.get(&apos;scenario_label&apos;)}, expect_mode=${vars.get(&apos;expect_mode&apos;)}, order_key=${vars.get(&apos;order_key&apos;)}, verify_target=${vars.get(&apos;verify_target&apos;)}, PatientCount=${vars.get(&apos;PatientCount&apos;)}, tgNum=${vars.get(&apos;tgNum&apos;)}&quot;)
</stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Mark StartTime" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.text.SimpleDateFormat
import java.util.TimeZone
import java.util.Date

def tz = (vars.get(&quot;TimeZone&quot;) ?: &quot;Asia/Seoul&quot;).toString()
def sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss,SSS&quot;)
sdf.setTimeZone(TimeZone.getTimeZone(tz))

long startMs = System.currentTimeMillis()
vars.putObject(&quot;caseStartMillis&quot;, startMs)

def startTs = sdf.format(new Date(startMs))
vars.put(&quot;case_start_ts&quot;, startTs)

// CSV/HTML이 기존 키를 쓰면 호환용으로 같이 세팅
vars.put(&quot;verify_startTime&quot;, startTs)

log.info(&quot;[CASE_START] scenario_id=${vars.get(&apos;scenario_id&apos;)} start_ts=${startTs} TZ=${tz}&quot;)
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Patient_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;

def pidLog = (vars.get(&quot;patient_id&quot;) ?: vars.get(&quot;PatientID&quot;) ?: vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString()
log.info(&quot;[PAT INSERT DBG] scenario_id=&quot; + (vars.get(&quot;scenario_id&quot;) ?: &quot;&quot;)
        + &quot; thread=&quot; + ctx.getThreadNum()
        + &quot; pid=&quot; + pidLog)


// Scenario(Thread) start time: set once
if (!vars.get(&quot;startTimeThread&quot;)) {
    vars.put(&quot;startTimeThread&quot;, String.valueOf(System.currentTimeMillis()))
}

	// JDBC connection information
	String url = &quot;${JDBC_URL}&quot;;
	String user = &quot;${JDBC_USER}&quot;;
	String password = &quot;${JDBC_PW}&quot;;

	// Define the query
	String query = &quot;INSERT INTO ROOT.PATIENTS (PATIENT_ID, NAME, BIRTHDATE, SEX) &quot; +
	                &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?)&quot;;

	// JDBC connection
	Connection conn = DriverManager.getConnection(url, user, password);

	// Prepare the statement
	PreparedStatement stmt = conn.prepareStatement(query);

	// Repeat the process for multiple sets of parameters
	int repeatCount = ${PatientCount}; // Number of repetitions set
		for (int i = 0; i &lt; repeatCount; i++) {
		    // Set String parameters for the query
		    String PatientID = vars.get(&quot;PatientID&quot; + i);
		    String Name = vars.get(&quot;Name&quot; + i);
		    String BirthDate = vars.get(&quot;BirthDate&quot; + i);
		    
		    // Set parameters for the query
		    stmt.setString(1, PatientID);
		    stmt.setString(2, &quot;QA&quot;+Name);
		    stmt.setString(3, BirthDate);
		    // Set gender based on whether i is odd or even
		    if (${User_Thread} % 2 == 0) {
		        stmt.setString(4, &quot;female&quot;);
		    } else {
		        stmt.setString(4, &quot;male&quot;);
		    }
		    
		    // Execute the query
		    int rowsInsert = stmt.executeUpdate();
		    
		    // Log
		    log.info(&quot;Inserted patientID: &quot; + PatientID);

		    vars.put(&quot;patient_id&quot;, PatientID)
			//log.info(&quot;[ID_MAP] patient_id=&quot; + vars.get(&quot;patient_id&quot;))

		    
		    // Clear parameters for reusing the statement
		    stmt.clearParameters();

		}
// Close the connection
conn.close();
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Patient Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount} // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
    
    // Create a Date object
    Date PatientSet = new Date(timestampDefault)
    Date EncounterSet = new Date(timestampDefault)
    Date NameSet = new Date(timestampDefault)

    // Set Date
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault) // Set the default timestamp    
    calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}))

    // --- Generate random birthdate for age between 19 and 150 ---
    int minAge = 19
    int maxAge = 110
    int randomAge = minAge + (int)(Math.random() * (maxAge - minAge + 1))
    
    // Copy current timestamp for age validation
    Calendar nowCal = Calendar.getInstance()
    nowCal.setTimeInMillis(timestampDefault)
    
    // Subtract random age in years
    calendar.add(Calendar.YEAR, -randomAge)
    
    // Randomize month and day
    int randomMonth = (int)(Math.random() * 12)  // 0-11
    calendar.set(Calendar.MONTH, randomMonth)
    int maxDay = calendar.getActualMaximum(Calendar.DAY_OF_MONTH)
    int randomDay = 1 + (int)(Math.random() * maxDay)
    calendar.set(Calendar.DAY_OF_MONTH, randomDay)
    
    // Ensure age is at least 19 (if birthday is in the future, subtract one more year)
    if (calendar.after(nowCal)) {
        calendar.add(Calendar.YEAR, -1)
    }
    
    // Final birthdate object
    long BirthDatetimeStamp = calendar.getTimeInMillis()
    Date BirthSet = new Date(BirthDatetimeStamp)
    
    String threadGroupName = ctx.getThreadGroup().getName()
    String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1]

    // Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i + &quot;yyMMddHHmmss&quot; + ${User_Thread} + threadGroupNumber)
    sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string
    String PatientID = sdf_patient.format(PatientSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_name = new SimpleDateFormat(i+&quot;ddHHmmss&quot;+${User_Thread})
    sdf_name.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String Name = sdf_name.format(NameSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_birthdate = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;)
    sdf_birthdate.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String BirthDate = sdf_birthdate.format(BirthSet)

    // Store in variables
    vars.put(&quot;PatientID&quot; + i, PatientID)
    vars.put(&quot;Name&quot; + i, Name)
    vars.put(&quot;BirthDate&quot; + i, BirthDate)
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Encounter_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;

	// JDBC connection information
	String url = &quot;${JDBC_URL}&quot;;
	String user = &quot;${JDBC_USER}&quot;;
	String password = &quot;${JDBC_PW}&quot;;

	// Define the query
	String query = &quot;INSERT INTO ROOT.ENCOUNTERS (ENCOUNTER_ID, PATIENT_ID, ADMISSION_DATE, DISCHARGE_DATE) &quot; +
	                &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;))&quot;;

    Connection conn = DriverManager.getConnection(url, user, password);
    PreparedStatement stmt = conn.prepareStatement(query);

	// Repeat the process for multiple sets of parameters
	int repeatCount = ${PatientCount}; // Number of repetitions set
		for (int i = 0; i &lt; repeatCount; i++) {
		    // Set parameters for the query
		    String EncounterID=vars.get(&quot;EncounterID&quot; + i);
		    String PatientID=vars.get(&quot;PatientID&quot; + i);
		    String AdmissionDate=vars.get(&quot;AdmissionDate&quot; + i);
		    String DisChargeDate=vars.get(&quot;DischargeDate&quot; + i);
		    stmt.setString(1, EncounterID);
		    stmt.setString(2, PatientID);
		    stmt.setString(3, AdmissionDate);
	         if (i == 9) {
		        stmt.setString(4, DisChargeDate);
		    } else {
		        stmt.setNull(4, java.sql.Types.DATE); // Set NULL value
		    }
		    
		    // Execute the query
		    int rowsInsert = stmt.executeUpdate();
		    
		    // Log the number of inserted rows
		    log.info(&quot;Inserted EncounterID: &quot; + EncounterID);

		    vars.put(&quot;encounter_id&quot;, EncounterID)  
			//log.info(&quot;[ID_MAP] encounter_id=&quot; + vars.get(&quot;encounter_id&quot;))

		    
		    // Clear parameters for reusing the statement
		    stmt.clearParameters();
		}
// Close the connection
conn.close();

 
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Encounter Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount} // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
    
    // Create a Date object
    Date PatientSet = new Date(timestampDefault)
    Date EncounterSet = new Date(timestampDefault)

    // Set Date
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault) // Set the default timestamp    
    calendar.add(Calendar.HOUR, -1)

    long DischargeDateTimestamp = calendar.getTimeInMillis()
    Date DischargeSet = new Date(DischargeDateTimestamp)

    calendar.setTimeInMillis(timestampDefault) // Reset timestamp    
    calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}))
    calendar.add(Calendar.MONTH, -(i+1))
    long AdmissionDatetimeStamp = calendar.getTimeInMillis()
    Date AdmissionSet = new Date(AdmissionDatetimeStamp)
    
    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_patient = new SimpleDateFormat(i+&quot;yyMMddHHmmss&quot;+${User_Thread})
    sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    
    // Format the date to string
    String PatientID = vars.get(&quot;PatientID&quot; + i)

    String threadGroupName = ctx.getThreadGroup().getName()
    String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1]

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_encounter = new SimpleDateFormat(i + &quot;yyyyMMddHHmmss&quot; + ${User_Thread} + threadGroupNumber)
    sdf_encounter.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String EncounterID = sdf_encounter.format(EncounterSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_admission = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    sdf_admission.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String AdmissionDate = sdf_admission.format(AdmissionSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_discharge = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    sdf_discharge.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String DischargeDate = sdf_discharge.format(DischargeSet)
    
    // Store in variables
    vars.put(&quot;EncounterID&quot; + i, EncounterID + &quot;|&quot; + PatientID)
    vars.put(&quot;AdmissionDate&quot; + i, AdmissionDate)
    vars.put(&quot;DischargeDate&quot; + i, DischargeDate)
}
</stringProp>
          </JSR223PreProcessor>
