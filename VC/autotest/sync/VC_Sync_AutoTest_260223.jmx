        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Verify_Vital">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*
import java.math.BigDecimal

/**
 * Verify_Vital_AndWriteCsv (Scenario 6) - CLEAN/COMPACT
 *
 * ✅ Verify: observed_dt set (최대 6세트) x 9 codes 전체 정합성 검증
 * ✅ Dump: 최신 observed_dt 1세트(9건)만 출력
 * ✅ Time mapping: VC observed_dt = EMR observed_dt - 9h
 * ✅ Code mapping: RESP-&gt;RR, PULSE-&gt;PR, TEMP-&gt;BT
 * ✅ Value compare: FiO2 %↔fraction(/100) 정규화 비교
 * ✅ Notes 폭발 방지: VC row count 부족/0이면 mismatch 상세 루프 스킵
 */

// -----------------------------
// 0) CommonUtils
// -----------------------------
def U = props.get(&quot;CommonUtils&quot;)
if (!(U instanceof Map)) throw new RuntimeException(&quot;[VITAL] CommonUtils not found in props.&quot;)
def closeQ     = U.closeQuietly
def setVcKey   = U.setVcKey
def dumpPretty = U.dumpPretty
def finishFn   = U.finish

// -----------------------------
// 1) vars / config
// -----------------------------
def scenarioId = (vars.get(&quot;scenario_id&quot;) ?: &quot;6&quot;).toString().trim()
def orderKey   = (vars.get(&quot;order_key&quot;) ?: &quot;400&quot;).toString().trim()
def expectMode = (vars.get(&quot;expect_mode&quot;) ?: &quot;SYNC_OK&quot;).toString().trim()

def emrUrl  = (vars.get(&quot;JDBC_URL&quot;) ?: &quot;&quot;).toString().trim()
def emrUser = (vars.get(&quot;JDBC_USER&quot;) ?: &quot;&quot;).toString().trim()
def emrPw   = (vars.get(&quot;JDBC_PW&quot;) ?: &quot;&quot;).toString()

def vcUrl   = (vars.get(&quot;JDBC_URL_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcUser  = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw    = (vars.get(&quot;JDBC_PW_VC&quot;) ?: &quot;&quot;).toString()

def pid = (vars.get(&quot;patient_id&quot;) ?: &quot;&quot;).toString().trim()
def eid = (vars.get(&quot;encounter_id&quot;) ?: &quot;&quot;).toString().trim()

def must = { String k, String v -&gt; if (!v?.trim()) throw new RuntimeException(&quot;[VITAL] ${k} empty&quot;); v.trim() }
must(&quot;JDBC_URL&quot;, emrUrl); must(&quot;JDBC_USER&quot;, emrUser)
must(&quot;JDBC_URL_VC&quot;, vcUrl); must(&quot;JDBC_USER_VC&quot;, vcUser)
must(&quot;patient_id&quot;, pid); must(&quot;encounter_id&quot;, eid)

def EMR_VITAL_TABLE = (vars.get(&quot;EMR_VITAL_TABLE&quot;) ?: &quot;ROOT.VITALS&quot;).toString().trim()
def VC_TBL_EMR_OBS  = (vars.get(&quot;VC_TBL_EMR_OBS&quot;)  ?: &quot;vitalcare.emr_observation&quot;).toString().trim()
def VC_TBL_VC_OBS   = (vars.get(&quot;VC_TBL_VC_OBS&quot;)   ?: &quot;vitalcare.vc_observation&quot;).toString().trim()
def VC_TBL_VC_EVENT = (vars.get(&quot;VC_TBL_VC_EVENT&quot;) ?: &quot;vitalcare.vc_event&quot;).toString().trim()

int SET_COUNT = ((vars.get(&quot;vital_set_count&quot;) ?: &quot;6&quot;).toString().trim() as int)
if (SET_COUNT &lt;= 0) SET_COUNT = 6

// codes (EMR)
def emrCodes = [&quot;DBP&quot;,&quot;FiO2&quot;,&quot;GCS&quot;,&quot;O2&quot;,&quot;PULSE&quot;,&quot;RESP&quot;,&quot;SBP&quot;,&quot;SpO2&quot;,&quot;TEMP&quot;]

def mapType = { String c -&gt;
  if (!c) return &quot;&quot;
  switch (c.trim()) {
    case &quot;RESP&quot;:  return &quot;RR&quot;
    case &quot;PULSE&quot;: return &quot;PR&quot;
    case &quot;TEMP&quot;:  return &quot;BT&quot;
    default:      return c.trim()
  }
}
def vcTypes = emrCodes.collect { mapType(it) }.unique()

final long OFFSET_9H_MS = 9L * 60L * 60L * 1000L

// dump sort
final String ORDER_EMR = &quot;&quot;&quot;
ORDER BY CASE CODE
  WHEN &apos;GCS&apos; THEN 1 WHEN &apos;PULSE&apos; THEN 2 WHEN &apos;RESP&apos; THEN 3 WHEN &apos;TEMP&apos; THEN 4
  WHEN &apos;SpO2&apos; THEN 5 WHEN &apos;SBP&apos; THEN 6 WHEN &apos;DBP&apos; THEN 7 WHEN &apos;FiO2&apos; THEN 8 WHEN &apos;O2&apos; THEN 9
  ELSE 99 END
&quot;&quot;&quot;
def orderCaseFor = { String col -&gt;
&quot;&quot;&quot;
ORDER BY CASE ${col}
  WHEN &apos;GCS&apos; THEN 1 WHEN &apos;PR&apos; THEN 2 WHEN &apos;RR&apos; THEN 3 WHEN &apos;BT&apos; THEN 4
  WHEN &apos;SpO2&apos; THEN 5 WHEN &apos;SBP&apos; THEN 6 WHEN &apos;DBP&apos; THEN 7 WHEN &apos;FiO2&apos; THEN 8 WHEN &apos;O2&apos; THEN 9
  ELSE 99 END
&quot;&quot;&quot;
}
final String ORDER_VC_TYPE   = orderCaseFor(&quot;type&quot;)
final String ORDER_VC_SUBCAT = orderCaseFor(&quot;subcategory&quot;)

// -----------------------------
// 2) value compare helpers
// -----------------------------
def asBd = { Object v -&gt;
  if (v == null) return null
  if (v instanceof Number) return BigDecimal.valueOf(((Number)v).doubleValue())
  def s = v.toString().trim()
  if (!s) return null
  try { return new BigDecimal(s) } catch (ignored) {
    def m = (s =~ /-?\d+(\.\d+)?/)
    return m.find() ? new BigDecimal(m.group(0)) : null
  }
}

def eqValue = { String emrCode, Object emrVal, Object vcVal -&gt;
  BigDecimal e = asBd(emrVal)
  BigDecimal v = asBd(vcVal)

  if (e != null &amp;&amp; v != null) {
    if (&quot;FiO2&quot;.equalsIgnoreCase(emrCode)) {
      if (e.compareTo(BigDecimal.ONE) &gt;= 0 &amp;&amp; v.compareTo(BigDecimal.ONE) &lt; 0) e = e.divide(new BigDecimal(&quot;100&quot;))
      else if (v.compareTo(BigDecimal.ONE) &gt;= 0 &amp;&amp; e.compareTo(BigDecimal.ONE) &lt; 0) v = v.divide(new BigDecimal(&quot;100&quot;))
    }
    return e.stripTrailingZeros().compareTo(v.stripTrailingZeros()) == 0
  }

  def es = (emrVal == null ? &quot;&quot; : emrVal.toString().trim())
  def vs = (vcVal  == null ? &quot;&quot; : vcVal.toString().trim())
  return es == vs
}

// -----------------------------
// 3) holders
// -----------------------------
def fails = []
def mismatchLines = []
String result = &quot;FAIL&quot;
String notes  = &quot;&quot;
String emrDumpStr = &quot;&quot;
String vcDumpStr  = &quot;&quot;

Connection eConn=null
Connection vConn=null

try {
  if (!&quot;SYNC_OK&quot;.equalsIgnoreCase(expectMode)) fails &lt;&lt; &quot;expect_mode=${expectMode} (expected SYNC_OK)&quot;

  // =====================================================
  // 4) EMR: 최근 observed_dt (최대 SET_COUNT)
  // =====================================================
  eConn = DriverManager.getConnection(emrUrl, emrUser, emrPw)

  def obsList = []
  PreparedStatement psObs=null; ResultSet rsObs=null
  try {
    psObs = eConn.prepareStatement(&quot;&quot;&quot;
      SELECT OBSERVED_DT
      FROM (
        SELECT DISTINCT OBSERVED_DT
        FROM ${EMR_VITAL_TABLE}
        WHERE PATIENT_ID=? AND ENCOUNTER_ID=?
          AND CODE IN (${emrCodes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
          AND DELETED_YN=0 AND INVALID=0
        ORDER BY OBSERVED_DT DESC
      )
      FETCH FIRST ${SET_COUNT} ROWS ONLY
    &quot;&quot;&quot;)
    int i=1
    psObs.setString(i++, pid); psObs.setString(i++, eid)
    emrCodes.each { c -&gt; psObs.setString(i++, c) }
    rsObs = psObs.executeQuery()
    while (rsObs.next()) obsList &lt;&lt; rsObs.getTimestamp(1)
  } finally { closeQ(rsObs); closeQ(psObs) }

  if (obsList.isEmpty()) {
    fails &lt;&lt; &quot;EMR observed_dt set not found (0 rows)&quot;
    emrDumpStr = &quot;${EMR_VITAL_TABLE}\n(0 rows)\n&quot;
    vcDumpStr  = &quot;&quot;
  } else {

    int expTotal = obsList.size() * emrCodes.size()

    Timestamp emrLatestObs = obsList[0]
    Timestamp vcLatestObs  = new Timestamp(emrLatestObs.getTime() - OFFSET_9H_MS)

    // =====================================================
    // 5) EMR 전체 로드
    // =====================================================
    def emrMap = [:]  // key = vcObsMillis|type
    PreparedStatement psEmr=null; ResultSet rsEmr=null
    try {
      psEmr = eConn.prepareStatement(&quot;&quot;&quot;
        SELECT OBSERVED_DT, CODE, VALUE
        FROM ${EMR_VITAL_TABLE}
        WHERE PATIENT_ID=? AND ENCOUNTER_ID=?
          AND OBSERVED_DT IN (${obsList.collect{&quot;?&quot;}.join(&quot;,&quot;)})
          AND CODE IN (${emrCodes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
          AND DELETED_YN=0 AND INVALID=0
      &quot;&quot;&quot;)
      int j=1
      psEmr.setString(j++, pid); psEmr.setString(j++, eid)
      obsList.each { ts -&gt; psEmr.setTimestamp(j++, ts) }
      emrCodes.each { c -&gt; psEmr.setString(j++, c) }
      rsEmr = psEmr.executeQuery()
      while (rsEmr.next()) {
        def emrObs  = rsEmr.getTimestamp(1)
        def emrCode = (rsEmr.getString(2) ?: &quot;&quot;).toString().trim()
        def emrVal  = rsEmr.getObject(3)
        def type    = mapType(emrCode)
        def vcObs   = new Timestamp(emrObs.getTime() - OFFSET_9H_MS)
        def key     = vcObs.getTime() + &quot;|&quot; + type
        emrMap[key] = [code: emrCode, val: emrVal, emrObs: emrObs, vcObs: vcObs]
      }
    } finally { closeQ(rsEmr); closeQ(psEmr) }

    if (emrMap.size() != expTotal) fails &lt;&lt; &quot;EMR vital rows != ${expTotal} (got=${emrMap.size()})&quot;

    // =====================================================
    // 6) EMR dump (latest set)
    // =====================================================
    PreparedStatement psDumpEmr=null; ResultSet rsDumpEmr=null
    try {
      psDumpEmr = eConn.prepareStatement(&quot;&quot;&quot;
        SELECT CREATED_DT, UPDATED_DT, PATIENT_ID, ENCOUNTER_ID, OBSERVED_DT, CODE, VALUE
        FROM ${EMR_VITAL_TABLE}
        WHERE PATIENT_ID=? AND ENCOUNTER_ID=?
          AND OBSERVED_DT=?
          AND CODE IN (${emrCodes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
          AND DELETED_YN=0 AND INVALID=0
        ${ORDER_EMR}
      &quot;&quot;&quot;)
      int k=1
      psDumpEmr.setString(k++, pid); psDumpEmr.setString(k++, eid)
      psDumpEmr.setTimestamp(k++, emrLatestObs)
      emrCodes.each { c -&gt; psDumpEmr.setString(k++, c) }
      rsDumpEmr = psDumpEmr.executeQuery()
      emrDumpStr = dumpPretty(&quot;${EMR_VITAL_TABLE} (latest set)&quot;, rsDumpEmr, 50)
      if (!emrDumpStr?.trim()) emrDumpStr = &quot;${EMR_VITAL_TABLE} (latest set)\n(0 rows)\n&quot;
    } finally { closeQ(rsDumpEmr); closeQ(psDumpEmr) }

    // =====================================================
    // 7) VC load + compare (3 tables)
    // =====================================================
    vConn = DriverManager.getConnection(vcUrl, vcUser, vcPw)
    setVcKey(vConn, &quot;VITAL&quot;)

    def vcPidExpr = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),   @secretkey, @iv) AS CHAR)&quot;
    def vcEidExpr = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR)&quot;

    def vcObsList = obsList.collect { new Timestamp(it.getTime() - OFFSET_9H_MS) }

    def loadVcMap = { String tableName, String typeCol, String valueCol, String extraWhere -&gt;
      def m = [:] // key -&gt; valueObj
      PreparedStatement ps=null; ResultSet rs=null
      try {
        ps = vConn.prepareStatement(&quot;&quot;&quot;
          SELECT observed_dt, ${typeCol} AS t, ${valueCol} AS v
          FROM ${tableName}
          WHERE ${vcPidExpr}=? AND ${vcEidExpr}=?
            AND observed_dt IN (${vcObsList.collect{&quot;?&quot;}.join(&quot;,&quot;)})
            AND ${typeCol} IN (${vcTypes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
            ${extraWhere ?: &quot;&quot;}
        &quot;&quot;&quot;)
        int p=1
        ps.setString(p++, pid); ps.setString(p++, eid)
        vcObsList.each { ts -&gt; ps.setTimestamp(p++, ts) }
        vcTypes.each { t -&gt; ps.setString(p++, t) }
        rs = ps.executeQuery()
        while (rs.next()) {
          def obs = rs.getTimestamp(1)
          def t   = (rs.getString(2) ?: &quot;&quot;).toString().trim()
          def v   = rs.getObject(3)
          def key = obs.getTime() + &quot;|&quot; + t
          m[key] = v
        }
        return m
      } finally { closeQ(rs); closeQ(ps) }
    }

    def vcObsMap  = loadVcMap(VC_TBL_VC_OBS,  &quot;type&quot;,        &quot;value&quot;, &quot;&quot;)
    def emrObsMap = loadVcMap(VC_TBL_EMR_OBS, &quot;type&quot;,        &quot;value&quot;, &quot;&quot;)
    def evtMap    = loadVcMap(VC_TBL_VC_EVENT,&quot;subcategory&quot;, &quot;value&quot;, &quot;AND category=&apos;Observation&apos;&quot;)

    int c1 = vcObsMap.size()
    int c2 = emrObsMap.size()
    int c3 = evtMap.size()

    if (c1 != expTotal) fails &lt;&lt; &quot;VC vc_observation rows != ${expTotal} (got=${c1})&quot;
    if (c2 != expTotal) fails &lt;&lt; &quot;VC emr_observation rows != ${expTotal} (got=${c2})&quot;
    if (c3 != expTotal) fails &lt;&lt; &quot;VC vc_event rows != ${expTotal} (got=${c3})&quot;
    
    boolean canDetailCompare =
      (fails.find { it.toString().startsWith(&quot;VC &quot;) } == null) &amp;&amp;
      (emrMap.size() == expTotal) &amp;&amp;
      (c1 == expTotal) &amp;&amp; (c2 == expTotal) &amp;&amp; (c3 == expTotal)

    if (canDetailCompare) {
      def addMismatch = { String where, String code, String type, Timestamp vcObs, Object ev, Object av -&gt;
        if (mismatchLines.size() &lt; 10) {
          mismatchLines &lt;&lt; &quot;value mismatch ${where} (${code}) [vcObs=${vcObs}, type=${type}] emr=${ev} vc=${av}&quot;
        }
      }

      emrMap.each { key, rec -&gt;
        def code   = rec.code
        def type   = mapType(code)
        def vcObs  = rec.vcObs
        def emrVal = rec.val

        def v1 = vcObsMap[key]
        def v2 = emrObsMap[key]
        def v3 = evtMap[key]

        if (v1 == null || v2 == null || v3 == null) {
          if (mismatchLines.size() &lt; 10) mismatchLines &lt;&lt; &quot;missing row (${code}) [vcObs=${vcObs}, type=${type}]&quot;
          return
        }

        if (!eqValue(code, emrVal, v1)) addMismatch(&quot;vc_observation&quot;, code, type, vcObs, emrVal, v1)
        if (!eqValue(code, emrVal, v2)) addMismatch(&quot;emr_observation&quot;, code, type, vcObs, emrVal, v2)
        if (!eqValue(code, emrVal, v3)) addMismatch(&quot;vc_event&quot;,       code, type, vcObs, emrVal, v3)
      }

      if (!mismatchLines.isEmpty()) {
        fails &lt;&lt; &quot;mismatches=${mismatchLines.size()} (showing up to 10): &quot; + mismatchLines.join(&quot;, &quot;)
      }
    }

    // =====================================================
    // 8) VC dumps (latest set only)
    // =====================================================
    def dumpVcSet = { String title, String sql, List&lt;Object&gt; bindVals -&gt;
      PreparedStatement ps=null; ResultSet rs=null
      try {
        ps = vConn.prepareStatement(sql)
        int b=1
        bindVals.each { v -&gt;
          if (v instanceof Timestamp) ps.setTimestamp(b++, (Timestamp)v)
          else ps.setString(b++, v.toString())
        }
        rs = ps.executeQuery()
        def s = dumpPretty(title, rs, 50)
        return s?.trim() ? s : &quot;${title}\n(0 rows)\n&quot;
      } finally { closeQ(rs); closeQ(ps) }
    }

    def vcObsDump = dumpVcSet(&quot;${VC_TBL_VC_OBS} (latest set)&quot;, &quot;&quot;&quot;
      SELECT created_dt, updated_dt,
             ${vcPidExpr} AS patient_id,
             ${vcEidExpr} AS encounter_id,
             observed_dt, type, value, raw_value
      FROM ${VC_TBL_VC_OBS}
      WHERE ${vcPidExpr}=? AND ${vcEidExpr}=?
        AND observed_dt=?
        AND type IN (${vcTypes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
      ${ORDER_VC_TYPE}
    &quot;&quot;&quot;, [pid, eid, vcLatestObs] + vcTypes)

    def emrObsDump = dumpVcSet(&quot;${VC_TBL_EMR_OBS} (latest set)&quot;, &quot;&quot;&quot;
      SELECT created_dt, updated_dt,
             ${vcPidExpr} AS patient_id,
             ${vcEidExpr} AS encounter_id,
             observed_dt, type, value, raw_value
      FROM ${VC_TBL_EMR_OBS}
      WHERE ${vcPidExpr}=? AND ${vcEidExpr}=?
        AND observed_dt=?
        AND type IN (${vcTypes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
      ${ORDER_VC_TYPE}
    &quot;&quot;&quot;, [pid, eid, vcLatestObs] + vcTypes)

    def eventDump = dumpVcSet(&quot;${VC_TBL_VC_EVENT} (latest set)&quot;, &quot;&quot;&quot;
      SELECT created_dt, updated_dt,
             ${vcPidExpr} AS patient_id,
             ${vcEidExpr} AS encounter_id,
             observed_dt, category, subcategory, value, raw_value
      FROM ${VC_TBL_VC_EVENT}
      WHERE ${vcPidExpr}=? AND ${vcEidExpr}=?
        AND observed_dt=?
        AND category=&apos;Observation&apos;
        AND subcategory IN (${vcTypes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
      ${ORDER_VC_SUBCAT}
    &quot;&quot;&quot;, [pid, eid, vcLatestObs] + vcTypes)

    vcDumpStr = (vcObsDump.trim() + &quot;\n\n&quot; + emrObsDump.trim() + &quot;\n\n&quot; + eventDump.trim()).trim() + &quot;\n&quot;
  }

  // =====================================================
  // 9) verdict
  // =====================================================
  result = fails.isEmpty() ? &quot;PASS&quot; : &quot;FAIL&quot;
  notes  = fails.isEmpty() ? &quot;&quot; : fails.join(&quot; | &quot;)

} catch (Throwable t) {
  log.error(&quot;[VITAL] Exception&quot;, t)
  result = &quot;FAIL&quot;
  notes  = &quot;exception: &quot; + t.getClass().getSimpleName() + &quot; - &quot; + (t.getMessage() ?: &quot;&quot;)
} finally {
  closeQ(eConn); closeQ(vConn)
  finishFn(prev, ctx, props, vars, orderKey, scenarioId, result, notes, (emrDumpStr ?: &quot;&quot;), (vcDumpStr ?: &quot;&quot;))
}

return</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Scenario 7" enabled="true">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
