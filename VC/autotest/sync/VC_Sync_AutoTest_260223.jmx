            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">vars.put(&quot;currentControllerName&quot;, &quot;Scenario 3&quot;)

vars.put(&quot;scenario_id&quot;, &quot;5&quot;)
vars.put(&quot;expect_mode&quot;, &quot;SYNC_OK&quot;)
vars.put(&quot;order_key&quot;, &quot;300&quot;)
vars.put(&quot;verify_target&quot;, &quot;PDL&quot;)

