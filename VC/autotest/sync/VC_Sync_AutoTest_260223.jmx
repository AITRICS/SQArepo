        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Init_ReportPaths">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.nio.charset.StandardCharsets
import java.text.SimpleDateFormat
import java.util.Date

/**
 * Init_ReportPaths (GLOBAL / setUp)
 * - outputDir 생성 및 props에 저장
 * - 실행 시각 기반 CSV/HTML 경로 생성 후 props(lastCsvFile/lastHtmlFile)에 저장
 * - CSV 헤더 1회 생성
 * - CSV 동시 append 보호용 lock 객체(props.csvLock) 준비
 */

def defaultDir = &quot;C:/Users/김민지/jmeter-sync-report&quot;

// 1) Output directory
def outputDir = (props.get(&quot;outputDir&quot;) ?: defaultDir).toString()
props.put(&quot;outputDir&quot;, outputDir)

def outPath = Paths.get(outputDir)
if (!Files.exists(outPath)) {
    Files.createDirectories(outPath)
}

// 2) Timestamped file names (minute precision)
def fileStamp = new SimpleDateFormat(&quot;yyMMdd_HHmm&quot;).format(new Date())
def baseName  = &quot;Sync_AutoTest_Report_${fileStamp}&quot;

def csvPath  = outPath.resolve(&quot;${baseName}.csv&quot;)
def htmlPath = outPath.resolve(&quot;${baseName}.html&quot;)

props.put(&quot;lastCsvFile&quot;,  csvPath.toString())
props.put(&quot;lastHtmlFile&quot;, htmlPath.toString())

// 3) CSV header (create once)
def csvEscape = { Object v -&gt;
    def s = (v == null) ? &quot;&quot; : v.toString()
    s = s.replace(&quot;\r\n&quot;, &quot;\n&quot;).replace(&quot;\r&quot;, &quot;\n&quot;)
    s = s.replace(&quot;\&quot;&quot;, &quot;\&quot;\&quot;&quot;)
    &quot;\&quot;${s}\&quot;&quot;
}

def headerLine = [
    &quot;order_key&quot;,
    &quot;Scenario(Parent)&quot;,
    &quot;Scenario&quot;,
    &quot;StartTime&quot;,
    &quot;EndTime&quot;,
    &quot;Source (EMR)&quot;,
    &quot;Destination (VC)&quot;,
    &quot;Test Result&quot;,
    &quot;Notes&quot;
].collect(csvEscape).join(&quot;,&quot;) + &quot;\n&quot;

if (!Files.exists(csvPath)) {
    Files.write(
        csvPath,
        headerLine.getBytes(StandardCharsets.UTF_8),
        StandardOpenOption.CREATE, StandardOpenOption.WRITE
    )
}

// 4) CSV append lock (shared)
if (props.get(&quot;csvLock&quot;) == null) {
    props.put(&quot;csvLock&quot;, new Object())
}

log.info(&quot;[Init_ReportPaths] outputDir=${outputDir}&quot;)
log.info(&quot;[Init_ReportPaths] CSV=${csvPath}&quot;)
log.info(&quot;[Init_ReportPaths] HTML=${htmlPath}&quot;)
log.info(&quot;[Init_ReportPaths] csvLockReady=&quot; + (props.get(&quot;csvLock&quot;) != null))
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Register_CommonUtils">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*
import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone

/**
 * Register_CommonUtils (setUp TG)
 * - &quot;진짜 공통 유틸&quot;만 props.CommonUtils 에 등록 (전역 공유)
 * - 개발/리팩토링 중에는 무조건 덮어쓰기(캐시 문제 방지)
 *
 * 포함 유틸:
 *  - closeQuietly(AutoCloseable)
 *  - nowStr()
 *  - startStrFromPrev(prevObj)
 *  - normTs(Object)
 *  - setVcKey(Connection, tag)
 *  - dumpPretty(title, rs, maxRows)
 *  - getLogResults(prev, ctx, props, vars)
 *  - writeCsv9(prev, ctx, props, vars, orderKey, scenarioLabel, startStr, endStr, emrDump, vcDump, result, notes)
 *  - finish(prev, ctx, props, vars, orderKey, scenarioLabel, result, notes, emrDump, vcDump)
 */

// -----------------------------
// 0) time formatter
// -----------------------------
def TZ = (vars.get(&quot;TimeZone&quot;) ?: &quot;Asia/Seoul&quot;).toString().trim()
def sdfLog = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss,SSS&quot;)
sdfLog.setTimeZone(TimeZone.getTimeZone(TZ))

def closeQuietly = { AutoCloseable c -&gt;
    try { if (c != null) c.close() } catch (ignored) {}
}

def nowStr = { -&gt;
    sdfLog.format(new Date(System.currentTimeMillis()))
}

def startStrFromPrev = { prevObj -&gt;
    long startMillis = 0L
    try { startMillis = (prevObj != null) ? (prevObj.getStartTime() as long) : 0L } catch (ignored) {}
    if (startMillis &lt;= 0L) startMillis = System.currentTimeMillis()
    sdfLog.format(new Date(startMillis))
}

// -----------------------------
// 0-1) normalize timestamp
// -----------------------------
def normTs = { Object v -&gt;
    if (v == null) return &quot;&quot;
    def s = v.toString().trim()
    if (!s) return &quot;&quot;

    s = s.replace(&quot;T&quot;, &quot; &quot;)
    s = s.replaceAll(/Z$/, &apos;&apos;)
    s = s.replaceAll(/([+-]\d{2}:?\d{2})$/, &apos;&apos;)

    int dot = s.indexOf(&quot;.&quot;)
    if (dot &gt;= 0) s = s.substring(0, dot)

    s = s.trim()
    if (s.length() == 16) s = s + &quot;:00&quot;
    if (s.length() &gt;= 19) s = s.substring(0, 19)
    return s
}

// -----------------------------
// 1) VC key setter (MySQL session vars)
// -----------------------------
def setVcKey = { Connection c, String tag -&gt;

    def sec =
            (vars.get(&quot;VC_SECRET&quot;) ?:
             props.get(&quot;VC_SECRET&quot;) ?:
             System.getenv(&quot;VC_SECRET&quot;) ?: &quot;&quot;).toString().trim()

    boolean required = ((vars.get(&quot;VC_SECRET_REQUIRED&quot;)
                        ?: props.get(&quot;VC_SECRET_REQUIRED&quot;)
                        ?: &quot;false&quot;).toString()
                        .equalsIgnoreCase(&quot;true&quot;))

    if (!sec) {
        if (required)
            throw new RuntimeException(&quot;[${tag}] VC_SECRET is empty. Set vars/props/env VC_SECRET.&quot;)
        sec = &quot;some_secret&quot;
    }

    PreparedStatement ps = null
    Statement st = null
    ResultSet rs = null

    try {
        ps = c.prepareStatement(
            &quot;SET @hashed_key = (SELECT UNHEX(SHA2(?, 256)))&quot;
        )
        ps.setString(1, sec)
        ps.execute()
        closeQuietly(ps); ps = null

        st = c.createStatement()
        st.execute(&quot;SET @secretkey = LEFT(@hashed_key, 16)&quot;)
        st.execute(&quot;SET @iv = RIGHT(@hashed_key, 16)&quot;)

        rs = st.executeQuery(&quot;SELECT LENGTH(@secretkey) klen, LENGTH(@iv) ivlen&quot;)
        rs.next()
        int klen = rs.getInt(&quot;klen&quot;)
        int ivlen = rs.getInt(&quot;ivlen&quot;)

        log.info(&quot;[VC_KEYCHK] tag=${tag} klen=${klen}, ivlen=${ivlen}&quot;)

        if (klen != 16 || ivlen != 16)
            throw new RuntimeException(&quot;[${tag}] VC session key length invalid&quot;)

    } finally {
        closeQuietly(rs)
        closeQuietly(ps)
        closeQuietly(st)
    }
}


// -----------------------------
// 2) Pretty dump ResultSet
// -----------------------------
def dumpPretty = { String title, ResultSet rs, int maxRows -&gt;
    def sb = new StringBuilder()
    sb.append(title ?: &quot;RESULT&quot;).append(&quot;\n&quot;)

    if (rs == null) {
        sb.append(&quot;(rs is null)\n&quot;)
        return sb.toString()
    }

    def md = rs.getMetaData()
    int colCount = md.getColumnCount()
    def cols = (1..colCount).collect { md.getColumnLabel(it) ?: (&quot;COL&quot; + it) }

    def isTimeCol = { String c -&gt;
        def x = (c ?: &quot;&quot;).toLowerCase()
        x.endsWith(&quot;_dt&quot;) || x.endsWith(&quot;_time&quot;) ||
        x.contains(&quot;date&quot;) || x.contains(&quot;time&quot;) ||
        x.contains(&quot;created&quot;) || x.contains(&quot;updated&quot;) ||
        x.contains(&quot;admission&quot;) || x.contains(&quot;discharge&quot;) || x.contains(&quot;observed&quot;)
    }

    def rows = []
    int cnt = 0
    while (rs.next() &amp;&amp; cnt &lt; maxRows) {
        rows &lt;&lt; (1..colCount).collect { i -&gt;
            def o = rs.getObject(i)
            if (o == null) return &quot;&quot;
            def col = cols[i - 1]
            if (o instanceof java.sql.Timestamp || o instanceof java.sql.Date || o instanceof java.util.Date || isTimeCol(col)) {
                return normTs(o)
            }
            o.toString()
        }
        cnt++
    }

    def widths = new int[colCount]
    for (int i = 0; i &lt; colCount; i++) widths[i] = cols[i].length()
    rows.each { r -&gt;
        for (int i = 0; i &lt; colCount; i++) {
            widths[i] = Math.max(widths[i], (r[i] ?: &quot;&quot;).length())
        }
    }

    sb.append((0..&lt;colCount).collect { i -&gt; cols[i].padRight(widths[i]) }.join(&quot;|&quot;)).append(&quot;\n&quot;)
    sb.append((0..&lt;colCount).collect { i -&gt; &quot;-&quot; * widths[i] }.join(&quot;+&quot;)).append(&quot;\n&quot;)

    rows.each { r -&gt;
        sb.append((0..&lt;colCount).collect { i -&gt; (r[i] ?: &quot;&quot;).padRight(widths[i]) }.join(&quot;|&quot;)).append(&quot;\n&quot;)
    }

    if (rows.isEmpty()) sb.append(&quot;(0 rows)\n&quot;)
    return sb.toString()
}

// -----------------------------
// 3) CSV helpers
// -----------------------------
def getLogResults = { prev, ctx, propsObj, varsObj -&gt;
    def hasVars = (varsObj.getObject(&quot;logResults&quot;) != null)
    def hasProps = (propsObj.get(&quot;logResults&quot;) != null)
    log.info(&quot;[CU_DBG] getLogResults hasVars=${hasVars} hasProps=${hasProps}&quot;)

    def lr = varsObj.getObject(&quot;logResults&quot;)
    if (lr != null) return lr

    lr = propsObj.get(&quot;logResults&quot;)
    if (lr != null) return lr

    throw new RuntimeException(&quot;[CommonUtils] logResults is null. Register_LogResults(setUp) 실행/스코프 확인 필요.&quot;)
}

def writeCsv9 = { prev, ctx, propsObj, varsObj,
                  String orderKey,
                  String scenarioLabel,
                  String startStr,
                  String endStr,
                  String emrDump,
                  String vcDump,
                  String result,
                  String notes -&gt;

    def lr = getLogResults(prev, ctx, propsObj, varsObj)

    def parent = (varsObj.get(&quot;currentControllerName&quot;) ?: &quot;Scenario&quot;).toString().trim()
    if (!parent) parent = &quot;Scenario&quot;

    Object[] fields9 = [
            (orderKey ?: &quot;999&quot;).toString(),
            parent,
            (scenarioLabel ?: &quot;&quot;).toString(),
            (startStr ?: &quot;&quot;).toString(),
            (endStr ?: &quot;&quot;).toString(),
            (emrDump ?: &quot;&quot;),
            (vcDump ?: &quot;&quot;),
            (result ?: &quot;&quot;).toString(),
            (notes ?: &quot;&quot;).toString()
    ] as Object[]

    lr(prev, ctx, propsObj, varsObj, fields9)
}

// -----------------------------
// 4) finish (✅ verify_* + CSV append + prev 세팅)
// -----------------------------
def finish = { prev, ctx, propsObj, varsObj,
               String orderKey,
               String scenarioLabel,
               String result,
               String notes,
               String emrDump,
               String vcDump -&gt;

    def startStr = (varsObj.get(&quot;verify_startTime&quot;) ?: startStrFromPrev(prev)).toString()
    def endStr = nowStr()

    varsObj.put(&quot;verify_scenario&quot;, (scenarioLabel ?: (varsObj.get(&quot;scenario_id&quot;) ?: &quot;0&quot;)).toString())
    varsObj.put(&quot;verify_result&quot;, (result ?: &quot;ERROR&quot;))
    varsObj.put(&quot;verify_notes&quot;, (notes ?: &quot;&quot;))
    varsObj.put(&quot;verify_emrDump&quot;, (emrDump ?: &quot;&quot;))
    varsObj.put(&quot;verify_vcDump&quot;, (vcDump ?: &quot;&quot;))
    varsObj.put(&quot;verify_startTime&quot;, startStr)
    varsObj.put(&quot;verify_endTime&quot;, endStr)

    try {
        long st = 0L
        try { st = (prev != null) ? (prev.getStartTime() as long) : 0L } catch (ignored) {}
        varsObj.put(&quot;verify_duration_ms&quot;, (st &gt; 0L) ? String.valueOf(System.currentTimeMillis() - st) : &quot;&quot;)
    } catch (ignored) {
        varsObj.put(&quot;verify_duration_ms&quot;, &quot;&quot;)
    }

    writeCsv9(prev, ctx, propsObj, varsObj, orderKey, scenarioLabel, startStr, endStr, emrDump, vcDump, result, notes)
    log.info(&quot;[CSV] appended orderKey=${orderKey} scenario=${scenarioLabel} result=${result}&quot;)

    boolean ok = &quot;PASS&quot;.equalsIgnoreCase(result) || &quot;SKIP&quot;.equalsIgnoreCase(result)
    prev.setSuccessful(ok)
    prev.setResponseMessage(&quot;SYNC &quot; + (result ?: &quot;ERROR&quot;) + ((notes?.trim()) ? (&quot; | &quot; + notes) : &quot;&quot;))
    log.info(&quot;[FINISH] result=${result} scenario=${scenarioLabel} orderKey=${orderKey}&quot;)
}

// -----------------------------
// 5) export + overwrite register
// -----------------------------
def CommonUtils = [
        version        : &quot;2026-02-19&quot;,
        TZ             : TZ,
        sdfLog          : sdfLog,
        closeQuietly    : closeQuietly,
        nowStr          : nowStr,
        startStrFromPrev: startStrFromPrev,
        normTs          : normTs,
        setVcKey        : setVcKey,
        dumpPretty      : dumpPretty,
        getLogResults   : getLogResults,
        writeCsv9       : writeCsv9,
        finish          : finish
]

props.put(&quot;CommonUtils&quot;, CommonUtils)
log.info(&quot;[Register_CommonUtils] overwritten. version=${CommonUtils.version} TZ=${TZ}&quot;)

return
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Register_LogResults" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.nio.charset.StandardCharsets

/**
 * Register_LogResults (PER THREAD ONCE)
 * - props.lastCsvFile 기반으로 CSV append writer(closure) 생성
 * - vars.putObject(&quot;logResults&quot;, closure)
 * - 파일/헤더 생성은 setUp(Init_ReportPaths)에서만 수행
 */

def csvPathStr = (props.get(&quot;lastCsvFile&quot;) ?: &quot;&quot;).toString()
if (!csvPathStr) {
    throw new RuntimeException(&quot;[Register_LogResults] props.lastCsvFile is empty. Init_ReportPaths(setUp) 실행 여부 확인 필요.&quot;)
}

def csvPath = Paths.get(csvPathStr)

// shared lock (fallback 유지)
def csvLock = props.get(&quot;csvLock&quot;)
if (csvLock == null) {
    csvLock = new Object()
    props.put(&quot;csvLock&quot;, csvLock)
    log.warn(&quot;[Register_LogResults] csvLock missing. Re-created lock object in props.&quot;)
}

// CSV escaping (multiline / quote safe)
def csvEscape = { Object v -&gt;
    def s = (v == null) ? &quot;&quot; : v.toString()
    s = s.replace(&quot;\r\n&quot;, &quot;\n&quot;).replace(&quot;\r&quot;, &quot;\n&quot;)
    s = s.replace(&quot;\&quot;&quot;, &quot;\&quot;\&quot;&quot;)
    &quot;\&quot;${s}\&quot;&quot;
}

/**
 * logResults(prev, ctx, props, vars, fields[])
 * fields length 지원:
 * - 7 : Scenario..Notes (legacy)                -&gt; order_key=999 + parent + 7
 * - 8 : order_key + Scenario..Notes            -&gt; order_key + parent + 7
 * - 9 : order_key + Scenario(Parent) + 7 cols  -&gt; 그대로
 */
def logResults = { prev, ctx, props, vars, Object[] fields -&gt;

    if (fields == null || fields.length == 0) {
        log.error(&quot;[logResults] fields is null/empty.&quot;)
        return
    }

    def parent = (vars.get(&quot;currentControllerName&quot;) ?: &quot;Scenario&quot;).toString().trim()
    if (!parent) parent = &quot;Scenario&quot;

    def rowFields = []

    switch (fields.length) {
        case 7:
            rowFields &lt;&lt; &quot;999&quot;
            rowFields &lt;&lt; parent
            rowFields.addAll(fields as List)
            break

        case 8:
            def orderKey = (fields[0] == null || fields[0].toString().trim().isEmpty()) ? &quot;999&quot; : fields[0].toString().trim()
            rowFields &lt;&lt; orderKey
            rowFields &lt;&lt; parent
            rowFields.addAll((fields as List).subList(1, fields.length))
            break

        case 9:
            rowFields.addAll(fields as List)
            break

        default:
            // 기존 동작 유지: 예상 외 길이도 그냥 기록
            rowFields &lt;&lt; &quot;999&quot;
            rowFields &lt;&lt; parent
            rowFields.addAll(fields as List)
            log.warn(&quot;[logResults] Unexpected fields length=${fields.length} (expected 7/8/9). Writing anyway.&quot;)
            break
    }

    def line = rowFields.collect(csvEscape).join(&quot;,&quot;) + &quot;\n&quot;

    synchronized (csvLock) {
        Files.write(
            csvPath,
            line.getBytes(StandardCharsets.UTF_8),
            StandardOpenOption.APPEND, StandardOpenOption.WRITE
        )
    }
}

vars.putObject(&quot;logResults&quot;, logResults)
props.put(&quot;logResults&quot;, logResults)   // ✅ 전역 백업/공용

log.info(&quot;[Register_LogResults] ready. threadNum=${ctx.getThreadNum()}, CSV=${csvPath}, parent=${vars.get(&quot;currentControllerName&quot;) ?: &apos;null&apos;}&quot;)
</stringProp>
        </JSR223Sampler>
