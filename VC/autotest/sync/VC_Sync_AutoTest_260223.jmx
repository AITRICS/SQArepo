        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="LABORATORY_Data_JSR223 Sampler">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;
import java.util.Random;

	// JDBC connection information
	String url = &quot;${JDBC_URL}&quot;;
	String user = &quot;${JDBC_USER}&quot;;
	String password = &quot;${JDBC_PW}&quot;;
	
	// Define the query
	String query = &quot;INSERT INTO ROOT.LABORATORIES (PATIENT_ID, ENCOUNTER_ID, DRAWN_DT, ORDERED_DT, RESULT_DT, CODE, VALUE, DELETED_YN, INVALID) &quot; +
	                &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?, ?, ?, ?)&quot;;

	Connection conn = DriverManager.getConnection(url, user, password);
	PreparedStatement stmt = conn.prepareStatement(query);
	int rowsInsert; 

	// Repeat the process for multiple sets of parameters
	int PatientRepeatCount = ${PatientCount} // Number of repetitions set
	int LabRepeatCount = ${ObservationCount}; // Number of repetitions set
	for (int i = 0; i &lt; PatientRepeatCount; i++) {
         String PatientID = vars.get(&quot;PatientID&quot; + i);
	    String EncounterID = vars.get(&quot;EncounterID&quot; + i);
		for (int j = 0; j &lt;= LabRepeatCount; j++) {
			String DrawnDt = vars.get(&quot;DrawnDt&quot; + j);
			String OrderedDt = vars.get(&quot;OrderedDt&quot; + j);
			String ResultDt = vars.get(&quot;ResultDt&quot; + j);	
			// Generate an Acute Physiology and Chronic Health Evaluation (APACHE) value ranging from 0.0 to 13.9
			String APH_Value = new Random().nextInt(14) + &quot;.&quot; + (new Random().nextInt(10));			
			// Generate a Bilirubin value ranging from 0.0 to 74.9
			String BILIRUBIN_Value = new Random().nextInt(75) + &quot;.&quot; + (new Random().nextInt(10));			
			// Generate a Creatinine value ranging from 0.0 to 19.9
			String CREATININE_Value = new Random().nextInt(20) + &quot;.&quot; + (new Random().nextInt(10));			
			// Generate a C-reactive protein (CRP) value ranging from 0.0 to 899.9
			String CRP_Value = new Random().nextInt(900) + &quot;.&quot; + (new Random().nextInt(10));			
			// Generate a bicarbonate (HCO3) value ranging from 0.0 to 99.9
			String HCO3_Value = new Random().nextInt(100) + &quot;.&quot; + (new Random().nextInt(10));			
			// Generate a hematocrit (HCT) value ranging from 0.0 to 99.9
			String HCT_Value = new Random().nextInt(100) + &quot;.&quot; + (new Random().nextInt(10));			
			// Generate a lactate value ranging from 0.0 to 19.9
			String LACTATE_Value = new Random().nextInt(20) + &quot;.&quot; + (new Random().nextInt(10));			
			// Generate a platelet count value ranging from 0.0 to 999.9
			String PLATELET_Value = new Random().nextInt(1000) + &quot;.&quot; + (new Random().nextInt(10));			
			// Generate a potassium value ranging from 0.0 to 14.9
			String POTASSIUM_Value = new Random().nextInt(15) + &quot;.&quot; + (new Random().nextInt(10));			
			// Generate a sodium value ranging from 0.0 to 499.9
			String SODIUM_Value = new Random().nextInt(500) + &quot;.&quot; + (new Random().nextInt(10));			
			// Generate a white blood cell (WBC) count value ranging from 0.0 to 99.9
			String WBC_Value = new Random().nextInt(100) + &quot;.&quot; + (new Random().nextInt(10));
			
		
			insertObservation(conn, stmt, PatientID, EncounterID, DrawnDt, OrderedDt, ResultDt, &quot;APH&quot;, APH_Value, j);
			insertObservation(conn, stmt, PatientID, EncounterID, DrawnDt, OrderedDt, ResultDt, &quot;BILIRUBIN&quot;, BILIRUBIN_Value, j);
			insertObservation(conn, stmt, PatientID, EncounterID, DrawnDt, OrderedDt, ResultDt, &quot;CREATININE&quot;, CREATININE_Value, j);
			insertObservation(conn, stmt, PatientID, EncounterID, DrawnDt, OrderedDt, ResultDt, &quot;CRP&quot;, CRP_Value, j);
			insertObservation(conn, stmt, PatientID, EncounterID, DrawnDt, OrderedDt, ResultDt, &quot;HCO3&quot;, HCO3_Value, j);
			insertObservation(conn, stmt, PatientID, EncounterID, DrawnDt, OrderedDt, ResultDt, &quot;HEMATOCRIT&quot;, HCT_Value, j);
			insertObservation(conn, stmt, PatientID, EncounterID, DrawnDt, OrderedDt, ResultDt, &quot;LACTATE&quot;, LACTATE_Value, j);
			insertObservation(conn, stmt, PatientID, EncounterID, DrawnDt, OrderedDt, ResultDt, &quot;PLATELET&quot;, PLATELET_Value, j);
			insertObservation(conn, stmt, PatientID, EncounterID, DrawnDt, OrderedDt, ResultDt, &quot;POTASSIUM&quot;, POTASSIUM_Value, j);
			insertObservation(conn, stmt, PatientID, EncounterID, DrawnDt, OrderedDt, ResultDt, &quot;SODIUM&quot;, SODIUM_Value, j);
			insertObservation(conn, stmt, PatientID, EncounterID, DrawnDt, OrderedDt, ResultDt, &quot;WBC&quot;, WBC_Value, j);
		}
	}

public void insertObservation(Connection conn, PreparedStatement stmt, String patientID, String encounterID, 
					    String DrawnDt, String OrderedDt, String ResultDt, String code, String value, int j){
	stmt.setString(1, patientID);
	stmt.setString(2, encounterID);
	stmt.setString(3, DrawnDt);
	stmt.setString(4, OrderedDt);
	stmt.setString(5, ResultDt);	
	stmt.setString(6, code);
	stmt.setDouble(7, Double.parseDouble(value));
	stmt.setInt(8, 0);
	stmt.setInt(9, 0);
	int rowsInsert = stmt.executeUpdate();
	// Clear parameters for reusing the statement
	stmt.clearParameters();
}
// Close the connection
conn.close();

 
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Observation Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}
int repeatCount = ${ObservationCount}

SimpleDateFormat sdfLabDt = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
sdfLabDt.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

for (int i = 0; i &lt;= repeatCount; i++) {

    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault)

    calendar.add(Calendar.MINUTE, -((i * ${Ob_Interval_Min}) + 60))
    long orderedTs = calendar.getTimeInMillis()

    calendar.add(Calendar.HOUR, +1)
    long drawnTs

    if (i == repeatCount - 1) {
        drawnTs = calendar.getTimeInMillis()
        Calendar lastlab = Calendar.getInstance()
        lastlab.setTimeInMillis(drawnTs)

        int minute = lastlab.get(Calendar.MINUTE)
        int mod = minute % 10
        if (mod != 0) lastlab.add(Calendar.MINUTE, 10 - mod)
        else lastlab.add(Calendar.MINUTE, 10)

        lastlab.set(Calendar.SECOND, 0)
        lastlab.set(Calendar.MILLISECOND, 0)
        drawnTs = lastlab.getTimeInMillis()
    } else {
        drawnTs = calendar.getTimeInMillis()
    }

    calendar.add(Calendar.HOUR, +1)
    long resultTs = calendar.getTimeInMillis()

    String orderedDt = sdfLabDt.format(new Date(orderedTs))
    String drawnDt   = sdfLabDt.format(new Date(drawnTs))
    String resultDt  = sdfLabDt.format(new Date(resultTs))

    vars.put(&quot;OrderedDt&quot; + i, orderedDt)
    vars.put(&quot;DrawnDt&quot; + i, drawnDt)
    vars.put(&quot;ResultDt&quot; + i, resultDt)
}

log.info(&quot;[LAB_VARS] ObservationCount=&quot; + repeatCount
        + &quot; ordered0=&quot; + vars.get(&quot;OrderedDt0&quot;)
        + &quot; resultLast=&quot; + vars.get(&quot;ResultDt&quot; + repeatCount))
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Wait_for_Sync">
