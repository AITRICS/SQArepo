        <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Wait_for_Sync">
          <intProp name="ActionProcessor.action">1</intProp>
          <intProp name="ActionProcessor.target">0</intProp>
          <stringProp name="ActionProcessor.duration">180000</stringProp>
        </TestAction>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="update_enddt" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*
import java.text.SimpleDateFormat

def emrUrl  = (vars.get(&quot;JDBC_URL&quot;) ?: &quot;&quot;).toString().trim()
def emrUser = (vars.get(&quot;JDBC_USER&quot;) ?: &quot;&quot;).toString().trim()
def emrPw   = (vars.get(&quot;JDBC_PW&quot;) ?: &quot;&quot;).toString()

def pid = (vars.get(&quot;patient_id&quot;) ?: vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString().trim()
def eid = (vars.get(&quot;encounter_id&quot;) ?: vars.get(&quot;EncounterID0&quot;) ?: &quot;&quot;).toString().trim()

def EMR_ICU_TABLE = (vars.get(&quot;EMR_ICU_TABLE&quot;) ?: &quot;ROOT.ICUS&quot;).toString().trim()

if (!pid) throw new RuntimeException(&quot;[ICU_OUT_UPD] pid empty&quot;)
if (!eid) throw new RuntimeException(&quot;[ICU_OUT_UPD] eid empty&quot;)
if (!emrUrl || !emrUser) throw new RuntimeException(&quot;[ICU_OUT_UPD] EMR JDBC vars empty&quot;)

Connection conn = null
PreparedStatement psSel = null
PreparedStatement psUpd = null
ResultSet rs = null

try {
  conn = DriverManager.getConnection(emrUrl, emrUser, emrPw)

  psSel = conn.prepareStatement(&quot;&quot;&quot;
    SELECT START_DT
    FROM ${EMR_ICU_TABLE}
    WHERE PATIENT_ID = ?
      AND ENCOUNTER_ID = ?
      AND DELETED_YN = 0
    ORDER BY CREATED_DT DESC
    FETCH FIRST 1 ROWS ONLY
  &quot;&quot;&quot;)
  psSel.setString(1, pid)
  psSel.setString(2, eid)

  rs = psSel.executeQuery()
  if (!rs.next()) throw new RuntimeException(&quot;[ICU_OUT_UPD] START_DT not found (0 rows)&quot;)

  Timestamp startDt = rs.getTimestamp(1)
  if (startDt == null) throw new RuntimeException(&quot;[ICU_OUT_UPD] START_DT is null&quot;)

  Timestamp endDt = new Timestamp(startDt.getTime() + 60L*60L*1000L) // +1h

  psUpd = conn.prepareStatement(&quot;&quot;&quot;
    UPDATE ${EMR_ICU_TABLE}
       SET END_DT = ?,
           UPDATED_DT = SYSDATE
     WHERE PATIENT_ID = ?
       AND ENCOUNTER_ID = ?
       AND DELETED_YN = 0
  &quot;&quot;&quot;)
  psUpd.setTimestamp(1, endDt)
  psUpd.setString(2, pid)
  psUpd.setString(3, eid)

  int rows = psUpd.executeUpdate()

  def fmt = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
  log.info(&quot;[ICU] out update affectedRows=&quot; + rows + &quot; end_dt=&quot; + fmt.format(new Date(endDt.getTime())))

  if (rows != 1) throw new RuntimeException(&quot;[ICU_OUT_UPD] affectedRows=&quot; + rows + &quot; (expected 1)&quot;)

} finally {
  try { if (rs != null) rs.close() } catch (ignored) {}
  try { if (psSel != null) psSel.close() } catch (ignored) {}
  try { if (psUpd != null) psUpd.close() } catch (ignored) {}
  try { if (conn != null) conn.close() } catch (ignored) {}
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Wait_for_Sync" enabled="true">
