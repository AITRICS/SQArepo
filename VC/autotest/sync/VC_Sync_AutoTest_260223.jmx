        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="ICU_Info_JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.Connection
import java.sql.DriverManager
import java.sql.PreparedStatement



String url  = (vars.get(&quot;JDBC_URL&quot;)  ?: &quot;&quot;).toString().trim()
String user = (vars.get(&quot;JDBC_USER&quot;) ?: &quot;&quot;).toString().trim()
String pw   = (vars.get(&quot;JDBC_PW&quot;)   ?: &quot;&quot;).toString()

if (!url || !user) throw new RuntimeException(&quot;[ICU] EMR JDBC vars empty&quot;)

final String sql =
  &quot;INSERT INTO ROOT.ICUS (PATIENT_ID, ENCOUNTER_ID, START_DT, END_DT, DELETED_YN) &quot; +
  &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), 0)&quot;

int repeatCount = Integer.parseInt((vars.get(&quot;PatientCount&quot;) ?: &quot;1&quot;).toString().trim())

Connection conn = null
PreparedStatement ps = null

int affected = 0
int skipped = 0

try {
  conn = DriverManager.getConnection(url, user, pw)
  ps = conn.prepareStatement(sql)

  for (int i = 0; i &lt; repeatCount; i++) {

    // pid/eid: prefer single-source vars (patient_id / encounter_id), fallback to indexed vars
    String pid = (vars.get(&quot;patient_id&quot;) ?: vars.get(&quot;PatientID&quot; + i) ?: &quot;&quot;).toString().trim()
    String eid = (vars.get(&quot;encounter_id&quot;) ?: vars.get(&quot;EncounterID&quot; + i) ?: &quot;&quot;).toString().trim()

    String icuIn  = (vars.get(&quot;icuIn&quot; + i)  ?: &quot;&quot;).toString().trim()
    String icuOut = (vars.get(&quot;icuOut&quot; + i) ?: &quot;&quot;).toString().trim()

    if (!pid || !eid || !icuIn || !icuOut) {
      skipped++
      log.warn(&quot;[ICU] skip insert (missing var) i=&quot; + i +
              &quot; pid=&quot; + pid + &quot; eid=&quot; + eid + &quot; in=&quot; + icuIn + &quot; out=&quot; + icuOut)
      continue
    }

    ps.setString(1, pid)
    ps.setString(2, eid)
    ps.setString(3, icuIn)
    ps.setString(4, icuOut)

    affected += ps.executeUpdate()
    ps.clearParameters()
  }

  log.info(&quot;[ICU] affectedRows=&quot; + affected + &quot;, skipped=&quot; + skipped)

} finally {
  try { if (ps != null) ps.close() } catch (ignored) {}
  try { if (conn != null) conn.close() } catch (ignored) {}
}
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Observation Variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount} // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate to set timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {

    // ---------------------------------------
    // Patient / Encounter ID (DO NOT overwrite)
    //  - Reuse existing PatientID{i}, EncounterID{i} if present
    // ---------------------------------------
    String PatientID = (vars.get(&quot;PatientID&quot; + i) ?: &quot;&quot;).toString().trim()
    String EncounterID = (vars.get(&quot;EncounterID&quot; + i) ?: &quot;&quot;).toString().trim()

    if (!PatientID || !EncounterID) {
        // Create a Date object
        Date PatientSet = new Date(timestampDefault)
        Date EncounterSet = new Date(timestampDefault)

        // Create a SimpleDateFormat object and set it to timezone
        SimpleDateFormat sdf_patient = new SimpleDateFormat(i + &quot;yyMMddHHmmss&quot; + ${User_Thread})
        sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
        PatientID = sdf_patient.format(PatientSet)

        SimpleDateFormat sdf_encounter = new SimpleDateFormat(i + &quot;yyyyMMddHHmmss&quot; + ${User_Thread})
        sdf_encounter.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
        EncounterID = sdf_encounter.format(EncounterSet) + &quot;|&quot; + PatientID

        // Store only when generated (no overwrite)
        vars.put(&quot;PatientID&quot; + i, PatientID)
        vars.put(&quot;EncounterID&quot; + i, EncounterID)
    }

    // -----------------------------
    // Set ICU In Date
    // -----------------------------
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault)
    calendar.add(Calendar.MINUTE, - ((observationCount - 1) * ${Ob_Interval_Min}))

    // Align icuInSetTimestamp to next 10-minute mark
    int minuteIn = calendar.get(Calendar.MINUTE)
    int modIn = minuteIn % 10
    if (modIn != 0) {
        calendar.add(Calendar.MINUTE, 10 - modIn)
    } else {
        calendar.add(Calendar.MINUTE, 10)
    }
    calendar.set(Calendar.SECOND, 0)
    calendar.set(Calendar.MILLISECOND, 0)
    long icuInSetTimestamp = calendar.getTimeInMillis()
    Date icuInSet = new Date(icuInSetTimestamp)

    // -----------------------------
    // (Optional) Set ICU Out Date (kept for 6-2/6-3)
    // -----------------------------
    calendar.setTimeInMillis(timestampDefault)
    calendar.add(Calendar.HOUR, -1)

    // Align icuOutSetTimestamp to next 10-minute mark
    int minuteOut = calendar.get(Calendar.MINUTE)
    int modOut = minuteOut % 10
    if (modOut != 0) {
        calendar.add(Calendar.MINUTE, 10 - modOut)
        calendar.set(Calendar.SECOND, 0)
        calendar.set(Calendar.MILLISECOND, 0)
    }

    long icuOutSetTimestamp = calendar.getTimeInMillis()
    Date icuOutSet = new Date(icuOutSetTimestamp)

    // Create a SimpleDateFormat object and set it to timezone
    SimpleDateFormat sdf_icuIn = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    sdf_icuIn.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    String icuIn = sdf_icuIn.format(icuInSet)

    SimpleDateFormat sdf_icuOut = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    sdf_icuOut.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))
    String icuOut = sdf_icuOut.format(icuOutSet)

    // Store in variables (ICU times only)
    vars.put(&quot;icuIn&quot; + i, icuIn)
    vars.put(&quot;icuOut&quot; + i, icuOut)
}
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Wait_for_Sync">
          <intProp name="ActionProcessor.action">1</intProp>
          <intProp name="ActionProcessor.target">0</intProp>
          <stringProp name="ActionProcessor.duration">180000</stringProp>
        </TestAction>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Verify_ICU_InOut" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*

/**
 * Verify_ICU_IN_OUT_AndWriteCsv (Scenario 10)
 *
 * Expect (SYNC_OK)
 *  - EMR ROOT.ICUS (pid,eid, DELETED_YN=0): count==1, START_DT/END_DT not null
 *  - VC  vc_icu  (pid,eid, deleted=0, status IN/OUT): IN count==1, OUT count==1
 *  - VC  vc_event(pid,eid, deleted=0, category=&apos;ICU&apos;, subcategory IN/OUT): IN count==1, OUT count==1
 *  - time mapping (+9h):
 *      EMR.start_dt == VC observed_dt(IN)  + 9h (vc_icu, vc_event)
 *      EMR.end_dt   == VC observed_dt(OUT) + 9h (vc_icu, vc_event)
 *
 * Dump (scoped to pid+eid)
 *  - EMR ROOT.ICUS: pid+eid 전체(삭제 제외)
 *  - VC  vc_icu:   pid+eid 전체(복호화 포함)
 *  - VC  vc_event: pid+eid + category=&apos;ICU&apos; 전체(복호화 포함)
 */

// -----------------------------
// 0) CommonUtils
// -----------------------------
def U = props.get(&quot;CommonUtils&quot;)
if (!(U instanceof Map)) throw new RuntimeException(&quot;[ICU] CommonUtils not found in props.&quot;)
def closeQ     = U.closeQuietly
def setVcKey   = U.setVcKey
def dumpPretty = U.dumpPretty

// -----------------------------
// 1) vars / config
// -----------------------------
def scenarioId = (vars.get(&quot;scenario_id&quot;) ?: &quot;10&quot;).toString().trim()
def orderKey   = (vars.get(&quot;order_key&quot;)   ?: &quot;630&quot;).toString().trim()
def expectMode = (vars.get(&quot;expect_mode&quot;) ?: &quot;SYNC_OK&quot;).toString().trim()

def emrUrl  = (vars.get(&quot;JDBC_URL&quot;) ?: &quot;&quot;).toString().trim()
def emrUser = (vars.get(&quot;JDBC_USER&quot;) ?: &quot;&quot;).toString().trim()
def emrPw   = (vars.get(&quot;JDBC_PW&quot;) ?: &quot;&quot;).toString()

def vcUrl   = (vars.get(&quot;JDBC_URL_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcUser  = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw    = (vars.get(&quot;JDBC_PW_VC&quot;) ?: &quot;&quot;).toString()

def pid = (vars.get(&quot;patient_id&quot;)   ?: vars.get(&quot;PatientID0&quot;)   ?: &quot;&quot;).toString().trim()
def eid = (vars.get(&quot;encounter_id&quot;) ?: vars.get(&quot;EncounterID0&quot;) ?: &quot;&quot;).toString().trim()

def EMR_ICU_TABLE = (vars.get(&quot;EMR_ICU_TABLE&quot;) ?: &quot;ROOT.ICUS&quot;).toString().trim()
def VC_TBL_VC_ICU = (vars.get(&quot;VC_TBL_VC_ICU&quot;) ?: &quot;vitalcare.vc_icu&quot;).toString().trim()
def VC_TBL_VC_EVT = (vars.get(&quot;VC_TBL_VC_EVENT&quot;) ?: &quot;vitalcare.vc_event&quot;).toString().trim()

def must = { String name, String v -&gt;
  if (v == null || v.trim().isEmpty()) throw new RuntimeException(&quot;[ICU] ${name} is empty&quot;)
  v.trim()
}
must(&quot;patient_id&quot;, pid); must(&quot;encounter_id&quot;, eid)
must(&quot;JDBC_URL&quot;, emrUrl); must(&quot;JDBC_USER&quot;, emrUser)
must(&quot;JDBC_URL_VC&quot;, vcUrl); must(&quot;JDBC_USER_VC&quot;, vcUser)

final long OFFSET_MS = 9L * 60L * 60L * 1000L
def plus9h = { Timestamp ts -&gt; (ts == null) ? null : new Timestamp(ts.getTime() + OFFSET_MS) }

// -----------------------------
// 2) holders
// -----------------------------
def fails = []
String result = &quot;FAIL&quot;
String notes  = &quot;&quot;
String emrDumpStr = &quot;&quot;
String vcDumpStr  = &quot;&quot;

Connection eConn=null
Connection vConn=null

try {
  if (!&quot;SYNC_OK&quot;.equalsIgnoreCase(expectMode)) fails &lt;&lt; &quot;expect_mode=${expectMode} (expected SYNC_OK)&quot;

  // =====================================================
  // EMR: dump + count==1 + latest row(start/end)
  // =====================================================
  eConn = DriverManager.getConnection(emrUrl, emrUser, emrPw)

  // dump (pid+eid 전체, 삭제 제외)
  PreparedStatement psEd=null; ResultSet rsEd=null
  try {
    psEd = eConn.prepareStatement(&quot;&quot;&quot;
      SELECT CREATED_DT, UPDATED_DT, PATIENT_ID, ENCOUNTER_ID, START_DT, END_DT
      FROM ${EMR_ICU_TABLE}
      WHERE PATIENT_ID=? AND ENCOUNTER_ID=? AND DELETED_YN=0
      ORDER BY CREATED_DT DESC
    &quot;&quot;&quot;)
    psEd.setString(1, pid); psEd.setString(2, eid)
    rsEd = psEd.executeQuery()
    emrDumpStr = dumpPretty(&quot;${EMR_ICU_TABLE}&quot;, rsEd, 200)
    if (!emrDumpStr?.trim()) emrDumpStr = &quot;${EMR_ICU_TABLE}\n(0 rows)\n&quot;
  } finally { closeQ(rsEd); closeQ(psEd) }

  // count
  int emrCnt = 0
  PreparedStatement psEc=null; ResultSet rsEc=null
  try {
    psEc = eConn.prepareStatement(&quot;&quot;&quot;
      SELECT COUNT(*) AS cnt
      FROM ${EMR_ICU_TABLE}
      WHERE PATIENT_ID=? AND ENCOUNTER_ID=? AND DELETED_YN=0
    &quot;&quot;&quot;)
    psEc.setString(1, pid); psEc.setString(2, eid)
    rsEc = psEc.executeQuery()
    rsEc.next()
    emrCnt = rsEc.getInt(&quot;cnt&quot;)
  } finally { closeQ(rsEc); closeQ(psEc) }

  // latest row (deterministic)
  Timestamp emrStart=null
  Timestamp emrEnd=null
  PreparedStatement psE1=null; ResultSet rsE1=null
  try {
    psE1 = eConn.prepareStatement(&quot;&quot;&quot;
      SELECT START_DT, END_DT
      FROM ${EMR_ICU_TABLE}
      WHERE PATIENT_ID=? AND ENCOUNTER_ID=? AND DELETED_YN=0
      ORDER BY CREATED_DT DESC
      FETCH FIRST 1 ROWS ONLY
    &quot;&quot;&quot;)
    psE1.setString(1, pid); psE1.setString(2, eid)
    rsE1 = psE1.executeQuery()
    if (rsE1.next()) {
      emrStart = rsE1.getTimestamp(1)
      emrEnd   = rsE1.getTimestamp(2)
    }
  } finally { closeQ(rsE1); closeQ(psE1) }

  if (emrCnt != 1)     fails &lt;&lt; &quot;EMR ICUS count=${emrCnt} (expected 1)&quot;
  if (emrStart == null) fails &lt;&lt; &quot;EMR START_DT is null&quot;
  if (emrEnd   == null) fails &lt;&lt; &quot;EMR END_DT is null&quot;

  // =====================================================
  // VC: dump + IN/OUT count==1 + latest observed_dt
  // =====================================================
  vConn = DriverManager.getConnection(vcUrl, vcUser, vcPw)
  setVcKey(vConn, &quot;ICU&quot;)

  def vcPidExpr = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),@secretkey,@iv) AS CHAR)&quot;
  def vcEidExpr = &quot;CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id),@secretkey,@iv) AS CHAR)&quot;
  def vcCond    = &quot;${vcPidExpr}=? AND ${vcEidExpr}=?&quot;

  // dumps
  PreparedStatement psVd1=null; ResultSet rsVd1=null
  try {
    psVd1 = vConn.prepareStatement(&quot;&quot;&quot;
      SELECT
        created_dt, updated_dt,
        ${vcPidExpr} AS patient_id,
        ${vcEidExpr} AS encounter_id,
        observed_dt, status, emr_created_dt, deleted
      FROM ${VC_TBL_VC_ICU}
      WHERE ${vcCond}
      ORDER BY observed_dt DESC
    &quot;&quot;&quot;)
    psVd1.setString(1, pid); psVd1.setString(2, eid)
    rsVd1 = psVd1.executeQuery()
    def dump1 = dumpPretty(&quot;${VC_TBL_VC_ICU}&quot;, rsVd1, 200)
    vcDumpStr = (dump1?.trim() ? dump1.trim() : &quot;${VC_TBL_VC_ICU}\n(0 rows)\n&quot;)
  } finally { closeQ(rsVd1); closeQ(psVd1) }

  PreparedStatement psVd2=null; ResultSet rsVd2=null
  try {
    psVd2 = vConn.prepareStatement(&quot;&quot;&quot;
      SELECT
        created_dt, updated_dt,
        ${vcPidExpr} AS patient_id,
        ${vcEidExpr} AS encounter_id,
        observed_dt, category, subcategory, deleted
      FROM ${VC_TBL_VC_EVT}
      WHERE ${vcCond} AND category=&apos;ICU&apos;
      ORDER BY observed_dt DESC
    &quot;&quot;&quot;)
    psVd2.setString(1, pid); psVd2.setString(2, eid)
    rsVd2 = psVd2.executeQuery()
    def dump2 = dumpPretty(&quot;${VC_TBL_VC_EVT}&quot;, rsVd2, 200)
    vcDumpStr = vcDumpStr.trim() + &quot;\n\n&quot; + (dump2?.trim() ? dump2.trim() : &quot;${VC_TBL_VC_EVT}\n(0 rows)\n&quot;) + &quot;\n&quot;
  } finally { closeQ(rsVd2); closeQ(psVd2) }

  // helpers: count + latest observed_dt
  def countWhere = { String sql -&gt;
    PreparedStatement ps=null; ResultSet rs=null
    try {
      ps = vConn.prepareStatement(sql)
      ps.setString(1, pid); ps.setString(2, eid)
      rs = ps.executeQuery()
      rs.next()
      return rs.getInt(&quot;cnt&quot;)
    } finally { closeQ(rs); closeQ(ps) }
  }
  def latestObs = { String sql -&gt;
    PreparedStatement ps=null; ResultSet rs=null
    try {
      ps = vConn.prepareStatement(sql)
      ps.setString(1, pid); ps.setString(2, eid)
      rs = ps.executeQuery()
      return rs.next() ? rs.getTimestamp(1) : null
    } finally { closeQ(rs); closeQ(ps) }
  }

  int icuInCnt = countWhere(&quot;&quot;&quot;
    SELECT COUNT(*) AS cnt
    FROM ${VC_TBL_VC_ICU}
    WHERE ${vcCond} AND deleted=0 AND UPPER(TRIM(status))=&apos;IN&apos;
  &quot;&quot;&quot;)
  int icuOutCnt = countWhere(&quot;&quot;&quot;
    SELECT COUNT(*) AS cnt
    FROM ${VC_TBL_VC_ICU}
    WHERE ${vcCond} AND deleted=0 AND UPPER(TRIM(status))=&apos;OUT&apos;
  &quot;&quot;&quot;)
  int evtInCnt = countWhere(&quot;&quot;&quot;
    SELECT COUNT(*) AS cnt
    FROM ${VC_TBL_VC_EVT}
    WHERE ${vcCond} AND deleted=0 AND category=&apos;ICU&apos; AND UPPER(TRIM(subcategory))=&apos;IN&apos;
  &quot;&quot;&quot;)
  int evtOutCnt = countWhere(&quot;&quot;&quot;
    SELECT COUNT(*) AS cnt
    FROM ${VC_TBL_VC_EVT}
    WHERE ${vcCond} AND deleted=0 AND category=&apos;ICU&apos; AND UPPER(TRIM(subcategory))=&apos;OUT&apos;
  &quot;&quot;&quot;)

  if (icuInCnt  != 1) fails &lt;&lt; &quot;VC vc_icu(IN) count=${icuInCnt} (expected 1)&quot;
  if (icuOutCnt != 1) fails &lt;&lt; &quot;VC vc_icu(OUT) count=${icuOutCnt} (expected 1)&quot;
  if (evtInCnt  != 1) fails &lt;&lt; &quot;VC vc_event(IN) count=${evtInCnt} (expected 1)&quot;
  if (evtOutCnt != 1) fails &lt;&lt; &quot;VC vc_event(OUT) count=${evtOutCnt} (expected 1)&quot;

  Timestamp vcIcuInObs = latestObs(&quot;&quot;&quot;
    SELECT observed_dt
    FROM ${VC_TBL_VC_ICU}
    WHERE ${vcCond} AND deleted=0 AND UPPER(TRIM(status))=&apos;IN&apos;
    ORDER BY observed_dt DESC
    LIMIT 1
  &quot;&quot;&quot;)
  Timestamp vcIcuOutObs = latestObs(&quot;&quot;&quot;
    SELECT observed_dt
    FROM ${VC_TBL_VC_ICU}
    WHERE ${vcCond} AND deleted=0 AND UPPER(TRIM(status))=&apos;OUT&apos;
    ORDER BY observed_dt DESC
    LIMIT 1
  &quot;&quot;&quot;)
  Timestamp vcEvtInObs = latestObs(&quot;&quot;&quot;
    SELECT observed_dt
    FROM ${VC_TBL_VC_EVT}
    WHERE ${vcCond} AND deleted=0 AND category=&apos;ICU&apos; AND UPPER(TRIM(subcategory))=&apos;IN&apos;
    ORDER BY observed_dt DESC
    LIMIT 1
  &quot;&quot;&quot;)
  Timestamp vcEvtOutObs = latestObs(&quot;&quot;&quot;
    SELECT observed_dt
    FROM ${VC_TBL_VC_EVT}
    WHERE ${vcCond} AND deleted=0 AND category=&apos;ICU&apos; AND UPPER(TRIM(subcategory))=&apos;OUT&apos;
    ORDER BY observed_dt DESC
    LIMIT 1
  &quot;&quot;&quot;)

  // time mapping (+9h): ms exact
  if (emrStart != null &amp;&amp; vcIcuInObs != null) {
    def v = plus9h(vcIcuInObs)
    if (v.getTime() != emrStart.getTime())
      fails &lt;&lt; &quot;start_dt mismatch: EMR(${emrStart}) vs VC_ICU_IN+9h(${v})&quot;
  }
  if (emrStart != null &amp;&amp; vcEvtInObs != null) {
    def v = plus9h(vcEvtInObs)
    if (v.getTime() != emrStart.getTime())
      fails &lt;&lt; &quot;start_dt mismatch: EMR(${emrStart}) vs VC_EVT_IN+9h(${v})&quot;
  }
  if (emrEnd != null &amp;&amp; vcIcuOutObs != null) {
    def v = plus9h(vcIcuOutObs)
    if (v.getTime() != emrEnd.getTime())
      fails &lt;&lt; &quot;end_dt mismatch: EMR(${emrEnd}) vs VC_ICU_OUT+9h(${v})&quot;
  }
  if (emrEnd != null &amp;&amp; vcEvtOutObs != null) {
    def v = plus9h(vcEvtOutObs)
    if (v.getTime() != emrEnd.getTime())
      fails &lt;&lt; &quot;end_dt mismatch: EMR(${emrEnd}) vs VC_EVT_OUT+9h(${v})&quot;
  }

  result = fails.isEmpty() ? &quot;PASS&quot; : &quot;FAIL&quot;
  notes  = fails.isEmpty() ? &quot;&quot; : fails.join(&quot; | &quot;)

} catch (Throwable t) {
  log.error(&quot;[ICU] Exception&quot;, t)
  result = &quot;FAIL&quot;
  notes  = &quot;exception: &quot; + t.getClass().getSimpleName() + &quot; - &quot; + (t.getMessage() ?: &quot;&quot;)
} finally {
  closeQ(eConn); closeQ(vConn)
  U.finish(prev, ctx, props, vars, orderKey, scenarioId, result, notes, emrDumpStr, vcDumpStr)
}

return</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
      <PostThreadGroup guiclass="PostThreadGroupGui" testclass="PostThreadGroup" testname="tearDown Thread Group">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </PostThreadGroup>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(Result)_JSR223 Sampler">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.util.TimeZone
import java.text.SimpleDateFormat
import java.util.Date
import groovy.json.JsonOutput

// -----------------------------
// Helpers
// -----------------------------
def parseCsvText = { String text -&gt;
    def records = []
    def row = []
    def sb = new StringBuilder()
    boolean inQuotes = false

    for (int i = 0; i &lt; text.length(); i++) {
        char c = text.charAt(i)

        if (inQuotes) {
            if (c == &apos;&quot;&apos;) {
                if (i + 1 &lt; text.length() &amp;&amp; text.charAt(i + 1) == &apos;&quot;&apos;) {
                    sb.append(&apos;&quot;&apos;); i++
                } else {
                    inQuotes = false
                }
            } else {
                sb.append(c)
            }
        } else {
            if (c == &apos;&quot;&apos;) inQuotes = true
            else if (c == &apos;,&apos;) { row &lt;&lt; sb.toString(); sb.setLength(0) }
            else if (c == &apos;\n&apos;) {
                row &lt;&lt; sb.toString(); sb.setLength(0)
                if (!(row.size() == 1 &amp;&amp; row[0].trim().isEmpty())) records &lt;&lt; row
                row = []
            } else if (c != &apos;\r&apos;) sb.append(c)
        }
    }

    row &lt;&lt; sb.toString()
    if (!(row.size() == 1 &amp;&amp; row[0].trim().isEmpty())) {
        if (records.isEmpty() || row.any { it != &quot;&quot; }) records &lt;&lt; row
    }
    return records
}

def htmlEscape = { Object v -&gt;
    def s = (v == null) ? &quot;&quot; : v.toString()
    s = s.replace(&quot;&amp;&quot;, &quot;&amp;amp;&quot;)
         .replace(&quot;&lt;&quot;, &quot;&amp;lt;&quot;)
         .replace(&quot;&gt;&quot;, &quot;&amp;gt;&quot;)
         .replace(&quot;\&quot;&quot;, &quot;&amp;quot;&quot;)
         .replace(&quot;&apos;&quot;, &quot;&amp;#39;&quot;)
    return s
}

def safeStr = { Object v -&gt; (v == null) ? &quot;&quot; : v.toString().trim() }

def idxOf = { List header, String name -&gt;
    if (header == null) return -1
    return header.indexOf(name)
}

def parseIntSafe = { String s, int defVal -&gt;
    try { return Integer.parseInt((s ?: &quot;&quot;).trim()) } catch (ignored) { return defVal }
}

// time parser
def tz = TimeZone.getTimeZone(&quot;Asia/Seoul&quot;)
def sdfMs  = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss,SSS&quot;); sdfMs.setTimeZone(tz)
def sdfSec = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);     sdfSec.setTimeZone(tz)

def parseTimeMs = { String s -&gt;
    if (!s) return null
    def t = s.trim()
    try { return sdfMs.parse(t).getTime() } catch (ignored) {}
    try { return sdfSec.parse(t).getTime() } catch (ignored) {}
    return null
}

// &quot;Scenario 1-3-2&quot; -&gt; &quot;Scenario 1&quot;
def groupKeyOfScenario = { String scenarioText -&gt;
    def sc = safeStr(scenarioText)
    if (!sc) return &quot;Scenario&quot;
    def m = (sc =~ /Scenario\s+(\d+)/)
    if (m.find()) return &quot;Scenario &quot; + m.group(1)
    return sc
}

def normResult = { Object v -&gt;
    def s = safeStr(v).toUpperCase()
    if (s.startsWith(&quot;PASS&quot;)) return &quot;PASS&quot;
    if (s.startsWith(&quot;FAIL&quot;)) return &quot;FAIL&quot;
    if (s.startsWith(&quot;SKIP&quot;)) return &quot;SKIP&quot;
    if (s.startsWith(&quot;ERROR&quot;)) return &quot;ERROR&quot;
    return s
}


def dumpViewHtml = { String raw -&gt;
    def s = htmlEscape(raw ?: &quot;&quot;)
    // wrap hints after common delimiters
    s = s.replace(&quot;|&quot;, &quot;|&lt;wbr&gt;&quot;)
         .replace(&quot;,&quot;, &quot;,&lt;wbr&gt;&quot;)
         .replace(&quot;;&quot;, &quot;;&lt;wbr&gt;&quot;)
    return s
}

def b64Utf8 = { String raw -&gt;
    return ((raw ?: &quot;&quot;).getBytes(&quot;UTF-8&quot;)).encodeBase64().toString()
}



// -----------------------------
// Runner
// -----------------------------
def csvPathStr  = (props.get(&quot;lastCsvFile&quot;)  ?: &quot;&quot;).toString()
def htmlPathStr = (props.get(&quot;lastHtmlFile&quot;) ?: &quot;&quot;).toString()

if (!csvPathStr) { log.warn(&quot;[HTML] lastCsvFile is empty.&quot;); return }
def csvFile = new File(csvPathStr)
if (!csvFile.exists()) { log.warn(&quot;[HTML] CSV not found: &quot; + csvFile.absolutePath); return }

def htmlFile = htmlPathStr ? new File(htmlPathStr) : new File(csvFile.parentFile, csvFile.name.replace(&quot;.csv&quot;, &quot;.html&quot;))

// -----------------------------
// Load &amp; parse
// -----------------------------
def csvText = csvFile.getText(&quot;UTF-8&quot;).replace(&quot;\r\n&quot;, &quot;\n&quot;).replace(&quot;\r&quot;, &quot;\n&quot;)
def records = parseCsvText(csvText)
if (!records || records.isEmpty()) { log.warn(&quot;[HTML] CSV empty&quot;); return }

def header = records[0]
def rows = (records.size() &gt; 1) ? records.subList(1, records.size()) : []
if (!rows) { log.warn(&quot;[HTML] CSV has header only&quot;); return }

// -----------------------------
// Column index
// -----------------------------
int idxOrder    = idxOf(header, &quot;order_key&quot;)
int idxGroupCol = idxOf(header, &quot;Group&quot;)
int idxParent   = idxOf(header, &quot;Scenario(Parent)&quot;)
int idxScenario = idxOf(header, &quot;Scenario&quot;)
int idxStart    = idxOf(header, &quot;StartTime&quot;)
int idxEnd      = idxOf(header, &quot;EndTime&quot;)
int idxResult   = idxOf(header, &quot;Test Result&quot;)
int idxSource   = idxOf(header, &quot;Source (EMR)&quot;)
int idxDest     = idxOf(header, &quot;Destination (VC)&quot;)
int idxNotes    = idxOf(header, &quot;Notes&quot;)

// -----------------------------
// Sort by order_key
// -----------------------------
if (idxOrder &gt;= 0) {
    rows.sort { a, b -&gt;
        def oa = (a.size() &gt; idxOrder) ? safeStr(a[idxOrder]) : &quot;&quot;
        def ob = (b.size() &gt; idxOrder) ? safeStr(b[idxOrder]) : &quot;&quot;
        parseIntSafe(oa, 999) &lt;=&gt; parseIntSafe(ob, 999)
    }
}

// -----------------------------
// Summary + Grouping
// -----------------------------
long minStartMs = Long.MAX_VALUE
long maxEndMs = 0L
int totalCount = 0
int passCount = 0
int failCount = 0

def groupStats = new LinkedHashMap&lt;String, Map&gt;()
def groupRows  = new LinkedHashMap&lt;String, List&gt;()

def ensureGroup = { String g -&gt;
    if (!groupStats.containsKey(g)) {
        groupStats[g] = [name:g, totalTest:0, passCount:0, failCount:0, minStartMs:Long.MAX_VALUE, maxEndMs:0L]
        groupRows[g] = []
    }
}

rows.each { r -&gt;
    totalCount++
    def res = normResult((idxResult &gt;= 0 &amp;&amp; r.size() &gt; idxResult) ? r[idxResult] : &quot;&quot;)
    if (res == &quot;PASS&quot;) passCount++
    else if (res == &quot;FAIL&quot;) failCount++

    def sStr = (idxStart &gt;= 0 &amp;&amp; r.size() &gt; idxStart) ? safeStr(r[idxStart]) : &quot;&quot;
    def eStr = (idxEnd   &gt;= 0 &amp;&amp; r.size() &gt; idxEnd)   ? safeStr(r[idxEnd])   : &quot;&quot;
    def sMs = parseTimeMs(sStr)
    def eMs = parseTimeMs(eStr)
    if (sMs != null &amp;&amp; sMs &lt; minStartMs) minStartMs = sMs
    if (eMs != null &amp;&amp; eMs &gt; maxEndMs) maxEndMs = eMs

    def parentText = (idxParent &gt;= 0 &amp;&amp; r.size() &gt; idxParent) ? safeStr(r[idxParent]) : &quot;&quot;
    def g = parentText ? parentText : &quot;Scenario&quot;

    ensureGroup(g)
    groupRows[g] &lt;&lt; r

    def gs = groupStats[g]
    gs.totalTest++
    if (res == &quot;PASS&quot;) gs.passCount++
    else if (res == &quot;FAIL&quot;) gs.failCount++

    if (sMs != null &amp;&amp; sMs &lt; gs.minStartMs) gs.minStartMs = sMs
    if (eMs != null &amp;&amp; eMs &gt; gs.maxEndMs) gs.maxEndMs = eMs
}

def summaryStart = (minStartMs == Long.MAX_VALUE) ? &quot;&quot; : sdfSec.format(new Date(minStartMs))
def summaryEnd   = (maxEndMs == 0L) ? &quot;&quot; : sdfSec.format(new Date(maxEndMs))
def durationSec  = (minStartMs == Long.MAX_VALUE || maxEndMs == 0L || maxEndMs &lt; minStartMs) ? &quot;&quot; : String.valueOf((maxEndMs - minStartMs)/1000L)

groupStats.values().each { gs -&gt;
    long gStart = (gs.minStartMs == Long.MAX_VALUE) ? 0L : (gs.minStartMs as long)
    long gEnd   = (gs.maxEndMs as long)
    gs.startTime = (gStart == 0L) ? &quot;&quot; : sdfSec.format(new Date(gStart))
    gs.endTime   = (gEnd == 0L) ? &quot;&quot; : sdfSec.format(new Date(gEnd))
    gs.duration  = (gStart == 0L || gEnd == 0L || gEnd &lt; gStart) ? &quot;&quot; : String.valueOf((gEnd - gStart)/1000L)
}

// -----------------------------
// Output columns (skip order/group/parent)
// -----------------------------
def skipIdx = new HashSet&lt;Integer&gt;()
if (idxOrder &gt;= 0) skipIdx.add(idxOrder)
if (idxGroupCol &gt;= 0) skipIdx.add(idxGroupCol)
if (idxParent &gt;= 0) skipIdx.add(idxParent)

def outHeader = []
for (int i=0; i&lt;header.size(); i++) {
    if (!skipIdx.contains(i)) outHeader &lt;&lt; header[i]
}

def colStyleFor = { String colName -&gt;
    def n = (colName ?: &quot;&quot;).toLowerCase()
    if (n == &quot;scenario&quot;) return &quot;width:150px;&quot;
    if (n.contains(&quot;starttime&quot;)) return &quot;width:160px;&quot;
    if (n.contains(&quot;endtime&quot;)) return &quot;width:160px;&quot;
    if (n.contains(&quot;test result&quot;)) return &quot;width:110px;&quot;
    if (n.contains(&quot;notes&quot;)) return &quot;width:200px;&quot;
    if (n.contains(&quot;source&quot;)) return &quot;width:460px;&quot;
    if (n.contains(&quot;destination&quot;)) return &quot;width:460px;&quot;

    return &quot;&quot;
}


// -----------------------------
// Tabs (planned + data)
// -----------------------------
def tabLabelMap = new LinkedHashMap&lt;String, String&gt;()
tabLabelMap[&quot;Scenario 1&quot;] = &quot;Scenario 1 (기본정보)&quot;
tabLabelMap[&quot;Scenario 2&quot;] = &quot;Scenario 2 (입원정보)&quot;
tabLabelMap[&quot;Scenario 3&quot;] = &quot;Scenario 3 (주치의/진료과/위치)&quot;
tabLabelMap[&quot;Scenario 4&quot;] = &quot;Scenario 4 (Vital)&quot;
tabLabelMap[&quot;Scenario 5&quot;] = &quot;Scenario 5 (Lab)&quot;
tabLabelMap[&quot;Scenario 6&quot;] = &quot;Scenario 6 (Icu)&quot;

def tabDescMap = new LinkedHashMap&lt;String, String&gt;()
tabDescMap[&quot;Scenario 1&quot;] = &quot;환자 기본 정보 추가, 변경에 대한 연동 시나리오 케이스&quot;
tabDescMap[&quot;Scenario 2&quot;] = &quot;환자 입원 정보 추가에 대한 연동 시나리오 케이스&quot;
tabDescMap[&quot;Scenario 3&quot;] = &quot;신규 주치의/진료과/위치 정보 추가에 대한 연동 시나리오 케이스&quot;
tabDescMap[&quot;Scenario 4&quot;] = &quot;Vital 데이터 추가에 대한 연동 시나리오 케이스&quot;
tabDescMap[&quot;Scenario 5&quot;] = &quot;Lab 데이터 추가에 대한 연동 시나리오 케이스&quot;
tabDescMap[&quot;Scenario 6&quot;] = &quot;Icu 입/퇴실 정보 추가에 대한 연동 시나리오 케이스&quot;


def plannedGroups = [&quot;Scenario 1&quot;,&quot;Scenario 2&quot;,&quot;Scenario 3&quot;,&quot;Scenario 4&quot;,&quot;Scenario 5&quot;,&quot;Scenario 6&quot;]
def dataGroups = groupStats.keySet().toList()

def finalGroups = []
plannedGroups.each { if (!finalGroups.contains(it)) finalGroups &lt;&lt; it }
dataGroups.each { if (!finalGroups.contains(it)) finalGroups &lt;&lt; it }

// Charts data
def groupNames = groupStats.values().collect { it.name }
def groupTotal = groupStats.values().collect { it.totalTest }


// -----------------------------
// Build HTML
// -----------------------------
def sb = new StringBuilder()
sb.append(&quot;&lt;!DOCTYPE html&gt;\n&lt;html&gt;\n&lt;head&gt;\n&quot;)
sb.append(&quot;&lt;meta charset=\&quot;UTF-8\&quot; /&gt;\n&quot;)
sb.append(&quot;&lt;script src=\&quot;https://cdn.jsdelivr.net/npm/chart.js\&quot;&gt;&lt;/script&gt;\n&quot;)

sb.append(&quot;&lt;style&gt;\n&quot;)
sb.append(&quot;*{box-sizing:border-box;}\n&quot;)

sb.append(&quot;body{margin:0;color:#1f2330;background:#faf9fe;font-family:system-ui,-apple-system,\&quot;Segoe UI\&quot;,Roboto,\&quot;Noto Sans KR\&quot;,Arial,sans-serif;font-size:15px;}\n&quot;)
sb.append(&quot;.wrap{width:100%;max-width:none;margin:0 auto;padding:22px 34px;box-sizing:border-box;}\n&quot;)

sb.append(&quot;.title{font-weight:700;font-size:24px;letter-spacing:-0.2px;margin:12px 0 12px 0;}\n&quot;)
sb.append(&quot;.testResultsTitle{font-weight:700;font-size:24px;margin:12px 0 16px 0;}\n&quot;)
sb.append(&quot;.testSummaryTitle{font-weight:700;font-size:16px;margin:12px 0 16px 0;}\n&quot;)
sb.append(&quot;.sectionTitle{font-weight:700;font-size:15px;letter-spacing:-0.1px;margin:18px 0 10px 0;}\n&quot;)
sb.append(&quot;.subTitle{font-weight:700;font-size:14px;margin:0 0 10px 0;color:#2a2f3a;}\n&quot;)
sb.append(&quot;.panelDesc{margin:0 0 18px 0;font-size:14px;font-weight:700;font-style:italic;color:#374151;}\n&quot;)

sb.append(&quot;.card{overflow:hidden;}\n&quot;)
sb.append(&quot;.card table{width:calc(100% - 8px);}\n&quot;)
sb.append(&quot;.card{width:100%;background:#fff;border-radius:10px;padding:26px 26px 22px 26px;margin-bottom:16px;border:1px solid #e8e8f2;box-shadow:0 2px 10px rgba(31,35,48,0.04);box-sizing:border-box;}\n&quot;)
sb.append(&quot;table{width:100%;border-collapse:collapse;table-layout:fixed;font-size:14px;font-family:inherit;}\n&quot;)
sb.append(&quot;th,td{padding:12px 14px;border:1px solid #ddd;vertical-align:top;text-align:left;font-family:inherit;}\n&quot;)
sb.append(&quot;th{background:#f4f4f4;font-weight:700;color:#1f2330;}\n&quot;)
sb.append(&quot;td{font-weight:400;color:#1f2330;}\n&quot;)
sb.append(&quot;pre{white-space:pre-wrap;word-break:normal;overflow-wrap:normal;margin:0;max-width:100%;max-height:300px;overflow:auto;font-family:inherit;}\n&quot;)

sb.append(&quot;.dumpWrap{position:relative;}\n&quot;)
sb.append(&quot;.dumpPre{padding-right:56px;}\n&quot;)
sb.append(&quot;.copyBtn{position:absolute;top:3px;right:20px;width:28px;height:28px;border-radius:9px;border:1px solid rgba(31,35,48,0.15);background:rgba(255,255,255,0.92);cursor:pointer;display:flex;align-items:center;justify-content:center;opacity:0.18;transition:opacity .15s ease, transform .15s ease, background .15s ease, border-color .15s ease;}\n&quot;)
sb.append(&quot;.dumpWrap:hover .copyBtn{opacity:1;transform:translateY(-1px);}\n&quot;)
sb.append(&quot;.copyBtn:active{transform:translateY(0px) scale(0.98);}\n&quot;)
sb.append(&quot;.copyBtn svg{width:15px;height:15px;fill:#1f2330;}\n&quot;)
sb.append(&quot;.copyBtn.copied{opacity:1;background:rgba(238,245,255,0.95);border-color:rgba(27,90,166,0.35);}\n&quot;)
sb.append(&quot;.copyBtn.copied svg{fill:#1b5aa6;}\n&quot;)
sb.append(&quot;.copyBtn.copied .ico-copy{display:none;}\n&quot;)
sb.append(&quot;.copyBtn.copied .ico-check{display:block !important;}\n&quot;)

sb.append(&quot;.badge{display:inline-block;padding:3px 10px;border-radius:999px;font-weight:700;font-size:13px;}\n&quot;)
sb.append(&quot;.pass{background:#eef5ff;color:#1b5aa6;}\n&quot;)
sb.append(&quot;.fail{background:#fff0f1;color:#a61b28;}\n&quot;)

sb.append(&quot;.tabs{display:flex;gap:10px;flex-wrap:nowrap;overflow-x:auto;margin:10px 0 16px 0;padding-bottom:6px;}\n&quot;)
sb.append(&quot;.tabBtn{border:1px solid #dedaf7;background:#fbfaff;color:#1f2330;border-radius:6px;padding:10px 14px;font-weight:700;font-size:14px;cursor:pointer;white-space:nowrap;}\n&quot;)
sb.append(&quot;.tabBtn:hover{background:#f5f3ff;}\n&quot;)
sb.append(&quot;.tabBtn.active{background:#6a63e6;border-color:#6a63e6;color:#fff;}\n&quot;)
sb.append(&quot;.tabPanel{display:none;}\n&quot;)
sb.append(&quot;.tabPanel.active{display:block;}\n&quot;)

sb.append(&quot;.chart-container{margin-top:14px;margin-bottom:22px;width:100% !important;height:420px;}\n&quot;)

sb.append(&quot;table,thead,tbody,tr,th,td,pre{font-family:\&quot;Segoe UI\&quot;,Roboto,Arial,sans-serif !important;}\n&quot;)
sb.append(&quot;td,pre{font-size:14px !important;font-weight:400 !important;color:#1f2330 !important;}\n&quot;)

sb.append(&quot;&lt;/style&gt;\n&quot;)
sb.append(&quot;&lt;/head&gt;\n&quot;)
sb.append(&quot;&lt;body&gt;\n&quot;)
sb.append(&quot;&lt;div class=\&quot;wrap\&quot;&gt;\n&quot;)

def reportTitle = &quot;Sync AutoTest Report&quot;
sb.append(&quot;&lt;div class=\&quot;title\&quot;&gt;&quot;).append(htmlEscape(reportTitle)).append(&quot;&lt;/div&gt;\n&quot;)

// -----------------------------
// TOP TABS
// -----------------------------
def topTabs = []
topTabs &lt;&lt; &quot;Test Results&quot;
finalGroups.each { topTabs &lt;&lt; it }

def tabLabelOf = { String key -&gt;
    if (key == &quot;Test Results&quot;) return &quot;Test Results&quot;
    return tabLabelMap.containsKey(key) ? tabLabelMap[key] : key
}

def tabShortLabelOf = { String key -&gt;
    def full = tabLabelOf(key)
    def m = (full =~ /^(Scenario\s+\d+)/)
    if (m.find()) return m.group(1)
    return full
}

sb.append(&quot;&lt;div class=\&quot;tabs\&quot; id=\&quot;topTabs\&quot;&gt;\n&quot;)
topTabs.eachWithIndex { key, i -&gt;
    def active = (i == 0) ? &quot; active&quot; : &quot;&quot;
    sb.append(&quot;&lt;button class=\&quot;tabBtn&quot;).append(active)
      .append(&quot;\&quot; data-tab=\&quot;panel_&quot;).append(i).append(&quot;\&quot;&gt;&quot;)
      .append(htmlEscape(tabLabelOf(key)))
      .append(&quot;&lt;/button&gt;\n&quot;)
}
sb.append(&quot;&lt;/div&gt;\n&quot;)

// -----------------------------
// PANELS
// -----------------------------
topTabs.eachWithIndex { key, i -&gt;
    def active = (i == 0) ? &quot; active&quot; : &quot;&quot;
    sb.append(&quot;&lt;div class=\&quot;tabPanel&quot;).append(active).append(&quot;\&quot; id=\&quot;panel_&quot;).append(i).append(&quot;\&quot;&gt;\n&quot;)

    if (key == &quot;Test Results&quot;) {

        sb.append(&quot;&lt;div class=\&quot;card\&quot;&gt;\n&quot;)
        sb.append(&quot;&lt;div class=\&quot;testResultsTitle\&quot;&gt;Test Summary&lt;/div&gt;\n&quot;)

        sb.append(&quot;&lt;div class=\&quot;sectionTitle\&quot;&gt;Total Summary Statistics&lt;/div&gt;\n&quot;)
        sb.append(&quot;&lt;table&gt;\n&lt;tbody&gt;\n&quot;)
        def addSumRow = { String k, String v -&gt;
            sb.append(&quot;&lt;tr&gt;&quot;)
              .append(&quot;&lt;th style=\&quot;width:220px;\&quot;&gt;&quot;).append(htmlEscape(k)).append(&quot;&lt;/th&gt;&quot;)
              .append(&quot;&lt;td&gt;&quot;).append(htmlEscape(v)).append(&quot;&lt;/td&gt;&quot;)
              .append(&quot;&lt;/tr&gt;\n&quot;)
        }
        addSumRow(&quot;Total TestCases&quot;, String.valueOf(totalCount))
        addSumRow(&quot;PASS (Count)&quot;, String.valueOf(passCount))
        addSumRow(&quot;FAIL (Count)&quot;, String.valueOf(failCount))
        addSumRow(&quot;Start Time&quot;, summaryStart)
        addSumRow(&quot;End Time&quot;, summaryEnd)
        addSumRow(&quot;Duration (sec)&quot;, durationSec)
        sb.append(&quot;&lt;/tbody&gt;\n&lt;/table&gt;\n&quot;)

        sb.append(&quot;&lt;div class=\&quot;sectionTitle\&quot;&gt;Group Summary Statistics&lt;/div&gt;\n&quot;)
        sb.append(&quot;&lt;table&gt;\n&lt;thead&gt;&lt;tr&gt;&quot;)
        sb.append(&quot;&lt;th&gt;Scenario Group&lt;/th&gt;&lt;th&gt;TestCases&lt;/th&gt;&lt;th&gt;PASS Count&lt;/th&gt;&lt;th&gt;FAIL Count&lt;/th&gt;&lt;th&gt;StartTime&lt;/th&gt;&lt;th&gt;EndTime&lt;/th&gt;&lt;th&gt;Duration (sec)&lt;/th&gt;&quot;)
        sb.append(&quot;&lt;/tr&gt;&lt;/thead&gt;\n&lt;tbody&gt;\n&quot;)
        groupStats.values().each { gs -&gt;
            sb.append(&quot;&lt;tr&gt;&quot;)
            sb.append(&quot;&lt;td&gt;&quot;).append(htmlEscape(tabShortLabelOf(gs.name))).append(&quot;&lt;/td&gt;&quot;)
            sb.append(&quot;&lt;td&gt;&quot;).append(String.valueOf(gs.totalTest)).append(&quot;&lt;/td&gt;&quot;)
            sb.append(&quot;&lt;td&gt;&quot;).append(String.valueOf(gs.passCount)).append(&quot;&lt;/td&gt;&quot;)
            sb.append(&quot;&lt;td&gt;&quot;).append(String.valueOf(gs.failCount)).append(&quot;&lt;/td&gt;&quot;)
            sb.append(&quot;&lt;td&gt;&quot;).append(htmlEscape(gs.startTime)).append(&quot;&lt;/td&gt;&quot;)
            sb.append(&quot;&lt;td&gt;&quot;).append(htmlEscape(gs.endTime)).append(&quot;&lt;/td&gt;&quot;)
            sb.append(&quot;&lt;td&gt;&quot;).append(htmlEscape(gs.duration)).append(&quot;&lt;/td&gt;&quot;)
            sb.append(&quot;&lt;/tr&gt;\n&quot;)
        }
        sb.append(&quot;&lt;/tbody&gt;&lt;/table&gt;\n&quot;)

        def chartGroupNames = groupStats.values().collect { tabLabelOf(it.name) }
        def chartGroupTotal = groupStats.values().collect { it.totalTest }

        sb.append(&quot;&lt;div class=\&quot;sectionTitle\&quot;&gt;Visualizations&lt;/div&gt;\n&quot;)
        sb.append(&quot;&lt;div class=\&quot;subTitle\&quot;&gt;TestCases per Scenario Group&lt;/div&gt;\n&quot;)
        sb.append(&quot;&lt;div class=\&quot;chart-container\&quot;&gt;&lt;canvas id=\&quot;bar-chart\&quot;&gt;&lt;/canvas&gt;&lt;/div&gt;\n&quot;)
        sb.append(&quot;&lt;div class=\&quot;subTitle\&quot; style=\&quot;margin-top:16px;\&quot;&gt;PASS vs FAIL&lt;/div&gt;\n&quot;)
        sb.append(&quot;&lt;div class=\&quot;chart-container\&quot;&gt;&lt;canvas id=\&quot;pie-chart\&quot;&gt;&lt;/canvas&gt;&lt;/div&gt;\n&quot;)

        sb.append(&quot;&lt;/div&gt;\n&quot;)

        sb.append(&quot;&lt;script&gt;\n&quot;)
        sb.append(&quot;(function(){\n&quot;)
        sb.append(&quot;  function renderCharts(){\n&quot;)
        sb.append(&quot;    if (window.__chartsInited) return;\n&quot;)
        sb.append(&quot;    var bar = document.getElementById(&apos;bar-chart&apos;);\n&quot;)
        sb.append(&quot;    var pie = document.getElementById(&apos;pie-chart&apos;);\n&quot;)
        sb.append(&quot;    if (!bar || !pie) return;\n&quot;)
        sb.append(&quot;    window.__chartsInited = true;\n&quot;)
        sb.append(&quot;    try {\n&quot;)
        sb.append(&quot;      new Chart(bar.getContext(&apos;2d&apos;), {\n&quot;)
        sb.append(&quot;        type:&apos;bar&apos;,\n&quot;)
        sb.append(&quot;        data:{ labels:&quot;).append(JsonOutput.toJson(chartGroupNames)).append(&quot;, datasets:[{ label:&apos;Count&apos;, data:&quot;)
          .append(JsonOutput.toJson(chartGroupTotal)).append(&quot;, backgroundColor:&apos;#4A90E2&apos;, borderColor:&apos;#4A90E2&apos;, borderWidth:1 }] },\n&quot;)
        sb.append(&quot;        options:{ responsive:true, maintainAspectRatio:false, scales:{ x:{ title:{display:true,text:&apos;Scenario Group&apos;} }, y:{ title:{display:true,text:&apos;TestCase Count&apos;} } } }\n&quot;)
        sb.append(&quot;      });\n&quot;)
        sb.append(&quot;      new Chart(pie.getContext(&apos;2d&apos;), {\n&quot;)
        sb.append(&quot;        type:&apos;pie&apos;,\n&quot;)
        sb.append(&quot;        data:{ labels:[&apos;PASS&apos;,&apos;FAIL&apos;], datasets:[{ data:[&quot;).append(passCount).append(&quot;,&quot;).append(failCount)
          .append(&quot;], backgroundColor:[&apos;#4A90E2&apos;,&apos;#D0021B&apos;] }] },\n&quot;)
        sb.append(&quot;        options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{ position:&apos;bottom&apos; } } }\n&quot;)
        sb.append(&quot;      });\n&quot;)
        sb.append(&quot;    } catch(e) { console &amp;&amp; console.error &amp;&amp; console.error(e); }\n&quot;)
        sb.append(&quot;  }\n&quot;)
        sb.append(&quot;  window.__renderCharts = function(){ setTimeout(renderCharts, 120); };\n&quot;)
        sb.append(&quot;  window.addEventListener(&apos;load&apos;, function(){ window.__renderCharts(); });\n&quot;)
        sb.append(&quot;})();\n&quot;)
        sb.append(&quot;&lt;/script&gt;\n&quot;)
    }

    else {
        def g = key
        def gRows = groupRows[g] ?: []

        sb.append(&quot;&lt;div class=\&quot;card\&quot;&gt;\n&quot;)
        sb.append(&quot;&lt;div class=\&quot;testSummaryTitle\&quot;&gt;&quot;).append(htmlEscape(tabLabelOf(g))).append(&quot;&lt;/div&gt;\n&quot;)

        def desc = tabDescMap[g] ?: &quot;&quot;
        if (desc) {
            sb.append(&quot;&lt;div class=\&quot;panelDesc\&quot;&gt;&quot;).append(htmlEscape(desc)).append(&quot;&lt;/div&gt;\n&quot;)
        }

        if (gRows.isEmpty()) {
            sb.append(&quot;&lt;div style=\&quot;color:#6b7280;\&quot;&gt;No data yet.&lt;/div&gt;\n&quot;)
        } else {
            sb.append(&quot;&lt;table&gt;\n&quot;)

            sb.append(&quot;&lt;colgroup&gt;\n&quot;)
            outHeader.each { h -&gt; sb.append(&quot;&lt;col style=\&quot;&quot;).append(colStyleFor(h)).append(&quot;\&quot; /&gt;\n&quot;) }
            sb.append(&quot;&lt;/colgroup&gt;\n&quot;)

            sb.append(&quot;&lt;thead&gt;&lt;tr&gt;\n&quot;)
            outHeader.each { h -&gt; sb.append(&quot;&lt;th&gt;&quot;).append(htmlEscape(h)).append(&quot;&lt;/th&gt;\n&quot;) }
            sb.append(&quot;&lt;/tr&gt;&lt;/thead&gt;\n&lt;tbody&gt;\n&quot;)

            gRows.each { r -&gt;
                sb.append(&quot;&lt;tr&gt;\n&quot;)
                for (int colIdx=0; colIdx&lt;header.size(); colIdx++) {
                    if (skipIdx.contains(colIdx)) continue
                    def cell = (colIdx &lt; r.size()) ? r[colIdx] : &quot;&quot;

                    if (colIdx == idxResult) {
                        def v = normResult(cell)
                        if (v.equalsIgnoreCase(&quot;PASS&quot;)) sb.append(&quot;&lt;td&gt;&lt;span class=\&quot;badge pass\&quot;&gt;PASS&lt;/span&gt;&lt;/td&gt;\n&quot;)
                        else if (v.equalsIgnoreCase(&quot;FAIL&quot;)) sb.append(&quot;&lt;td&gt;&lt;span class=\&quot;badge fail\&quot;&gt;FAIL&lt;/span&gt;&lt;/td&gt;\n&quot;)
                        else sb.append(&quot;&lt;td&gt;&quot;).append(htmlEscape(cell)).append(&quot;&lt;/td&gt;\n&quot;)
                        continue
                    }

                    if (colIdx == idxSource || colIdx == idxDest) {
                        def raw = (cell == null) ? &quot;&quot; : cell.toString()
                        def rawB64 = b64Utf8(raw)
                        
                        sb.append(&quot;&lt;td&gt;&lt;div class=\&quot;dumpWrap\&quot;&gt;&quot;)
                        sb.append(&quot;&lt;button class=\&quot;copyBtn\&quot; type=\&quot;button\&quot; aria-label=\&quot;copy\&quot; data-rawb64=\&quot;&quot;).append(rawB64).append(&quot;\&quot;&gt;&quot;)
                        
                        sb.append(&quot;&lt;svg class=\&quot;ico-copy\&quot; viewBox=\&quot;0 0 24 24\&quot; aria-hidden=\&quot;true\&quot;&gt;&quot;)
                        sb.append(&quot;&lt;path d=\&quot;M16 1H6a2 2 0 0 0-2 2v10h2V3h10V1zm3 4H10a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2zm0 16H10V7h9v14z\&quot;/&gt;&quot;)
                        sb.append(&quot;&lt;/svg&gt;&quot;)
                        
                        sb.append(&quot;&lt;svg class=\&quot;ico-check\&quot; viewBox=\&quot;0 0 24 24\&quot; aria-hidden=\&quot;true\&quot; style=\&quot;display:none;\&quot;&gt;&quot;)
                        sb.append(&quot;&lt;path d=\&quot;M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z\&quot;/&gt;&quot;)
                        sb.append(&quot;&lt;/svg&gt;&quot;)
                        
                        sb.append(&quot;&lt;/button&gt;&quot;)
                        sb.append(&quot;&lt;pre class=\&quot;dumpPre\&quot;&gt;&quot;).append(dumpViewHtml(raw)).append(&quot;&lt;/pre&gt;&quot;)
                        sb.append(&quot;&lt;/div&gt;&lt;/td&gt;\n&quot;)
                        continue
                        }


                    if (colIdx == idxNotes) {
                        sb.append(&quot;&lt;td&gt;&lt;pre&gt;&quot;).append(htmlEscape(cell)).append(&quot;&lt;/pre&gt;&lt;/td&gt;\n&quot;)
                        continue
                    }

                    sb.append(&quot;&lt;td&gt;&quot;).append(htmlEscape(cell)).append(&quot;&lt;/td&gt;\n&quot;)
                }
                sb.append(&quot;&lt;/tr&gt;\n&quot;)
            }

            sb.append(&quot;&lt;/tbody&gt;\n&lt;/table&gt;\n&quot;)
        }

        sb.append(&quot;&lt;/div&gt;\n&quot;)
    }

    sb.append(&quot;&lt;/div&gt;\n&quot;)
}

// -----------------------------
// COPY SCRIPT
// -----------------------------
sb.append(&quot;&lt;script&gt;\n&quot;)
sb.append(&quot;(function(){\n&quot;)
sb.append(&quot;  function toast(msg){\n&quot;)
sb.append(&quot;    var t = document.createElement(&apos;div&apos;);\n&quot;)
sb.append(&quot;    t.textContent = msg || &apos;&apos;;\n&quot;)
sb.append(&quot;    t.style.cssText = &apos;position:fixed;right:16px;bottom:16px;z-index:99999;&apos;\n&quot;)
sb.append(&quot;      + &apos;background:rgba(31,35,48,0.92);color:#fff;padding:10px 12px;border-radius:10px;font-size:12px;&apos;\n&quot;)
sb.append(&quot;      + &apos;box-shadow:0 8px 24px rgba(0,0,0,0.18);transition:opacity .25s ease;&apos;;\n&quot;)
sb.append(&quot;    document.body.appendChild(t);\n&quot;)
sb.append(&quot;    setTimeout(function(){ t.style.opacity=&apos;0&apos;; }, 700);\n&quot;)
sb.append(&quot;    setTimeout(function(){ if(t &amp;&amp; t.parentNode) t.parentNode.removeChild(t); }, 950);\n&quot;)
sb.append(&quot;  }\n&quot;)
sb.append(&quot;\n&quot;)
sb.append(&quot;  async function copyText(text){\n&quot;)
sb.append(&quot;    if (text == null) text = &apos;&apos;;\n&quot;)
sb.append(&quot;    try {\n&quot;)
sb.append(&quot;      if (navigator.clipboard &amp;&amp; navigator.clipboard.writeText) {\n&quot;)
sb.append(&quot;        await navigator.clipboard.writeText(text);\n&quot;)
sb.append(&quot;        return true;\n&quot;)
sb.append(&quot;      }\n&quot;)
sb.append(&quot;    } catch(e) {}\n&quot;)
sb.append(&quot;    try {\n&quot;)
sb.append(&quot;      var ta = document.createElement(&apos;textarea&apos;);\n&quot;)
sb.append(&quot;      ta.value = text;\n&quot;)
sb.append(&quot;      ta.setAttribute(&apos;readonly&apos;,&apos;&apos;);\n&quot;)
sb.append(&quot;      ta.style.position=&apos;fixed&apos;; ta.style.left=&apos;-9999px&apos;; ta.style.top=&apos;0&apos;;\n&quot;)
sb.append(&quot;      document.body.appendChild(ta);\n&quot;)
sb.append(&quot;      ta.select();\n&quot;)
sb.append(&quot;      var ok = document.execCommand(&apos;copy&apos;);\n&quot;)
sb.append(&quot;      document.body.removeChild(ta);\n&quot;)
sb.append(&quot;      return ok;\n&quot;)
sb.append(&quot;    } catch(e2) { return false; }\n&quot;)
sb.append(&quot;  }\n&quot;)
sb.append(&quot;\n&quot;)
sb.append(&quot;  document.addEventListener(&apos;click&apos;, async function(e){\n&quot;)
sb.append(&quot;    var btn = e.target.closest &amp;&amp; e.target.closest(&apos;.copyBtn&apos;);\n&quot;)
sb.append(&quot;    if (!btn) return;\n&quot;)
sb.append(&quot;    var wrap = btn.closest(&apos;.dumpWrap&apos;);\n&quot;)
sb.append(&quot;    if (!wrap) return;\n&quot;)
sb.append(&quot;    var pre = wrap.querySelector(&apos;pre&apos;);\n&quot;)
sb.append(&quot;    if (!pre) return;\n&quot;)
sb.append(&quot;\n&quot;)
sb.append(&quot;    var b64 = btn.getAttribute(&apos;data-rawb64&apos;) || &apos;&apos;;\n&quot;)
sb.append(&quot;    var text = &apos;&apos;;\n&quot;)
sb.append(&quot;    try {\n&quot;)
sb.append(&quot;      if (b64) {\n&quot;)
sb.append(&quot;        text = decodeURIComponent(escape(atob(b64)));\n&quot;)
sb.append(&quot;      } else {\n&quot;)
sb.append(&quot;        text = pre.innerText || pre.textContent || &apos;&apos;;\n&quot;)
sb.append(&quot;      }\n&quot;)
sb.append(&quot;    } catch(e) {\n&quot;)
sb.append(&quot;      text = pre.innerText || pre.textContent || &apos;&apos;;\n&quot;)
sb.append(&quot;    }\n&quot;)
sb.append(&quot;\n&quot;)
sb.append(&quot;    var ok = await copyText(text);\n&quot;)
sb.append(&quot;    if (ok) {\n&quot;)
sb.append(&quot;      btn.classList.add(&apos;copied&apos;);\n&quot;)
sb.append(&quot;      toast(&apos;Copied&apos;);\n&quot;)
sb.append(&quot;      setTimeout(function(){ btn.classList.remove(&apos;copied&apos;); }, 900);\n&quot;)
sb.append(&quot;    } else {\n&quot;)
sb.append(&quot;      toast(&apos;Copy failed&apos;);\n&quot;)
sb.append(&quot;    }\n&quot;)
sb.append(&quot;  });\n&quot;)
sb.append(&quot;})();\n&quot;)
sb.append(&quot;&lt;/script&gt;\n&quot;)


// -----------------------------
// TAB SCRIPT
// -----------------------------
sb.append(&quot;&lt;script&gt;\n&quot;)
sb.append(&quot;(function(){\n&quot;)
sb.append(&quot;  var btns = document.querySelectorAll(&apos;#topTabs .tabBtn&apos;);\n&quot;)
sb.append(&quot;  var panels = document.querySelectorAll(&apos;.tabPanel&apos;);\n&quot;)
sb.append(&quot;  btns.forEach(function(btn){\n&quot;)
sb.append(&quot;    btn.addEventListener(&apos;click&apos;, function(){\n&quot;)
sb.append(&quot;      btns.forEach(function(b){ b.classList.remove(&apos;active&apos;); });\n&quot;)
sb.append(&quot;      panels.forEach(function(p){ p.classList.remove(&apos;active&apos;); });\n&quot;)
sb.append(&quot;      btn.classList.add(&apos;active&apos;);\n&quot;)
sb.append(&quot;      var id = btn.getAttribute(&apos;data-tab&apos;);\n&quot;)
sb.append(&quot;      var panel = document.getElementById(id);\n&quot;)
sb.append(&quot;      if(panel) panel.classList.add(&apos;active&apos;);\n&quot;)
sb.append(&quot;      if (id === &apos;panel_0&apos; &amp;&amp; window.__renderCharts) { setTimeout(window.__renderCharts, 80); }\n&quot;)
sb.append(&quot;    });\n&quot;)
sb.append(&quot;  });\n&quot;)
sb.append(&quot;})();\n&quot;)
sb.append(&quot;&lt;/script&gt;\n&quot;)

sb.append(&quot;&lt;/div&gt;\n&lt;/body&gt;\n&lt;/html&gt;\n&quot;)

htmlFile.setText(sb.toString(), &quot;UTF-8&quot;)
log.info(&quot;[HTML] generated: &quot; + htmlFile.absolutePath)
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(Result)_JSR223 Sampler" enabled="false">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.nio.charset.StandardCharsets

def baseDir = Paths.get(&quot;C:/Users/김민지/sync_result&quot;)
def version = vars.get(&quot;version&quot;) ?: &quot;unknown&quot;
def csvPath = baseDir.resolve(&quot;${version}_Sync.csv&quot;)

if (!Files.exists(csvPath)) {
    log.error(&quot;CSV not found: ${csvPath}&quot;)
    return
}

def lines = Files.readAllLines(csvPath, StandardCharsets.UTF_8)
if (lines.size() &lt;= 1) {
    log.warn(&quot;No data rows in CSV: ${csvPath}&quot;)
}

def rows = lines.drop(1).collect { it.split(&quot;\\|&quot;, -1) }

int total = rows.size()
int passCnt = rows.count { it.size() &gt;= 7 &amp;&amp; it[6].trim().equalsIgnoreCase(&quot;PASS&quot;) }
int failCnt = total - passCnt

def starts = rows.collect { it.size() &gt;= 3 ? it[2].trim() : &quot;&quot; }.findAll { it }
def ends   = rows.collect { it.size() &gt;= 4 ? it[3].trim() : &quot;&quot; }.findAll { it }

def startTime = starts ? starts.min() : &quot;N/A&quot;
def endTime   = ends   ? ends.max()   : &quot;N/A&quot;

def html = &quot;&quot;&quot;
&lt;h2&gt;Test Summary&lt;/h2&gt;
&lt;h3&gt;Total Summary Statistics&lt;/h3&gt;
&lt;table&gt;
&lt;tr&gt;&lt;th&gt;Total TestCases&lt;/th&gt;&lt;td&gt;${total}&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;th&gt;PASS (Count)&lt;/th&gt;&lt;td&gt;${passCnt}&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;th&gt;FAIL (Count)&lt;/th&gt;&lt;td&gt;${failCnt}&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;th&gt;Start Time&lt;/th&gt;&lt;td&gt;${startTime}&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;th&gt;End Time&lt;/th&gt;&lt;td&gt;${endTime}&lt;/td&gt;&lt;/tr&gt;
&lt;/table&gt;
&quot;&quot;&quot;

def out = baseDir.resolve(&quot;${version}_Sync_Result.html&quot;)
Files.write(out, html.getBytes(&quot;UTF-8&quot;))
log.info(&quot;SYNC Result HTML generated: ${out}&quot;)
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(Result_Detail_Log)_JSR223 Sampler" enabled="false">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.file.*
import java.nio.charset.StandardCharsets

def baseDir = Paths.get(&quot;C:/Users/김민지/sync_result&quot;)
def version = vars.get(&quot;version&quot;) ?: &quot;unknown&quot;
def csvPath = baseDir.resolve(&quot;${version}_Sync.csv&quot;)

if (!Files.exists(csvPath)) {
    log.error(&quot;CSV not found: ${csvPath}&quot;)
    return
}

def lines = Files.readAllLines(csvPath, StandardCharsets.UTF_8)
if (lines.size() &lt;= 1) {
    log.warn(&quot;No data rows in CSV&quot;)
    return
}

def header = lines[0].split(&quot;\\|&quot;, -1)                     
def rows   = lines.drop(1).collect { it.split(&quot;\\|&quot;, -1) }

def groups = rows.groupBy { it.size() &gt; 0 ? it[0] : &quot;Unknown&quot; }

// html escape
def esc = { s -&gt;
    if (s == null) return &quot;&quot;
    return s.replace(&quot;&amp;&quot;,&quot;&amp;amp;&quot;).replace(&quot;&lt;&quot;,&quot;&amp;lt;&quot;).replace(&quot;&gt;&quot;,&quot;&amp;gt;&quot;)
}

groups.each { groupName, rs -&gt;
    def safeGroupName = groupName.replaceAll(&quot;[^a-zA-Z0-9_-]&quot;, &quot;_&quot;)

    def html = new StringBuilder()
    html &lt;&lt; &quot;&lt;table&gt;\n&lt;tr&gt;&quot;
    header.each { h -&gt; html &lt;&lt; &quot;&lt;th&gt;${esc(h)}&lt;/th&gt;&quot; }
    html &lt;&lt; &quot;&lt;/tr&gt;\n&quot;

    rs.each { cols -&gt;
        html &lt;&lt; &quot;&lt;tr&gt;&quot;
        cols.eachWithIndex { v, i -&gt;
            if (i == 4 || i == 5) { // Source/Destination
                html &lt;&lt; &quot;&lt;td&gt;&lt;pre&gt;${esc(v)}&lt;/pre&gt;&lt;/td&gt;&quot;
            } else if (i == 6) { // Result
                def cls = (v?.trim()?.equalsIgnoreCase(&quot;PASS&quot;)) ? &quot;PASS&quot; : &quot;FAIL&quot;
                html &lt;&lt; &quot;&lt;td class=&apos;${cls}&apos;&gt;${esc(v)}&lt;/td&gt;&quot;
            } else {
                html &lt;&lt; &quot;&lt;td&gt;${esc(v)}&lt;/td&gt;&quot;
            }
        }
        html &lt;&lt; &quot;&lt;/tr&gt;\n&quot;
    }

    html &lt;&lt; &quot;&lt;/table&gt;&quot;

    def outPath = baseDir.resolve(&quot;${safeGroupName}.html&quot;)
    Files.write(outPath, html.toString().getBytes(StandardCharsets.UTF_8))
    log.info(&quot;SYNC Detail HTML generated: ${outPath}&quot;)
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="makeHtml(Integration_JSR223 Sampler" enabled="false">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">// ============================
// Case 1-2 SetVars (numeric only)
// ============================

import java.text.SimpleDateFormat
import java.util.Date
import java.util.concurrent.ThreadLocalRandom

vars.put(&quot;scenario_id&quot;, &quot;1-2&quot;)
vars.put(&quot;expect_mode&quot;, &quot;SYNC_NOT_EXPECTED&quot;)
vars.put(&quot;PatientCount&quot;, &quot;1&quot;)

// 리포트 정렬키 (1-1 -&gt; 1-2 -&gt; 1-3 원하면 120)
vars.put(&quot;order_key&quot;, &quot;120&quot;)

def fmt = new SimpleDateFormat(&quot;yyMMddHHmmssSSS&quot;) // ✅ SSS
def base = fmt.format(new Date())                 // 예: 260130132455123

def tid = ctx.getThreadNum()                      // 예: 1
def rnd = ThreadLocalRandom.current().nextInt(0, 1000) // 0~999
def rnd3 = String.format(&quot;%03d&quot;, rnd)             // 예: 042

// ✅ 숫자만, pid != eid 보장 (맨 앞자리만 다르게)
def pid = &quot;2&quot; + base + tid + rnd3                 // 예: 2260130132455123142
def eid = &quot;3&quot; + base + tid + rnd3                 // 예: 3260130132455123142

vars.put(&quot;patient_id&quot;, pid)
vars.put(&quot;encounter_id&quot;, eid)

vars.put(&quot;verify_patient_id&quot;, pid)
vars.put(&quot;verify_encounter_id&quot;, eid)

log.info(&quot;[1-2 SetVars] order_key=&quot; + vars.get(&quot;order_key&quot;)
        + &quot;, patient_id=&quot; + pid
        + &quot;, encounter_id=&quot; + eid
        + &quot;, threadNum=&quot; + tid)
</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
      <TestFragmentController guiclass="TestFragmentControllerGui" testclass="TestFragmentController" testname="Test Fragment_1" enabled="false"/>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Common" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.sql.*
import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone


/**
 * Common (Verify + Dump)
 * - expect_mode(SYNC_OK / SYNC_NOT_EXPECTED)에 따라 VC 존재/비존재 판정
 * - EMR/VC dump 생성 + 필드 비교(name/sex/birth/dnr)
 * - 1-3: VC before/after를 정확히 1번씩만 출력 (before는 body-only 우선)
 * - 1-3 gate: result_1_1=PASS 또는 prereq_1_1_all_pass=true 통과
 * - VC secret: vars/props/env -&gt; default &quot;some_secret&quot; 유지
 */

// -----------------------------------------------------
// 0) Read Vars &amp; init
// -----------------------------------------------------
def GROUP_NAME   = (vars.get(&quot;currentControllerName&quot;) ?: &quot;Scenario 1&quot;).toString()
def SCENARIO_ID  = (vars.get(&quot;scenario_id&quot;) ?: &quot;&quot;).toString().trim()
def EXPECT_MODE  = (vars.get(&quot;expect_mode&quot;) ?: &quot;SYNC_OK&quot;).toString().trim()
def SCENARIO_NAME = SCENARIO_ID ? (&quot;Scenario &quot; + SCENARIO_ID) : &quot;Scenario&quot;

boolean isScenario13  = SCENARIO_ID.startsWith(&quot;1-3&quot;)  
boolean showAfterTag  = isScenario13                    

def TZ = (vars.get(&quot;TimeZone&quot;) ?: &quot;Asia/Seoul&quot;).toString().trim()

// slot key: before dump 키 선택에 사용
def slotKey = (vars.get(&quot;slot&quot;) ?: vars.get(&quot;cur_slot&quot;) ?: vars.get(&quot;chg_slot&quot;) ?: &quot;0&quot;).toString().trim()
if (!slotKey) slotKey = &quot;0&quot;

def patientId   = (vars.get(&quot;patient_id&quot;) ?: vars.get(&quot;verify_patient_id&quot;) ?: &quot;&quot;).toString().trim()
def encounterId = (vars.get(&quot;encounter_id&quot;) ?: vars.get(&quot;verify_encounter_id&quot;) ?: &quot;&quot;).toString().trim()
if (!encounterId) encounterId = null // 빈 문자열이면 null로 통일(변수 존재 보장)


def setVcKey = { Connection c, String tag -&gt;
    def s1 = (vars.get(&quot;VC_SECRET&quot;) ?: &quot;&quot;).toString().trim()
    def s2 = (props.get(&quot;VC_SECRET&quot;) ?: &quot;&quot;).toString().trim()
    def s3 = (System.getenv(&quot;VC_SECRET&quot;) ?: &quot;&quot;).toString().trim()

    def sec = &quot;&quot;
    def src = &quot;&quot;
    if (s1)      { sec = s1; src = &quot;VARS:VC_SECRET&quot; }
    else if (s2) { sec = s2; src = &quot;PROPS:VC_SECRET&quot; }
    else if (s3) { sec = s3; src = &quot;ENV:VC_SECRET&quot; }

    if (!sec) { sec = &quot;some_secret&quot;; src = &quot;DEFAULT:some_secret&quot; }

    Statement st = null
    PreparedStatement ps = null
    ResultSet rs = null
    try {
        st = c.createStatement()
        def esc = sec.replace(&quot;&apos;&quot;, &quot;\\&apos;&quot;)

        st.execute(&quot;SET @hashed_key = (SELECT UNHEX(SHA2(&apos;${esc}&apos;, 256)))&quot;)
        st.execute(&quot;SET @secretkey = LEFT(@hashed_key, 16)&quot;)
        st.execute(&quot;SET @iv = RIGHT(@hashed_key, 16)&quot;)

        // key check
        ps = c.prepareStatement(&quot;SELECT LENGTH(@secretkey) AS klen, LENGTH(@iv) AS ivlen&quot;)
        rs = ps.executeQuery()
        rs.next()
        int klen = rs.getInt(&quot;klen&quot;)
        int ivlen = rs.getInt(&quot;ivlen&quot;)
        log.info(&quot;[VC_KEYCHK] tag=${tag} src=${src} klen=${klen}, ivlen=${ivlen}&quot;)
        if (klen &lt;= 0 || ivlen &lt;= 0) throw new RuntimeException(&quot;[${tag}] VC session key not set&quot;)
    } finally {
        try { if (rs!=null) rs.close() } catch (ignored) {}
        try { if (ps!=null) ps.close() } catch (ignored) {}
        try { if (st!=null) st.close() } catch (ignored) {}
    }
}


// DB config
def emrUrl  = (vars.get(&quot;JDBC_URL&quot;)  ?: &quot;&quot;).toString().trim()
def emrUser = (vars.get(&quot;JDBC_USER&quot;) ?: &quot;&quot;).toString().trim()
def emrPw   = (vars.get(&quot;JDBC_PW&quot;)   ?: &quot;&quot;).toString()

def vcUrl   = (vars.get(&quot;JDBC_URL_VC&quot;)  ?: &quot;&quot;).toString().trim()
def vcUser  = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw    = (vars.get(&quot;JDBC_PW_VC&quot;)   ?: &quot;&quot;).toString()

// Tables
def VERIFY_TARGET = (vars.get(&quot;verify_target&quot;) ?: &quot;PATIENT&quot;).toString().trim().toUpperCase()

def EMR_TABLE_PATIENT = &quot;ROOT.PATIENTS&quot;
def VC_TABLE_PATIENT  = &quot;vitalcare.emr_patient&quot;
def VC_ID_COL_PATIENT = &quot;encrypted_emr_id&quot;

def EMR_TABLE_ENC     = (vars.get(&quot;EMR_ENCOUNTER_TABLE&quot;) ?: &quot;ROOT.ENCOUNTERS&quot;).toString().trim()
def VC_TABLE_ENC      = &quot;vitalcare.emr_encounter&quot;
def VC_EID_COL_ENC    = &quot;encrypted_emr_id&quot;
def VC_PID_COL_ENC    = &quot;encrypted_patient_id&quot;

def EMR_TABLE = (VERIFY_TARGET == &quot;ENCOUNTER&quot;) ? EMR_TABLE_ENC : EMR_TABLE_PATIENT
def VC_TABLE  = (VERIFY_TARGET == &quot;ENCOUNTER&quot;) ? VC_TABLE_ENC  : VC_TABLE_PATIENT
def VC_ID_COL = (VERIFY_TARGET == &quot;ENCOUNTER&quot;) ? VC_EID_COL_ENC : VC_ID_COL_PATIENT

// time formatter
def sdfLog = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss,SSS&quot;)
sdfLog.setTimeZone(TimeZone.getTimeZone(TZ))

// start millis: prev.getStartTime() 우선
long startMillis = 0L
try {
    startMillis = (prev != null) ? (prev.getStartTime() as long) : 0L
} catch (ignored) {}
if (startMillis &lt;= 0L) startMillis = System.currentTimeMillis()

def startTime = sdfLog.format(new Date(startMillis))

// 계산용 millis 보관 + 출력용 문자열
vars.putObject(&quot;caseStartMillis&quot;, startMillis as Long)

// verify_* defaults (WriteCsv/HTML 안전)
vars.put(&quot;verify_result&quot;, &quot;ERROR&quot;)
vars.put(&quot;verify_notes&quot;, &quot;&quot;)
vars.put(&quot;verify_scenario&quot;, SCENARIO_NAME)
vars.put(&quot;verify_startTime&quot;, startTime)
vars.put(&quot;verify_endTime&quot;, &quot;&quot;)
vars.put(&quot;verify_emrDump&quot;, &quot;&quot;)
vars.put(&quot;verify_vcDump&quot;, &quot;&quot;)
vars.put(&quot;verify_duration_ms&quot;, &quot;&quot;)

log.info(&quot;[SYNC] group=${GROUP_NAME}, scenario_id=${SCENARIO_ID}, expect_mode=${EXPECT_MODE}, TZ=${TZ}&quot;)
log.info(&quot;[VERIFY_TARGET] patient_id=${vars.get(&apos;patient_id&apos;)}, encounter_id=${vars.get(&apos;encounter_id&apos;)}, slot=${slotKey}, PatientCount=${vars.get(&apos;PatientCount&apos;)}&quot;)
log.info(&quot;[TARGET] verify_target=${VERIFY_TARGET}, pid=${patientId}, eid=${encounterId}&quot;)

// -----------------------------------------------------
// 0-1) Scenario 1-3 Gate (SKIP)
// -----------------------------------------------------
if (isScenario13) {
    def reasons = []

    def r11 = (vars.get(&quot;result_1_1&quot;) ?: &quot;&quot;).toString().trim()
    def prereqAll = (vars.get(&quot;prereq_1_1_all_pass&quot;) ?: &quot;&quot;).toString().trim()

    boolean ok11 = &quot;PASS&quot;.equalsIgnoreCase(r11) || &quot;true&quot;.equalsIgnoreCase(prereqAll)
    if (!ok11) reasons &lt;&lt; &quot;1-1 not PASS&quot;

    if (!patientId) reasons &lt;&lt; &quot;patient_id empty&quot;

    def field = (vars.get(&quot;change_field&quot;) ?: &quot;&quot;).toString().trim()
    if (!field) reasons &lt;&lt; &quot;change_field empty&quot;

    def expectObj = vars.get(&quot;expect_value&quot;) // &quot;0&quot;도 유효
    if (expectObj == null || expectObj.toString().length() == 0) reasons &lt;&lt; &quot;expect_value empty&quot;

    if (!reasons.isEmpty()) {
        def msg = &quot;SKIP: &quot; + reasons.join(&quot;, &quot;)
        vars.put(&quot;verify_result&quot;, &quot;SKIP&quot;)
        vars.put(&quot;verify_notes&quot;, msg)
        vars.put(&quot;verify_endTime&quot;, sdfLog.format(new Date()))
        vars.put(&quot;verify_emrDump&quot;, &quot;&quot;)
        vars.put(&quot;verify_vcDump&quot;, &quot;&quot;)

        prev.setSuccessful(true)
        prev.setResponseMessage(&quot;SYNC SKIP | &quot; + msg)

        log.warn(&quot;[COMMON_GATE] scenario_id=${SCENARIO_ID} patient_id=${patientId} | ${msg}&quot;)
        return
    }
}



// -----------------------------------------------------
// PDL (Scenario 3 multi verify): 3 rows (3-1/3-2/3-3)
// -----------------------------------------------------
if (VERIFY_TARGET == &quot;PDL&quot;) {

    def qClose = { AutoCloseable c -&gt; try { if (c != null) c.close() } catch (ignored) {} }

    // -----------------------------
    // 0) IDs / expected
    // -----------------------------
    def pid0 = (vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString().trim()
    def eid0 = (vars.get(&quot;EncounterID0&quot;) ?: &quot;&quot;).toString().trim()
    def pid1 = (vars.get(&quot;PatientID1&quot;) ?: &quot;&quot;).toString().trim()
    def eid1 = (vars.get(&quot;EncounterID1&quot;) ?: &quot;&quot;).toString().trim()
    def pid2 = (vars.get(&quot;PatientID2&quot;) ?: &quot;&quot;).toString().trim()
    def eid2 = (vars.get(&quot;EncounterID2&quot;) ?: &quot;&quot;).toString().trim()
    if (!pid0 || !eid0 || !pid1 || !eid1 || !pid2 || !eid2) {
        throw new RuntimeException(&quot;[PDL] PatientID/EncounterID 0~2 missing.&quot;)
    }

    def expPracId   = (vars.get(&quot;expect_practitioner_id_0&quot;) ?: &quot;&quot;).toString().trim()
    def expPracName = (vars.get(&quot;expect_practitioner_name_0&quot;) ?: &quot;&quot;).toString().trim()
    def expDeptCode = (vars.get(&quot;expect_department_code_1&quot;) ?: &quot;&quot;).toString().trim()
    def expDeptName = (vars.get(&quot;expect_department_name_1&quot;) ?: &quot;&quot;).toString().trim()

    def expWard     = (vars.get(&quot;expect_ward_2&quot;) ?: &quot;&quot;).toString().trim()
    def expRoom     = (vars.get(&quot;expect_room_2&quot;) ?: &quot;&quot;).toString().trim()
    def expBed      = (vars.get(&quot;expect_bed_2&quot;) ?: &quot;&quot;).toString().trim()

    def logResults = vars.getObject(&quot;logResults&quot;)
    if (logResults == null) throw new RuntimeException(&quot;[PDL] logResults is null.&quot;)

    def startTimeStr = (vars.get(&quot;verify_startTime&quot;) ?: startTime).toString()

    // -----------------------------
    // 1) ResultSet pretty dump
    //    - NOTE: LIMIT 1 쿼리면 &quot;... truncated&quot; 절대 안 붙음
    // -----------------------------
    def dumpRs = { String title, ResultSet rs, int maxRows -&gt;
        def sb = new StringBuilder()
        sb.append(title).append(&quot;\n&quot;)
        if (rs == null) { sb.append(&quot;(rs is null)\n&quot;); return sb.toString() }

        def md = rs.getMetaData()
        int colCount = md.getColumnCount()
        def cols = (1..colCount).collect { md.getColumnLabel(it) }

        def rows = []
        int cnt = 0
        while (rs.next() &amp;&amp; cnt &lt; maxRows) {
            rows &lt;&lt; (1..colCount).collect { i -&gt;
                def o = rs.getObject(i)
                (o == null) ? &quot;&quot; : o.toString()
            }
            cnt++
        }

        boolean hasMore = false
        if (cnt == maxRows) {
            if (rs.next()) hasMore = true
        }

        def widths = new int[colCount]
        for (int i=0;i&lt;colCount;i++) widths[i] = cols[i].length()
        rows.each { r -&gt;
            for (int i=0;i&lt;colCount;i++) widths[i] = Math.max(widths[i], (r[i] ?: &quot;&quot;).length())
        }

        sb.append((0..&lt;colCount).collect { i -&gt; cols[i].padRight(widths[i]) }.join(&quot;|&quot;)).append(&quot;\n&quot;)
        sb.append((0..&lt;colCount).collect { i -&gt; &quot;-&quot; * widths[i] }.join(&quot;+&quot;)).append(&quot;\n&quot;)
        rows.each { r -&gt;
            sb.append((0..&lt;colCount).collect { i -&gt; (r[i] ?: &quot;&quot;).padRight(widths[i]) }.join(&quot;|&quot;)).append(&quot;\n&quot;)
        }

        if (rows.isEmpty()) sb.append(&quot;(0 rows)\n&quot;)
        else if (hasMore) sb.append(&quot;... (truncated, maxRows=&quot;).append(maxRows).append(&quot;)\n&quot;)

        sb.toString()
    }



    // -----------------------------
    // 3) CSV writer (header order match)
    // -----------------------------
    def writeRow = { String orderKey, String scenarioLabel, String result, String notes,
                     String emrDumpStr, String vcDumpStr -&gt;

        def endStr = sdfLog.format(new Date())

        def parent = (vars.get(&quot;currentControllerName&quot;) ?: &quot;Scenario&quot;).toString().trim()
        if (!parent) parent = &quot;Scenario&quot;

        Object[] fields = [
            (orderKey ?: &quot;999&quot;).toString(),   // order_key
            parent,                           // Scenario(Parent)
            (scenarioLabel ?: &quot;&quot;).toString(), // Scenario
            (startTimeStr ?: &quot;&quot;).toString(),  // StartTime
            (endStr ?: &quot;&quot;).toString(),        // EndTime
            (emrDumpStr ?: &quot;&quot;),               // Source (EMR)
            (vcDumpStr ?: &quot;&quot;),                // Destination (VC)
            (result ?: &quot;&quot;).toString(),        // Test Result
            (notes ?: &quot;&quot;).toString()          // Notes
        ] as Object[]

        logResults(prev, ctx, props, vars, fields)
    }

    // -----------------------------
    // 4) DB connect
    // -----------------------------
    Connection pdlEmr = null
    Connection pdlVc  = null

    try {
        if (!emrUrl || !emrUser) throw new RuntimeException(&quot;[PDL] EMR JDBC_URL/JDBC_USER empty&quot;)
        if (!vcUrl  || !vcUser)  throw new RuntimeException(&quot;[PDL] VC JDBC_URL_VC/JDBC_USER_VC empty&quot;)

        pdlEmr = DriverManager.getConnection(emrUrl, emrUser, emrPw)
        pdlVc  = DriverManager.getConnection(vcUrl,  vcUser,  vcPw)
        setVcKey(pdlVc)

connVc = DriverManager.getConnection(vcUrl, vcUser, vcPw)
setVcKey(connVc, &quot;PDL&quot;)



        // -----------------------------
        // 5) Dumps / Queries
        //    - Scenario 3 리포트 컬럼 요구사항 반영
        // -----------------------------
        def dumpEncounter = { String pid, String eid, String kind -&gt;
            PreparedStatement ps = null
            ResultSet rs = null
            try {
                String sql
                if (kind == &quot;PRAC&quot;) {
                    sql = &quot;&quot;&quot;
                        SELECT
                          ee.created_dt,
                          ee.updated_dt,
                          CAST(AES_DECRYPT(FROM_BASE64(ee.encrypted_patient_id), @secretkey, @iv) AS CHAR) AS patient_id,
                          CAST(AES_DECRYPT(FROM_BASE64(ee.encrypted_emr_id),     @secretkey, @iv) AS CHAR) AS encounter_id,
                          ee.admission_dt,
                          ee.practitioner_id
                        FROM vitalcare.emr_encounter ee
                        WHERE CAST(AES_DECRYPT(FROM_BASE64(ee.encrypted_patient_id), @secretkey, @iv) AS CHAR) = ?
                          AND CAST(AES_DECRYPT(FROM_BASE64(ee.encrypted_emr_id),     @secretkey, @iv) AS CHAR) = ?
                        LIMIT 1
                    &quot;&quot;&quot;
                } else if (kind == &quot;DEPT&quot;) {
                    sql = &quot;&quot;&quot;
                        SELECT
                          ee.created_dt,
                          ee.updated_dt,
                          CAST(AES_DECRYPT(FROM_BASE64(ee.encrypted_patient_id), @secretkey, @iv) AS CHAR) AS patient_id,
                          CAST(AES_DECRYPT(FROM_BASE64(ee.encrypted_emr_id),     @secretkey, @iv) AS CHAR) AS encounter_id,
                          ee.admission_dt,
                          ee.department_id
                        FROM vitalcare.emr_encounter ee
                        WHERE CAST(AES_DECRYPT(FROM_BASE64(ee.encrypted_patient_id), @secretkey, @iv) AS CHAR) = ?
                          AND CAST(AES_DECRYPT(FROM_BASE64(ee.encrypted_emr_id),     @secretkey, @iv) AS CHAR) = ?
                        LIMIT 1
                    &quot;&quot;&quot;
                } else { // LOC
                    sql = &quot;&quot;&quot;
                        SELECT
                          ee.created_dt,
                          ee.updated_dt,
                          CAST(AES_DECRYPT(FROM_BASE64(ee.encrypted_patient_id), @secretkey, @iv) AS CHAR) AS patient_id,
                          CAST(AES_DECRYPT(FROM_BASE64(ee.encrypted_emr_id),     @secretkey, @iv) AS CHAR) AS encounter_id,
                          ee.admission_dt,
                          LENGTH(ee.location_id_ope) AS location_id_ope_len
                        FROM vitalcare.emr_encounter ee
                        WHERE CAST(AES_DECRYPT(FROM_BASE64(ee.encrypted_patient_id), @secretkey, @iv) AS CHAR) = ?
                          AND CAST(AES_DECRYPT(FROM_BASE64(ee.encrypted_emr_id),     @secretkey, @iv) AS CHAR) = ?
                        LIMIT 1
                    &quot;&quot;&quot;
                }

                ps = pdlVc.prepareStatement(sql)
                ps.setString(1, pid)
                ps.setString(2, eid)
                rs = ps.executeQuery()
                return dumpRs(&quot;vitalcare.emr_encounter&quot;, rs, 1)
            } finally { qClose(rs); qClose(ps) }
        }

        // ROOT.LOCATIONS: end_dt 제거(요구 반영)
        def dumpEmrLocationsCols = { String pid, String eid, String kind -&gt;
            PreparedStatement ps = null
            ResultSet rs = null
            try {
                String sql =
                    (kind == &quot;PRAC&quot;) ? &quot;&quot;&quot;
                        SELECT CREATED_DT, UPDATED_DT, PATIENT_ID, ENCOUNTER_ID, START_DT,
                               PRACTITIONER_ID, PRACTITIONER_NAME
                        FROM ROOT.LOCATIONS
                        WHERE PATIENT_ID=? AND ENCOUNTER_ID=?
                    &quot;&quot;&quot; :
                    (kind == &quot;DEPT&quot;) ? &quot;&quot;&quot;
                        SELECT CREATED_DT, UPDATED_DT, PATIENT_ID, ENCOUNTER_ID, START_DT,
                               DEPARTMENT_CODE, DEPARTMENT_NAME
                        FROM ROOT.LOCATIONS
                        WHERE PATIENT_ID=? AND ENCOUNTER_ID=?
                    &quot;&quot;&quot; :
                    &quot;&quot;&quot;
                        SELECT CREATED_DT, UPDATED_DT, PATIENT_ID, ENCOUNTER_ID, START_DT,
                               WARD, ROOM, BED
                        FROM ROOT.LOCATIONS
                        WHERE PATIENT_ID=? AND ENCOUNTER_ID=?
                    &quot;&quot;&quot;

                ps = pdlEmr.prepareStatement(sql)
                ps.setString(1, pid)
                ps.setString(2, eid)
                rs = ps.executeQuery()
                return dumpRs(&quot;ROOT.LOCATIONS&quot;, rs, 5)
            } finally { qClose(rs); qClose(ps) }
        }

        def dumpPractitioner = { String code -&gt;
            PreparedStatement ps = null
            ResultSet rs = null
            try {
                ps = pdlVc.prepareStatement(&quot;&quot;&quot;
                    SELECT emr_id, created_dt, updated_dt, code,
                           CAST(AES_DECRYPT(FROM_BASE64(encrypted_name), @secretkey, @iv) AS CHAR) AS name
                    FROM vitalcare.emr_practitioner
                    WHERE code = ?
                    LIMIT 1
                &quot;&quot;&quot;)
                ps.setString(1, code)
                rs = ps.executeQuery()
                return dumpRs(&quot;vitalcare.emr_practitioner&quot;, rs, 1)
            } finally { qClose(rs); qClose(ps) }
        }

        def dumpDepartment = { String code -&gt;
            PreparedStatement ps = null
            ResultSet rs = null
            try {
                ps = pdlVc.prepareStatement(&quot;&quot;&quot;
                    SELECT emr_id, created_dt, updated_dt, code, name
                    FROM vitalcare.emr_department
                    WHERE code = ?
                    LIMIT 1
                &quot;&quot;&quot;)
                ps.setString(1, code)
                rs = ps.executeQuery()
                return dumpRs(&quot;vitalcare.emr_department&quot;, rs, 1)
            } finally { qClose(rs); qClose(ps) }
        }

        // 3-3 핵심 검증: emr_location.emr_id_ope == emr_encounter.location_id_ope
        // - 리포트는 emr_id_ope_len만 보여주고, 내부적으로 &quot;연결 존재&quot;로 sync 증명
        def findLocationByEncounter = { String pid, String eid -&gt;
            PreparedStatement ps = null
            ResultSet rs = null
            try {
                ps = pdlVc.prepareStatement(&quot;&quot;&quot;
                    SELECT
                      el.created_dt,
                      el.updated_dt,
                      el.ward,
                      CAST(AES_DECRYPT(FROM_BASE64(el.room), @secretkey, @iv) AS CHAR) AS room,
                      CAST(AES_DECRYPT(FROM_BASE64(el.bed),  @secretkey, @iv) AS CHAR) AS bed,
                      el.type,
                      LENGTH(el.emr_id_ope) AS emr_id_ope_len
                    FROM vitalcare.emr_location el
                    WHERE el.emr_id_ope = (
                        SELECT ee.location_id_ope
                        FROM vitalcare.emr_encounter ee
                        WHERE CAST(AES_DECRYPT(FROM_BASE64(ee.encrypted_patient_id), @secretkey, @iv) AS CHAR)=?
                          AND CAST(AES_DECRYPT(FROM_BASE64(ee.encrypted_emr_id),     @secretkey, @iv) AS CHAR)=?
                        LIMIT 1
                    )
                    LIMIT 1
                &quot;&quot;&quot;)
                ps.setString(1, pid)
                ps.setString(2, eid)
                rs = ps.executeQuery()
                return dumpRs(&quot;vitalcare.emr_location&quot;, rs, 1)
            } finally { qClose(rs); qClose(ps) }
        }

        // (옵션) 3-3에서 ward/room/bed 기대값까지 같이 확인하고 싶으면 이거 사용
        def checkLocationCols = { String locDump, List fails -&gt;
            if (expWard &amp;&amp; !locDump.contains(&quot;|&quot; + expWard + &quot;|&quot;)) fails &lt;&lt; &quot;field mismatch: ward&quot;
            if (expRoom &amp;&amp; !locDump.contains(&quot;|&quot; + expRoom + &quot;|&quot;)) fails &lt;&lt; &quot;field mismatch: room&quot;
            if (expBed  &amp;&amp; !locDump.contains(&quot;|&quot; + expBed  + &quot;|&quot;)) fails &lt;&lt; &quot;field mismatch: bed&quot;
        }

        // -----------------------------
        // 6) Case runner (3 rows)
        // -----------------------------
        def runCase = { String caseId, String pid, String eid, String kind, Closure check -&gt;
            def fails = []
            def emrDumpStr = dumpEmrLocationsCols(pid, eid, kind)
            def vcEncDump  = dumpEncounter(pid, eid, kind)

            // encounter row existence (minimal)
            PreparedStatement ps = null
            ResultSet rs = null
            try {
                ps = pdlVc.prepareStatement(&quot;&quot;&quot;
                    SELECT practitioner_id, department_id, location_id_ope
                    FROM vitalcare.emr_encounter
                    WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id), @secretkey, @iv) AS CHAR) = ?
                      AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id),     @secretkey, @iv) AS CHAR) = ?
                    LIMIT 1
                &quot;&quot;&quot;)
                ps.setString(1, pid)
                ps.setString(2, eid)
                rs = ps.executeQuery()
                if (!rs.next()) fails &lt;&lt; &quot;VC row not found&quot;
                else check(rs, fails, vcEncDump)
            } finally { qClose(rs); qClose(ps) }

            def result  = fails.isEmpty() ? &quot;PASS&quot; : &quot;FAIL&quot;
            def passNote = (caseId == &quot;3-1&quot;) ? &quot;new practitioner&quot; : (caseId == &quot;3-2&quot;) ? &quot;new department&quot; : &quot;new location&quot;
            def notes   = (result == &quot;PASS&quot;) ? passNote : fails.join(&quot; | &quot;)

            def vcDumpStrFinal = (vars.get(&quot;pdl_vc_dump_&quot; + caseId) ?: vcEncDump).toString()
            def orderKey = (caseId == &quot;3-1&quot;) ? &quot;311&quot; : (caseId == &quot;3-2&quot;) ? &quot;312&quot; : &quot;313&quot;

            writeRow(orderKey, &quot;Scenario &quot; + caseId, result, notes, emrDumpStr, vcDumpStrFinal)
        }

        // 3-1: practitioner (id + name)
        runCase(&quot;3-1&quot;, pid0, eid0, &quot;PRAC&quot;) { ResultSet r, List fails, String vcEncDump -&gt;
            def prac = (r.getString(&quot;practitioner_id&quot;) ?: &quot;&quot;).toString().trim()
            if (!prac) fails &lt;&lt; &quot;practitioner_id is empty&quot;
            if (expPracId &amp;&amp; prac != expPracId) fails &lt;&lt; &quot;field mismatch: practitioner_id&quot;

            def pracDump = dumpPractitioner(expPracId)

            PreparedStatement ps2 = null
            ResultSet rs2 = null
            try {
                ps2 = pdlVc.prepareStatement(&quot;&quot;&quot;
                    SELECT CAST(AES_DECRYPT(FROM_BASE64(encrypted_name), @secretkey, @iv) AS CHAR) AS name
                    FROM vitalcare.emr_practitioner
                    WHERE code = ?
                    LIMIT 1
                &quot;&quot;&quot;)
                ps2.setString(1, expPracId)
                rs2 = ps2.executeQuery()
                if (!rs2.next()) fails &lt;&lt; &quot;VC practitioner not found (code=&quot; + expPracId + &quot;)&quot;
                else {
                    def nm = (rs2.getString(&quot;name&quot;) ?: &quot;&quot;).toString().trim()
                    if (expPracName &amp;&amp; nm != expPracName) fails &lt;&lt; &quot;field mismatch: practitioner_name&quot;
                }
            } finally { qClose(rs2); qClose(ps2) }

            vars.put(&quot;pdl_vc_dump_3-1&quot;, (vcEncDump + &quot;\n&quot; + pracDump))
        }

        // 3-2: department (code + name)
        runCase(&quot;3-2&quot;, pid1, eid1, &quot;DEPT&quot;) { ResultSet r, List fails, String vcEncDump -&gt;
            def dept = (r.getString(&quot;department_id&quot;) ?: &quot;&quot;).toString().trim()
            if (!dept) fails &lt;&lt; &quot;department_id is empty&quot;
            if (expDeptCode &amp;&amp; dept != expDeptCode) fails &lt;&lt; &quot;field mismatch: department_id&quot;

            def deptDump = dumpDepartment(expDeptCode)

            PreparedStatement ps2 = null
            ResultSet rs2 = null
            try {
                ps2 = pdlVc.prepareStatement(&quot;&quot;&quot;
                    SELECT name
                    FROM vitalcare.emr_department
                    WHERE code = ?
                    LIMIT 1
                &quot;&quot;&quot;)
                ps2.setString(1, expDeptCode)
                rs2 = ps2.executeQuery()
                if (!rs2.next()) fails &lt;&lt; &quot;VC department not found (code=&quot; + expDeptCode + &quot;)&quot;
                else {
                    def nm = (rs2.getString(&quot;name&quot;) ?: &quot;&quot;).toString().trim()
                    if (expDeptName &amp;&amp; nm != expDeptName) fails &lt;&lt; &quot;field mismatch: department_name&quot;
                }
            } finally { qClose(rs2); qClose(ps2) }

            vars.put(&quot;pdl_vc_dump_3-2&quot;, (vcEncDump + &quot;\n&quot; + deptDump))
        }

        // 3-3: location
        // - encounter: location_id_ope_len &gt; 0
        // - location: emr_location.emr_id_ope == encounter.location_id_ope 인 row 존재
        runCase(&quot;3-3&quot;, pid2, eid2, &quot;LOC&quot;) { ResultSet r, List fails, String vcEncDump -&gt;

            // encounter dump에는 location_id_ope_len만 나오므로 별도 계산 불필요
            // 다만 &quot;연결된 location row&quot; 존재 여부로 sync 증명
            def locDump = findLocationByEncounter(pid2, eid2)
            if (locDump.contains(&quot;(0 rows)&quot;)) {
                fails &lt;&lt; &quot;VC emr_location not linked with encounter.location_id_ope&quot;
            } else {
                // (옵션) 기대 ward/room/bed까지 검사하고 싶으면 주석 해제
                // checkLocationCols(locDump, fails)
            }

            // Destination dump (빈줄 1줄)
            vars.put(&quot;pdl_vc_dump_3-3&quot;, (vcEncDump + &quot;\n&quot; + locDump))
        }

        // -----------------------------
        // 7) mark pass
        // -----------------------------
        vars.put(&quot;verify_result&quot;, &quot;PASS&quot;)
        vars.put(&quot;verify_notes&quot;, &quot;&quot;)
        vars.put(&quot;verify_endTime&quot;, sdfLog.format(new Date()))
        prev.setSuccessful(true)
        prev.setResponseMessage(&quot;SYNC PASS | PDL wrote 3 rows&quot;)
        return

    } finally {
        qClose(pdlEmr)
        qClose(pdlVc)
    }
}



// -----------------------------------------------------
// Helpers
// -----------------------------------------------------
def closeQuietly = { AutoCloseable c -&gt;
    try { if (c != null) c.close() } catch (ignored) {}
}

def normalizeSex = { v -&gt;
    if (v == null) return &quot;&quot;
    def val = v.toString().trim().toLowerCase()
    if (val == &quot;male&quot; || val == &quot;m&quot;) return &quot;M&quot;
    if (val == &quot;female&quot; || val == &quot;f&quot;) return &quot;F&quot;
    return val.toUpperCase()
}

// yyyy-MM-dd / yyyy-MM-dd HH:mm:ss / yyyy-MM-dd HH:mm:ss.SSS / ISO 형태 섞여도 &quot;yyyy-MM-dd&quot;만 뽑기
def normalizeBirth = { v -&gt;
    if (v == null) return &quot;&quot;
    def s = v.toString().trim()
    if (s.contains(&quot; &quot;)) return s.split(&quot; &quot;)[0]
    if (s.contains(&quot;T&quot;)) return s.split(&quot;T&quot;)[0]
    return s
}

def normalizeDnr = { v -&gt;
    if (v == null) return &quot;0&quot;
    def val = v.toString().trim().toLowerCase()
    if (val == &quot;true&quot;)  return &quot;1&quot;
    if (val == &quot;false&quot;) return &quot;0&quot;
    return val
}

/**
 * ENCOUNTER admission_dt 규칙:
 * EMR ADMISSION_DATE(any time) -&gt; VC admission_dt = &quot;전날 15:00:00&quot; (TZ 기준)
 * return format: yyyy-MM-dd HH:mm:ss
 */
def toPrevDay15 = { v -&gt;
    if (v == null) return &quot;&quot;
    def s = v.toString().trim()
    if (!s) return &quot;&quot;

    Date dt = null
    def fmts = [
        &quot;yyyy-MM-dd HH:mm:ss.SSS&quot;,
        &quot;yyyy-MM-dd HH:mm:ss&quot;,
        &quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss.SSS&quot;,
        &quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;,
        &quot;yyyy-MM-dd&quot;
    ]

    for (String f : fmts) {
        try {
            def sdf = new SimpleDateFormat(f)
            sdf.setTimeZone(TimeZone.getTimeZone(TZ))
            dt = sdf.parse(s)
            break
        } catch (ignored) {}
    }
    if (dt == null) return &quot;&quot;

    def cal = Calendar.getInstance(TimeZone.getTimeZone(TZ))
    cal.setTime(dt)
    cal.add(Calendar.DATE, -1)
    cal.set(Calendar.HOUR_OF_DAY, 15)
    cal.set(Calendar.MINUTE, 0)
    cal.set(Calendar.SECOND, 0)
    cal.set(Calendar.MILLISECOND, 0)

    def out = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    out.setTimeZone(TimeZone.getTimeZone(TZ))
    return out.format(cal.getTime())
}

String dumpResultSetAllColumnsPretty(String tableName, ResultSet rs, int maxRows) {
    def sb = new StringBuilder()
    sb.append(tableName).append(&quot;\n&quot;)

    if (rs == null) {
        sb.append(&quot;(rs is null)\n&quot;)
        return sb.toString()
    }

    def md = rs.getMetaData()
    int colCount = md.getColumnCount()

    def colNames = []
    for (int i = 1; i &lt;= colCount; i++) colNames &lt;&lt; md.getColumnLabel(i)

    def rows = []
    int count = 0
    while (rs.next()) {
        def row = []
        for (int i = 1; i &lt;= colCount; i++) {
            def obj = rs.getObject(i)
            row &lt;&lt; ((obj == null) ? &quot;&quot; : obj.toString())
        }
        rows &lt;&lt; row
        count++
        if (count &gt;= maxRows) break
    }

    def widths = new int[colCount]
    for (int i = 0; i &lt; colCount; i++) widths[i] = colNames[i].length()
    rows.each { r -&gt;
        for (int i = 0; i &lt; colCount; i++)
            widths[i] = Math.max(widths[i], (r[i] ?: &quot;&quot;).length())
    }

    sb.append((0..&lt;colCount).collect { i -&gt; colNames[i].padRight(widths[i]) }.join(&quot;|&quot;)).append(&quot;\n&quot;)
    sb.append((0..&lt;colCount).collect { i -&gt; &quot;-&quot; * widths[i] }.join(&quot;+&quot;)).append(&quot;\n&quot;)
    rows.each { r -&gt;
        sb.append((0..&lt;colCount).collect { i -&gt; (r[i] ?: &quot;&quot;).padRight(widths[i]) }.join(&quot;|&quot;)).append(&quot;\n&quot;)
    }

 if (rows.isEmpty()) {
    sb.append(&quot;(0 rows)\n&quot;)
} else {
    // maxRows만큼만 담았는데 실제로 더 있으면 그때만 truncated
    boolean hasMore = false
    if (count &gt;= maxRows) {
        try { hasMore = rs.next() } catch (ignored) { hasMore = false }
    }
    if (hasMore) sb.append(&quot;... (truncated, maxRows=&quot;).append(maxRows).append(&quot;)\n&quot;)
}


    return sb.toString()
}


// dump에서 title line 한번 제거(중복 before 제거용)
def stripTitleOnce = { String dump, String expectedPrefix -&gt;
    if (!dump) return &quot;&quot;
    def s = dump.toString()
    if (s.startsWith(expectedPrefix)) {
        int idx = s.indexOf(&quot;\n&quot;)
        if (idx &gt;= 0) return s.substring(idx + 1)
    }
    s
}



// =====================================================
// CSV + Finalize
// - logResults(closure) 존재/타입 체크
// - 9컬럼 CSV row 쓰기(order_key + parent + 7cols) 표준화
// - 블록(VITAL/LAB 등)에서 이거만 호출하고 return 하면 절대 안깨짐
// =====================================================

def _requireLogResults = {
    def lr = vars.getObject(&quot;logResults&quot;)
    if (lr == null) {
        throw new RuntimeException(&quot;[COMMON] logResults is null. Register_LogResults 실행/스코프 확인 필요.&quot;)
    }
    // Groovy Closure 여부는 컴파일 환경에 따라 달라서 간단히 callable만 체크
    try {
        lr.call(prev, ctx, props, vars, [&quot;999&quot;,&quot;Scenario&quot;,&quot;Scenario&quot;,&quot;&quot;, &quot;&quot;, &quot;&quot;, &quot;&quot;, &quot;&quot;, &quot;&quot;] as Object[])
    } catch (Throwable t) {
        // 위 call은 실제 CSV에 쓰지 않게 하려면 아래처럼 &apos;검사용 더미 call&apos; 대신 타입만 확인하는 방식이 안전함.
        // 그런데 JMeter/Groovy 환경마다 Closure/ScriptObject 타입이 달라서, call 가능성 검증이 가장 확실함.
        // 더미 row가 찍히면 안되니까, 실제로는 call을 하지 않고 &quot;toString&quot; + &quot;respondsTo&quot;로만 체크.
    }
    return lr
}

// ⚠️ 더미 call로 CSV에 한 줄 찍히는 걸 막기 위해, 위 방식 대신 &quot;call 가능성만&quot; 가볍게 검사하는 버전:
def getLogResults = {
    def lr = vars.getObject(&quot;logResults&quot;)
    if (lr == null) {
        throw new RuntimeException(&quot;[COMMON] logResults is null. Register_LogResults 실행/스코프 확인 필요.&quot;)
    }
    // callable 검사(최소)
    if (!(lr instanceof groovy.lang.Closure)) {
        // 일부 환경에서 Closure가 아니어도 call()이 되는 객체가 있을 수 있어서, 한 번 더 확인
        try {
            lr.metaClass.getMetaMethod(&quot;call&quot;, prev, ctx, props, vars, [] as Object[])
        } catch (ignored) {
            log.warn(&quot;[COMMON] logResults is not a Closure. Will try invoke as callable anyway.&quot;)
        }
    }
    return lr
}

/**
 * writeCsv9(orderKey, scenarioLabel, result, notes, emrDump, vcDump, startTimeStr, endTimeStr)
 * - 9 fields 정확히 맞춰서 logResults로 append
 * - parent(Scenario Parent)는 Register_LogResults가 넣는게 아니라,
 *   지금 네 logResults는 9개면 &quot;그대로&quot; 쓰니까 여기서 parent까지 포함해서 9개를 만들어줌
 */
def writeCsv9 = { String orderKey,
                  String scenarioLabel,
                  String result,
                  String notes,
                  String emrDumpStr,
                  String vcDumpStr,
                  String startTimeStr,
                  String endTimeStr -&gt;

    def lr = getLogResults()

    def parent = (vars.get(&quot;currentControllerName&quot;) ?: &quot;Scenario&quot;).toString().trim()
    if (!parent) parent = &quot;Scenario&quot;

    Object[] fields9 = [
        (orderKey ?: &quot;999&quot;).toString(),     // order_key
        parent,                              // Scenario(Parent)
        (scenarioLabel ?: &quot;&quot;).toString(),    // Scenario
        (startTimeStr ?: &quot;&quot;).toString(),     // StartTime
        (endTimeStr ?: &quot;&quot;).toString(),       // EndTime
        (emrDumpStr ?: &quot;&quot;),                  // Source (EMR)
        (vcDumpStr ?: &quot;&quot;),                   // Destination (VC)
        (result ?: &quot;&quot;).toString(),           // Test Result
        (notes ?: &quot;&quot;).toString()             // Notes
    ] as Object[]

    lr(prev, ctx, props, vars, fields9)
}

/**
 * finishAndReturn(result, notes, emrDump, vcDump, orderKey, scenarioLabel)
 * - verify_* 세팅 + CSV append + prev 세팅 + return용
 * - VITAL/LAB 블록 끝에서 이거만 호출하고 return 하면 &quot;아래 로직 침범&quot; 방지
 */
def finishAndReturn = { String result,
                        String notes,
                        String emrDumpStr,
                        String vcDumpStr,
                        String orderKey,
                        String scenarioLabel -&gt;

    long endMillis = System.currentTimeMillis()
    def endTimeStr = sdfLog.format(new Date(endMillis))
    def startTimeStr = (vars.get(&quot;verify_startTime&quot;) ?: startTime).toString()

    // verify vars (HTML/CSV 공용)
    vars.put(&quot;verify_result&quot;, (result ?: &quot;ERROR&quot;))
    vars.put(&quot;verify_notes&quot;, (notes ?: &quot;&quot;))
    vars.put(&quot;verify_emrDump&quot;, (emrDumpStr ?: &quot;&quot;))
    vars.put(&quot;verify_vcDump&quot;, (vcDumpStr ?: &quot;&quot;))
    vars.put(&quot;verify_endTime&quot;, endTimeStr)

    // duration
    try {
        def st = vars.getObject(&quot;caseStartMillis&quot;) as Long
        if (st != null) vars.put(&quot;verify_duration_ms&quot;, String.valueOf(endMillis - st))
        else vars.put(&quot;verify_duration_ms&quot;, &quot;&quot;)
    } catch (ignored) {
        vars.put(&quot;verify_duration_ms&quot;, &quot;&quot;)
    }

    // CSV append (9 cols)
    writeCsv9(
        (orderKey ?: &quot;999&quot;),
        (scenarioLabel ?: (vars.get(&quot;verify_scenario&quot;) ?: SCENARIO_NAME).toString()),
        (result ?: &quot;ERROR&quot;),
        (notes ?: &quot;&quot;),
        (emrDumpStr ?: &quot;&quot;),
        (vcDumpStr ?: &quot;&quot;),
        startTimeStr,
        endTimeStr
    )

    // sampler verdict
    prev.setSuccessful(&quot;PASS&quot;.equalsIgnoreCase(result) || &quot;SKIP&quot;.equalsIgnoreCase(result))
    prev.setResponseMessage(&quot;SYNC &quot; + (result ?: &quot;ERROR&quot;) + ((notes?.trim()) ? (&quot; | &quot; + notes) : &quot;&quot;))

    log.info(&quot;[COMMON_FINAL] result=${result}, scenario=${SCENARIO_ID}, orderKey=${orderKey}, end=${endTimeStr}&quot;)
    return
}




// -----------------------------------------------------
// VITAL (Verify + Dump)  [FINAL]
// - 목적: EMR(Oracle) ROOT.VITALS 생성 데이터가 VC(MySQL)로 동기화 되었는지 검증
// - 검증: count 중심 (expectedCount 있으면 그걸 우선)
// - 덤프: EMR/VC 각각 최근 N건 pretty dump (CSV/HTML에 넣을 verify_emrDump / verify_vcDump)
// - VC: emr_observation / vc_observation / vc_event 테이블 구조가 달라서 SELECT 컬럼 분리
// -----------------------------------------------------
if (&quot;VITAL&quot;.equalsIgnoreCase(VERIFY_TARGET)) {

    log.info(&quot;[VITAL_BLOCK_ENTER] tables=ROOT.VITALS -&gt; emr_observation/vc_observation/vc_event&quot;)

    // ---------- local helpers ----------
    def closeQ = { AutoCloseable c -&gt; try { if (c != null) c.close() } catch (ignored) {} }

    def must = { String name, def val -&gt;
        if (val == null) throw new RuntimeException(&quot;${name} is null&quot;)
        def s = val.toString().trim()
        if (!s) throw new RuntimeException(&quot;${name} is empty&quot;)
        return s
    }

    // ---------- inputs ----------
    def pid = (vars.get(&quot;patient_id&quot;) ?: patientId ?: &quot;&quot;).toString().trim()
    def eid = (vars.get(&quot;encounter_id&quot;) ?: encounterId ?: &quot;&quot;).toString().trim()

    // sanity
    must(&quot;patient_id&quot;, pid)
    must(&quot;encounter_id&quot;, eid)
    must(&quot;JDBC_URL&quot;, emrUrl);  must(&quot;JDBC_USER&quot;, emrUser)
    must(&quot;JDBC_URL_VC&quot;, vcUrl); must(&quot;JDBC_USER_VC&quot;, vcUser)

    // ---------- tunables ----------
    def EMR_VITAL_TABLE = (vars.get(&quot;EMR_VITAL_TABLE&quot;) ?: &quot;ROOT.VITALS&quot;).toString().trim()

    def VC_TBL_EMR_OBS  = (vars.get(&quot;VC_TBL_EMR_OBS&quot;)  ?: &quot;vitalcare.emr_observation&quot;).toString().trim()
    def VC_TBL_VC_OBS   = (vars.get(&quot;VC_TBL_VC_OBS&quot;)   ?: &quot;vitalcare.vc_observation&quot;).toString().trim()
    def VC_TBL_VC_EVENT = (vars.get(&quot;VC_TBL_VC_EVENT&quot;) ?: &quot;vitalcare.vc_event&quot;).toString().trim()

    int DUMP_N = ((vars.get(&quot;vital_dump_n&quot;) ?: &quot;15&quot;).toString().trim() as int)

    // expected count (optional)
    def expCntStr = (vars.get(&quot;vital_expected_count&quot;) ?: &quot;&quot;).toString().trim()
    Integer expectedCount = expCntStr ? Integer.parseInt(expCntStr) : null

    // EMR codes + mapping to VC types
    def emrCodes = [&quot;DBP&quot;,&quot;FiO2&quot;,&quot;GCS&quot;,&quot;O2&quot;,&quot;PULSE&quot;,&quot;RESP&quot;,&quot;SBP&quot;,&quot;SpO2&quot;,&quot;TEMP&quot;]
    def mapType = { String emrCode -&gt;
        if (emrCode == null) return &quot;&quot;
        switch (emrCode.trim()) {
            case &quot;RESP&quot;:  return &quot;RR&quot;
            case &quot;PULSE&quot;: return &quot;PR&quot;
            case &quot;TEMP&quot;:  return &quot;BT&quot;
            default:      return emrCode.trim()
        }
    }
    def vcTypes = emrCodes.collect { mapType(it) }.findAll { it }.unique()

    // ---------- runtime holders ----------
    def failsLocal = []
    def emrDumpStr = &quot;&quot;
    def vcDumpStr  = &quot;&quot;

    Connection eConn = null
    Connection vConn = null

    try {
        // =====================================================
        // 1) EMR (Oracle): count + dump
        // =====================================================
        eConn = DriverManager.getConnection(emrUrl, emrUser, emrPw)

        int emrCnt = 0
        PreparedStatement psEmrCnt = null
        ResultSet rsEmrCnt = null
        try {
            psEmrCnt = eConn.prepareStatement(&quot;&quot;&quot;
                SELECT COUNT(*) AS cnt
                FROM ${EMR_VITAL_TABLE}
                WHERE PATIENT_ID = ?
                  AND ENCOUNTER_ID = ?
                  AND CODE IN (${emrCodes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
                  AND DELETED_YN = 0
                  AND INVALID = 0
            &quot;&quot;&quot;)
            int idx = 1
            psEmrCnt.setString(idx++, pid)
            psEmrCnt.setString(idx++, eid)
            emrCodes.each { c -&gt; psEmrCnt.setString(idx++, c) }

            rsEmrCnt = psEmrCnt.executeQuery()
            rsEmrCnt.next()
            emrCnt = rsEmrCnt.getInt(&quot;cnt&quot;)
        } finally {
            closeQ(rsEmrCnt); closeQ(psEmrCnt)
        }

        PreparedStatement psEmrDump = null
        ResultSet rsEmrDump = null
        try {
            psEmrDump = eConn.prepareStatement(&quot;&quot;&quot;
                SELECT CREATED_DT, UPDATED_DT, PATIENT_ID, ENCOUNTER_ID, OBSERVED_DT, CODE, VALUE, DELETED_YN
                FROM ${EMR_VITAL_TABLE}
                WHERE PATIENT_ID = ?
                  AND ENCOUNTER_ID = ?
                  AND CODE IN (${emrCodes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
                  AND DELETED_YN = 0
                  AND INVALID = 0
                ORDER BY OBSERVED_DT DESC, ID DESC
                FETCH FIRST ${DUMP_N} ROWS ONLY
            &quot;&quot;&quot;)
            int idx2 = 1
            psEmrDump.setString(idx2++, pid)
            psEmrDump.setString(idx2++, eid)
            emrCodes.each { c -&gt; psEmrDump.setString(idx2++, c) }

            rsEmrDump = psEmrDump.executeQuery()
            emrDumpStr = dumpResultSetAllColumnsPretty(&quot;${EMR_VITAL_TABLE}&quot;, rsEmrDump, DUMP_N)
            if (!emrDumpStr?.trim()) emrDumpStr = &quot;${EMR_VITAL_TABLE}\n(0 rows)\n&quot;
        } finally {
            closeQ(rsEmrDump); closeQ(psEmrDump)
        }

        // =====================================================
        // 2) VC (MySQL): connect + set @secretkey/@iv
        // =====================================================
        vConn = DriverManager.getConnection(vcUrl, vcUser, vcPw)
        setVcKey(vConn, &quot;VITAL&quot;)

        // =====================================================
        // 3) VC counts: emr_observation / vc_observation / vc_event
        // =====================================================
        def countVcObs = { String tableName, String typeColName -&gt;
            PreparedStatement ps = null
            ResultSet rs = null
            try {
                ps = vConn.prepareStatement(&quot;&quot;&quot;
                    SELECT COUNT(*) AS cnt
                    FROM ${tableName}
                    WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id), @secretkey, @iv) AS CHAR) = ?
                      AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR) = ?
                      AND ${typeColName} IN (${vcTypes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
                &quot;&quot;&quot;)
                int k = 1
                ps.setString(k++, pid)
                ps.setString(k++, eid)
                vcTypes.each { t -&gt; ps.setString(k++, t) }

                rs = ps.executeQuery()
                rs.next()
                return rs.getInt(&quot;cnt&quot;)
            } finally { closeQ(rs); closeQ(ps) }
        }

        def countVcEvent = {
            PreparedStatement ps = null
            ResultSet rs = null
            try {
                ps = vConn.prepareStatement(&quot;&quot;&quot;
                    SELECT COUNT(*) AS cnt
                    FROM ${VC_TBL_VC_EVENT}
                    WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id), @secretkey, @iv) AS CHAR) = ?
                      AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR) = ?
                      AND category = ?
                      AND subcategory IN (${vcTypes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
                &quot;&quot;&quot;)
                int k = 1
                ps.setString(k++, pid)
                ps.setString(k++, eid)
                ps.setString(k++, &quot;Observation&quot;)
                vcTypes.each { t -&gt; ps.setString(k++, t) }

                rs = ps.executeQuery()
                rs.next()
                return rs.getInt(&quot;cnt&quot;)
            } finally { closeQ(rs); closeQ(ps) }
        }

        int vcEmrObsCnt = countVcObs(VC_TBL_EMR_OBS, &quot;type&quot;)
        int vcVcObsCnt  = countVcObs(VC_TBL_VC_OBS,  &quot;type&quot;)
        int vcEventCnt  = countVcEvent()

        // =====================================================
        // 4) VC dumps (table별 컬럼 분리!)
        // =====================================================
        def dumpVcEmrObs = { String tableName -&gt;
            PreparedStatement ps = null
            ResultSet rs = null
            try {
                ps = vConn.prepareStatement(&quot;&quot;&quot;
                    SELECT created_dt, updated_dt, 
                    CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),   @secretkey, @iv) AS CHAR) AS patient_id,
                    CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR) AS encounter_id,
                    observed_dt, type, value, raw_value
                    FROM ${tableName}
                    WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id), @secretkey, @iv) AS CHAR) = ?
                      AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR) = ?
                      AND type IN (${vcTypes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
                    ORDER BY observed_dt DESC, id DESC
                    LIMIT ${DUMP_N}
                &quot;&quot;&quot;)
                int p = 1
                ps.setString(p++, pid)
                ps.setString(p++, eid)
                vcTypes.each { t -&gt; ps.setString(p++, t) }

                rs = ps.executeQuery()
                def s = dumpResultSetAllColumnsPretty(&quot;${tableName}&quot;, rs, DUMP_N)
                return s?.trim() ? s : &quot;${tableName}\n(0 rows)\n&quot;
            } finally { closeQ(rs); closeQ(ps) }
        }

        def dumpVcVcObs = { String tableName -&gt;
            PreparedStatement ps = null
            ResultSet rs = null
            try {
                ps = vConn.prepareStatement(&quot;&quot;&quot;
                    SELECT created_dt, updated_dt, 
                    CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),   @secretkey, @iv) AS CHAR) AS patient_id,
                    CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR) AS encounter_id,
                    observed_dt, type, value, raw_value, emr_created_dt
                    FROM ${tableName}
                    WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id), @secretkey, @iv) AS CHAR) = ?
                      AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR) = ?
                      AND type IN (${vcTypes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
                    ORDER BY observed_dt DESC, id DESC
                    LIMIT ${DUMP_N}
                &quot;&quot;&quot;)
                int p = 1
                ps.setString(p++, pid)
                ps.setString(p++, eid)
                vcTypes.each { t -&gt; ps.setString(p++, t) }

                rs = ps.executeQuery()
                def s = dumpResultSetAllColumnsPretty(&quot;${tableName}&quot;, rs, DUMP_N)
                return s?.trim() ? s : &quot;${tableName}\n(0 rows)\n&quot;
            } finally { closeQ(rs); closeQ(ps) }
        }

        def dumpVcEvent = {
            PreparedStatement ps = null
            ResultSet rs = null
            try {
                ps = vConn.prepareStatement(&quot;&quot;&quot;
                    SELECT created_dt, updated_dt, 
                    CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id),   @secretkey, @iv) AS CHAR) AS patient_id,
                    CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR) AS encounter_id,
                    observed_dt, category, subcategory, value, raw_value
                    FROM ${VC_TBL_VC_EVENT}
                    WHERE CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id), @secretkey, @iv) AS CHAR) = ?
                      AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_encounter_id), @secretkey, @iv) AS CHAR) = ?
                      AND category = &apos;Observation&apos;
                      AND subcategory IN (${vcTypes.collect{&quot;?&quot;}.join(&quot;,&quot;)})
                    ORDER BY observed_dt DESC, id DESC
                    LIMIT ${DUMP_N}
                &quot;&quot;&quot;)
                int p = 1
                ps.setString(p++, pid)
                ps.setString(p++, eid)
                vcTypes.each { t -&gt; ps.setString(p++, t) }

                rs = ps.executeQuery()
                def s = dumpResultSetAllColumnsPretty(&quot;${VC_TBL_VC_EVENT}&quot;, rs, DUMP_N)
                return s?.trim() ? s : &quot;${VC_TBL_VC_EVENT}\n(0 rows)\n&quot;
            } finally { closeQ(rs); closeQ(ps) }
        }

        def vcDump1 = dumpVcEmrObs(VC_TBL_EMR_OBS)
        def vcDump2 = dumpVcVcObs(VC_TBL_VC_OBS)
        def vcDump3 = dumpVcEvent()

        // 보기 좋게 title 중복 제거(네 Common에 stripTitleOnce가 있다면 써도 됨)
        // 여기서는 안전하게 그대로 합침
        vcDumpStr =
            vcDump1.trim() + &quot;\n\n&quot; +
            vcDump2.trim() + &quot;\n\n&quot; +
            vcDump3.trim() + &quot;\n&quot;

        // =====================================================
        // 5) 판정
        // =====================================================
        if (expectedCount != null) {
            if (emrCnt != expectedCount)      failsLocal &lt;&lt; &quot;EMR count mismatch (expected=${expectedCount}, actual=${emrCnt})&quot;
            if (vcEmrObsCnt != expectedCount) failsLocal &lt;&lt; &quot;VC emr_observation count mismatch (expected=${expectedCount}, actual=${vcEmrObsCnt})&quot;
            if (vcVcObsCnt  != expectedCount) failsLocal &lt;&lt; &quot;VC vc_observation count mismatch (expected=${expectedCount}, actual=${vcVcObsCnt})&quot;
            if (vcEventCnt  != expectedCount) failsLocal &lt;&lt; &quot;VC vc_event count mismatch (expected=${expectedCount}, actual=${vcEventCnt})&quot;
        } else {
            if (vcEmrObsCnt != emrCnt) failsLocal &lt;&lt; &quot;count mismatch: EMR(${emrCnt}) != VC emr_observation(${vcEmrObsCnt})&quot;
            if (vcVcObsCnt  != emrCnt) failsLocal &lt;&lt; &quot;count mismatch: EMR(${emrCnt}) != VC vc_observation(${vcVcObsCnt})&quot;
            if (vcEventCnt  != emrCnt) failsLocal &lt;&lt; &quot;count mismatch: EMR(${emrCnt}) != VC vc_event(${vcEventCnt})&quot;
        }

        // =====================================================
        // 6) 최종 반영 (Common 규약에 맞춤)
        // =====================================================
        def result = failsLocal.isEmpty() ? &quot;PASS&quot; : &quot;FAIL&quot;
        def notes  = failsLocal.isEmpty() ? &quot;&quot; : failsLocal.join(&quot; | &quot;)

        vars.put(&quot;verify_emrDump&quot;, emrDumpStr ?: &quot;&quot;)
        vars.put(&quot;verify_vcDump&quot;,  vcDumpStr  ?: &quot;&quot;)
        vars.put(&quot;verify_result&quot;,  result)
        vars.put(&quot;verify_notes&quot;,   notes)

        long endMillis = System.currentTimeMillis()
        vars.putObject(&quot;caseEndMillis&quot;, endMillis as Long)
        vars.put(&quot;verify_endTime&quot;, sdfLog.format(new Date(endMillis)))
        vars.put(&quot;verify_duration_ms&quot;, String.valueOf(endMillis - startMillis))

        prev.setSuccessful(&quot;PASS&quot;.equalsIgnoreCase(result))
        prev.setResponseMessage(&quot;SYNC &quot; + result + (notes ? (&quot; | &quot; + notes) : &quot;&quot;))

        log.info(&quot;[VITAL] result=${result}, notes=${notes}&quot;)
        log.info(&quot;[VITAL] counts: EMR=${emrCnt}, VC(emr_obs)=${vcEmrObsCnt}, VC(vc_obs)=${vcVcObsCnt}, VC(event)=${vcEventCnt}&quot;)

    } catch (Throwable e) {
        log.error(&quot;[VITAL] Exception&quot;, e)

        def msg = &quot;exception: &quot; + e.getClass().getSimpleName() + &quot; - &quot; + (e.getMessage() ?: &quot;&quot;)
        vars.put(&quot;verify_result&quot;, &quot;FAIL&quot;)
        vars.put(&quot;verify_notes&quot;, msg)
        vars.put(&quot;verify_emrDump&quot;, emrDumpStr ?: &quot;&quot;)
        vars.put(&quot;verify_vcDump&quot;,  vcDumpStr  ?: &quot;&quot;)

        prev.setSuccessful(false)
        prev.setResponseMessage(&quot;SYNC FAIL | &quot; + msg)

    } finally {
        closeQ(eConn)
        closeQ(vConn)
    }

    // VITAL 블록 여기서 종료 (다른 target 로직으로 흘러가지 않게)
    // (Common 구조가 if/else if 체인이라면 이 줄은 없어도 됨)
}





// -----------------------------------------------------
// Runtime holders
// -----------------------------------------------------
def emr = [:]
def vc  = [:]
def fails = []

def emrDump = &quot;&quot;
def vcAfterDumpRaw = &quot;&quot;
boolean vcFoundFlag = false

Connection connEmr = null
Connection connVc  = null

def emrTitle     = EMR_TABLE + (showAfterTag ? &quot; (after)&quot; : &quot;&quot;)
def vcAfterTitle = VC_TABLE  + (showAfterTag ? &quot; (after)&quot; : &quot;&quot;)

int MAX_DUMP_ROWS = 5

try {
    // sanity checks
    if (!patientId) throw new RuntimeException(&quot;patient_id is empty&quot;)
    if (!emrUrl)    throw new RuntimeException(&quot;JDBC_URL is empty&quot;)
    if (!emrUser)   throw new RuntimeException(&quot;JDBC_USER is empty&quot;)
    if (!vcUrl)     throw new RuntimeException(&quot;JDBC_URL_VC is empty&quot;)
    if (!vcUser)    throw new RuntimeException(&quot;JDBC_URL_VC is empty&quot;)

    if (VERIFY_TARGET == &quot;ENCOUNTER&quot;) {
        if (!encounterId) throw new RuntimeException(&quot;encounter_id is empty (verify_target=ENCOUNTER)&quot;)
    }

    // =====================================================
    // 1) EMR Dump + fields
    // =====================================================
    connEmr = DriverManager.getConnection(emrUrl, emrUser, emrPw)
    setVcKey(connVc, &quot;RUNTIME&quot;)

    PreparedStatement psEmrDump = null
    ResultSet rsEmrDump = null
    PreparedStatement psEmr = null
    ResultSet rsEmr = null

    try {
        if (VERIFY_TARGET == &quot;ENCOUNTER&quot;) {
            // --- EMR ENCOUNTERS dump: pid + eid ---
            def emrTitleEnc = EMR_TABLE + (showAfterTag ? &quot; (after)&quot; : &quot;&quot;)
            psEmrDump = connEmr.prepareStatement(&quot;SELECT * FROM ${EMR_TABLE} WHERE PATIENT_ID = ? AND ENCOUNTER_ID = ?&quot;)
            psEmrDump.setString(1, patientId)
            psEmrDump.setString(2, encounterId)
            rsEmrDump = psEmrDump.executeQuery()
            emrDump = dumpResultSetAllColumnsPretty(emrTitleEnc, rsEmrDump, MAX_DUMP_ROWS)

            closeQuietly(rsEmrDump); rsEmrDump = null
            closeQuietly(psEmrDump); psEmrDump = null

            // --- minimal fields for compare (pid/eid/admission) ---
            psEmr = connEmr.prepareStatement(&quot;&quot;&quot;
                SELECT PATIENT_ID, ENCOUNTER_ID, ADMISSION_DATE
                FROM ${EMR_TABLE}
                WHERE PATIENT_ID = ? AND ENCOUNTER_ID = ?
            &quot;&quot;&quot;)
            psEmr.setString(1, patientId)
            psEmr.setString(2, encounterId)
            rsEmr = psEmr.executeQuery()

            if (!rsEmr.next()) {
                fails &lt;&lt; &quot;EMR encounter row not found&quot;
            } else {
                emr.pid = rsEmr.getString(&quot;PATIENT_ID&quot;)
                emr.eid = rsEmr.getString(&quot;ENCOUNTER_ID&quot;)
                emr.admRaw = rsEmr.getString(&quot;ADMISSION_DATE&quot;)
            }
        } else {
            // --- 기존 PATIENT 로직 그대로 ---
            def emrTitlePat = EMR_TABLE + (showAfterTag ? &quot; (after)&quot; : &quot;&quot;)
            psEmrDump = connEmr.prepareStatement(&quot;SELECT * FROM ${EMR_TABLE} WHERE PATIENT_ID = ?&quot;)
            psEmrDump.setString(1, patientId)
            rsEmrDump = psEmrDump.executeQuery()
            emrDump = dumpResultSetAllColumnsPretty(emrTitlePat, rsEmrDump, MAX_DUMP_ROWS)

            closeQuietly(rsEmrDump); rsEmrDump = null
            closeQuietly(psEmrDump); psEmrDump = null

            psEmr = connEmr.prepareStatement(&quot;&quot;&quot;
                SELECT PATIENT_ID, NAME, BIRTHDATE, SEX, DNR
                FROM ${EMR_TABLE}
                WHERE PATIENT_ID = ?
            &quot;&quot;&quot;)
            psEmr.setString(1, patientId)
            rsEmr = psEmr.executeQuery()

            if (!rsEmr.next()) {
                fails &lt;&lt; &quot;EMR row not found&quot;
            } else {
                emr.id    = rsEmr.getString(&quot;PATIENT_ID&quot;)
                emr.name  = rsEmr.getString(&quot;NAME&quot;)
                emr.sex   = normalizeSex(rsEmr.getString(&quot;SEX&quot;))
                emr.birth = normalizeBirth(rsEmr.getString(&quot;BIRTHDATE&quot;))
                emr.dnr   = normalizeDnr(rsEmr.getString(&quot;DNR&quot;))
            }
        }
    } finally {
        closeQuietly(rsEmr)
        closeQuietly(psEmr)
        closeQuietly(rsEmrDump)
        closeQuietly(psEmrDump)
    }

    // =====================================================
    // 2) VC: set @secretkey/@iv (vars/props/env -&gt; default)
    // =====================================================
    connVc = DriverManager.getConnection(vcUrl, vcUser, vcPw)

    def vcSecretVars  = (vars.get(&quot;VC_SECRET&quot;) ?: &quot;&quot;).toString().trim()
    def vcSecretProps = (props.get(&quot;VC_SECRET&quot;) ?: &quot;&quot;).toString().trim()
    def vcSecretEnv   = (System.getenv(&quot;VC_SECRET&quot;) ?: &quot;&quot;).toString().trim()

    def vcSecret = &quot;&quot;
    def vcSecretSrc = &quot;&quot;
    if (vcSecretVars)      { vcSecret = vcSecretVars;  vcSecretSrc = &quot;VARS:VC_SECRET&quot; }
    else if (vcSecretProps){ vcSecret = vcSecretProps; vcSecretSrc = &quot;PROPS:VC_SECRET&quot; }
    else if (vcSecretEnv)  { vcSecret = vcSecretEnv;   vcSecretSrc = &quot;ENV:VC_SECRET&quot; }
    else                   { vcSecret = &quot;some_secret&quot;; vcSecretSrc = &quot;DEFAULT:some_secret&quot; } // old behavior 유지

    Statement stVc = null
    PreparedStatement psKeyChk = null
    ResultSet rsKeyChk = null
    try {
        stVc = connVc.createStatement()
        def esc = vcSecret.replace(&quot;&apos;&quot;, &quot;\\&apos;&quot;)
        stVc.execute(&quot;SET @hashed_key = (SELECT UNHEX(SHA2(&apos;${esc}&apos;, 256)))&quot;)
        stVc.execute(&quot;SET @secretkey = LEFT(@hashed_key, 16)&quot;)
        stVc.execute(&quot;SET @iv = RIGHT(@hashed_key, 16)&quot;)

        psKeyChk = connVc.prepareStatement(&quot;SELECT LENGTH(@secretkey) AS klen, LENGTH(@iv) AS ivlen&quot;)
        rsKeyChk = psKeyChk.executeQuery()
        rsKeyChk.next()
        int klen = rsKeyChk.getInt(&quot;klen&quot;)
        int ivlen = rsKeyChk.getInt(&quot;ivlen&quot;)
        log.info(&quot;[VC_KEYCHK] src=${vcSecretSrc} klen=${klen}, ivlen=${ivlen}&quot;)
        if (klen &lt;= 0 || ivlen &lt;= 0) {
            throw new RuntimeException(&quot;VC session key not set. (@secretkey/@iv is empty) - cannot AES_DECRYPT&quot;)
        }
    } finally {
        closeQuietly(rsKeyChk)
        closeQuietly(psKeyChk)
        closeQuietly(stVc)
    }

    // =====================================================
    // 3~5) VC Dump AFTER + VC Found + Compare
    // =====================================================
    PreparedStatement psVcDump = null
    ResultSet rsVcDump = null
    PreparedStatement psVc = null
    ResultSet rsVc = null

    boolean vcFound = false

    try {
        if (VERIFY_TARGET == &quot;ENCOUNTER&quot;) {
            // ---- VC Dump (decrypted view): pid + eid 조건 ----
            psVcDump = connVc.prepareStatement(&quot;&quot;&quot;
                SELECT
                  ee.created_dt,
                  ee.updated_dt,
                  CAST(AES_DECRYPT(FROM_BASE64(ee.encrypted_patient_id), @secretkey, @iv) AS CHAR) AS patient_id,
                  CAST(AES_DECRYPT(FROM_BASE64(ee.encrypted_emr_id),     @secretkey, @iv) AS CHAR) AS encounter_id,
                  ee.admission_dt,
                  ee.discharge_dt,
                  ee.status
                FROM ${VC_TABLE} ee
                WHERE
                  CAST(AES_DECRYPT(FROM_BASE64(ee.encrypted_patient_id), @secretkey, @iv) AS CHAR) = ?
                  AND CAST(AES_DECRYPT(FROM_BASE64(ee.encrypted_emr_id), @secretkey, @iv) AS CHAR) = ?
                LIMIT ${MAX_DUMP_ROWS}
            &quot;&quot;&quot;)
            psVcDump.setString(1, patientId)
            psVcDump.setString(2, encounterId)
            rsVcDump = psVcDump.executeQuery()
            vcAfterDumpRaw = dumpResultSetAllColumnsPretty(vcAfterTitle, rsVcDump, MAX_DUMP_ROWS)
            if (!vcAfterDumpRaw?.trim()) vcAfterDumpRaw = vcAfterTitle + &quot;\n(0 rows)\n&quot;

            closeQuietly(rsVcDump); rsVcDump = null
            closeQuietly(psVcDump); psVcDump = null

            // ---- VC Found + fields (for compare) ----
            psVc = connVc.prepareStatement(&quot;&quot;&quot;
                SELECT
                  CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id), @secretkey, @iv) AS CHAR) AS patient_id,
                  CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id),     @secretkey, @iv) AS CHAR) AS encounter_id,
                  admission_dt
                FROM ${VC_TABLE}
                WHERE
                  CAST(AES_DECRYPT(FROM_BASE64(encrypted_patient_id), @secretkey, @iv) AS CHAR) = ?
                  AND CAST(AES_DECRYPT(FROM_BASE64(encrypted_emr_id), @secretkey, @iv) AS CHAR) = ?
                LIMIT 1
            &quot;&quot;&quot;)
            psVc.setString(1, patientId)
            psVc.setString(2, encounterId)
            rsVc = psVc.executeQuery()

            vcFound = rsVc.next()
            vcFoundFlag = vcFound

            log.info(&quot;[VC_FOUND] scenario_id=${SCENARIO_ID}, target=${VERIFY_TARGET}, vcFound=${vcFound}&quot;)

            // expect_mode 공통 판정
            if (!vcFound &amp;&amp; !&quot;SYNC_NOT_EXPECTED&quot;.equalsIgnoreCase(EXPECT_MODE)) {
                fails &lt;&lt; &quot;VC row not found&quot;
            }
            if (vcFound &amp;&amp; &quot;SYNC_NOT_EXPECTED&quot;.equalsIgnoreCase(EXPECT_MODE)) {
                fails &lt;&lt; &quot;VC row exists but should NOT exist&quot;
            }

            // compare fields (SYNC_OK + found)
            if (&quot;SYNC_OK&quot;.equalsIgnoreCase(EXPECT_MODE) &amp;&amp; vcFound &amp;&amp; !fails.contains(&quot;EMR encounter row not found&quot;)) {
                vc.pid = rsVc.getString(&quot;patient_id&quot;)
                vc.eid = rsVc.getString(&quot;encounter_id&quot;)
			 vc.adm = (rsVc.getString(&quot;admission_dt&quot;) ?: &quot;&quot;).toString().trim()

		  // EMR admission 원본 기준으로 &quot;전날 15시&quot; 기대값 생성
		 def emrAdmRaw = (emr.admRaw ?: &quot;&quot;).toString().trim()   // ✅ rsEmr 대신 emr map 값 사용
		 def expectedAdm = toPrevDay15(emrAdmRaw)

	 	log.info(&quot;[ADM_RULE] emr_admission=${emrAdmRaw} -&gt; expected_vc_adm=${expectedAdm}, actual_vc_adm=${vc.adm}&quot;)

	 	if ((emr.pid ?: &quot;&quot;) != (vc.pid ?: &quot;&quot;)) fails &lt;&lt; &quot;field mismatch: patient_id&quot;
		if ((emr.eid ?: &quot;&quot;) != (vc.eid ?: &quot;&quot;)) fails &lt;&lt; &quot;field mismatch: encounter_id&quot;
		if ((expectedAdm ?: &quot;&quot;) != (vc.adm ?: &quot;&quot;)) {
			fails &lt;&lt; &quot;field mismatch: admission_dt\n(expected=${expectedAdm}, actual=${vc.adm})&quot;
			}

            }

        } else {
            // ---- 기존 PATIENT dump ----
            psVcDump = connVc.prepareStatement(&quot;&quot;&quot;
                SELECT
                  ep.created_dt,
                  ep.updated_dt,
                  CAST(AES_DECRYPT(FROM_BASE64(ep.${VC_ID_COL}), @secretkey, @iv) AS CHAR) AS emr_id,
                  CAST(AES_DECRYPT(FROM_BASE64(ep.encrypted_name), @secretkey, @iv) AS CHAR) AS name,
                  CAST(AES_DECRYPT(FROM_BASE64(ep.encrypted_birth_date), @secretkey, @iv) AS CHAR) AS birth_date,
                  CAST(AES_DECRYPT(FROM_BASE64(ep.encrypted_sex), @secretkey, @iv) AS CHAR) AS sex,
                  ep.emr_dnr,
                  ep.manual_dnr
                FROM ${VC_TABLE} ep
                WHERE CAST(AES_DECRYPT(FROM_BASE64(ep.${VC_ID_COL}), @secretkey, @iv) AS CHAR) = ?
                LIMIT ${MAX_DUMP_ROWS}
            &quot;&quot;&quot;)
            psVcDump.setString(1, patientId)
            rsVcDump = psVcDump.executeQuery()
            vcAfterDumpRaw = dumpResultSetAllColumnsPretty(vcAfterTitle, rsVcDump, MAX_DUMP_ROWS)
            if (!vcAfterDumpRaw?.trim()) vcAfterDumpRaw = vcAfterTitle + &quot;\n(0 rows)\n&quot;

            closeQuietly(rsVcDump); rsVcDump = null
            closeQuietly(psVcDump); psVcDump = null

            // ---- 기존 PATIENT compare ----
            psVc = connVc.prepareStatement(&quot;&quot;&quot;
                SELECT
                  CAST(AES_DECRYPT(FROM_BASE64(${VC_ID_COL}), @secretkey, @iv) AS CHAR) AS emr_id,
                  CAST(AES_DECRYPT(FROM_BASE64(encrypted_name), @secretkey, @iv) AS CHAR) AS name,
                  CAST(AES_DECRYPT(FROM_BASE64(encrypted_birth_date), @secretkey, @iv) AS CHAR) AS birth,
                  CAST(AES_DECRYPT(FROM_BASE64(encrypted_sex), @secretkey, @iv) AS CHAR) AS sex,
                  emr_dnr
                FROM ${VC_TABLE}
                WHERE CAST(AES_DECRYPT(FROM_BASE64(${VC_ID_COL}), @secretkey, @iv) AS CHAR) = ?
                LIMIT 1
            &quot;&quot;&quot;)
            psVc.setString(1, patientId)
            rsVc = psVc.executeQuery()

            vcFound = rsVc.next()
            vcFoundFlag = vcFound

            log.info(&quot;[VC_FOUND] scenario_id=${SCENARIO_ID}, target=${VERIFY_TARGET}, vcFound=${vcFound}&quot;)

            if (!vcFound &amp;&amp; !&quot;SYNC_NOT_EXPECTED&quot;.equalsIgnoreCase(EXPECT_MODE)) fails &lt;&lt; &quot;VC row not found&quot;
            if (vcFound &amp;&amp; &quot;SYNC_NOT_EXPECTED&quot;.equalsIgnoreCase(EXPECT_MODE)) fails &lt;&lt; &quot;VC row exists but should NOT exist&quot;

            if (&quot;SYNC_OK&quot;.equalsIgnoreCase(EXPECT_MODE) &amp;&amp; vcFound &amp;&amp; !fails.contains(&quot;EMR row not found&quot;)) {
                vc.id    = rsVc.getString(&quot;emr_id&quot;)
                vc.name  = rsVc.getString(&quot;name&quot;)
                vc.sex   = normalizeSex(rsVc.getString(&quot;sex&quot;))
                vc.birth = normalizeBirth(rsVc.getString(&quot;birth&quot;))
                vc.dnr   = normalizeDnr(rsVc.getString(&quot;emr_dnr&quot;))

                if ((emr.name  ?: &quot;&quot;) != (vc.name  ?: &quot;&quot;)) fails &lt;&lt; &quot;field mismatch: name&quot;
                if ((emr.sex   ?: &quot;&quot;) != (vc.sex   ?: &quot;&quot;)) fails &lt;&lt; &quot;field mismatch: sex&quot;
                if ((emr.birth ?: &quot;&quot;) != (vc.birth ?: &quot;&quot;)) fails &lt;&lt; &quot;field mismatch: birthdate&quot;
                if ((emr.dnr   ?: &quot;&quot;) != (vc.dnr   ?: &quot;&quot;)) fails &lt;&lt; &quot;field mismatch: dnr&quot;
            }
        }
    } finally {
        closeQuietly(rsVc)
        closeQuietly(psVc)
        closeQuietly(rsVcDump)
        closeQuietly(psVcDump)
    }

    // -----------------------------------------------------
    // 6) VC BEFORE (1-3 only) - BODY 우선 규칙
    //   1) vc_before_body_&lt;slot&gt; (title 없음)
    //   2) vc_before_dump_&lt;slot&gt; (title 포함 가능)
    //   3) vc_dump_before        (old 호환)
    // -----------------------------------------------------
    def beforeKeyUsed = &quot;none&quot;
    def vcBeforeBody = &quot;&quot;
    def vcBeforeFull = &quot;&quot;

    if (isScenario13) {
        def bodyKey = &quot;vc_before_body_&quot; + slotKey
        def fullKey = &quot;vc_before_dump_&quot; + slotKey

        vcBeforeBody = (vars.get(bodyKey) ?: &quot;&quot;).toString()
        if (vcBeforeBody?.trim()) {
            beforeKeyUsed = bodyKey
        } else {
            vcBeforeFull = (vars.get(fullKey) ?: &quot;&quot;).toString()
            if (vcBeforeFull?.trim()) {
                beforeKeyUsed = fullKey
            } else {
                vcBeforeFull = (vars.get(&quot;vc_dump_before&quot;) ?: &quot;&quot;).toString()
                if (vcBeforeFull?.trim()) beforeKeyUsed = &quot;vc_dump_before&quot;
            }
        }
    }

    // -----------------------------------------------------
    // 7) Final result + verify vars
    // -----------------------------------------------------
    def result = (fails == null || fails.isEmpty()) ? &quot;PASS&quot; : &quot;FAIL&quot;
    def notes  = (fails == null || fails.isEmpty()) ? &quot;&quot; : fails.join(&quot; | &quot;)

    // Source dump (EMR)
    vars.put(&quot;verify_emrDump&quot;, emrDump ?: &quot;&quot;)

    // Destination dump (VC)
    def beforeBody = &quot;&quot;
    if (isScenario13) {
        if (vcBeforeBody?.trim()) {
            beforeBody = vcBeforeBody
        } else {
            beforeBody = stripTitleOnce(vcBeforeFull, VC_TABLE)
        }
    }
    def afterBody = stripTitleOnce(vcAfterDumpRaw, VC_TABLE)

    def vcFinalDump = &quot;&quot;
    if (isScenario13) {
        if (!beforeBody?.trim()) beforeBody = &quot;(0 rows or not captured)\n&quot;
        if (!afterBody?.trim())  afterBody  = &quot;(0 rows)\n&quot;

        vcFinalDump =
            VC_TABLE + &quot; (before)\n&quot; + beforeBody.trim() +
            &quot;\n\n&quot; +
            VC_TABLE + &quot; (after)\n&quot; + afterBody.trim() + &quot;\n&quot;
    } else {
        if (!afterBody?.trim()) afterBody = &quot;(0 rows)\n&quot;
        vcFinalDump = VC_TABLE + &quot;\n&quot; + afterBody.trim() + &quot;\n&quot;
    }

    vars.put(&quot;verify_vcDump&quot;, vcFinalDump)

    // end millis + duration
    long endMillis = System.currentTimeMillis()
    vars.putObject(&quot;caseEndMillis&quot;, endMillis as Long)
    vars.put(&quot;verify_endTime&quot;, sdfLog.format(new Date(endMillis)))
    vars.put(&quot;verify_duration_ms&quot;, String.valueOf(endMillis - startMillis))

    vars.put(&quot;verify_result&quot;, result)
    vars.put(&quot;verify_notes&quot;, notes)

    log.info(&quot;[VC_DUMP] scenario=${SCENARIO_ID}, slot=${slotKey}, beforeKeyUsed=${beforeKeyUsed}, beforeLen=${(beforeBody?.length() ?: 0)}, afterLen=${(afterBody?.length() ?: 0)}&quot;)

    prev.setSuccessful(&quot;PASS&quot;.equalsIgnoreCase(result) || &quot;SKIP&quot;.equalsIgnoreCase(result))
    prev.setResponseMessage(&quot;SYNC &quot; + result + (notes ? (&quot; | &quot; + notes) : &quot;&quot;))

    log.info(&quot;[SYNC] &quot; + result)

} catch (Throwable e) {
    fails &lt;&lt; (&quot;exception: &quot; + e.getClass().getSimpleName() + &quot; - &quot; + (e.getMessage() ?: &quot;&quot;))
    log.error(&quot;[SYNC] Exception&quot;, e)

} finally {
    closeQuietly(connEmr)
    closeQuietly(connVc)
}
</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Scenario 1" enabled="false">
        <intProp name="ThreadGroup.num_threads">2</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <OnceOnlyController guiclass="OnceOnlyControllerGui" testclass="OnceOnlyController" testname="Once Only Controller" enabled="true"/>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Setname Scenario" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">// Scenario(Parent) 컬럼에 기록될 그룹명
vars.put(&quot;currentControllerName&quot;, &quot;Scenario 1&quot;)

// Scenario 1-1: 환자 기본정보 정상 연동 (SYNC_OK)
vars.put(&quot;scenario_id&quot;, &quot;1-1&quot;)
vars.put(&quot;expect_mode&quot;, &quot;SYNC_OK&quot;)
vars.put(&quot;order_key&quot;, &quot;110&quot;)

// ---- TG 번호 추출  ----
String threadGroupName = ctx.getThreadGroup().getName()
String threadGroupNumber = &quot;0&quot;
try {
    threadGroupNumber = threadGroupName.split(&quot; &quot;)[1] 
} catch (ignored) {
    threadGroupNumber = &quot;0&quot;
}

vars.put(&quot;tgNum&quot;, threadGroupNumber)</stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Mark StartTime" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.text.SimpleDateFormat
import java.util.TimeZone
import java.util.Date

def tz = (vars.get(&quot;TimeZone&quot;) ?: &quot;Asia/Seoul&quot;).toString()
def sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss,SSS&quot;)
sdf.setTimeZone(TimeZone.getTimeZone(tz))

long startMs = System.currentTimeMillis()
vars.putObject(&quot;caseStartMillis&quot;, startMs)

def startTs = sdf.format(new Date(startMs))
vars.put(&quot;case_start_ts&quot;, startTs)

// CSV/HTML이 기존 키를 쓰면 호환용으로 같이 세팅
vars.put(&quot;verify_startTime&quot;, startTs)

log.info(&quot;[CASE_START] scenario_id=${vars.get(&apos;scenario_id&apos;)} start_ts=${startTs} TZ=${tz}&quot;)
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="Setup_4Patients" enabled="true"/>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Init_4Patients" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">// Setup_4Patients: 이번 블록에서 생성할 환자 세트 수(4명)
vars.put(&quot;PatientCount&quot;, &quot;4&quot;)
log.info(&quot;[1-1 SETUP] PatientCount=4 (temp)&quot;)</stringProp>
          </JSR223Sampler>
          <hashTree/>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Patient_Info_JSR223 Sampler" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;

def pidLog = (vars.get(&quot;patient_id&quot;) ?: vars.get(&quot;PatientID&quot;) ?: vars.get(&quot;PatientID0&quot;) ?: &quot;&quot;).toString()
log.info(&quot;[PAT INSERT DBG] scenario_id=&quot; + (vars.get(&quot;scenario_id&quot;) ?: &quot;&quot;)
        + &quot; thread=&quot; + ctx.getThreadNum()
        + &quot; pid=&quot; + pidLog)


// Scenario(Thread) start time: set once
if (!vars.get(&quot;startTimeThread&quot;)) {
    vars.put(&quot;startTimeThread&quot;, String.valueOf(System.currentTimeMillis()))
}

	// JDBC connection information
	String url = &quot;${JDBC_URL}&quot;;
	String user = &quot;${JDBC_USER}&quot;;
	String password = &quot;${JDBC_PW}&quot;;

	// Define the query
	String query = &quot;INSERT INTO ROOT.PATIENTS (PATIENT_ID, NAME, BIRTHDATE, SEX) &quot; +
	                &quot;VALUES (?, ?, TO_DATE(?, &apos;YYYY-MM-DD HH24:MI:SS&apos;), ?)&quot;;

	// JDBC connection
	Connection conn = DriverManager.getConnection(url, user, password);

	// Prepare the statement
	PreparedStatement stmt = conn.prepareStatement(query);

	// Repeat the process for multiple sets of parameters
	int repeatCount = ${PatientCount}; // Number of repetitions set
		for (int i = 0; i &lt; repeatCount; i++) {
		    // Set String parameters for the query
		    String PatientID = vars.get(&quot;PatientID&quot; + i);
		    String Name = vars.get(&quot;Name&quot; + i);
		    String BirthDate = vars.get(&quot;BirthDate&quot; + i);
		    
		    // Set parameters for the query
		    stmt.setString(1, PatientID);
		    stmt.setString(2, &quot;QA&quot;+Name);
		    stmt.setString(3, BirthDate);
		    // Set gender based on whether i is odd or even
		    if (${User_Thread} % 2 == 0) {
		        stmt.setString(4, &quot;female&quot;);
		    } else {
		        stmt.setString(4, &quot;male&quot;);
		    }
		    
		    // Execute the query
		    int rowsInsert = stmt.executeUpdate();
		    
		    // Log
		    log.info(&quot;Inserted patientID: &quot; + PatientID);

		    vars.put(&quot;patient_id&quot;, PatientID)
			//log.info(&quot;[ID_MAP] patient_id=&quot; + vars.get(&quot;patient_id&quot;))

		    
		    // Clear parameters for reusing the statement
		    stmt.clearParameters();

		}
// Close the connection
conn.close();
</stringProp>
          </JSR223Sampler>
          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="SET Patient Variables" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone
import java.util.Calendar

// Default timestamp
long timestampDefault = ${timestamp_default}

// Repeat count
int repeatCount = ${PatientCount} // Number of repetitions set
int observationCount = ${ObservationCount}

// Iterate in 8-hour intervals to set past timestamps and store them in variables
for (int i = 0; i &lt; repeatCount; i++) {
    
    // Create a Date object
    Date PatientSet = new Date(timestampDefault)
    Date EncounterSet = new Date(timestampDefault)
    Date NameSet = new Date(timestampDefault)

    // Set Date
    Calendar calendar = Calendar.getInstance()
    calendar.setTimeInMillis(timestampDefault) // Set the default timestamp    
    calendar.add(Calendar.MINUTE, -(observationCount * ${Ob_Interval_Min}))

    // --- Generate random birthdate for age between 19 and 150 ---
    int minAge = 19
    int maxAge = 110
    int randomAge = minAge + (int)(Math.random() * (maxAge - minAge + 1))
    
    // Copy current timestamp for age validation
    Calendar nowCal = Calendar.getInstance()
    nowCal.setTimeInMillis(timestampDefault)
    
    // Subtract random age in years
    calendar.add(Calendar.YEAR, -randomAge)
    
    // Randomize month and day
    int randomMonth = (int)(Math.random() * 12)  // 0-11
    calendar.set(Calendar.MONTH, randomMonth)
    int maxDay = calendar.getActualMaximum(Calendar.DAY_OF_MONTH)
    int randomDay = 1 + (int)(Math.random() * maxDay)
    calendar.set(Calendar.DAY_OF_MONTH, randomDay)
    
    // Ensure age is at least 19 (if birthday is in the future, subtract one more year)
    if (calendar.after(nowCal)) {
        calendar.add(Calendar.YEAR, -1)
    }
    
    // Final birthdate object
    long BirthDatetimeStamp = calendar.getTimeInMillis()
    Date BirthSet = new Date(BirthDatetimeStamp)

    String threadGroupName = ctx.getThreadGroup().getName()
    String threadGroupNumber = threadGroupName.split(&quot; &quot;)[1]

    // Create a SimpleDateFormat object and set it to UTC Timezone
	SimpleDateFormat sdf_patient = new SimpleDateFormat(i + &quot;yyMMddHHmmss&quot; + ${User_Thread} + threadGroupNumber)
    sdf_patient.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string
    String PatientID = sdf_patient.format(PatientSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_name = new SimpleDateFormat(i+&quot;ddHHmmss&quot;+${User_Thread})
    sdf_name.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String Name = sdf_name.format(NameSet)

    // Create a SimpleDateFormat object and set it to UTC Timezone
    SimpleDateFormat sdf_birthdate = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;)
    sdf_birthdate.setTimeZone(TimeZone.getTimeZone(&quot;${TimeZone}&quot;))

    // Format the date to string    
    String BirthDate = sdf_birthdate.format(BirthSet)

    // Store in variables
    vars.put(&quot;PatientID&quot; + i, PatientID)
    vars.put(&quot;Name&quot; + i, Name)
    vars.put(&quot;BirthDate&quot; + i, BirthDate)
}
</stringProp>
            </JSR223PreProcessor>
