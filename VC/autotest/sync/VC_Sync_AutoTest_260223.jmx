                <hashTree>
                  <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="BindSlot_And_ChangePlan" enabled="true">
                    <stringProp name="scriptLanguage">groovy</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">/**
 * BindSlot_And_ChangePlan
 * - chg_slot 증가(0..3) 및 cur_slot 확정
 * - slot별 pid/eid를 patient_id/encounter_id에 바인딩
 * - slot별 change_field 자동 결정 + 저장(change_field_&lt;slot&gt; + change_field)
 * - scenario_id(1-3-1~4) / verify_scenario 세팅
 */

int slot = (vars.get(&quot;chg_slot&quot;) ?: &quot;-1&quot;) as int
slot++
vars.put(&quot;chg_slot&quot;, String.valueOf(slot))
vars.put(&quot;cur_slot&quot;, String.valueOf(slot))

if (slot &lt; 0 || slot &gt; 3) {
  throw new RuntimeException(&quot;[BindSlot_And_ChangePlan] chg_slot out of range: &quot; + slot)
}

// 1) slot별 patient/eid 바인딩
def pidKey = &quot;p_pid_&quot; + slot
def eidKey = &quot;p_eid_&quot; + slot

def pid = (vars.get(pidKey) ?: &quot;&quot;).toString().trim()
if (!pid) throw new RuntimeException(&quot;[BindSlot_And_ChangePlan] &quot; + pidKey + &quot; empty (slot binding failed)&quot;)
vars.put(&quot;patient_id&quot;, pid)

def eid = (vars.get(eidKey) ?: &quot;&quot;).toString().trim()
if (eid) vars.put(&quot;encounter_id&quot;, eid)

// 2) change_field 자동 결정 (slot=0..3 고정룰)
def field
switch (slot) {
  case 0: field = &quot;name&quot;;      break
  case 1: field = &quot;birthdate&quot;; break
  case 2: field = &quot;sex&quot;;       break
  case 3: field = &quot;dnr&quot;;       break
  default: field = &quot;&quot;
}
if (!field) throw new RuntimeException(&quot;[BindSlot_And_ChangePlan] auto field empty: slot=&quot; + slot)

// 3) slot별 키 + 공통 키 동시 세팅
vars.put(&quot;change_field_&quot; + slot, field)
vars.put(&quot;change_field&quot;, field)

// 4) scenario/verify_scenario 세팅 (1-3-1~1-3-4)
String s13 = &quot;1-3-&quot; + (slot + 1)
vars.put(&quot;scenario_id&quot;, s13)
vars.put(&quot;verify_scenario&quot;, &quot;Scenario &quot; + s13)

// 덤프 타이틀 단일화용(기존 유지)
vars.put(&quot;dump_title&quot;, vars.get(&quot;verify_scenario&quot;))

log.info(&quot;[1-3 PLAN] slot=&quot; + slot
  + &quot;, scenario_id=&quot; + s13
  + &quot;, field=&quot; + field
  + &quot;, pid=&quot; + pid
  + &quot;, eid=&quot; + (eid ?: &quot;&quot;))
</stringProp>
                  </JSR223Sampler>
                  <hashTree/>
                  <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Dump_VC_Before" enabled="true">
                    <stringProp name="scriptLanguage">groovy</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">/**
 * Dump_VC_Before
 * - slot 기준 VC before 덤프 생성
 * - NEW    : vc_before_body_&lt;slot&gt; (타이틀 제거 BODY-only)
 * - COMPAT : vc_before_dump_&lt;slot&gt; (타이틀 포함 FULL)
 * - 매 커넥션마다 @secretkey/@iv 세팅 (JMeter 세션 재사용 보장 X)
 */

import java.sql.*
import java.text.SimpleDateFormat
import java.util.TimeZone

int slot = ((vars.get(&quot;cur_slot&quot;) ?: vars.get(&quot;chg_slot&quot;) ?: vars.get(&quot;slot&quot;) ?: &quot;0&quot;) as int)
if (slot &lt; 0) slot = 0

def pid = (vars.get(&quot;patient_id&quot;) ?: &quot;&quot;).toString().trim()
if (!pid) throw new RuntimeException(&quot;[Dump_VC_Before] patient_id empty&quot;)

def vcUrl  = (vars.get(&quot;JDBC_URL_VC&quot;)  ?: &quot;&quot;).toString().trim()
def vcUser = (vars.get(&quot;JDBC_USER_VC&quot;) ?: &quot;&quot;).toString().trim()
def vcPw   = (vars.get(&quot;JDBC_PW_VC&quot;)   ?: &quot;&quot;).toString()
if (!vcUrl || !vcUser) throw new RuntimeException(&quot;[Dump_VC_Before] JDBC_URL_VC/JDBC_USER_VC empty&quot;)

def VC_TABLE  = &quot;vitalcare.emr_patient&quot;
def VC_ID_COL = &quot;encrypted_emr_id&quot;
int MAX_ROWS = 20

def outBodyKey = &quot;vc_before_body_&quot; + slot
def outFullKey = &quot;vc_before_dump_&quot; + slot

def dumpResultSetAllColumnsPretty = { String titleLine, ResultSet rs, int maxRows -&gt;
  def sb = new StringBuilder()
  sb.append(titleLine).append(&quot;\n&quot;)

  if (rs == null) {
    sb.append(&quot;(rs is null)\n&quot;)
    return sb.toString()
  }

  ResultSetMetaData md = rs.getMetaData()
  int colCount = md.getColumnCount()

  def colNames = []
  for (int i = 1; i &lt;= colCount; i++) colNames &lt;&lt; md.getColumnLabel(i)

  def rows = []
  int count = 0
  while (rs.next()) {
    def row = []
    for (int i = 1; i &lt;= colCount; i++) {
      def obj = rs.getObject(i)
      row &lt;&lt; ((obj == null) ? &quot;&quot; : obj.toString())
    }
    rows &lt;&lt; row
    count++
    if (count &gt;= maxRows) break
  }

  def widths = new int[colCount]
  for (int i = 0; i &lt; colCount; i++) widths[i] = colNames[i].length()
  rows.each { r -&gt;
    for (int i = 0; i &lt; colCount; i++) widths[i] = Math.max(widths[i], (r[i] ?: &quot;&quot;).length())
  }

  sb.append((0..&lt;colCount).collect { i -&gt; colNames[i].padRight(widths[i]) }.join(&quot;|&quot;)).append(&quot;\n&quot;)
  sb.append((0..&lt;colCount).collect { i -&gt; &quot;-&quot; * widths[i] }.join(&quot;+&quot;)).append(&quot;\n&quot;)

  rows.each { r -&gt;
    sb.append((0..&lt;colCount).collect { i -&gt; (r[i] ?: &quot;&quot;).padRight(widths[i]) }.join(&quot;|&quot;)).append(&quot;\n&quot;)
  }

  if (rows.isEmpty()) sb.append(&quot;(0 rows)\n&quot;)
  else if (count &gt;= maxRows) sb.append(&quot;... (truncated, maxRows=&quot;).append(maxRows).append(&quot;)\n&quot;)

  return sb.toString()
}

def stripLeadingTitleLine = { String fullDump, String titleLine -&gt;
  if (fullDump == null) return &quot;&quot;
  def x = fullDump.toString()
  def t = (titleLine ?: &quot;&quot;).toString()
  def prefix = t + &quot;\n&quot;
  return x.startsWith(prefix) ? x.substring(prefix.length()) : x
}

Connection conn = null
Statement st = null
PreparedStatement psKey = null
ResultSet rsKey = null
PreparedStatement ps = null
ResultSet rs = null

try {
  conn = DriverManager.getConnection(vcUrl, vcUser, vcPw)

  // 0) Key material 결정 (VC_SECRET &gt; fallback)
  def vcSecret = (vars.get(&quot;VC_SECRET&quot;) ?: &quot;&quot;).toString().trim()
  def secretSrc = &quot;UDV:VC_SECRET&quot;
  if (!vcSecret) {
    vcSecret = &quot;some_secret&quot;
    secretSrc = &quot;DEFAULT:some_secret&quot;
  }

  // 1) 매 커넥션에서 @secretkey/@iv 세팅
  st = conn.createStatement()
  def esc = vcSecret.replace(&quot;&apos;&quot;, &quot;\\&apos;&quot;)
  st.execute(&quot;SET @hashed_key = (SELECT UNHEX(SHA2(&apos;${esc}&apos;, 256)))&quot;)
  st.execute(&quot;SET @secretkey = LEFT(@hashed_key, 16)&quot;)
  st.execute(&quot;SET @iv        = RIGHT(@hashed_key, 16)&quot;)

  // 2) 세션 키 체크
  psKey = conn.prepareStatement(&quot;SELECT LENGTH(@secretkey) AS klen, LENGTH(@iv) AS ivlen&quot;)
  rsKey = psKey.executeQuery()
  rsKey.next()
  int klen = rsKey.getInt(&quot;klen&quot;)
  int ivlen = rsKey.getInt(&quot;ivlen&quot;)

  log.info(&quot;[VC_BEFORE_KEY] slot=&quot; + slot + &quot; src=&quot; + secretSrc + &quot; klen=&quot; + klen + &quot;, ivlen=&quot; + ivlen)
  if (klen &lt;= 0 || ivlen &lt;= 0) throw new RuntimeException(&quot;[Dump_VC_Before] VC key setup failed: @secretkey/@iv empty&quot;)

  // 3) Dump query (VC BEFORE - decrypted view + raw)
  def sql = &quot;&quot;&quot;
    SELECT
      ep.created_dt,
      ep.updated_dt,
      CAST(AES_DECRYPT(FROM_BASE64(ep.${VC_ID_COL}), @secretkey, @iv) AS CHAR) AS emr_id,
      CAST(AES_DECRYPT(FROM_BASE64(ep.encrypted_name), @secretkey, @iv) AS CHAR) AS name,
      CAST(AES_DECRYPT(FROM_BASE64(ep.encrypted_birth_date), @secretkey, @iv) AS CHAR) AS birth_date,
      CAST(AES_DECRYPT(FROM_BASE64(ep.encrypted_sex), @secretkey, @iv) AS CHAR) AS sex,
      ep.emr_dnr,
      ep.manual_dnr
    FROM ${VC_TABLE} ep
    WHERE CAST(AES_DECRYPT(FROM_BASE64(ep.${VC_ID_COL}), @secretkey, @iv) AS CHAR) = ?
    LIMIT ${MAX_ROWS}
  &quot;&quot;&quot;
  ps = conn.prepareStatement(sql)
  ps.setString(1, pid)
  rs = ps.executeQuery()

  def title = VC_TABLE + &quot; (before)&quot;
  def fullDump = dumpResultSetAllColumnsPretty(title, rs, MAX_ROWS)
  def bodyDump = stripLeadingTitleLine(fullDump, title)

  vars.put(outBodyKey, bodyDump ?: &quot;&quot;)
  vars.put(outFullKey, fullDump ?: &quot;&quot;)

  log.info(&quot;[VC_BEFORE] saved bodyKey=&quot; + outBodyKey + &quot; bodyLen=&quot; + (bodyDump?.length() ?: 0)
    + &quot; | fullKey=&quot; + outFullKey + &quot; fullLen=&quot; + (fullDump?.length() ?: 0)
    + &quot; | pid=&quot; + pid)

} finally {
  try { if (rsKey != null) rsKey.close() } catch (ignored) {}
  try { if (psKey != null) psKey.close() } catch (ignored) {}
  try { if (rs != null) rs.close() } catch (ignored) {}
  try { if (ps != null) ps.close() } catch (ignored) {}
  try { if (st != null) st.close() } catch (ignored) {}
  try { if (conn != null) conn.close() } catch (ignored) {}
}
</stringProp>
                  </JSR223Sampler>
                  <hashTree/>
                  <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Update_EMR" enabled="true">
                    <stringProp name="scriptLanguage">groovy</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">/**
 * Update_EMR
 * - change_field에 따라 EMR UPDATE 수행
 * - slot_start_ms_&lt;slot&gt; / slot_start_ts_&lt;slot&gt; 저장 (변경 시작 시점)
 * - expect_*_&lt;slot&gt; 저장 (VC 검증용 기대값)
 */

import java.sql.*
import java.text.SimpleDateFormat
import java.time.LocalDate
import java.util.Date
import java.util.TimeZone

// 0) slot 확정 (start 저장보다 먼저)
int slot = ((vars.get(&quot;cur_slot&quot;) ?: vars.get(&quot;chg_slot&quot;) ?: vars.get(&quot;slot&quot;) ?: &quot;0&quot;) as int)
if (slot &lt; 0) slot = 0

// 1) slot 시작시각 기록 (EMR 변경 시작 시점)
def tz = TimeZone.getTimeZone(&quot;Asia/Seoul&quot;)
def sdfLog = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss,SSS&quot;)
sdfLog.setTimeZone(tz)

long now = System.currentTimeMillis()
vars.putObject(&quot;slot_start_ms_&quot; + slot, now as Long)
vars.put(&quot;slot_start_ts_&quot; + slot, sdfLog.format(new Date(now)))
log.info(&quot;[1-3 SLOT_START@EMR] slot=&quot; + slot + &quot; ts=&quot; + vars.get(&quot;slot_start_ts_&quot; + slot))

// 2) inputs
def pid = (vars.get(&quot;patient_id&quot;) ?: &quot;&quot;).trim()
if (!pid) throw new RuntimeException(&quot;[Update_EMR] patient_id is empty&quot;)

def field = (vars.get(&quot;change_field&quot;) ?: &quot;&quot;).trim()
if (!field) throw new RuntimeException(&quot;[Update_EMR] change_field empty&quot;)

def url  = (vars.get(&quot;JDBC_URL&quot;) ?: &quot;&quot;).trim()
def user = (vars.get(&quot;JDBC_USER&quot;) ?: &quot;&quot;).trim()
def pw   = (vars.get(&quot;JDBC_PW&quot;) ?: &quot;&quot;).trim()
if (!url || !user) throw new RuntimeException(&quot;[Update_EMR] JDBC_URL/JDBC_USER empty&quot;)

Connection conn = null
PreparedStatement ps = null

try {
  conn = DriverManager.getConnection(url, user, pw)
  conn.setAutoCommit(false)

  if (field == &quot;name&quot;) {
    def base = (vars.get(&quot;base_name_&quot; + slot) ?: vars.get(&quot;base_name&quot;) ?: &quot;&quot;).trim()
    if (!base) {
      log.warn(&quot;[1-3 UPDATE] SKIP(name): base_name empty. pid=&quot; + pid)
      prev.setSuccessful(true)
      conn.rollback()
      return
    }

    def hhmm = new SimpleDateFormat(&quot;HHmm&quot;).format(new Date())
    def newVal = base + &quot;_test&quot; + hhmm

    ps = conn.prepareStatement(&quot;UPDATE ROOT.PATIENTS SET NAME=? WHERE PATIENT_ID=?&quot;)
    ps.setString(1, newVal)
    ps.setString(2, pid)

    int affected = ps.executeUpdate()
    conn.commit()

    vars.put(&quot;expect_name_&quot; + slot, newVal)
    log.info(&quot;[1-3 UPDATE] slot=&quot; + slot + &quot; name: &quot; + base + &quot; -&gt; &quot; + newVal + &quot;, affected=&quot; + affected)

  } else if (field == &quot;sex&quot;) {
    def baseSex = (vars.get(&quot;base_sex_&quot; + slot) ?: vars.get(&quot;base_sex&quot;) ?: &quot;&quot;).trim()
    if (!baseSex) {
      log.warn(&quot;[1-3 UPDATE] SKIP(sex): base_sex empty.&quot;)
      prev.setSuccessful(true)
      conn.rollback()
      return
    }

    def baseNorm = baseSex.toUpperCase()
    if (baseNorm == &quot;MALE&quot;) baseNorm = &quot;M&quot;
    if (baseNorm == &quot;FEMALE&quot;) baseNorm = &quot;F&quot;

    def newSexEmr = (baseNorm == &quot;M&quot;) ? &quot;female&quot; : &quot;male&quot;
    def expectVc  = (baseNorm == &quot;M&quot;) ? &quot;F&quot; : &quot;M&quot;

    ps = conn.prepareStatement(&quot;UPDATE ROOT.PATIENTS SET SEX=? WHERE PATIENT_ID=?&quot;)
    ps.setString(1, newSexEmr)
    ps.setString(2, pid)

    int affected = ps.executeUpdate()
    conn.commit()

    vars.put(&quot;expect_sex_&quot; + slot, expectVc)
    log.info(&quot;[1-3 UPDATE] slot=&quot; + slot + &quot; sex: &quot; + baseSex + &quot; -&gt; &quot; + newSexEmr
      + &quot; | expect(VC)=&quot; + expectVc + &quot;, affected=&quot; + affected)

  } else if (field == &quot;birthdate&quot;) {
    def baseBirthRaw = (vars.get(&quot;base_birth_&quot; + slot) ?: vars.get(&quot;base_birth&quot;) ?: &quot;&quot;).trim()
    if (!baseBirthRaw) {
      log.warn(&quot;[1-3 UPDATE] SKIP(birthdate): base_birth empty.&quot;)
      prev.setSuccessful(true)
      conn.rollback()
      return
    }

    def baseBirth = baseBirthRaw.length() &gt;= 10 ? baseBirthRaw.substring(0, 10) : baseBirthRaw
    def newBirthStr = LocalDate.parse(baseBirth).minusYears(1).toString()

    ps = conn.prepareStatement(&quot;UPDATE ROOT.PATIENTS SET BIRTHDATE=? WHERE PATIENT_ID=?&quot;)
    ps.setDate(1, java.sql.Date.valueOf(newBirthStr))
    ps.setString(2, pid)

    int affected = ps.executeUpdate()
    conn.commit()

    vars.put(&quot;expect_birth_&quot; + slot, newBirthStr)
    log.info(&quot;[1-3 UPDATE] slot=&quot; + slot + &quot; birth: &quot; + baseBirth + &quot; -&gt; &quot; + newBirthStr + &quot;, affected=&quot; + affected)

  } else if (field == &quot;dnr&quot;) {
    def baseDnr = (vars.get(&quot;base_dnr_&quot; + slot) ?: vars.get(&quot;base_dnr&quot;) ?: &quot;&quot;).trim()
    if (!baseDnr) {
      log.warn(&quot;[1-3 UPDATE] SKIP(dnr): base_dnr empty.&quot;)
      prev.setSuccessful(true)
      conn.rollback()
      return
    }

    def newVal
    if (baseDnr == &quot;0&quot;) newVal = &quot;1&quot;
    else if (baseDnr == &quot;1&quot;) newVal = &quot;0&quot;
    else throw new RuntimeException(&quot;[Update_EMR] base_dnr not 0/1: &quot; + baseDnr)

    ps = conn.prepareStatement(&quot;UPDATE ROOT.PATIENTS SET DNR=? WHERE PATIENT_ID=?&quot;)
    ps.setString(1, newVal)
    ps.setString(2, pid)

    int affected = ps.executeUpdate()
    conn.commit()

    vars.put(&quot;expect_dnr_&quot; + slot, newVal)
    log.info(&quot;[1-3 UPDATE] slot=&quot; + slot + &quot; dnr: &quot; + baseDnr + &quot; -&gt; &quot; + newVal + &quot;, affected=&quot; + affected)

  } else {
    throw new RuntimeException(&quot;[Update_EMR] unknown change_field: &quot; + field)
  }

} finally {
  try { if (ps != null) ps.close() } catch (ignored) {}
  try { if (conn != null) conn.close() } catch (ignored) {}
}
</stringProp>
                  </JSR223Sampler>
                  <hashTree/>
                </hashTree>
                <TestAction guiclass="TestActionGui" testclass="TestAction" testname="Wait_for_Sync" enabled="true">
                  <intProp name="ActionProcessor.action">1</intProp>
                  <intProp name="ActionProcessor.target">0</intProp>
                  <stringProp name="ActionProcessor.duration">180000</stringProp>
                </TestAction>
                <hashTree/>
                <LoopController guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller_Verify" enabled="true">
                  <stringProp name="LoopController.loops">4</stringProp>
                </LoopController>
                <hashTree>
                  <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="BindSlot_VerifyTarget" enabled="true">
                    <stringProp name="scriptLanguage">groovy</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">/**
 * BindSlot_VerifyTarget
 * - ver_slot 증가(0..3) 및 slot/cur_slot 바인딩 (Common 대상 전환)
 * - slot별 pid/eid, change_field, expect_value 세팅
 * - VC before dump를 Common 키(vc_dump_before)에 바인딩
 * - scenario_id / verify_scenario (1-3-1~4) 세팅
 * - verify_notes에 &quot;change=&lt;field&gt;&quot; 기본 문구 포함
 */

int slot = (vars.get(&quot;ver_slot&quot;) ?: &quot;-1&quot;) as int
slot++
vars.put(&quot;ver_slot&quot;, String.valueOf(slot))

vars.put(&quot;slot&quot;, String.valueOf(slot))
vars.put(&quot;cur_slot&quot;, String.valueOf(slot))

def pid = (vars.get(&quot;p_pid_&quot; + slot) ?: &quot;&quot;).toString().trim()
def eid = (vars.get(&quot;p_eid_&quot; + slot) ?: &quot;&quot;).toString().trim()
if (!pid) throw new RuntimeException(&quot;[BindSlot_VerifyTarget] missing pid for slot=&quot; + slot)

vars.put(&quot;patient_id&quot;, pid)
vars.put(&quot;encounter_id&quot;, eid)

// VC before dump -&gt; Common 키
// 우선순위: BODY-only(신규) &gt; FULL(compat)
// (Common이 BODY를 우선 사용하도록 설계된 상태를 그대로 반영)
def beforeBody = (vars.get(&quot;vc_before_body_&quot; + slot) ?: &quot;&quot;).toString()
def beforeFull = (vars.get(&quot;vc_before_dump_&quot; + slot) ?: &quot;&quot;).toString()
vars.put(&quot;vc_dump_before&quot;, beforeBody ? beforeBody : beforeFull)

// change field
def field = (vars.get(&quot;change_field_&quot; + slot) ?: &quot;&quot;).toString().trim()
if (!field) throw new RuntimeException(&quot;[BindSlot_VerifyTarget] change_field_&quot; + slot + &quot; empty&quot;)
vars.put(&quot;change_field&quot;, field)

// expect_value (Common이 보는 키)
def expect = &quot;&quot;
if (field == &quot;name&quot;)           expect = (vars.get(&quot;expect_name_&quot;  + slot) ?: &quot;&quot;).toString()
else if (field == &quot;sex&quot;)       expect = (vars.get(&quot;expect_sex_&quot;   + slot) ?: &quot;&quot;).toString()
else if (field == &quot;birthdate&quot;) expect = (vars.get(&quot;expect_birth_&quot; + slot) ?: &quot;&quot;).toString()
else if (field == &quot;dnr&quot;)       expect = (vars.get(&quot;expect_dnr_&quot;   + slot) ?: &quot;&quot;).toString()

if (!expect?.toString()?.trim()) {
  throw new RuntimeException(&quot;[BindSlot_VerifyTarget] expect_value empty. field=&quot; + field + &quot;, slot=&quot; + slot)
}
vars.put(&quot;expect_value&quot;, expect)

// scenario 표기: 1-3-1~4 고정
String s13 = &quot;1-3-&quot; + (slot + 1)
vars.put(&quot;scenario_id&quot;, s13)
vars.put(&quot;verify_scenario&quot;, &quot;Scenario &quot; + s13)

// notes: 항상 change=&lt;field&gt; 포함 (PASS/FAIL 공통)
def baseNotes = (vars.get(&quot;verify_notes&quot;) ?: &quot;&quot;).toString().trim()
def notePrefix = &quot;change=&quot; + field
vars.put(&quot;verify_notes&quot;, baseNotes ? (notePrefix + &quot; | &quot; + baseNotes) : notePrefix)

log.info(&quot;[1-3 VERIFY_BIND] slot=&quot; + slot
  + &quot;, scenario_id=&quot; + s13
  + &quot;, field=&quot; + field
  + &quot;, pid=&quot; + pid
  + &quot;, beforeLen=&quot; + ((vars.get(&quot;vc_dump_before&quot;) ?: &quot;&quot;).toString().length())
  + &quot;, expectLen=&quot; + (expect?.toString()?.length() ?: 0))
</stringProp>
                  </JSR223Sampler>
                  <hashTree/>
                  <ModuleController guiclass="ModuleControllerGui" testclass="ModuleController" testname="Module Controller" enabled="true">
                    <collectionProp name="ModuleController.node_path">
                      <stringProp name="764597751">Test Plan</stringProp>
                      <stringProp name="764597751">Test Plan</stringProp>
                      <stringProp name="230036048">Test Fragment_1</stringProp>
                    </collectionProp>
                  </ModuleController>
                  <hashTree/>
                  <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="MergeDumps_And_Notes" enabled="true">
                    <stringProp name="scriptLanguage">groovy</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">/**
 * MergeDumps_And_Notes
 * - verify_emrDump / verify_vcDump는 Common이 생성 (여기서 건드리지 않음)
 * - verify_notes는 항상 &quot;change=&lt;field&gt;&quot; 포함 (중복이면 1회만 유지)
 * - field가 비어있으면 slot 기반 change_field_&lt;slot&gt;에서 fallback
 */

int slot = (vars.get(&quot;ver_slot&quot;) ?: vars.get(&quot;vr_slot&quot;) ?: &quot;0&quot;) as int

def field = (vars.get(&quot;change_field&quot;) ?: &quot;&quot;).toString().trim()
if (!field) field = (vars.get(&quot;change_field_&quot; + slot) ?: &quot;&quot;).toString().trim()
if (!field) field = &quot;unknown&quot;

def baseNotes = (vars.get(&quot;verify_notes&quot;) ?: &quot;&quot;).toString().trim()
def prefix = &quot;change=&quot; + field

// 이미 prefix가 들어있으면 중복으로 붙이지 않음
def newNotes
if (!baseNotes) newNotes = prefix
else if (baseNotes.startsWith(prefix)) newNotes = baseNotes
else newNotes = prefix + &quot; | &quot; + baseNotes

vars.put(&quot;verify_notes&quot;, newNotes)

log.info(&quot;[1-3 NOTES] &quot; + newNotes)
</stringProp>
                  </JSR223Sampler>
                  <hashTree/>
                  <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="WriteCsv_BySlot" enabled="true">
                    <stringProp name="scriptLanguage">groovy</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">/**
 * WriteCsv_BySlot
 * - verify_* 결과로 slot별 CSV 1줄 append (1-3은 총 4줄)
 * - slot_start_ts_&lt;slot&gt; 우선 사용, 없으면 verify_startTime/case_start_ts fallback
 */

if (!vars.get(&quot;verify_result&quot;)) {
  throw new RuntimeException(&quot;[WriteCsv_BySlot] verify_result is empty (Common might have failed)&quot;)
}

def logResults = (Closure) vars.getObject(&quot;logResults&quot;)
if (logResults == null) {
  throw new RuntimeException(&quot;[WriteCsv_BySlot] logResults is null (check Init/Register_LogResults)&quot;)
}

// slot 결정 (BindSlot_VerifyTarget이 ver_slot을 증가시킨 상태)
int slot = (vars.get(&quot;ver_slot&quot;) ?: vars.get(&quot;vr_slot&quot;) ?: vars.get(&quot;slot&quot;) ?: &quot;0&quot;) as int

def st = (vars.get(&quot;slot_start_ts_&quot; + slot)
       ?: vars.get(&quot;verify_startTime&quot;)
       ?: vars.get(&quot;case_start_ts&quot;)
       ?: &quot;&quot;).toString()

def et = (vars.get(&quot;verify_endTime&quot;)
       ?: vars.get(&quot;case_end_ts&quot;)
       ?: &quot;&quot;).toString()

def fields = [
  (vars.get(&quot;verify_scenario&quot;) ?: &quot;Scenario&quot;),
  st,
  et,
  (vars.get(&quot;verify_emrDump&quot;) ?: &quot;&quot;),
  (vars.get(&quot;verify_vcDump&quot;) ?: &quot;&quot;),
  (vars.get(&quot;verify_result&quot;) ?: &quot;&quot;),
  (vars.get(&quot;verify_notes&quot;) ?: &quot;&quot;)
] as Object[]

logResults(prev, ctx, props, vars, fields)

log.info(&quot;[CSV 1-3] appended scenario=&quot; + (vars.get(&quot;verify_scenario&quot;) ?: &quot;&quot;)
  + &quot;, result=&quot; + (vars.get(&quot;verify_result&quot;) ?: &quot;&quot;)
  + &quot;, slot=&quot; + slot
  + &quot;, start=&quot; + st
  + &quot;, end=&quot; + et)
</stringProp>
                  </JSR223Sampler>
                  <hashTree/>
                </hashTree>
              </hashTree>
              <IfController guiclass="IfControllerPanel" testclass="IfController" testname="If Controller_ReportOnly (Fail)" enabled="true">
                <stringProp name="IfController.condition">${__groovy(!&quot;true&quot;.equalsIgnoreCase(vars.get(&quot;prereq_ok&quot;) ?: &quot;false&quot;))}</stringProp>
                <boolProp name="IfController.evaluateAll">false</boolProp>
                <boolProp name="IfController.useExpression">true</boolProp>
              </IfController>
              <hashTree>
                <LoopController guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller_Verify_Fail" enabled="true">
                  <stringProp name="LoopController.loops">4</stringProp>
                </LoopController>
                <hashTree>
                  <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="BindSlot_ReportTarget" enabled="true">
                    <stringProp name="scriptLanguage">groovy</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">/**
 * BindSlot_ReportTarget
 * - prereq FAIL 시 1-3-1~4 리포트 &quot;출력 전용&quot; 바인딩
 * - UPDATE / WAIT / DB 조회 없이 CSV 출력용 변수만 세팅
 * - slot별 change_field / scenario / notes 고정
 */

int slot = (vars.get(&quot;vr_slot&quot;) ?: &quot;-1&quot;) as int
slot++
vars.put(&quot;vr_slot&quot;, String.valueOf(slot))

def pid = (vars.get(&quot;p_pid_&quot; + slot) ?: &quot;&quot;).toString().trim()
def eid = (vars.get(&quot;p_eid_&quot; + slot) ?: &quot;&quot;).toString().trim()
if (!pid || !eid) {
  throw new RuntimeException(&quot;[BindSlot_ReportTarget] missing pid/eid for slot=&quot; + slot)
}

// slot별 change field 고정 (1-3-1~4)
def fields = [&quot;name&quot;, &quot;birthdate&quot;, &quot;sex&quot;, &quot;dnr&quot;]
def field = (slot &gt;= 0 &amp;&amp; slot &lt; fields.size()) ? fields[slot] : &quot;unknown&quot;
vars.put(&quot;change_field&quot;, field)
vars.put(&quot;change_field_&quot; + slot, field)

// scenario / verify_scenario
String s13 = &quot;1-3-&quot; + (slot + 1)
vars.put(&quot;scenario_id&quot;, s13)
vars.put(&quot;verify_scenario&quot;, &quot;Scenario &quot; + s13)

// 출력용 바인딩
vars.put(&quot;patient_id&quot;, pid)
vars.put(&quot;encounter_id&quot;, eid)

// FAIL 리포트 전용 상태
vars.put(&quot;expect_mode&quot;, &quot;REPORT_ONLY&quot;)
vars.put(&quot;verify_result&quot;, &quot;FAIL&quot;)
vars.put(&quot;verify_emrDump&quot;, &quot;&quot;)
vars.put(&quot;verify_vcDump&quot;, &quot;&quot;)

// notes: change=&lt;field&gt; + prereq fail 사유
def prereqMsg = (vars.get(&quot;prereq_fail_notes&quot;)
              ?: vars.get(&quot;csv_notes&quot;)
              ?: &quot;Prereq FAIL&quot;).toString().trim()

def msg = prereqMsg ? prereqMsg : &quot;Prereq FAIL&quot;
vars.put(&quot;verify_notes&quot;, &quot;change=&quot; + field + &quot; | &quot; + msg)

log.info(&quot;[1-3 FAIL_REPORT] slot=&quot; + slot
  + &quot;, scenario_id=&quot; + s13
  + &quot;, field=&quot; + field
  + &quot;, pid=&quot; + pid)
</stringProp>
                  </JSR223Sampler>
                  <hashTree/>
                  <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="WriteCsv_BySlot" enabled="true">
                    <stringProp name="scriptLanguage">groovy</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">/**
 * WriteCsv_BySlot (FAIL SUMMARY)
 * - 1-3 prereq FAIL 시 요약 1줄 CSV append
 * - StartTime: case_1_3_start_ms 기준
 * - EndTime  : case_end_ts 우선, 없으면 현재 시각
 * - Dump는 비움 (요약행)
 */

import java.text.SimpleDateFormat
import java.util.Date
import java.util.TimeZone

def logResults = (Closure) vars.getObject(&quot;logResults&quot;)
if (logResults == null) {
  throw new RuntimeException(&quot;[WriteCsv_BySlot_FAIL] logResults is null (check Init/Register)&quot;)
}

// time formatter
def tz = TimeZone.getTimeZone(&quot;Asia/Seoul&quot;)
def sdfLog = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss,SSS&quot;)
sdfLog.setTimeZone(tz)

// start time: case_1_3_start_ms 우선
def stMs = vars.getObject(&quot;case_1_3_start_ms&quot;) as Long
def st = &quot;&quot;
if (stMs != null &amp;&amp; stMs &gt; 0L) st = sdfLog.format(new Date(stMs))
if (!st.trim()) st = sdfLog.format(new Date()) // fallback

// end time
def et = (vars.get(&quot;case_end_ts&quot;) ?: &quot;&quot;).toString()
if (!et.trim()) et = sdfLog.format(new Date())

// scenario
def scenario = (vars.get(&quot;verify_scenario&quot;) ?: &quot;Scenario 1-3&quot;).toString()

// result
def result = &quot;FAIL&quot;

// notes 우선순위
def notes = (vars.get(&quot;verify_notes&quot;) ?: vars.get(&quot;csv_notes&quot;) ?: &quot;&quot;).toString().trim()
if (!notes) {
  notes = (prev?.getResponseMessage()
        ?: prev?.getResponseDataAsString()
        ?: &quot;&quot;).toString().trim()
}
if (!notes) notes = &quot;verify_loop_fail triggered&quot;

// 요약행: dump 비움
def emrDump = &quot;&quot;
def vcDump  = &quot;&quot;

def fields = [
  scenario,
  st,
  et,
  emrDump,
  vcDump,
  result,
  notes
] as Object[]

logResults(prev, ctx, props, vars, fields)

log.info(&quot;[CSV 1-3 FAIL SUMMARY] appended scenario=&quot; + scenario
  + &quot;, start=&quot; + st
  + &quot;, end=&quot; + et
  + &quot;, notes=&quot; + notes)
</stringProp>
                  </JSR223Sampler>
